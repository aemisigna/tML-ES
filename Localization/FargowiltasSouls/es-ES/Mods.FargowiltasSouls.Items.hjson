	Tooltip:
		'''
		Genera una sala del Ataúd Maldito en tu cursor
		Reemplaza las salas del Ataúd Maldito existentes
		'''
}

GildedSceptre: {
	DisplayName: Cetro Dorado
	Tooltip:
		'''
		Dibuja un círculo para activar los proyectiles
		Los proyectiles activados persiguen al enemigo más cercano
		Los proyectiles activados infligen más daño según la precisión del círculo
		'''
}

AccursedAnkh: {
	DisplayName: Ankh Maldito
	Tooltip: Mientras se sostiene, aumenta la regeneración de vida y la disipación de penalizaciones, pero reduce la defensa en 10
}

SisypheanFist: {
	DisplayName: Guantelete de Sísifo
	Tooltip:
		'''
		Mientras estás en el suelo, arranca una enorme roca de la tierra
		Suelta el botón para lanzarla hacia tu cursor
		El daño de la roca escala con su velocidad
		Atraviesa a los enemigos con poca vida
		'''
}

EgyptianFlail: {
	DisplayName: Nekhakha
	Tooltip:
		'''
		Tus invocaciones se centrarán en los enemigos golpeados
		Ocasionalmente causa explosiones de Fuego de las Sombras
		'''
}

SpiritLongbow: {
	DisplayName: Arco Largo Espiritual
	Tooltip:
		'''
		Convierte las flechas en Flechas Espirituales que liberan llamas espirituales tras de sí
		Mantén el botón para cargar disparos con más daño y mayor velocidad
		Atraviesa a los enemigos con poca vida
		'''
}

CursedCoffinBag: {
	DisplayName: Bolsa del Tesoro (Ataúd Maldito)
