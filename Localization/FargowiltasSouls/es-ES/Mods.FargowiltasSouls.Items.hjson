		'''
}

GoldEnchant: {
	DisplayName: Encantamiento de Oro
	Tooltip:
		'''
		Tus ataques infligen Midas
		Envía automáticamente las monedas a tu hucha al recogerlas (funciona en el inventario y la apariencia)
