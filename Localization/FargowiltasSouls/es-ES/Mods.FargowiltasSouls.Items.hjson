}

IronEnchant: {
	DisplayName: Encantamiento de Hierro
	Tooltip:
		'''
		Funciona desde las ranuras de inventario y apariencia:
		Tus reforjas siempre otorgan un gran prefijo por un +50% de coste
		Aumenta el alcance de recogida de objetos
