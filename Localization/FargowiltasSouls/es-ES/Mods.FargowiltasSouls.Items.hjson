	Tooltip: ""
}

UmbraRegalia: {
	DisplayName: Umbra Regalia
	Tooltip:
		'''
		Clic Izquierdo para apuñalar rápidamente con la lanza
		Mantén Clic Derecho para cargar un lanzamiento de lanza
		Se vuelve más fuerte cuando está completamente cargada
		Puede seguir ganando daño por un tiempo tras la carga completa
		'La recompensa por una poderosa revancha...'
		'''
}

CoffinPainting: {
	DisplayName: Cuadro del Ataúd
	Tooltip: ""
}

ElectricWhip: {
	DisplayName: Cadena Voltáica
	Tooltip:
		'''
		Azota a los enemigos para disparar rayos en cadena desde los súbditos cercanos, hasta 4 veces por golpe
		'La sangre vital de un enemigo derrotado...'
		'''
}

TheDestroyer: {
	DisplayName: El Destructor
	Tooltip:
		'''
		Azota a tus súbditos para disparar un láser a un enemigo cercano, hasta 6 veces por golpe
		Cada 20.º golpe, el destructor se libera y sigue tu ratón durante 5 segundos
		'La recompensa por una poderosa revancha...'
		'''
}

FallenStarDayItem: {
