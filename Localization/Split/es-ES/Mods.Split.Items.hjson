BountifulCauldron: {
	DisplayName: Caldero Abundante
	Tooltip:
		'''
		Infunde a los jugadores cercanos con mejoras de poción
		{$BountifulCauldron.NearbyWarning}
		Alcance medio
		'¡Nuevas tecnologías!'
		'''
	Toggle: Clic para activar/desactivar
	QuickBuff: Clic derecho para aplicar todas las pociones
	AddBuff: Doble clic para añadir desde
	Inventory: el inventario
	Clear: Clic derecho para limpiar los efectos
	NearbyWarning: Solo un Caldero puede funcionar en el área a la vez
	NearbyError:
		'''
		[c/FF0000:¡Ya hay otro caldero activo en el área!]
		[c/FF0000:Desactívalo o rómpelo para seguir obteniendo mejoras.]
		'''
}

EtherealCauldron: {
	DisplayName: Caldero Etéreo
	Tooltip:
		'''
		Infunde a los jugadores cercanos con mejoras de poción
		{$BountifulCauldron.NearbyWarning}
		Las mejoras se agotarán más lento cuando esté apagado
		Aumenta la duración de las mejoras en un 25%
		Alcance medio
		'''
}

MoltenCauldron: {
	DisplayName: Caldero Fundido
	Tooltip:
		'''
		Infunde a los jugadores cercanos con mejoras de poción
		{$BountifulCauldron.NearbyWarning}
		Las mejoras no se agotarán mientras esté apagado
		Añadir muchas pociones reduce la tasa de agotamiento
		Aumenta la duración de las mejoras en un 50%
		Alcance enorme
		'''
}

MagicCauldron: {
	DisplayName: Caldero Mágico
	Tooltip:
		'''
		Infunde a los jugadores cercanos con mejoras de poción
		Se puede apagar para detener por completo el agotamiento de pociones
		Añadir muchas pociones reduce la tasa de agotamiento
		Aumenta la duración de las mejoras en un 50%
		Alcance infinito
