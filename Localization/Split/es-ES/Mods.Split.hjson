Dialogue: {
	Menace: {
		Defeat:
			'''
			! name Amenaza
			! portrait 0 1
			! delay 2.2
			! pause_at 2 0.5
			- ¡Ja! ¡Nunca le pasa nada malo a la Amenaza!
			! portrait 1 1
			! shake 20 1.0
			! name Amenaza (Derrotada)
			! delay 0.2
			...
			! portrait 2 1
			! delay 1
			...
			'''
		Escape:
			'''
			! name Amenaza
			! portrait 3 1
			! delay 2
			- ¡La próxima vez, debilucho!
			'''
	}

	MysteriousStranger:
		'''
		! name Forastero Misterioso
		! portrait 4 0
		! delay 2.5
		! pause_at 9 0.5
		- Adelante, diles lo que viste.
		- Nadie te creerá.
		'''
}

