Astrologist: {
	DisplayName: Astróloga

	TownNPCMood: {
		Content: No sé qué tal los demás, pero a mí me parece bien todo.
		NoHome: ¿Una casita, por favor? ...¿no se supone que para eso debería acudir a ti?
		FarFromHome: Sé que a cierta persona le encanta dormir al aire libre, pero yo prefiero tener mi propia caja de madera.
		LoveSpace: No había tenido tanto espacio desde... Vaya, ¡NUNCA había tenido tanto espacio!
		DislikeCrowded: Deshazte de la multitud, por favor.
		HateCrowded: Qué agobio hay aquí, es como estar de vuelta en el Nexo.
		LoveBiome: Me encanta {BiomeName}. ¡El cielo está clarísimo aquí!
		LikeBiome: "{BiomeName}... No hay magos atractivos por aquí, pero tampoco está mal."
		DislikeBiome: "{BiomeName} no es lo mío. Confundo la nieve con las estrellas."
		HateBiome: ¡¿{BiomeName}?! ¡Yo paso!
		LoveNPC: "{NPCName}... Él sí que tiene aura."
		LikeNPC: Me gusta {NPCName}. ¡Los ancianos son lo mejor!
		DislikeNPC: "{NPCName} me molesta un poco."
		HateNPC: "{NPCName} es un recordatorio andante de todo lo que no me gustaba del Nexo."
		LikeNPC_Princess: ¿{NPCName}? Vaya, ¿no es adorable?
		Princess_LovesNPC: "{NPCName}... ¡ella sí que es especial!"
	}

	Census.SpawnCondition: Condiciones desconocidas
}

