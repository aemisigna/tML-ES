Paraffin: {
	DisplayName: Parafina

	Rejected: {
		1: ¿Cómo pudo ser?... ¿No fui suficiente para ti?
		2: Nadie... ¡Nadie se atreve a rechazar a Parafina!
	}

	Defeat: {
		1: ¡Parafina ha sido derrotada!
		2: ¡Parafina sale volando otra vez!
		3: El Dominio del Inframundo se ha calmado...
	}

	Summon: {
		1: ¡Parafina ha despertado!
		2: ¡Parafina contraataca!
	}

	Unleashed: Un mal ancestral ha sido desatado...
}

Seth: {
	DisplayName: Seth

	HeatSnapDeath: {
		1: Seth se derritió por completo...
		2: Seth muerde el polvo...
		3: Seth no era digno...
	}

	Summon: {
		1: ¡Seth ha llegado!
		2: ¡El Desencadenado ha despertado!
	}

	Defeat: {
		1: ¡Seth ha sido derrotado!
		2: ¡El Desencadenado ha sido derrotado!
	}

	Approaching: La tormenta solar se aproxima...

	Taunt: {
		1: <Seth> Alimaña.
		2: <Seth> Sométete, alimaña.
		3: <Seth> No eres nada.
		4: <Seth> Escoria.
		5: <Seth> Quiébrate ante mí.
		6: <Seth> Tu cuerpo se hará añicos.
		7: <Seth> Ahora es momento de temer.
		8: <Seth> Débil.
		9: <Seth> Grita, alimaña.
		10: <Seth> Error.
	}

	Fail: {
		1: El Sol del Templo no ha salido. No lo apresures.
		2: El Sol del Templo no ha salido. Aniquila a su guardián.
		3: El Sol del Templo no ha salido. El Golem debe ser derrotado.
		4: El Sol del Templo no ha salido. Todavía no estás listo.
	}
}

