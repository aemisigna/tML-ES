Configs: {
	DebugConfig: {
		DisplayName: Debug Config

		calamityDifficulty: {
			Label: Calamity Difficulty Tester
			Tooltip:
				'''
				Tricks the game into thinking a Calamity difficulty is enabled
				Does not work if Calamity itself is enabled
				0 - None
				1 - Revengeance
				2 - Death
				3 - Malice or Boss Rush
				'''
		}

		eternityMode: {
			Label: Eternity Mode Tester
			Tooltip:
				'''
				Tricks the game into thinking Eternity mode is enabled
				Does not work if Fargo's Souls itself is enabled
				'''
		}

		forceHJAltSprites: {
			Label: Force Homeward Journey Alternate Sprites
			Tooltip:
				'''
				Some bosses in Homeward Journey have alternate sprites
				This force enables it to test if it breaks something
				'''
		}
	}

	SupportedModsConfig: {
		DisplayName: Supported Mods Config

		Calamity: {
			Label: "[i/s1:1281] Revengeance AIs"
			Tooltip: Revengeance mode AI for other mods
		}

		Eternity: {
			Label: "[i/s1:3577] Eternity AIs"
			Tooltip: Eternity mode AI for other mods
		}

		Infernum: {
			Label: "[i/s1:2701] Infernum counts as Eternity"
			Tooltip: Infernum mode counts as Malice + Eternity mode for supported (other) mods' bosses
		}

		BossRush: {
			Label: "[i/s1:43] Boss Rush support"
			Tooltip:
				'''
				Adds supported mods' bosses to boss rush
				NOTE: These mods' corresponding support toggle must be enabled!
				'''
		}

		DefenseDamage: {
			Label: "[i/s1:442] Defense Damage Support"
			Tooltip: Allows defense damage integration for supported mods
		}

		Consolaria: {
			Label: "[g:2] Consolaria"
			Tooltip: <Revengeance+>Consolaria
		}

		Homeward: {
			Label: "[i/s1:4765] Homeward Journey"
			Tooltip: <Revengeance+>ContinentOfJourney
		}

		Redemption: {
			Label: "[i/s1:554] Redemption"
			Tooltip: <Revengeance+>Redemption
		}

		SOTS: {
			Label: "[i/s1:3581] Secret of the Shadows"
			Tooltip: <Revengeance+>SOTS
		}

		Spooky: {
			Label: "[i/s1:1725] Spooky"
