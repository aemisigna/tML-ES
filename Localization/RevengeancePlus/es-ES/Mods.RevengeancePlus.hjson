Configs: {
	DebugConfig: {
		DisplayName: Configuración de Depuración

		calamityDifficulty: {
			Label: Probador de Dificultad de Calamity
			Tooltip:
				'''
				Hace creer al juego que una dificultad de Calamity está activada
				No funciona si Calamity está activado
				0 - Ninguna
				1 - Revengeance
				2 - Muerte
				3 - Malicia o Maratón de Jefes
				'''
		}

		eternityMode: {
			Label: Probador del Modo Eternidad
			Tooltip:
				'''
				Hace creer al juego que el Modo Eternidad está activado
				No funciona si Fargo's Souls está activado
				'''
		}

		forceHJAltSprites: {
