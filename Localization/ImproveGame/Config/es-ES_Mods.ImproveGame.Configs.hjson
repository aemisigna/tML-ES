UIConfigs: {
	DisplayName: Configuración Personal

	BigBackpackButton: {
		Label: "[centeritem:3813] Botón de Mochila Grande"
		Tooltip: ""
	}

	ResetNativeUI: {
		Label: "[centeritem:1544] Restablecer a UI vanilla"
		Tooltip: ""
	}

	GeneralFontOffsetY: {
		Label: "[centeritem:1543] Desplazamiento Y de fuente normal de UI"
		Tooltip: ""
	}

	BigFontOffsetY: {
		Label: "[centeritem:1543] Desplazamiento Y de fuente grande de UI"
		Tooltip: ""
	}

	ShowMoreData: {
		Label: "[centeritem:1344] Mostrar datos de depuración"
		Tooltip:
			'''
			Opciones de desarrollador, no para jugadores
			Activarlo mostrará información de depuración
			'''
	}

	ShowModName: {
		Label: "[centeritem:ImproveGame/LiquidWand] Mostrar de qué mod son los objetos"
		Tooltip: ""
	}

	PlyInfo: {
		Label: "[centeritem:3124] Estadísticas del jugador"
		Tooltip: Aparece un trébol de cuatro hojas junto al icono de logros
	}

	QoLAutoTrash: {
		Label: "[centeritem:348] Auto-basura"
		Tooltip:
			'''
			Una papelera automática.
			Los objetos se moverán a esta papelera si su tipo está dentro.
			Conserva los últimos 6 objetos tirados.
			Shift+Ctrl+Clic izquierdo en un objeto para moverlo a la papelera.
			'''
	}

	FontOffsetPreviewText: Ajusta el valor de desplazamiento para que el texto encaje en la línea.
	BigFontOffsetPreviewText: El veloz zorro marrón...

	OpenConfig: {
		Label: "{$Mods.ImproveGame.Configs.ImproveConfigs.OpenConfig.Label}"
		Tooltip: "{$Mods.ImproveGame.Configs.ImproveConfigs.OpenConfig.Tooltip}"
	}

	KeepFocus: {
		Label: "[centeritem:TVHeadMask] Mantener el juego en ejecución al perder el foco"
		Tooltip:
			'''
			El juego seguirá ejecutándose aunque se pierda el foco (es decir, en segundo plano)
			en lugar de pausarse en un jugador.
			'''
	}

	ExplosionEffect: {
		Label: "[centeritem:TNTBarrel] Efectos de explosión de varitas"
		Tooltip: Alterna los efectos de explosión de las varitas de este mod.
	}

	Headers: {
		MinimapHeader: "[centeritem:WorldGlobe] Ajustes de marcadores del mapa"
		UIHeader: "[centeritem:EchoMonolith] Ajustes de UI"
		GameHeader: "[centeritem:JimsDrone] Ajustes del juego"
	}

	MarkFloatingIsland: {
		Tooltip: Tamaño de los iconos del mapa de Islas flotantes marcadas; 0 para ocultar
		Label: "[centeritem:ImproveGame/FloatingIslandGlobe] Tamaño del icono de Islas flotantes"
	}

	MarkAether: {
		Tooltip: Tamaño de los iconos del mapa del Éter marcado; 0 para ocultar
		Label: "[centeritem:ImproveGame/AetherGlobe] Tamaño del icono del Éter"
	}

	MarkTemple: {
		Tooltip: Tamaño de los iconos del mapa del Templo de la selva marcado; 0 para ocultar
		Label: "[centeritem:ImproveGame/TempleGlobe] Tamaño del icono del Templo de la selva"
	}

	MarkDungeon: {
		Tooltip: Tamaño de los iconos del mapa de la Mazmorra marcada; 0 para ocultar
		Label: "[centeritem:ImproveGame/DungeonGlobe] Tamaño del icono de la Mazmorra"
	}

	MarkPyramid: {
		Label: "[centeritem:ImproveGame/PyramidGlobe] Tamaño del icono de Pirámide"
		Tooltip: Tamaño de los iconos del mapa de Pirámides marcadas; 0 para ocultar
	}

	MarkPlantera: {
		Label: "[centeritem:ImproveGame/PlanteraGlobe] Tamaño del icono del Brote de Plantera"
		Tooltip: Tamaño de los iconos del mapa de {$MapObject.PlanterasBulb} marcados; 0 para ocultar
	}

	MarkEnchantedSword: {
		Label: "[centeritem:ImproveGame/EnchantedSwordGlobe] Tamaño del icono de Espada encantada"
		Tooltip: Tamaño de los iconos del mapa de {$ItemName.EnchantedSword} marcadas; 0 para ocultar
	}

	MarkMarbleCave: {
		Label: "[centeritem:ImproveGame/MarbleCaveGlobe] Tamaño del icono de Cueva de mármol"
		Tooltip: Tamaño de los iconos del mapa de Cuevas de mármol marcadas; 0 para ocultar
	}

	MarkGraniteCave: {
		Label: "[centeritem:ImproveGame/GraniteCaveGlobe] Tamaño del icono de Cueva de granito"
		Tooltip: Tamaño de los iconos del mapa de Cuevas de granito marcadas; 0 para ocultar
	}

	MarkHive: {
		Label: "[centeritem:ImproveGame/GraniteCaveGlobe] Tamaño del icono de Colmena"
		Tooltip: Tamaño de los iconos del mapa de colmenas marcadas; 0 para ocultar
	}

	MarkEmptyAutofisher: {
		Label: "[centeritem:ImproveGame/Autofisher] Tamaño del icono de Máquina de Pesca sin cebo"
		Tooltip: Tamaño de los iconos del mapa de Máquinas de Pesca sin cebo; 0 para ocultar
	}

	SuicideButton: {
		Label: Matar al jugador
		Tooltip: Tu personaje morirá al pulsar este botón; [c/FF4444:piénsalo dos veces antes de pulsarlo].
	}

	MagicMirrorInstantTp: {
		Label: "[centeritem:MagicMirror] Objetos de regreso instantáneos"
		Tooltip: Los objetos de regreso como el Espejo mágico son instantáneos; se elimina el retraso antes del teletransporte.
	}

	HideNoConsumeBuffs: {
		Label: "[centeritem:297] Ocultar iconos de mejora de pociones infinitas"
		Tooltip:
			'''
			Oculta los iconos de mejora de las pociones infinitas
			Los efectos siguen proporcionándose por sus mejoras originales, pero no se muestran
			'''
	}

	InfernoTransparency: {
		Label: "[centeritem:InfernoPotion] Alfa del anillo de Infierno"
		Tooltip: Alfa de los anillos de Infierno en tu perspectiva; 1 es sólido y 0 es transparente.
	}

	InvisibleTransparency: {
		Label: "[centeritem:InvisibilityPotion] Alfa de invisibilidad"
		Tooltip: Alfa de tu personaje en tu perspectiva al estar invisible; 1 es sólido y 0 es transparente.
	}

	ThemeType: {
		Tooltip: Esquema de color de la UI de Quality of Terraria.
		Label: "[qotglyph:12] Esquema de color de UI"
	}

	ShowShimmerInfo: {
		Label: "[centeritem:BottomlessShimmerBucket] Mostrar info de Fulgor"
		Tooltip: Muestra en la descripción en qué se puede fulgurar un objeto.
	}

	ShowAmmoInfo: {
		Label: "[centeritem:1302] Mostrar tipo de munición usada"
		Tooltip: Muestra el tipo de munición que usa o a la que pertenece un objeto (si tiene)
	}

	ResetUIPositionsButton: {
		Label: Restablecer posición de UI
		Tooltip: Restaura todas las posiciones de UI al valor predeterminado; especialmente útil cuando no encuentras la UI de la Mochila Grande
	}

	EnableBlur: {
		Label: "[centeritem:MulticoloredStainedGlass] Desenfoque de UI"
		Tooltip:
			'''
			Proporciona un efecto de desenfoque a la UI de QoT
			No funciona con iluminación Retro
			Consejo: Un "denominador de escala" mayor funciona mejor en pantallas de alta resolución,
			que se establece con otra opción de configuración
			'''
	}

	SingleBlur: {
		Label: "[centeritem:MulticoloredStainedGlass] Desenfoque de UI individual (alto rendimiento)"
		Tooltip: Desenfoca cada ventana de UI por separado, lo cual es más bonito, pero puede causar problemas de compatibilidad (p. ej.: filtros que desaparecen, texto sobre la cabeza al enviar mensajes, etc.)
	}

	BlurZoomMultiplierDenominator: {
		Label: "[centeritem:MulticoloredStainedGlass] Escala de desenfoque (mayor = menos carga)"
		Tooltip:
			'''
			Cuanto mayor sea este valor, menos potencia de cálculo se requiere
			Si el desenfoque causa lag, prueba a aumentar este valor
			Los valores sugeridos son:
			- GPU normal, resolución 4K: 4
			- GPU de gama alta: 1
			1 significa que el desenfoque se basa en la resolución original
			Aumentar este valor afecta el alcance del desenfoque
			Puede que quieras ajustar las opciones de abajo en consecuencia
			'''
	}

	BlurIterationCount: {
		Label: "[centeritem:MulticoloredStainedGlass] Iteraciones (mayor = más carga)"
		Tooltip:
			'''
			Cuanto mayor sea el valor, más desenfocado estará el fondo
			Si el desenfoque causa lag, prueba a reducir este valor
			'''
	}

	BlurIterationOffsetMultiplier: {
		Label: "[centeritem:MulticoloredStainedGlass] Coeficiente de desplazamiento de muestreo (sin impacto de rendimiento)"
		Tooltip: Cuanto mayor sea el valor, más desenfocado estará el fondo, pero pueden aparecer rayas
	}

	BlurMixingNumber: {
		Label: "[centeritem:MulticoloredStainedGlass] Muestreo de color (mayor = más carga)"
		Tooltip: Cuanto mayor sea el valor, más colores se muestrean para el desenfoque
	}

	AutoSummon: {
		Label: "[centeritem:SlimeStaff] Reinvocación automática"
		Tooltip:
			'''
			Invoca el último esbirro usado tras reaparecer
			Se desactiva si el mod "Summoners' Association" está cargado
			¡Summoners' Association ofrece un control de invocación más fino!
			'''
	}

	RecipeSearch: {
		Label: "[centeritem:ImproveGame/SearchIcon] Búsqueda de recetas"
		Tooltip: Muestra una barra de búsqueda cuando el menú de recetas está expandido
	}

	RemoveGraveyardVisual: {
		Label: "[centeritem:RichGravestone2] Quitar visual del cementerio"
		Tooltip: Elimina el efecto visual del cementerio. Su funcionalidad como bioma no se verá afectada
	}

	RemoveGraveyardMist: {
		Label: "[centeritem:RichGravestone2] Quitar niebla del cementerio"
		Tooltip: Elimina el efecto de niebla del cementerio. La niebla indica si estás en el bioma
	}

	RemoveGraveyardMusic: {
