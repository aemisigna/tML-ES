	NotFound: No se pudo encontrar ningún líquido de Fulgor
	Reveal: "{0} marcó {ImproveGame.Mods.Items.AetherGlobe.BiomeName} en el mapa."
}

DetectorDrone: {
	Tooltip:
		'''
		Vuela alto y bajo para explorar terrenos
		Actualiza tu mapa explorado y emite luz para ver en la oscuridad
		ADVERTENCIA: No te alejes demasiado o explotará
		'''
	DisplayName: Dron Explorador
}

DevMark: {
	DisplayName: Marca del Desarrollador
	Tooltip:
		'''
		[c/ff0000:Objeto de desarrollador]
		Cuando está en el inventario, la Varita de Construcción no consumirá materiales (solo funciona en un jugador)
		Abrir la Máquina de Pesca la llenará automáticamente con equipo de pesca
		Se puede colocar en la ranura de accesorio de la Máquina de Pesca para aumentar significativamente su velocidad de pesca
		'''
}

Expelliarmus: {
	DisplayName: ¡Expelliarmus!
	Tooltip:
		'''
		[c/ff0000:Objeto de depuración]
		Saquea PNJs
		Puede probar el botín de PNJs
		'''
}

ShimmerTech: {
	DisplayName: Fulgorímetro
	Tooltip:
		'''
		[c/ff0000:Objeto de depuración]
		Elimina las bonificaciones de fulgor de tu jugador
		<right> en su lugar elimina las bonificaciones de fulgor del mundo
		{$ItemName.AegisCrystal}
		{$ItemName.ArcaneCrystal}
		{$ItemName.AegisFruit}
		{$ItemName.Ambrosia}
		{$ItemName.GummyWorm}
		{$ItemName.GalaxyPearl}
		{$ItemName.CombatBookVolumeTwo}
		{$ItemName.PeddlersSatchel}
		'¡Oh Dios, puedo ver el infinito!'
		'''
}

Dummy: {
	DisplayName: Muñeco Espantapájaros
	Tooltip:
		'''
		Se puede usar para probar el DPS
		Clic izquierdo para invocar un Muñeco en el cursor
		Clic derecho para eliminar el muñeco elegido
		Alt + Clic derecho para eliminar todos los muñecos
		También puedes usar comandos para modificar atributos:
		 /dummy info → ver estadísticas del muñeco
		 /help dummy → obtener el uso del muñeco
		'No me hagas daño :)'
		'''
	ConfigUIOpenTip: Pulsa {0} para mostrar el panel de configuración al sostener el objeto
	NoneKeyBind: <Ninguna>
	CannotUse: Este objeto actualmente no funciona en multijugador.
}

StorageCommunicator: {
	DisplayName: Telecom de Almacenamiento
	Tooltip:
		'''
		Te permite abrir un Gestor de Almacenamiento de forma remota
		<right> en cualquier Gestor de Almacenamiento para conectarte a él
		Usa el objeto para abrir el Gestor de Almacenamiento conectado
		'''
	NotSet: Actualmente no conectado
	SetTo: Conectado al Gestor de Almacenamiento en [{0}, {1}]
	MissingStorage: Gestor de Almacenamiento no encontrado
	Unlocated: No conectado a ningún Gestor de Almacenamiento, <right> un Gestor de Almacenamiento mientras sostienes este objeto para conectarlos
}

WeatherBook: {
	DisplayName: Libro de Climas
	Tooltip:
		'''
		Desbloquea el control del clima en el Panel de Control
		Cambia la dirección del viento, la fase lunar y la lluvia,
		así como la hora tras derrotar al Muro de Carne
		'''
}

AddChestIconDummy: {
	DisplayName: Icono Añadir Cofre Dummy
	Tooltip: ""
}

SearchIcon: {
	DisplayName: Receta no encontrada
	Tooltip: Ninguna receta cumple las condiciones
}

BaitSupplier: {
	DisplayName: Cámara de Cebo
	Tooltip:
		'''
		Toma automáticamente cebo de cofres colocados cerca
		para reabastecer todas las máquinas de pesca sin cebo del mundo
		'''
}

UniversalAmmoIcon: {
