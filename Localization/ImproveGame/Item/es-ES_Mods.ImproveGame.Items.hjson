	Tooltip: ""
}

LicenseBook: {
	DisplayName: Licencia
	Tooltip: Úsalo para ver la licencia y las referencias de QoT.
}

LiquidWandAdvanced: {
	DisplayName: Varita de Líquidos Definitiva
	Tooltip:
		'''
		Absorbe/Coloca el líquido elegido en un área seleccionada
		<right> mientras la sostienes para abrir el panel de control de líquidos
		Puede absorber/colocar una cantidad ilimitada de líquidos
		'''
}

WallPlaceSelectorMode: {
	DisplayName: Varita de Tecnología (Seleccionando)
	Tooltip:
		'''
		Coloca muros del inventario en un área seleccionada
		<right> para cambiar al modo de colocación
		'''
}

ActuationRodMkII: {
	DisplayName: Varita de Actuación Definitiva
	Tooltip:
		'''
		Activa bloques en un área seleccionada
		No necesita actuadores colocados
		'''
}

ShellShipInBottle: {
	DisplayName: Barco de Concha en una Botella
	Tooltip:
		'''
		Pregunta al Guía cómo fabricarlo con una Caracola
		¡Luego tíralo al Fulgor y mira qué pasa!
		'''
}

ShellShipInBottle_Shimmered: {
	DisplayName: Barco en una Botella Fulgurado
