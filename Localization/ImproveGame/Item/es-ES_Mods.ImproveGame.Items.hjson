		'''
		Almacena información de Cadena de Munición; se puede compartir con otros jugadores
		Usa este objeto para guardar esa información en tu computadora
		'''
	FromPlayer: Del jugador: {0}
	Added: Cadena de Munición añadida como: {0}
}

AddIconDummy: {
