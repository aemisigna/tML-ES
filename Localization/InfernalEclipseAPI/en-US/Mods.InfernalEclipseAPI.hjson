DiaryTooltip:
	'''
	[c/E3AF40:A mysterious diary which has been left unsigned...]
	[c/BEBEBE:Press "Left Shift" to open the diary]
	'''
BullyingTooltip:
	'''
	Increases most non-summon damage by 2% for each unused minion slot.
	Reduces summon damage by 10% for each used minion slot.
	Whips now scale with your melee bonuses instead of summoner bonuses
	Increases whip damage by 25%, and whip range by 50%
	[c/E3AF40:A paper note with a microchip on it, designed by Dylan]
	[c/BEBEBE:Press "Left Shift" to read the writing on the back of the note]
	'''

Configs: {
	InfernalConfig: {
		WrathoftheGodsBossesInBossRush: {
			Tooltip: Adds XG-07 Mars, the Avatar of Emptinesss, and Nameless Deity to Boss Rush.
			Label: Wrath of the God's Bosses In Boss Rush
		}

		BetsyInBossRush: {
			Tooltip: Adds Betsy to Boss Rush - CURRENTLY BUGGED
			Label: Betsy In Boss Rush
		}

		DreadnautillusInBossRush: {
			Tooltip: Adds Dreadnautillus to Boss Rush
			Label: Dreadnautillus In Boss Rush
		}

		Headers: {
			BossRushChanges: Boss Rush Toggles
			BalanceChanges: Balance Changes
			Miscellaneous: Miscellaneous
			MultiplayerAdjustments: Multiplayer Adjustments & Utilities
			Main: Main
			Secret: Expiremental Adjustments & Secret Settings
			Music: Music Toggles
			CompatibilityChanges: Compatibility Changes
		}

		ThoriumBalanceChangess: {
			Tooltip:
				'''
				Modifies Thorium and mutliple Thorium addon items to be in tune with Calamity's balance.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
			Label: Thorium Balance Changes
		}

		CalamityRecipeTweaks: {
			Tooltip: Adjusts a few Calamity recipes and removes most of the Vanilla QOL recipes
			Label: Calamity Recipe Tweaks
		}

		CalamityBalanceChanges: {
			Tooltip:
				'''
				Modifies Calamity and mutliple Calamity addon items that are either undertuned or overtuned.
				Also adjusts a few cross-mod recipes to mantain balance.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
			Label: Calamity Balance Changes
		}

		BossKillCheckOnOres: {
			Tooltip:
				'''
				Makes changes to certain items to make them unobtainable until their intended tier.
				Prevents certain ores & tiles from being mined until you kill certain bosses.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
			Label: Maintain Calamity Tier Progression
		}

		VanillaBalanceChanges: {
			Tooltip:
				'''
				Modifies a few Vanilla items to be in tune with Calamity's balance.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
			Label: Vanilla Balance Changes
		}

		DisplayName: Main Config

		TerraBladeBossInBossRush: {
			Tooltip: Adds the Terra Blade Boss to Boss Rush
			Label: Terra Blade Boss In Boss Rush
		}

		InfernumModeForced: {
			Tooltip:
				'''
				Locks the Calamity difficulty slider, even outside of boss fights
				Make sure to set the difficulty before enabling this config
				Helpful for servers where you don't want the difficulty being changed
				'''
			Label: Calamity Difficulty Slider Locked
		}

		SOTSBalanceChanges: {
			Tooltip:
				'''
				Modifies Secrets of the Shadows items to be in tune with Calamity's balance.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
			Label: Secrets of the Shadows Balance Changes
		}

		ConsolariaBalanceChanges: {
			Tooltip:
				'''
				Modifies Consolaria items to be in tune with Calamity's balance.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
			Label: Consolaria Balance Changes
		}

		InfernumRecipeTweaks: {
			Tooltip:
				'''
				Adjusts a few Infernum recipes.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
			Label: Infernum Recipe Tweaks
		}

		ForceFullXerocDialogue: {
			Label: Force Full Xeroc Dialogue
			Tooltip: Forces the game to display the full Xeroc Dialogue when starting Boss Rush & when you beat it. Helpful for servers.
		}

		SOTSThrowerToRogue: {
			Tooltip: Makes the void + thrower items from Unofficial SOTS Bard, Thrower, and Healer void + rogue items
			Label: Merge Void + Thrower and Rogue class
		}

		DisableBloodOrbPotions: {
			Tooltip: Disables the crafting recipes for potions that use blood orbs.
			Label: Disable Blood Orb Potions
		}

		PreventBossCheese: {
			Tooltip: Adds some mechanics to the game that prevent certain ways to easily kill certain bosses.
			Label: Prevent Boss Exploits
		}

		DisableUnfinisedContent: {
			Label: Disable Unfinised Content
			Tooltip: Disables any unfinished content from mods to keep the player experience consistent.
		}

		DisableDuplicateContent: {
			Label: Disable Duplicate Content
			Tooltip: Disables any duplicate content two mods may add.
		}

		AdditonalVanillaBossAdjustments: {
			Label: Additonal Vanilla Boss Adjustments
			Tooltip:
				'''
				Slighty adjusts the stats of some vanilla bosses to be more of a challenge.
				This setting does not remove any Ragnarok Mode exclusive AI changes added to vanilla bosses.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
		}

		MergeCraftingTrees: {
			Label: Merge Crafting Trees
			Tooltip:
				'''
				Merges the crafting trees for similar items from multiple mods & adds cross-mod crafting materials to certain items.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
		}

		BloodOrbPotionDuplication: {
			Label: Blood Orb Potion Duplication
			Tooltip: Replaces the Blood Orb potion recipes with duplication recipes instead.
		}

		ChanageWeaponClasses: {
			Label: Change Weapon Classes
			Tooltip: Changes the class of some weapons to give more varity or to make more sense with the weapon.
		}

		DisplayWorldEntryMessages: {
			Label: Display World Entry Messages
			Tooltip: Enables/Disables the messages upon entering a world.
		}

		EnableInterlude4: {
			Label: Interlude 4
			Tooltip:
				'''
				Togggles the 4th Interlude theme. 
				This interlude will play after both the Exo Mechs & Supreme Calamitas have been defeated.
				This song will override Their Fabricator & Acceptance when it plays.
				'''
		}

		AdjustAdvisorSpawnConditions: {
			Label: Adjust Advisor Spawn Conditions
			Tooltip:
				'''
				Adjusts the spawn conditions for the Advisor so it's not always active in the world.
				Useful if you use the Infernum boss bar and don't want it always being active due to the Advisor being alive all the time.
				This is known to cause problems in multiplayer, so disable this if your planning to play multiplayer.
				'''
		}

		MultiplayerBossRespawnTimer: {
			Label: Multiplayer Boss Respawn Timer
			Tooltip:
				'''
				How long it takes to respawn during a boss fight.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being set to 60.]
				'''
		}

		MinimumDifficultyToPreventRespawns: {
			Label: Minimum Difficulty To Prevent Respawns
			Tooltip: The minmum difficulty to apply the respawn prevention system.
		}

		MultiplayerRespawnsAllowed: {
			Label: Multiplayer Respawns Allowed
			Tooltip:
				'''
				The number of respawns allowed during boss fights.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being set to 1.]
				'''
		}

		NerfThoriumMulticlass: {
			Label: Nerf Thorium Multiclass
			Tooltip:
				'''
				Adds some systems to prevent Bard & Healer from multiclassing and getting too strong.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
		}

		ColoredRelics: {
			Label: Colored Relics
			Tooltip: Toggles this mod's colored relics.
		}

		ForceMenu: {
			Label: Force Menu Theme
			Tooltip: Forces the Infernal Eclipse of Ragnarok Menu theme to be selected on mod load.
		}

		AutomatedConfigSetup: {
			Label: Automated Config Setup
			Tooltip: Automatically sets up some other mod's configs to be the intended configs for the Infernal Eclipse of Ragnarok modpack.
		}

		MoveDeerclopsChecklistEntry: {
			Label: Move Deerclops Checklist Entry
			Tooltip: Moves Deerclops to be before Skeletron in boss checklist to match Calamity & Infernum's tier placement.
		}

		DontEnableThis: {
			Label: Don't Enable This
			Tooltip:
				'''
				Don't enable this. It will probably give you the wrong idea and it will lead to unbalanced & broken gameplay.
				[c/7C0A02:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being OFF.]
				'''
		}

		CalamityExpertAccessories: {
			Label: Calamity Expert Accessories
			Tooltip: Toggles certain drops from Calamity bosses being expert rarity.
		}

		ThereIsNoReasonDisableThis: {
			Label: There Is No Reason Disable This
			Tooltip:
				'''
				There is no reason to disable this as it disables difficulties that are buggy and unbalanced when merged with Infernum.
				Only disable this config if you know the consequences, and do not report bugs with this config disabled.
				[c/FFFF00:The Infernal Eclipse of Ragnarok mod pack is balanced around this setting being ON.]
				'''
		}

		DeveloperMode: {
			Label: Developer Mode
			Tooltip: Toggles the availablity of tools useful for development.
		}

		ForceRagnarokInfernumModeInSubworlds: {
			Label: Force Ragnarok Mode and Infernum Mode In Subworlds
			Tooltip:
				'''
				Automatically enables either Infernum Mode or Ragnarok Mode based on your worlds vanilla difficuly upon entering a subworld.
				Expert Mode sets it to Infernum; Master Mode sets it to Ragnarok Mode.
				'''
		}

		BereftVassalRagnarok: {
			Label: Ragnarok Bereft Vassal Theme
			Tooltip: Toggles if 'Dead Kingdom's Champion' by Techhy plays during the Bereft Vassal boss fight in Ragnarok Mode.
		}

		DoGRagnarok: {
			Label: Ragnarok Devourer of Gods Final Phase Theme
			Tooltip: Toggles if 'Last Battle (Ballos Mix)' by DM DOKURO plays during Devourer of Gods' final phase and desperation in Ragnaork Mode
		}

		WarMachineBossInBossRush: {
			Label: Wulfrum Mothership In Boss Rush
			Tooltip: Adds the Wulfrum Mothership boss to Boss Rush
		}

		MothershipMusic: {
			Label: Wulfrum Mothership Music
			Tooltip: Toggles which theme plays during the Wulfrum Mothership boss fight
		}

		MaxVoidOnRespawn: {
			Tooltip: Toggles if you respawn with max void or the default amount
			Label: Max Void On Respawn
		}

		SolynCampsiteFixes: {
			Label: Solyn Campsite Fixes
			Tooltip: ""
		}

		CnidrionMusic: {
			Label: Cnidrion Music
			Tooltip: Toggles if 'Seahorse Scrutiny (Rebirth)' by Brimston Premium plays while a Cnidrion is alive.
		}
	}

	Difficulty: {
