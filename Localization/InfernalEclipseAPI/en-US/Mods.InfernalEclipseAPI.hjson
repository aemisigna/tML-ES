	The454CasullandTheJackal: {
		DisplayName: .454 Casull and The Jackal
		Tooltip:
			'''
			Shooting either gun will swap the first two bullet type ammos in your ammo slots
			<left> to shoot The Jackal, a low-fire rate pistol meant for single-target damage
			The Jackal will convert Musket Balls into High Velocity Bullets
			<right> to shoot .454 Casull, a high-fire rate pistol meant for mobbing
			The .454 Casull will convert Musket Balls into Meteor Shots
			Bullets inflict [cbuff:CalamityMod/Laceration] and tear blood orbs out of targets on hit
			Picking up these blood orbs reduces the duration of [cbuff:PotionSickness]
			[c/7C0A02:'Even Jesus wept...']
			[c/aaaaaa:Shift-<right> this item in your inventory to toggle the] [i:EndlessMusketPouch] [c/aaaaaa:ammo swap]
			'''
	}

	RuinousPlasmaInjection: {
		DisplayName: Ruinous Plasma Injection
		Tooltip:
			'''
			Permanently increases max void by 10 and void regeneration speed by 1%
			Can be used 5 times
			'''
	}

	FinalFractalMusicBox: {
		DisplayName: Music Box (Terra Blade)
		Tooltip: Plays 'FINAL FRACTAL' by ENNWAY
	}

	CragmawMireRelic: {
		DisplayName: Infernal Cragmaw Mire Relic
		Tooltip: "{0}"
	}

	IllusionistRelic: {
		DisplayName: Infernal Illusionist Relic
		Tooltip: "{0}"
	}

	Catlight: {
		DisplayName: Catlight
		Tooltip:
			'''
			'Are bosses too hard? Then buy Catlight Industries' Catlight!'
			[c/7C0A02:Buy our product now]
			'''
	}

	AlloyofEden: {
		DisplayName: Alloy of Eden
		Tooltip: An alloy composed of the strongest materials from multiple universes
	}

	SolynsSpellbook: {
		DisplayName: Solyn's Spellbook
		Tooltip:
			'''
			A book that appeared in Solyn's old tent after the defeat of the Nameless Deity and completion of her bookshelf
			Finely detailed diagrams of numerous magical artifacts fill up the book's pages
			Picking up this item or holding it in your inventory permanently unlocks new recipes
			'''
	}

	TheChickenWing: {
		DisplayName: The Chicken Wing
		Tooltip:
			'''
			Inflicts [cbuff:Oiled] on enemies
			Grows more powerful the better fed you are
			Defeating enemies temporarily grants [cbuff:HeartyMeal]
			'Not the part you think it is.'
			'''
	}

	WulfrumMothershipRelic: {
		DisplayName: Infernal Wulfrum Mothership Relic
		Tooltip: "{0}"
	}

	SoulDrivenHeadphonesEclipse: {
		DisplayName: Soul-Driven Headphones (Eclipse Edition)
		Tooltip:
			'''
			Allows you to pick and play custom Infernal Eclipse of Ragnarok music, as well as some other unique themes
			As you hold onto them, you vaguely feel an otherworldly presence
			You can also hear the sounds of instruments passionately playing
			'''
	}

	SplitFirebrand: {
		DisplayName: Split Firebrand
		Tooltip: ""

		Progression: {
			Skeletron:
				'''
				This firey Whip that you've made burns through iron and foes alike
				Yet it was the potential to burn brighter, defeat the curse of the dungeon to fuel the fire
				'''
			WoF:
				'''
				A spark has grown larger, making it wild
				There's more to set ablaze... Defeat the gate of the underworld to fuel the fire
				'''
			Mechs:
				'''
				When the fire goes wilder, it doesn't suddenly calm, there's more to be reached and more to be ashed
				Melt the metal overseers to fuel the fire
				'''
			Plantera:
				'''
				Can you feel it? Your hands burning, sweat turning into mist... Yet it must burn hotter
				Defeat the Predator of the Jungle to fuel the fire
				'''
			Golem:
				'''
				Even when you move, you can feel the fire dance on your skin, a deadly dance but beautiful none the less
				Defeat the guardian of the lizhard temple
				'''
			MoonLord:
				'''
				Strike again and again, never stop till flames touch the stars
				Beat the moon's harbinger to fuel the fire
				'''
			Full:
				'''
				A new potential unlocked, something truly hidden from most but pried open by you
				It's evolution is done, but not yours, keep going even if you have to discard it
				'''
		}

		TagDebuff: {
			Skeletron:
				'''
				2 summon tag damage
				Every third swing will instead cause the whip to extend outwards, dealing 1.5x damage
				Inflicts the [iebuff:InfernalEclipseAPI/SoulBurn] debuff to incinerate foes
				'''
			WoF:
				'''
				4 summon tag damage
				Every third swing will instead cause the whip to extend outwards, dealing 1.5x damage
				Inflicts the [iebuff:InfernalEclipseAPI/SoulBurn2] debuff to incinerate foes
				'''
			Mechs:
				'''
				5 summon tag damage
				Every third swing will instead cause the whip to extend outwards, dealing 1.5x damage
				Inflicts the [iebuff:InfernalEclipseAPI/SoulBurn3] debuff to incinerate foes
				Minions that touch the whip will be set ablaze!
				Ablazed minions deal 1.05x damage and inflict [iebuff:OnFire3]
				'''
			Plantera:
				'''
				7 summon tag damage
				Every third swing will instead cause the whip to extend outwards, dealing 1.5x damage
				Inflicts the [iebuff:InfernalEclipseAPI/SoulBurn4] debuff to incinerate foes
				Minions that touch the whip will be set ablaze!
				Ablazed minions deal 1.1x damage and inflict [iebuff:OnFire3]
				Press {0} to unleash a wave of fire on a 1 minute cooldown
				'''
			Golem:
				'''
				10 summon tag damage
				Every third swing will instead cause the whip to extend outwards, dealing 1.5x damage
				Inflicts the [iebuff:InfernalEclipseAPI/SoulBurn5] debuff to incinerate foes
				Minions that touch the whip will be set ablaze!
				Ablazed minions deal 1.15x damage and inflict [iebuff:CalamityMod/BrimstoneFlames]
				Press {0} to unleash a wave of fire on a 1 minute cooldown
				The first enemy hit each swing will grant the user a stack of [iebuff:InfernalEclipseAPI/HotHands]
				'''
			MoonLord:
				'''
				12 summon tag damage
				Every third swing will instead cause the whip to extend outwards, dealing 1.5x damage
				Inflicts the [iebuff:InfernalEclipseAPI/SoulBurn6] debuff to incinerate foes
				Minions that touch the whip will be set ablaze!
				Ablazed minions deal 1.2x damage and inflict [iebuff:CalamityMod/BrimstoneFlames]
				Press {0} to unleash a wave of fire on a 1 minute cooldown
				The first enemy hit each swing will grant the user a stack of [iebuff:InfernalEclipseAPI/HotHands2]
				'''
			Full:
				'''
				20 summon tag damage
				Every third swing will instead cause the whip to extend outwards, dealing 1.5x damage
				Inflicts the [iebuff:InfernalEclipseAPI/SoulBurn7] debuff to incinerate foes
				Minions that touch the whip will be set ablaze!
				Ablazed minions deal 1.35x damage and inflict both [iebuff:CalamityMod/BrimstoneFlames] and [iebuff:CalamityMod/StaticDischarge]
				Press {0} to unleash a wave of fire on a 1 minute cooldown
				The first enemy hit each swing will grant the user a stack of [iebuff:InfernalEclipseAPI/HotHands2]
				'''
		}

		Lore:
			'''
			'When Dylan first came, he seemed to have brought some weapons from his home world'
			'These were used by those who opposed the tyrannical rule of those who's power matched God's'
			'Now that you've managed to replicate one of these crafts, maybe it will grow into something wonderful'
			'''
	}

	//Localization Team: do not change [ieconstruct:ChaosConstruct], as it is replaced with a colored version using the Name perameter below.
	ChaosLure: {
		DisplayName: Chaos Lure
		Tooltip:
			'''
			An Electromagnetic Lure overcharged with chaotic energy
			Attracts a [IELuxTag:ChaosConstruct]
			Not consumable
			'''
		Name: Chaos Construct
	}
}

