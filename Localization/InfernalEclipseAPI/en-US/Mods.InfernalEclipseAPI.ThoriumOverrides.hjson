	}
	*/
	
	ShootingStarHat.SetBonus:
		'''
		Symphonic empowerments last 6 seconds longer
		Each unique empowerment you have increases your symphonic damage by 2.5%
		Each unique empowerment you have increases your inspiration regeneration by 2%
		'''

	SoulofPlight: {
		DisplayName: Soul of Spite
