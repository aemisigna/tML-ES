ThrowerTechniques: {
	Decoy: {
		DisplayName: Decoy
		Description:
			'''
			Call in an enemy decoy and gain increased attack speed for a second
			The decoy will attempt to grab the attention of nearby enemies
			'''
	}

	BloodLotus: {
		DisplayName: Blood Lotus
		Description:
			'''
			Stop in place and release a torrent of knives at the nearest enemy
			Every knife heals you up to 10% of the damage dealt
			The torrent grants the player 100 defence but fades on taking damage
			'''
	}

	SmokeBomb: {
		DisplayName: Smoke Bomb
		Description:
			'''
			Release a smoke bomb
			Smoke bombs briefly grant you damage immunity and increased attack speed for 2 seconds
			'''
	}
