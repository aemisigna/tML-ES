	ChromaticMassInABottle: {
		Tooltip: "'Aunque KrogNar estaba tramando algo, Aaron simplemente no podía ignorar la presencia de esta energía.'"
		DisplayName: Masa Cromática en una Botella
	}

	Swordofthe14thGlitch: {
		DisplayName: Espada del Cénit
		Tooltip:
			'''
			Clic Derecho para embestir hacia el cursor, realizando un ataque giratorio al final de la embestida que genera múltiples rayos de espada teledirigidos
			La decimocuarta forma del Cristal del Glitch, empuñada por Zane Guritchi
			'''
	}

	BossRushTier6MusicBox: {
		Tooltip: Reproduce 'Descent Of Divinities' de psykomatic
		DisplayName: Caja Musical (Boss Rush - Nivel 6)
	}

	NovaBomb: {
		DisplayName: Bomba Nova
		Tooltip:
			'''
			Canaliza algunas de las fuerzas más misteriosas del Viajero y las libera en un ataque explosivo de gran área de efecto
			Clic Derecho para colapsar el agujero negro antes de tiempo
			'No te preocupes Willow, puedo solo con esto.'
			'''
	}

	BossRushTierNamelessMusicBox: {
		Tooltip: Reproduce 'TWISTED GARDEN [Remix]' de Kuudray
		DisplayName: Caja Musical (Boss Rush - Nivel ???)
	}

