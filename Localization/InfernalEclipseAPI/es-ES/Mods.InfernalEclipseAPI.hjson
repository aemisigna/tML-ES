		DisplayName: Audífonos Impulsados por Almas (Edición Eclipse)
		Tooltip:
			'''
			Te permite elegir y reproducir música personalizada de Infernal Eclipse of Ragnarok, así como algunos otros temas únicos
			Mientras los sostienes, sientes vagamente una presencia sobrenatural
			También puedes oír los sonidos de instrumentos tocando apasionadamente
			'''
	}

	SplitFirebrand: {
		DisplayName: Split Firebrand
		Tooltip: ""

		Progression: {
			Skeletron:
				'''
				Este ardiente Látigo que has hecho quema tanto el hierro como a sus enemigos
				Sin embargo, tenía el potencial de arder más brillante, derrota la maldición de la mazmorra para alimentar el fuego
				'''
			WoF:
				'''
				Una chispa ha crecido más, volviéndose salvaje
				Hay más para incendiar... Derrota la puerta del inframundo para alimentar el fuego
				'''
			Mechs:
				'''
				Cuando el fuego se vuelve más salvaje, no se calma de repente, hay más por alcanzar y más por convertir en cenizas
				Funde a los supervisores metálicos para alimentar el fuego
				'''
			Plantera:
				'''
				¿Lo sientes? Tus manos ardiendo, el sudor convirtiéndose en niebla... Sin embargo debe arder más caliente
				Derrota al Depredador de la Jungla para alimentar el fuego
				'''
			Golem:
				'''
				Incluso cuando te mueves, puedes sentir el fuego danzar sobre tu piel, una danza mortal pero hermosa de todos modos
				Derrota al guardián del templo lizhard
				'''
			MoonLord:
				'''
				Golpea una y otra vez, nunca te detengas hasta que las llamas toquen las estrellas
				Vence al heraldo de la luna para alimentar el fuego
				'''
			Full:
				'''
				Un nuevo potencial desbloqueado, algo verdaderamente oculto para la mayoría pero abierto a la fuerza por ti
				Su evolución está completa, pero la tuya no, sigue adelante incluso si tienes que descartarlo
				'''
		}

		TagDebuff: {
			Skeletron:
				'''
				2 de daño de marca de invocación
				Cada tercer golpe hará que el látigo se extienda hacia afuera, infligiendo 1.5x de daño
				Inflige el efecto negativo [iebuff:InfernalEclipseAPI/SoulBurn] para incinerar enemigos
				'''
			WoF:
				'''
				4 de daño de marca de invocación
				Cada tercer golpe hará que el látigo se extienda hacia afuera, infligiendo 1.5x de daño
				Inflige el efecto negativo [iebuff:InfernalEclipseAPI/SoulBurn2] para incinerar enemigos
				'''
			Mechs:
				'''
				5 de daño de marca de invocación
				Cada tercer golpe hará que el látigo se extienda hacia afuera, infligiendo 1.5x de daño
				Inflige el efecto negativo [iebuff:InfernalEclipseAPI/SoulBurn3] para incinerar enemigos
				¡Los esbirros que toquen el látigo se incendiarán!
				Los esbirros incendiados infligen 1.05x de daño e infligen [iebuff:OnFire3]
				'''
			Plantera:
				'''
				7 de daño de marca de invocación
				Cada tercer golpe hará que el látigo se extienda hacia afuera, infligiendo 1.5x de daño
				Inflige el efecto negativo [iebuff:InfernalEclipseAPI/SoulBurn4] para incinerar enemigos
				¡Los esbirros que toquen el látigo se incendiarán!
				Los esbirros incendiados infligen 1.1x de daño e infligen [iebuff:OnFire3]
				Presiona {0} para liberar una ola de fuego con un tiempo de reutilización de 1 minuto
				'''
			Golem:
				'''
				10 de daño de marca de invocación
				Cada tercer golpe hará que el látigo se extienda hacia afuera, infligiendo 1.5x de daño
				Inflige el efecto negativo [iebuff:InfernalEclipseAPI/SoulBurn5] para incinerar enemigos
				¡Los esbirros que toquen el látigo se incendiarán!
				Los esbirros incendiados infligen 1.15x de daño e infligen [iebuff:CalamityMod/BrimstoneFlames]
				Presiona {0} para liberar una ola de fuego con un tiempo de reutilización de 1 minuto
				El primer enemigo golpeado en cada golpe otorgará al usuario una carga de [iebuff:InfernalEclipseAPI/HotHands]
				'''
			MoonLord:
				'''
				12 de daño de marca de invocación
				Cada tercer golpe hará que el látigo se extienda hacia afuera, infligiendo 1.5x de daño
				Inflige el efecto negativo [iebuff:InfernalEclipseAPI/SoulBurn6] para incinerar enemigos
				¡Los esbirros que toquen el látigo se incendiarán!
				Los esbirros incendiados infligen 1.2x de daño e infligen [iebuff:CalamityMod/BrimstoneFlames]
				Presiona {0} para liberar una ola de fuego con un tiempo de reutilización de 1 minuto
				El primer enemigo golpeado en cada golpe otorgará al usuario una carga de [iebuff:InfernalEclipseAPI/HotHands2]
				'''
			Full:
				'''
				20 de daño de marca de invocación
				Cada tercer golpe hará que el látigo se extienda hacia afuera, infligiendo 1.5x de daño
				Inflige el efecto negativo [iebuff:InfernalEclipseAPI/SoulBurn7] para incinerar enemigos
				¡Los esbirros que toquen el látigo se incendiarán!
				Los esbirros incendiados infligen 1.35x de daño e infligen tanto [iebuff:CalamityMod/BrimstoneFlames] como [iebuff:CalamityMod/StaticDischarge]
				Presiona {0} para liberar una ola de fuego con un tiempo de reutilización de 1 minuto
				El primer enemigo golpeado en cada golpe otorgará al usuario una carga de [iebuff:InfernalEclipseAPI/HotHands2]
				'''
		}

		Lore:
			'''
			'Cuando Dylan llegó por primera vez, parecía haber traído algunas armas de su mundo natal'
			'Estas fueron usadas por quienes se opusieron al gobierno tiránico de aquellos cuyo poder igualaba al de Dios'
			'Ahora que has logrado replicar una de estas creaciones, tal vez se convierta en algo maravilloso'
			'''
	}

	//Localization Team: do not change [ieconstruct:ChaosConstruct], as it is replaced with a colored version using the Name perameter below.
	ChaosLure: {
		DisplayName: Señuelo del Caos
		Tooltip:
			'''
			Un Señuelo Electromagnético sobrecargado con energía caótica
			Atrae a un [IELuxTag:ChaosConstruct]
			No se consume
			'''
		Name: Constructo del Caos
	}
}

