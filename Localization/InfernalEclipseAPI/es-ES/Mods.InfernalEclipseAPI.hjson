	Lycanroc: {
		DisplayName: Lycanroc
		Tooltip: ""

		Progression: {
			WoF:
				'''
				Derrota al guardián del Infierno para ganar más poder...
				No se ha obtenido poder extra...
				'''
			Mechs:
				'''
				Con la derrota del Muro de Carne, las balas disparadas por esta arma infligen [cbuff:CalamityMod/Crumbling]
				Derrota a las bestias mecánicas para ganar más poder...
				'''
			Plantera:
				'''
				Con la derrota de las máquinas de Draedon, esta arma ahora convierte balas normales en balas de alta velocidad
				Derrota al guardián de la jungla para ganar más poder...
				'''
			Golem:
				'''
				Con la derrota de Plantera, tu furia ahora hace que esta arma dispare increíblemente rápido
				Derrota al constructo del Templo Lizhard para ganar más poder...
				'''
			Cultist:
				'''
				Con la derrota de Golem, tu adrenalina garantiza golpes críticos
				Derrota al líder del culto ancestral para ganar más poder...
				'''
			MoonLord:
				'''
				Con la derrota del Culto Lunático, esta arma ahora tiene una probabilidad de super crítico
				Derrota al cadáver Eldritch para ganar más poder...
				'''
			Full: ¡Lycanroc ha despertado por completo, y su poder máximo ha sido liberado!
		}

		Lore: "'¿Qué vas a hacer? ¿Matarme?'"
	}

	CelestialIllumination: {
		DisplayName: Iluminación Celestial
		Tooltip: ""

		Progression: {
			Deus:
				'''
				Derrota al horror eldritch para ganar más poder...
				No se ha obtenido poder extra...
				'''
			MoonLord:
				'''
				Con la derrota del Moon Lord, tus estrellas son más rápidas
				Derrota a los guardianes de la llama profanada para ganar más poder...
				'''
			Providence:
				'''
				Con la derrota de Providence, tus ataques infligen [cbuff:CalamityMod/HolyFlames]
				Derrota a los centinelas del azote para ganar más poder...
				'''
			Polterghast:
				'''
				Con la derrota de Polterghast, puedes disparar un rayo celestial
				Derrota al Devourer of Gods para ganar más poder...
				'''
			DoG:
				'''
				Con la derrota del Devourer of Gods, tus estrellas persiguen
				Derrota al fénix resplandeciente para ganar más poder...
				'''
			Full: ¡La Iluminación Celestial ha despertado por completo, y su verdadera fuerza ha sido revelada!
			ProfanedGuardians:
				'''
				Con la derrota de los Guardianes Profanados, puedes disparar un rayo celestial
				Derrota a la Diosa de la Llama para ganar más poder...
				'''
			Sentinels:
				'''
				Con la derrota de los Centinelas, el rayo celestial dura más tiempo
				Derrota al Devourer of Gods para ganar más poder...
				'''
