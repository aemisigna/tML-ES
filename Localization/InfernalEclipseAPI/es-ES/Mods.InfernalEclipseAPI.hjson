DiaryTooltip:
	'''
	[c/E3AF40:Un misterioso diario que ha sido dejado sin firmar...]
	[c/BEBEBE:Presiona "Mayús Izquierda" para abrir el diario]
	'''
BullyingTooltip:
	'''
	Aumenta la mayoría del daño que no es de invocación en un 2% por cada ranura de esbirro no usada.
	Reduce el daño de invocación en un 10% por cada ranura de esbirro usada.
	Los látigos ahora escalan con tus bonos cuerpo a cuerpo en lugar de bonos de invocador
	Aumenta el daño de látigo en un 25%, y el rango de látigo en un 50%
	[c/E3AF40:Una nota de papel con un microchip pegado, diseñada por Dylan]
	[c/BEBEBE:Presiona "Mayús Izquierda" para leer lo escrito al reverso de la nota]
	'''

Configs: {
	InfernalConfig: {
		WrathoftheGodsBossesInBossRush: {
			Tooltip: Añade a XG-07 Mars, al Avatar of Emptinesss, y a la Deidad Sin Nombre al Boss Rush.
			Label: Jefes de Wrath of the Gods en Boss Rush
		}

		BetsyInBossRush: {
			Tooltip: Añade a Betsy al Boss Rush - ACTUALMENTE CON ERRORES
			Label: Betsy en Boss Rush
		}

		DreadnautillusInBossRush: {
			Tooltip: Añade a Dreadnautillus al Boss Rush
			Label: Dreadnautillus en Boss Rush
		}

		Headers: {
			BossRushChanges: Interruptores del Boss Rush
			BalanceChanges: Cambios de Balance
			Miscellaneous: Varios
			MultiplayerAdjustments: Ajustes y Utilidades Multijugador
			Main: Principal
			Secret: Ajustes Experimentales y Configuración Secreta
			Music: Interruptores de Música
			CompatibilityChanges: Cambios de Compatibilidad
		}

		ThoriumBalanceChangess: {
			Tooltip:
				'''
				Modifica Thorium y múltiples objetos de complementos de Thorium para que estén en sintonía con el balance de Calamity.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
			Label: Cambios de Balance de Thorium
		}

		CalamityRecipeTweaks: {
			Tooltip: Ajusta algunas recetas de Calamity y elimina la mayoría de las recetas de calidad de vida de Vanilla
			Label: Ajustes de Recetas de Calamity
		}

		CalamityBalanceChanges: {
			Tooltip:
				'''
				Modifica Calamity y múltiples objetos de complementos de Calamity que están mal calibrados, ya sea por debajo o por encima.
				También ajusta algunas recetas entre mods para mantener el balance.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
			Label: Cambios de Balance de Calamity
		}

		BossKillCheckOnOres: {
			Tooltip:
				'''
				Hace cambios a ciertos objetos para que no puedan obtenerse hasta su nivel previsto.
				Impide que ciertos minerales y bloques sean minados hasta que derrotes a ciertos jefes.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
			Label: Mantener la Progresión por Niveles de Calamity
		}

		VanillaBalanceChanges: {
			Tooltip:
				'''
				Modifica algunos objetos de Vanilla para que estén en sintonía con el balance de Calamity.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
			Label: Cambios de Balance de Vanilla
		}

		DisplayName: Configuración Principal

		TerraBladeBossInBossRush: {
			Tooltip: Añade al Jefe Terra Blade al Boss Rush
			Label: Jefe Terra Blade en Boss Rush
		}

		InfernumModeForced: {
			Tooltip:
				'''
				Bloquea el control deslizante de dificultad de Calamity, incluso fuera de las peleas contra jefes
				Asegúrate de configurar la dificultad antes de activar esta configuración
				Útil para servidores donde no quieres que la dificultad sea cambiada
				'''
			Label: Control Deslizante de Dificultad de Calamity Bloqueado
		}

		SOTSBalanceChanges: {
			Tooltip:
				'''
				Modifica los objetos de Secrets of the Shadows para que estén en sintonía con el balance de Calamity.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
			Label: Cambios de Balance de Secrets of the Shadows
		}

		ConsolariaBalanceChanges: {
			Tooltip:
				'''
				Modifica los objetos de Consolaria para que estén en sintonía con el balance de Calamity.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
			Label: Cambios de Balance de Consolaria
		}

		InfernumRecipeTweaks: {
			Tooltip:
				'''
				Ajusta algunas recetas de Infernum.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
			Label: Ajustes de Recetas de Infernum
		}

		ForceFullXerocDialogue: {
			Label: Forzar Diálogo Completo de Xeroc
			Tooltip: Fuerza al juego a mostrar el diálogo completo de Xeroc al iniciar el Boss Rush y al vencerlo. Útil para servidores.
		}

		SOTSThrowerToRogue: {
			Tooltip: Convierte los objetos de vacío + arrojadizo de Unofficial SOTS Bard, Thrower, and Healer en objetos de vacío + pícaro
			Label: Fusionar Clase Vacío + Arrojadizo y Pícaro
		}

		DisableBloodOrbPotions: {
			Tooltip: Desactiva las recetas de crafteo para pociones que usan orbes de sangre.
			Label: Desactivar Pociones de Orbe de Sangre
		}

		PreventBossCheese: {
			Tooltip: Añade algunas mecánicas al juego que evitan ciertas formas de matar fácilmente a determinados jefes.
			Label: Evitar Exploits de Jefes
		}

		DisableUnfinisedContent: {
			Label: Desactivar Contenido Sin Terminar
			Tooltip: Desactiva cualquier contenido sin terminar de los mods para mantener consistente la experiencia del jugador.
		}

		DisableDuplicateContent: {
			Label: Desactivar Contenido Duplicado
			Tooltip: Desactiva cualquier contenido duplicado que dos mods puedan añadir.
		}

		AdditonalVanillaBossAdjustments: {
			Label: Ajustes Adicionales a los Jefes de Vanilla
			Tooltip:
				'''
				Ajusta ligeramente las estadísticas de algunos jefes de Vanilla para que sean más desafiantes.
				Esta configuración no elimina ningún cambio de IA exclusivo del Modo Ragnarok añadido a los jefes de Vanilla.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
		}

		MergeCraftingTrees: {
			Label: Fusionar Árboles de Crafteo
			Tooltip:
				'''
				Fusiona los árboles de crafteo de objetos similares de múltiples mods y añade materiales de crafteo entre mods a ciertos objetos.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
		}

		BloodOrbPotionDuplication: {
			Label: Duplicación de Poción de Orbe de Sangre
			Tooltip: Reemplaza las recetas de poción de Orbe de Sangre con recetas de duplicación en su lugar.
		}

		ChanageWeaponClasses: {
			Label: Cambiar Clases de Armas
			Tooltip: Cambia la clase de algunas armas para dar más variedad o para que tengan más sentido con el arma.
		}

		DisplayWorldEntryMessages: {
			Label: Mostrar Mensajes al Entrar al Mundo
			Tooltip: Activa/Desactiva los mensajes al entrar a un mundo.
		}

		EnableInterlude4: {
			Label: Interludio 4
			Tooltip:
				'''
				Activa/desactiva el tema del 4.º Interludio.
				Este interludio sonará después de que tanto los Exo Mechs como la Supreme Calamitas hayan sido derrotados.
				Esta canción reemplazará a Their Fabricator y Acceptance cuando suene.
				'''
		}

		AdjustAdvisorSpawnConditions: {
			Label: Ajustar Condiciones de Aparición del Asesor
			Tooltip:
				'''
				Ajusta las condiciones de aparición del Asesor para que no esté siempre activo en el mundo.
				Útil si usas la barra de jefe de Infernum y no quieres que esté siempre activa debido a que el Asesor está vivo todo el tiempo.
				Se sabe que esto causa problemas en multijugador, así que desactívalo si planeas jugar multijugador.
				'''
		}

		MultiplayerBossRespawnTimer: {
			Label: Temporizador de Reaparición de Jefes en Multijugador
			Tooltip:
				'''
				Cuánto tiempo tarda en reaparecer durante una pelea contra un jefe.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción configurada en 60.]
				'''
		}

		MinimumDifficultyToPreventRespawns: {
			Label: Dificultad Mínima Para Evitar Reapariciones
			Tooltip: La dificultad mínima para aplicar el sistema de prevención de reaparición.
		}

		MultiplayerRespawnsAllowed: {
			Label: Reapariciones Permitidas en Multijugador
			Tooltip:
				'''
				La cantidad de reapariciones permitidas durante las peleas contra jefes.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción configurada en 1.]
				'''
		}

		NerfThoriumMulticlass: {
			Label: Debilitar Multiclase de Thorium
			Tooltip:
				'''
				Añade algunos sistemas para evitar que Bardo y Sanador hagan multiclase y se vuelvan demasiado fuertes.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
		}

		ColoredRelics: {
			Label: Reliquias de Colores
			Tooltip: Activa/desactiva las reliquias de colores de este mod.
		}

		ForceMenu: {
			Label: Forzar Tema del Menú
			Tooltip: Fuerza a que el tema del menú de Infernal Eclipse of Ragnarok sea seleccionado al cargar el mod.
		}

		AutomatedConfigSetup: {
			Label: Configuración Automatizada
			Tooltip: Configura automáticamente algunas configuraciones de otros mods para que sean las previstas para el mod pack Infernal Eclipse of Ragnarok.
		}

		MoveDeerclopsChecklistEntry: {
			Label: Mover Entrada de Deerclops en la Lista de Jefes
			Tooltip: Mueve a Deerclops para que aparezca antes de Skeletron en la lista de jefes, para coincidir con el orden de nivel de Calamity e Infernum.
		}

		DontEnableThis: {
			Label: No Actives Esto
			Tooltip:
				'''
				No actives esto. Probablemente te dará la idea equivocada y llevará a una jugabilidad desbalanceada y rota.
				[c/7C0A02:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en OFF.]
				'''
		}

		CalamityExpertAccessories: {
			Label: Accesorios de Modo Experto de Calamity
			Tooltip: Activa/desactiva que ciertos objetos de jefes de Calamity sean de rareza experta.
		}

		ThereIsNoReasonDisableThis: {
			Label: No Hay Razón Para Desactivar Esto
			Tooltip:
				'''
				No hay razón para desactivar esto, ya que desactiva dificultades que tienen errores y están desbalanceadas al fusionarse con Infernum.
				Solo desactiva esta configuración si conoces las consecuencias, y no reportes errores con esta configuración desactivada.
				[c/FFFF00:El mod pack Infernal Eclipse of Ragnarok está balanceado con esta opción en ON.]
				'''
		}

		DeveloperMode: {
			Label: Modo Desarrollador
			Tooltip: Activa/desactiva la disponibilidad de herramientas útiles para el desarrollo.
		}

		ForceRagnarokInfernumModeInSubworlds: {
