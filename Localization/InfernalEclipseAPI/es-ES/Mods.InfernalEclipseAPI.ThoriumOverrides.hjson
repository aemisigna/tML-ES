ThrowerTechniques: {
	Decoy: {
		DisplayName: Señuelo
		Description:
			'''
			Invoca un señuelo enemigo y gana velocidad de ataque aumentada durante un segundo
			El señuelo intentará captar la atención de los enemigos cercanos
			'''
	}

	BloodLotus: {
		DisplayName: Loto Sangriento
		Description:
			'''
			Detente en el lugar y libera un torrente de cuchillos hacia el enemigo más cercano
			Cada cuchillo te sana hasta 10% del daño infligido
			El torrente otorga al jugador 100 de defensa, pero se desvanece al recibir daño
			'''
	}

	SmokeBomb: {
		DisplayName: Bomba de Humo
		Description:
			'''
			Libera una bomba de humo
			Las bombas de humo te otorgan brevemente inmunidad al daño y velocidad de ataque aumentada durante 2 segundos
			'''
	}
}
