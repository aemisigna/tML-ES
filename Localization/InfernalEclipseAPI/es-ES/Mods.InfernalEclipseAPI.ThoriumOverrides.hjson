	MagmaSeersMask.Tooltip:
		'''
		'Comanda un ejército fortificado en magma'
		50% de daño de invocación aumentado
		Aumenta tu número máximo de súbditos y centinelas en 2
		Aumenta el retroceso de los súbditos
		'''
	CursedFlailCore.Tooltip:
		'''
		Las armas de mangual liberan una bola con púas maldita al primer golpe
		Los golpes posteriores tienen probabilidad de liberar más bolas con púas malditas
		Las bolas con púas malditas aplican llamas malditas a los enemigos dañados
		'''
	VileFlailCore.Tooltip:
		'''
		Las armas de mangual liberan una bola con púas vil al primer golpe
		Los golpes posteriores tienen probabilidad de liberar más bolas con púas viles
		Las bolas con púas viles aplican icor a los enemigos dañados
		'''
	IronFlailCore.Tooltip:
		'''
		Las armas de mangual liberan una bola con púas rodante al primer golpe
		Los golpes posteriores tienen probabilidad de liberar más bolas con púas rodantes
		'''
	BloomingShield.Tooltip:
		'''
		Generas constantemente un escudo de 20 de vida
		Los hechizos curativos sanarán 1 de vida adicional, 2 si el escudo está al máximo
		Fuera de combate, tu recuperación de vida aumentará hasta 5 con el tiempo
		'''
	AstroBeetleHusk.Tooltip:
		'''
		Daño recibido reducido en un 5%
		Generas constantemente un escudo de 50 de vida
		'''
