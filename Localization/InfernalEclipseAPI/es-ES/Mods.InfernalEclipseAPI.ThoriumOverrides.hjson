Buffs: {
	NinjaBuff.Description: La velocidad de lanzamiento aumenta en un 20%, y la probabilidad de golpe crítico de lanzamiento aumenta en un 10%
	BloodRush.Description: 15% de velocidad de picar aumentada
}

Items: {
	CapeoftheSurvivor: {
		DisplayName: Capa del Superviviente
		Tooltip:
			'''
			'La propia tela de esta capa ha sido diseñada para guiarte a través de los días más difíciles'
			Ganas rápidamente hasta un 15% de reducción de daño con el tiempo
			Recibir un golpe reduce brevemente esta bonificación a -10% de reducción de daño
			Mientras esta bonificación esté por encima de 0%, ganas hasta 2 de recuperación de vida
			'''
	}

	/*
	ScryingGlass: {
	DisplayName: Scrying Glass
	Tooltip: Pressing the '{$Keybinds.AccessoryAbility.DisplayName}' key will toggle an increased range of view
	}
	*/
	
	ShootingStarHat.SetBonus:
		'''
		Las potenciaciones sinfónicas duran 6 segundos más
		Cada potenciación única que tengas aumenta tu daño sinfónico en un 2,5%
		Cada potenciación única que tengas aumenta tu regeneración de inspiración en un 2%
		'''

	SoulofPlight: {
		DisplayName: Alma de la Aflicción
		Tooltip: "'La esencia de las criaturas malditas'"
	}

	SoulofPlightinaBottle: {
		DisplayName: Alma de Aflicción en Botella
		Tooltip: ""
	}

	KeyofPlight: {
		DisplayName: Llave de Aflicción
		Tooltip: "'Cargada con la esencia de muchas almas'"
	}

	MasterMarksmansScouter.Tooltip:
		'''
		'La pólvora eliminará a los débiles'
		El enemigo más cercano es marcado y recibe 10% más de daño de todas las fuentes
		Tu daño a distancia aplica llamas malditas a los enemigos
		'''
	AssassinsGuard.Tooltip:
		'''
		16% de daño a distancia aumentado
		15% de probabilidad de golpe crítico a distancia aumentada
		25% de probabilidad de no consumir munición reducida
		'''

	Kinetoscythe: {
		DisplayName: Cineto-guadaña
		Tooltip:
			'''
			Hace girar rápidamente una guadaña de alta tecnología a tu alrededor
			<right> para generar una guadaña de energía giratoria estacionaria
			Gira la guadaña mientras la guadaña de energía está activa para hacer que rastree a los enemigos
			'''
	}

	BlackMIDI: {
		DisplayName: MIDI Negro
		Tooltip:
			'''
			Libera rápidamente un océano de ruido hacia tu cursor
			El ruido amarillo sana al usuario por 0,5% del daño infligido
			'''
	}

	DreamCatcher: {
		DisplayName: Atrapasueños
		Tooltip:
			'''
			Invoca hasta un atrapasueños en la ubicación del cursor
			Permanecer dentro del atrapasueños te sanará 20% de la vida máxima si recibes daño fatal
			Los jugadores revividos tendrán estadísticas temporalmente reducidas y no podrán revivir de nuevo durante 2 minutos
			'Para atrapar y acunar las esperanzas del mundo...'
			'''
	}

	HereticBreaker: {
