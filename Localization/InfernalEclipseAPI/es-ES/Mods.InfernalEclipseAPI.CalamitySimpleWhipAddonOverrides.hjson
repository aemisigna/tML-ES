	MermaidsTear: {
		DisplayName: Lágrima de Sirena
		Tooltip:
			'''
			Los enemigos golpeados por este látigo son empalados por una hoja espectral en el siguiente ataque de un súbdito
			La hoja espectral inflige 25% del daño del súbdito 8 veces seguidas
			El daño de empalamiento perfora 50 de armadura
			'''
	}

	MandibleLash: {
		DisplayName: Latigazo de Mandíbula
		Tooltip:
			'''
			1 de daño de conexión por invocación
			Los enemigos golpeados por este látigo hacen que el siguiente ataque de un súbdito lance una bola de arena
			La bola de arena es afectada por la gravedad e inflige 40% del daño del súbdito
			La bola de arena explota al impactar con un bloque, dañando a los enemigos cercanos
			'''
	}

	DarkMandibleLash: {
		DisplayName: Latigazo de Mandíbula Oscura
		Tooltip:
			'''
			2 de daño de conexión por invocación
			Los enemigos golpeados por este látigo hacen que el siguiente ataque de un súbdito lance una bola de arena
			La bola de arena es afectada por la gravedad e inflige 40% del daño del súbdito
			La bola de arena explota al impactar con un bloque, dañando a los enemigos cercanos
			'''
	}

	ShieldConduit: {
		DisplayName: Conducto de Escudo
		Tooltip:
			'''
			2 de daño de conexión por invocación
			Cambia automáticamente entre dos modos.
			'''
		HoldShiftTooltip:
			'''
			-----------------------------
			Modo Defensa:
			Golpear a un enemigo con el látigo hace que los ataques de los súbditos liberen fragmentos de escudo azules durante un breve tiempo
			Recoger fragmentos acumula carga de escudo
			Al alcanzar 50 de carga, obtienes un escudo de 50 HP
			-----------------------------
			Modo Ataque:
			Golpear a un enemigo con el látigo hace que los ataques de los súbditos liberen fragmentos de escudo rojos durante un breve tiempo.
			Los fragmentos rojos persiguen a los enemigos, infligiendo 10% del daño del súbdito +3 de daño fijo.
			-----------------------------
			La liberación de fragmentos de escudo tiene un enfriamiento muy corto
			Cuando el escudo recibe daño, entra en un enfriamiento de recarga que dura entre 5 y 50 segundos según el escudo restante
			Si el escudo se rompe por completo, el enfriamiento de recarga se convierte en 60 segundos
			Durante el enfriamiento, cambia al Modo Ataque
			Cuando termina el enfriamiento, cambia al Modo Defensa
			Si queda algo de escudo, recoger fragmentos restaura la durabilidad del escudo.
			'''
	}

