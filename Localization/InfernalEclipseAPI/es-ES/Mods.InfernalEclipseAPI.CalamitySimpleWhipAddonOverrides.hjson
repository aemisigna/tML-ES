	GlitterGutter: {
		DisplayName: Canalón de Purpurina
		Tooltip:
			'''
			10% de probabilidad de golpe crítico de conexión por invocación
			Los enemigos golpeados por este látigo hacen que el siguiente ataque de un súbdito libere fragmentos de cristal teledirigidos
			'''
	}

	DestructionChain: {
		DisplayName: Cadena de Destrucción
		Tooltip:
			'''
			Los enemigos golpeados por este látigo hacen que el siguiente ataque de un súbdito desencadene una explosión
			Los enemigos eliminados por esta explosión desencadenan otra explosión, que puede seguir encadenándose
			'''
	}

	GloamshardConduit: {
		DisplayName: Conducto de Fragmento Crepuscular
		Tooltip:
			'''
			Multiplicador de daño de conexión por invocación: x1.1
			10% de probabilidad de golpe crítico de conexión por invocación

			   Los enemigos golpeados por este látigo reciben x1.25 de daño del siguiente ataque de un súbdito y explotan
			'''
	}

	Satellite: {
		DisplayName: Satélite
		Tooltip: "   Los enemigos golpeados por este látigo reciben un golpe crítico garantizado de un súbdito."
	}

	ResonantVoid: {
		DisplayName: Vacío Resonante
		Tooltip:
			'''
			Multiplicador de daño de conexión por invocación: x1.12
			12% de probabilidad de golpe crítico de conexión por invocación

			Los enemigos golpeados por este látigo reciben x1.25 de daño del siguiente ataque de un súbdito y explotan

			Ignora parte de la armadura de los enemigos
			'''
	}

	SkybreakerCoil: {
		DisplayName: Bobina Rompecielos
		Tooltip:
			'''
			Todos los enemigos golpeados por este látigo reciben x1.30 de daño del siguiente ataque de un súbdito y liberan una descarga eléctrica
			La descarga electrocuta rápidamente a los enemigos cercanos durante un breve tiempo y tiene penetración de armadura
			'''
	}

	Milkyway: {
		DisplayName: Vía Láctea
		Tooltip:
			'''
			+10 de daño de conexión por invocación por acumulación
			Los enemigos golpeados por este látigo reciben un golpe crítico garantizado de x4 de daño de un súbdito
			La marca de este látigo se acumula consigo misma
			Una cantidad de cometas igual al número de acumulaciones orbita alrededor del enemigo
			'''
	}

	Loadout: {
		DisplayName: Loadout
		Tooltip:
			'''
			Multiplicador de daño de conexión por invocación: x1.07
			7% de probabilidad de golpe crítico de conexión por invocación
			Los enemigos golpeados por este látigo son alcanzados por un láser en el siguiente ataque de un súbdito
			Ignora parte de la armadura de los enemigos
			'''
	}

	AncientBonds: {
		DisplayName: Vínculos Ancestrales
		Tooltip:
			'''
			Los enemigos golpeados por este látigo son empalados por una hoja espectral en el siguiente ataque de un súbdito
			La hoja espectral inflige 20% del daño del súbdito 3 veces seguidas
			El daño de empalamiento perfora 5 de armadura
			'''
	}

	PrimalBonds: {
		DisplayName: Vínculos Primigenios
		Tooltip:
