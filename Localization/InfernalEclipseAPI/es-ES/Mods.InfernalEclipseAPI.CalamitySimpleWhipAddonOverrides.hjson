			Solo se puede equipar un accesorio de Empuñadura a la vez
			'''
	}

	BuddyEmblem: {
		DisplayName: Emblema del Compañero
		Tooltip:
			'''
			Aumenta significativamente el daño cuando solo hay un Súbdito presente
			El daño del súbdito aumenta según la cantidad de espacios de súbdito sin usar
			Cuanto más potencia este efecto a un súbdito, ligeramente más grande se vuelve
			Algunos súbditos no pueden beneficiarse de este efecto
			Algunos efectos de marca de látigo se reducen
			'¡Yo te elijo!'
			'''
	}

	StrikerEmblem: {
		DisplayName: Emblema del Atacante
		Tooltip:
			'''
			Ya no puedes invocar súbditos ni centinelas
			Los látigos golpean a los enemigos tres veces adicionales infligiendo 33% de daño
			Estos golpes se benefician de los efectos de marca de invocación
			Aumenta el alcance del látigo en un 10%
			10% de aumento en el daño de invocación por cada espacio de súbdito sin usar
			'¡Muere, monstruo!'
			'''
	}
