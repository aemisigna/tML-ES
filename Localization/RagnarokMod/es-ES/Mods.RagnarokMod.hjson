		BardEmpowermentBarOffsetX: {
			Label: Desplazamiento X de la Barra de Potenciación de Bardo
			Tooltip: ""
		}

		BardEmpowermentBarOffsetY: {
			Label: Desplazamiento Y de la Barra de Potenciación de Bardo
			Tooltip: ""
		}

		RiffMusicVolume: {
			Label: Volumen de Música de Riff
			Tooltip:
				'''
				Establece el volumen para la música de Riff.
				Ponerlo en 0 deshabilitará la música de Riff, y no atenuará la música que suena cuando comienza un riff.
				'''
		}

		StartText: {
			Label: Texto de Inicio
			Tooltip: Habilita o Deshabilita el texto de bienvenida al entrar al mundo.
		}

		RiffScreenEffectIntensity: {
			Label: Intensidad del Efecto de Pantalla de Riff
			Tooltip: Controla la intensidad de los Efectos de Pantalla de Riff. Ponlo en 0 para deshabilitarlo.
		}

		MissSoundPreset: {
			Label: Preajuste de Sonido de Fallo
			Tooltip: Elige un estilo de sonido preestablecido para tus sonidos de tiempo fallado.
		}

		CustomMissSoundPath: {
			Label: Ruta de Sonido de Fallo Personalizada
			Tooltip:
				'''
				Escribe una ruta de sonido de mod para el sonido de tiempo fallado personalizado que deseas usar.
				Por ejemplo, 'RagnarokMod/Sounds/bonk'.
				Debe tener un archivo .ogg correspondiente en la carpeta Sounds del mod, de lo contrario podría causar fallos o simplemente no funcionar.
				No hace nada a menos que el Preajuste de Sonido de Fallo esté configurado en Personalizado.
				'''
		}

		MissSoundVolume: {
			Label: Volumen del Sonido de Fallo
			Tooltip: Establece el volumen para el sonido de tiempo fallado.
		}

		MissSoundDuringRiff: {
			Label: Sonido de Fallo Durante el Riff
			Tooltip: Determina si el sonido de tiempo fallado se reproducirá durante un riff activo.
		}

		PlaySoundDuringRiff: {
			Label: Reproducir Sonido Durante el Riff
			Tooltip:
				'''
				Determina si el sonido del instrumento se reproduce durante los riffs.
				Ponlo en 1 para reproducir siempre el sonido durante los riffs, -1 para nunca reproducir el sonido durante los riffs.
				0 solo reproducirá el sonido durante los riffs para ítems específicos previstos, como las Castañuelas Fúngicas.
				'''
		}

		MeterOffsetX: {
			Label: Desplazamiento X del Medidor
			Tooltip: ""
		}

		MeterOffsetY: {
			Label: Desplazamiento Y del Medidor
			Tooltip: ""
		}

		RiffsOverrideEventMusic: {
			Label: Los Riffs Anulan la Música de Eventos
			Tooltip: Alterna si la Música de Riff anula la música de Evento
		}

		RiffsOverrideBossMusic: {
			Label: Los Riffs Anulan la Música de Jefes
			Tooltip: Alterna si la Música de Riff anula la música de Jefe
		}
