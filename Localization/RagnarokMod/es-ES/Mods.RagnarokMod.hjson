		}

		jelly: {
			Label: IA de la Reina Medusa
			Tooltip: Selecciona qué reelaboración de IA debe usarse. Desactivado para el comportamiento por defecto.
		}

		bossstatstweak: {
			Label: Ajuste de Estadísticas de Jefes
			Tooltip: Selecciona si los jefes de Thorium reciben ajustes de estadísticas (daño de ataque, vida, defensa, reducción de daño) para el escalado de Calamity.
		}

		bossrush: {
			Label: Maratón de Jefes de Thorium
			Tooltip: Selecciona qué modo de maratón de jefes debe usarse. Desactivado deshabilita el maratón de jefes.
		}

		viscount: {
			Label: IA del Vizconde
			Tooltip: Selecciona qué reelaboración de IA debe usarse. Desactivado para el comportamiento vanilla. Automático usa la IA de Ragnarok si no se detecta ninguna otra reelaboración.
		}

		granite: {
			Label: IA de la Tormenta de Energía de Granito
			Tooltip: Selecciona qué reelaboración de IA debe usarse. Desactivado para el comportamiento vanilla. Automático usa la IA de Ragnarok si no se detecta ninguna otra reelaboración.
		}

		champion: {
			Label: IA del Campeón Enterrado
			Tooltip: Selecciona qué reelaboración de IA debe usarse. Desactivado para el comportamiento vanilla. Automático usa la IA de Ragnarok si no se detecta ninguna otra reelaboración.
		}

		scouter: {
			Label: IA del Explorador Estelar
			Tooltip: Selecciona qué reelaboración de IA debe usarse. Desactivado para el comportamiento vanilla. Automático usa la IA de Ragnarok si no se detecta ninguna otra reelaboración.
		}

		strider: {
			Label: IA del Zancudo Boreal
			Tooltip: Selecciona qué reelaboración de IA debe usarse. Desactivado para el comportamiento vanilla. Automático usa la IA de Ragnarok si no se detecta ninguna otra reelaboración.
		}

		beholder: {
