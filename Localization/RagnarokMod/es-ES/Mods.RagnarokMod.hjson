	SilvaHeadHealer: {
		DisplayName: Yelmo Enredado de Silva
		Tooltip:
			'''
			25% de uso de maná reducido
			70% de daño no radiante reducido y 55% de daño radiante aumentado
			20% de probabilidad de golpe crítico radiante aumentada
			Los hechizos de curación curarán 9 de vida adicional
			+80 de maná máximo
			'''
		SetBonus:
			'''
			Tus hechizos de curación aumentarán la recuperación de vida y la tasa de recuperación de vida de tus aliados
			Los aliados curados recibirán 50 de vida máxima adicional
			Ocasionalmente serás bendecido con curaciones o escudos de vida
			Ocurrirá con más frecuencia con poca vida
			+3 PV/s de regeneración de vida
			5% de velocidad y aceleración máxima de carrera aumentadas
			Recibir daño letal te revivirá y te hará invulnerable a todo daño durante 5 segundos
			Este efecto tiene un enfriamiento de 5 minutos, que no disminuye mientras haya jefes o eventos activos
			'''
	}

