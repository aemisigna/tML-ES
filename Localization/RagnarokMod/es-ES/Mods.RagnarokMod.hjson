	AprilChaos: {
		DisplayName: Caos de Abril

		Headers: {
			AprilChaos: Caos de Abril
			RadiantMage: Mago Radiante
			MeleeSummoner: Invocador Cuerpo a Cuerpo
			RogueRanger: Arquero Pícaro
			ObnoxiousBard: Bardo Insoportable
		}

		MasterToggle: {
			Label: Interruptor Maestro
			Tooltip: Deshabilita/Habilita todas las opciones de abajo.
		}

		RadMage: {
			Label: Mago Radiante
			Tooltip:
				'''
				El Sanador se sentía como una simple extensión del Mago.
				Así que lo arreglamos.
				Reemplazando al Mago con el Sanador.
				Toda la magia es curación si crees lo suficiente.
				O golpeas lo suficientemente fuerte.
				'''
		}

		MelSum: {
			Label: Invocador Cuerpo a Cuerpo
			Tooltip:
				'''
				El Invocador tenía algunos vacíos de progresión desafortunados.
				Así que lo arreglamos.
				Dándole todo el Cuerpo a Cuerpo al Invocador.
				Tus esbirros ahora te respetan.
				Tu espada no.
				'''
		}

		RogRan: {
			Label: Arquero Pícaro
			Tooltip:
				'''
				El Pícaro está recuperando sus raíces.
				Absorbiendo al Arquero.
				Siempre fueron la misma persona.
				Uno solo tenía mejores zapatos.
				'''
		}

		ObBard: {
			Label: Bardo Insoportable
