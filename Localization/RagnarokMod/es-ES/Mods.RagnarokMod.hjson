	Asterion: {
		DisplayName: Asterión
		Tooltip:
			'''
			Crea un fractal ramificado de luz estelar a tu alrededor
			Esta luz estelar te otorga ocasionalmente Estallidos Estelares al golpear enemigos con éxito
			Presiona <right> con suficientes Estallidos Estelares para crear a Asterión
			Asterión consume Estallidos Estelares rápidamente, pero libera pulsos estelares constantes
			Estos pulsos te curan a ti y a los aliados cercanos, e infligen [cbuff:CalamityMod/Voidfrost] a los enemigos
			'Tan leal como un sabueso'
			'''
	}

	FungalCastanets: {
		DisplayName: Castañuelas Fúngicas
		Tooltip:
			'''
			Los clics alternos de las castañuelas rocían esporas fúngicas persistentes
			Presiona <right> para tocar el riff de [c/00FFFF:¡1NF3S+@+!0N Riff!]
			Durante el riff, tus castañuelas se convierten en las garras de Crabulon mientras llueven esporas desde arriba
			'¡Suena como garras de cangrejo!'
			'''
