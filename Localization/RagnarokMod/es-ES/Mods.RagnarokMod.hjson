	Steampipes: {
		DisplayName: Gaita de Vapor
		Tooltip: ¡Gaita a vapor!
	}

	ElysianSong: {
		DisplayName: Canción Elísea
		Tooltip: "'Tan cerca de la trompeta de un ángel, y sin embargo tan lejos...'"
	}

	ExecutionerMark05: {
		DisplayName: El Verdugo: Marca 05
		Tooltip:
			'''
			Comienza lento, pero irá ganando velocidad continuamente
			Al alcanzar la velocidad máxima, se lanzará hacia el enemigo más cercano y explotará en una gran área de efecto
