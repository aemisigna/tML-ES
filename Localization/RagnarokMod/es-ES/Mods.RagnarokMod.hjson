Configs: {
	BossProgressionConfig: {
		DisplayName: Configuración de Progresión de Jefes
		Headers.BossProgressionChanges: Cambios de Progresión de Jefes

		GrandFlareGun: {
			Label: Cambio de Receta del Gran Pájaro del Trueno
			Tooltip: Cambia la Gran Pistola de Bengalas y la Bengala de Tormenta para requerir Mandíbulas de León Marino de Tormenta en lugar de Plumas de Buitre. Por defecto: Verdadero
		}

		DesertMedallion: {
			Label: Cambio de Receta del Azote del Desierto
			Tooltip: Cambia el Medallón del Desierto para usar Lingotes de Arenisca del Gran Pájaro del Trueno. Por defecto: Verdadero
		}

		DecapoditaSprout: {
			Label: Cambio de Receta de Crabulon
			Tooltip: Cambia el Brote de Decapodita para usar Fragmentos de Perla, Plumas de Tormenta y Gelatina de la Reina. Por defecto: Verdadero
		}

		MarbleGranite: {
			Label: Cambios de Receta de las Tormentas de Energía de Granito y el Campeón Enterrado
			Tooltip: Cambia la Hoja Antigua y el Núcleo Inestable para requerir Lingotes de Aerialita. Por defecto: Verdadero
		}

		OverloadedSludge: {
			Label: Cambio de Receta del Dios Limo
			Tooltip: Cambia el Lodo Sobrecargado para usar Mármol Encantado y Granito Potenciado. Por defecto: Verdadero
		}

		StarCaller: {
			Label: Cambio de Receta del Explorador Estelar
			Tooltip: Cambia el Invocador de Estrellas para usar Lingotes de Aerialita y el material del jefe maligno. Por defecto: Verdadero
		}

		CryoKey: {
			Label: Cambio de Receta de Cryogen
			Tooltip: Cambia la Llave Crio para usar Colmillos del Zancudo. Por defecto: Verdadero
		}

		MechBosses: {
			Label: Cambio de Receta de los Jefes Mecánicos
			Tooltip: Cambia el Ojo, el Gusano y la Calavera Mecánicos para que cada uno requiera una Placa Madre Alienígena Extraña. Por defecto: Verdadero
		}

		Lich: {
			Label: Cambio de Invocación del Liche
			Tooltip: Cambia la Filacteria Antigua para requerir Esencia del Caos para invocar al Liche en lugar de calabazas. Por defecto: Verdadero
		}

		CharredIdol: {
			Label: Cambio de Receta del Elemental de Azufre
			Tooltip: Cambia el Ídolo Carbonizado para requerir un Corazón del Vacío. Por defecto: Verdadero
		}

		Seafood: {
			Label: Cambio de Receta del Azote Acuático
			Tooltip: Cambia el Marisco para requerir Gelatina de la Reina. Por defecto: Verdadero
		}

		EyeOfDesolation: {
			Label: Cambio de Receta del Clon de Calamitas
			Tooltip: Cambia el Ojo de la Desolación para requerir la Perla Vidente del Vacío. Por defecto: Verdadero
		}

		DeathWhistle: {
			Label: Cambio de Receta del Devastador
			Tooltip: Cambia el Silbato de la Muerte para requerir Tela Maldita. Por defecto: Verdadero
		}

		DoomSayerCoin: {
			Label: Cambio de Receta de los Primordiales
			Tooltip: Cambia la Moneda del Augur de Perdición para requerir Cenizas de la Calamidad. Por defecto: Verdadero
		}

		RuneOfKos: {
			Label: Cambios de Aparición de la Providencia
			Tooltip: Cambia la receta de la Marca de la Providencia para requerir Geodas Divinas y Esencias de los Primordiales, y hace que ya no caiga de la Providencia. Por defecto: Verdadero
		}
	}

	ClassBalancerConfig: {
		DisplayName: Configuración del Balanceador de Clases

		Headers: {
			ClassBalanceChanges: Cambios de Balance de Clases
			ClassMechanicChanges: Cambios de Mecánicas de Clase
		}

		HealerDamageModifier: {
			Label: Modificador de Daño de Sanador
			Tooltip: Multiplicador para el daño de Sanador. El multiplicador se aplica después de todos los demás cambios.
		}

		BardDamageModifier: {
			Label: Modificador de Daño de Bardo
			Tooltip: Multiplicador para el daño de Bardo. El multiplicador se aplica después de todos los demás cambios.
		}

		RogueDamageModifier: {
			Label: Modificador de Daño de Pícaro
			Tooltip: Multiplicador para el daño de Pícaro/Lanzamiento. El multiplicador se aplica después de todos los demás cambios.
		}

		RangedDamageModifier: {
			Label: Modificador de Daño a Distancia
			Tooltip: Multiplicador para el daño a Distancia. El multiplicador se aplica después de todos los demás cambios.
		}

		MagicDamageModifier: {
			Label: Modificador de Daño Mágico
			Tooltip: Multiplicador para el daño Mágico. El multiplicador se aplica después de todos los demás cambios.
		}

		SummonDamageModifier: {
			Label: Modificador de Daño de Invocación
			Tooltip: Multiplicador para el daño de Invocación. El multiplicador se aplica después de todos los demás cambios.
		}

		MeleeDamageModifier: {
			Label: Modificador de Daño Cuerpo a Cuerpo
			Tooltip: Multiplicador para el daño Cuerpo a Cuerpo. El multiplicador se aplica después de todos los demás cambios.
		}

		HealingBonusModifier: {
			Label: Modificador de Bono de Curación
			Tooltip: Multiplicador para los bonos de curación. El multiplicador se aplica después de todos los demás cambios.
		}

		RiffsRequireRiffInstrumentToBeHeld: {
			Label: Los Riffs Requieren que el Instrumento del Riff Esté Equipado
			Tooltip: Los riffs terminan automáticamente cuando el arma deja de estar equipada.
		}

		MistimedDamagePen: {
			Label: Penalización de Daño por Desincronización
			Tooltip:
				'''
				Penalización de daño de Thorium por fallar los tiempos en ataques con instrumentos grandes.
				El valor por defecto de Thorium es 0.75, lo que significa que los ataques desincronizados infligen 75% menos daño.
				El valor por defecto de Ragnarok es 0.6, lo que significa que los ataques desincronizados infligen 60% menos daño.
				[c/7C0A02:Sin embargo, algunos mods pueden forzar este valor a otro para su propio balance.]
				'''
		}
	}

	ItemBalancerConfig: {
		DisplayName: Configuración del Balanceador de Ítems
		Headers.ItemBalanceChanges: Encabezado de Cambios de Balance de Ítems

		OmegaCore: {
			Label: Núcleo Omega
			Tooltip: Reduce el bono de velocidad de movimiento del Núcleo Omega para mantenerlo más equilibrado con el avance del juego.
		}

		genericweaponchanges: {
			Label: Ajustes Genéricos de Armas
			Tooltip: Aplica reajustes generales de balance de armas.
		}
	}

