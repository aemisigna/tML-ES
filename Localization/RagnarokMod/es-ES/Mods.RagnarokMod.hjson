			'''
			Presiona <left> para tocar el ukelele
			Presiona <right> para lanzar el ukelele
			'No sirve como una buena disculpa'
			'''
	}

	NightmareFreezer: {
		DisplayName: Congelador de Pesadillas
		Tooltip:
			'''
			Girar la guadaña libera periódicamente una ráfaga de dardos gélidos
			'Encontrado en algún lugar entre Halloween y Navidad... ¡se podría hacer una película sobre eso!'
			'''
	}

	DragonForce: {
		DisplayName: Fuerza de Dragón
		Tooltip:
			'''
			Consume inspiración rápidamente mientras canalizas un infierno hacia tu cursor
			Presiona <right> para tocar el riff de [c/FF4500:Rugido del Dragón de la Jungla]
			Mientras el riff está activo, el infierno que libera esta arma se amplifica
			'''
	}

	Lamentation: {
