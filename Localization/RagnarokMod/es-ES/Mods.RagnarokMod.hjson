		DisplayName: Enfriamiento de la Guadaña Elemental
		Description: ¡La Guadaña Elemental está en enfriamiento!
	}

	ScytheAirBuff: {
		DisplayName: Bendición del Aire
		Description: Siempre tienes viento a favor
		ItemTooltip: +20% de velocidad de movimiento y tiempo de alas
	}

	ScytheBrimstoneBuff: {
		DisplayName: Bendición del Azufre
		Description: Tus enemigos estallan en llamas malditas
		ItemTooltip: Inflige [cbuff:CalamityMod/BrimstoneFlames] al golpear
	}

	ScytheEarthBuff: {
		DisplayName: Bendición de la Tierra
		Description: La tierra te protege
		ItemTooltip: +10 de defensa
	}

	ScytheOasisBuff: {
		DisplayName: Bendición del Oasis
		Description: Te sientes rejuvenecido por el oasis del desierto
		ItemTooltip: +15 PV/s de regeneración de vida
	}

	ScytheSandBuff: {
		DisplayName: Bendición de la Arena
		Description: Las arenas te fortalecen
		ItemTooltip: +5% de daño de ataque
	}

	ScytheWaterBuff: {
		DisplayName: Bendición del Agua
		Description: El agua guía tu mano
		ItemTooltip: +5% de velocidad de todos los ataques
	}

	AuricSurge: {
		DisplayName: Sobrecarga Áurica
		Description: Estás siendo castigado desde tu interior.
	}

	KellyPetBuff: {
		DisplayName: ¡Kelly!
		Description: Kelly te seguirá.
	}

	NightfallenDebuff: {
		DisplayName: Anochecido
		Description: La oscuridad consume.
		ItemTooltip:
			'''
			Sin tipo - 100 DPS
			+10% de daño recibido de todas las fuentes
			'''
	}

	LeviathanHeartBubble: {
		DisplayName: Burbuja del Leviatán
		Description: La Burbuja del Leviatán te otorga +5% de reducción de daño
		ItemTooltip: +5% de reducción de daño
	}

	LeviathanHeartBubbleCorrupted: {
		DisplayName: Burbuja del Leviatán Corrupta
		Description:
			'''
			La Burbuja del Leviatán Corrupta te otorga +10% de daño
			Pero recibes 5% más de daño
			'''
		ItemTooltip: +10% de daño de ataque, +5% de daño recibido de todas las fuentes
	}
}

Tooltips: {
	WhiteDwarfSetBonus:
		'''
		Los ataques de pícaro tienen un 5% de probabilidad de liberar una bengala de marfil desde el cosmos con 1.75x de daño
		El daño de la bengala se basa en el daño no crítico, pero puede hacer crítico
		'''

	LeviathanHeart: {
		NormalTooltip:
			'''
			Los hechizos de curación curan un 25% más de pv
			Los hechizos de curación aplican [rbuff:RagnarokMod/LeviathanHeartBubble] al objetivo.
			'''
		CorruptTooltip:
			'''
			¡La Burbuja del Leviatán reacciona a tu energía oscura!
			Todos los costos de vida se reducen en 1
			Gastar vida te otorga [rbuff:RagnarokMod/LeviathanHeartBubbleCorrupted]
			10% de velocidad de ataque radiante aumentada
			'''
	}
}

Compat: {
	TechPoints: Aumenta tus puntos de técnica máximos en
	Recharge: y la recarga en
	BasicDamage: daño básico
	DupeDamage: de tu daño de pícaro es duplicado
	DupeCap: El daño de duplicación tiene un tope de
	NoGuideStack: El efecto no se acumula con otras Guías
	Power: % de Poder
	Smited: fue castigado.
	Darkness: cayó en la oscuridad.
	TurnedToAmmo: fue convertido en munición.
	Recoil: no pudo soportar el retroceso.
}

Items: {
	DrumStick: {
		DisplayName: Baqueta
		Tooltip: "'¡Tus enemigos son tus tambores!'"
	}

	AerospecBard: {
		DisplayName: Sombrero de Pala Aerospec
		Tooltip:
			'''
			5% de velocidad de ejecución y regeneración de inspiración aumentada
			+2 segundos a la duración de la potenciación
			'''
		SetBonus:
			'''
			Recibir más de 25 de daño en un solo golpe provoca una lluvia de plumas teledirigidas
			Permite caer más rápido y desactiva el daño por caída
			6% de daño sinfónico aumentado
			7% de velocidad de movimiento aumentada
			'''
	}

	AerospecHealer: {
		DisplayName: Capucha Aerospec
		Tooltip:
			'''
			10% de daño no radiante reducido
			10% de daño radiante aumentado
			+20 de maná máximo
			'''
		SetBonus:
			'''
			10% de daño no radiante reducido
			10% de daño radiante aumentado
			Recibir más de 25 de daño en un solo golpe provoca una lluvia de plumas teledirigidas
			Permite caer más rápido y desactiva el daño por caída
			Los hechizos de curación curan 2 de vida adicional
			10% de velocidad de movimiento aumentada
			'''
	}

	AuricTeslaFrilledHelmet: {
		DisplayName: Yelmo Volante Tesla Áurico
		DisplayNameEclipse: Yelmo Volante Tesla Primordial
		Tooltip:
			'''
			20% de daño sinfónico, probabilidad de golpe crítico y velocidad de persecución de instrumentos de viento aumentada
			5% de velocidad de movimiento aumentada
			30% de regeneración de inspiración aumentada
			+15 de inspiración máxima
			+2 rebotes de proyectil de instrumentos de cuerda
			'''
		SetBonus:
			'''
			Efectos de armadura de Llamasangre, Matadioses y Rapsoda
			Presionar la tecla '{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}' activará ambas habilidades de armadura de Rapsoda
			'''
		SetBonusHelheim: Efectos de armadura de Estragón, Llamasangre y Matadioses
	}

	AuricTeslaHealerHead: {
		DisplayName: Semblante Irradiante Tesla Áurico
		DisplayNameEclipse: Semblante Irradiante Tesla Primordial
		Tooltip:
			'''
			Corrompe tus poderes radiantes
			100% de daño radiante aumentado pero 80% de daño no radiante reducido
			25% de probabilidad de golpe crítico radiante aumentada
			5% de velocidad de movimiento aumentada
			25% de uso de maná reducido
			Los hechizos de curación curan 10 de vida adicional
			+100 de maná máximo
			'''
		ToggleTooltip: "[c/aaaaaa:Shift + clic derecho sobre este ítem en tu inventario para alternar] [c/CC44FF:poderes radiantes corrompidos]"
		SetBonus:
			'''
			Efectos de armadura de Llamasangre, Silva y Tejedor de Sueños
			Presionar la tecla '{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}' activará ambas habilidades de armadura de Tejedor de Sueños
			50% de daño radiante aumentado
			'''
		SetBonusHelheim:
			'''
			Efectos de armadura de Estragón, Llamasangre y Silva
			50% de daño radiante aumentado
			'''
	}

	BlazingDrumBeat: {
		DisplayName: Baqueta Encendida
		Tooltip:
			'''
			Acertar los tiempos correctamente aumentará de forma constante su daño y nivel de potenciación
			Fallar los tiempos reducirá estos bonos considerablemente y costará 9 de inspiración
			Estos bonos se mantienen entre cambios de arma, pero se desvanecen gradualmente mientras no sea tu arma activa
			Encadenar dos o más aciertos liberará un gran tajo llameante
			Los tajos llameantes infligen [cbuff:CalamityMod/HolyFlames] a todos los enemigos en el área
			'''
	}

	BloodflareHeadBard: {
		DisplayName: Yelmo con Púas Llamasangre
		Tooltip:
			'''
			20% de daño sinfónico y 12% de probabilidad de golpe crítico sinfónico aumentados
			+15% de regeneración de inspiración y +6 de inspiración máxima
			+15% de probabilidad de que caigan notas de inspiración de los enemigos
			'''
		SetBonus:
			'''
			Infligir daño sinfónico aplicará Sangre Ardiente a los enemigos
			Acumularás sed de sangre, 2 puntos por cada enemigo golpeado (solo puede ocurrir 3 veces por segundo)
			Al alcanzar 100 puntos: 20% de daño y probabilidad de golpe sinfónico aumentados, 25% de velocidad de movimiento aumentada
			Las potenciaciones se prolongarán 3 segundos adicionales y la regeneración de inspiración será 10% más rápida
			Presionar la tecla 'Habilidad de Armadura' consumirá 20 puntos para restaurar 10 de inspiración
			Perderás 25 puntos al recibir un golpe, y los perderás rápidamente si no golpeas enemigos durante más de 5 segundos
			Tus puntos también se reinician cuando aparece un jefe
			'''
	}

	BloodflareHeadHealer: {
		DisplayName: Semblante Sombrío Llamasangre
		Tooltip:
			'''
			20% de uso de maná reducido
			70% de daño no radiante reducido y 50% de daño radiante aumentado
			20% de probabilidad de golpe crítico radiante aumentada
			Los hechizos de curación curarán 7 de vida adicional
			+60 de maná máximo
			'''
		SetBonus:
			'''
			Infligir daño radiante aplicará Sangre Ardiente a los enemigos
			Acumularás sed de sangre, 2 puntos por cada enemigo golpeado (solo puede ocurrir 3 veces por segundo)
			Al alcanzar 100 puntos: 20% de daño y probabilidad de golpe radiante aumentados, 20% de velocidad de movimiento aumentada
			y tus hechizos de curación curarán 3 de vida adicional
			Además, te curas por una pequeña fracción del daño que infliges
			Presionar la tecla 'Habilidad de Armadura' consumirá 20 puntos para restaurar 25 de vida + tu curación adicional
			Perderás 25 puntos al recibir un golpe, y los perderás rápidamente si no golpeas enemigos durante más de 5 segundos
			Tus puntos también se reinician cuando aparece un jefe
			'''
	}

	CalamityBell: {
		DisplayName: Campana de la Calamidad
		Tooltip: Dispara ráfagas de fuego de azufre teledirigidas que infligen [cbuff:CalamityMod/BrimstoneFlames] al golpear
