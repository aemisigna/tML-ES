	IrradiantInfinity: {
		DisplayName: Infinito Irradiante
		Tooltip:
			'''
			Presiona <left> para disparar un orbe [c/FF5555:Rojo Irradiante] con retroceso masivo
			Presiona <right> para invocar un orbe [c/55AAFF:Azul Irradiante] que sigue a tu cursor
			El [c/55AAFF:Azul Irradiante] atrae a los enemigos cercanos y crece con cada golpe
			Al alcanzar la masa crítica, golpéalo con el [c/FF5555:Rojo Irradiante] para liberar el [c/CC44FF:Púrpura Irradiante]
			'''
