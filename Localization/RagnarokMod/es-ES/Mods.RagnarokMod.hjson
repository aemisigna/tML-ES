			La Sirena canta junto con tu melodía encantadora.
			Daño sinfónico aumentado en 15%
			Tasa de regeneración de inspiración aumentada en 20%
			Anahita cantará junto con tus instrumentos de cuerda, disparando proyectiles de agua adicionales
			'''
	}

	ScourgesFrets: {
		DisplayName: Trastes del Azote
		Tooltip:
			'''
			Envía ondas de sonido rebotantes que parecen estar hechas de arena
			Presiona <right> para tocar el riff de [c/34C9EB:Guardiana de los Antiguos Mares]
			Mientras el riff está activo, los ataques de esta guitarra son el doble de grandes e infligen 25% más de daño
			Sincroniza tus ataques durante el riff para reducir el enfriamiento
			'''
	}

	AuricGreatscythe: {
		DisplayName: Gran Guadaña Áurica
		Tooltip:
			'''
			Esta guadaña se carga cuanto más tiempo la giras,
			acelerando hasta velocidades increíbles
			Presiona <right> para arrojar un rayo de electricidad
			'''
