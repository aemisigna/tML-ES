		Tooltip: Dispara gigablastes de azufre teledirigidos que infligen [cbuff:CalamityMod/BrimstoneFlames] al golpear
	}

	Virusprayer: {
		DisplayName: Pulverizador de Virus
		Tooltip: Dispara una ráfaga de burbujas ácidas
	}

	IntergelacticRobohelm: {
		DisplayName: Robocasco Intergaláctico
		Tooltip:
			'''
			Aumenta el daño sinfónico, la probabilidad de golpe crítico y la velocidad de ejecución en 20%
			Aumenta la regeneración de inspiración en 15%
			Aumenta la inspiración máxima en 6
			Aumenta la duración de la potenciación en 3 segundos
			Reduce el daño recibido en 12%
			'''
	}

	IntergelacticRamhelm: {
		DisplayName: Casco de Carnero Intergaláctico
		Tooltip:
			'''
			Reduce el daño no radiante en 40%
			Aumenta el daño radiante en 30%
			Aumenta la probabilidad de golpe crítico radiante y la velocidad de ataque en 15%
