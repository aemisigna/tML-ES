	}

	DevourerOfSines: {
		DisplayName: Devorador de Senos
		Tooltip:
			'''
			Canaliza esta arma para crear una onda senoidal masiva
			Presiona <right> para tocar el riff de [c/501eb4:Colapso Universal]
			Mientras el riff está activo, todos los jugadores en el área tienen vuelo ilimitado
			'''
	}

	Ectambourine: {
		DisplayName: Ectambourine
		Tooltip:
			'''
			Lanza una cantidad interminable de panderetas fantasmales
			Presiona <right> para hacer sonar las panderetas lanzadas, dañando a los enemigos cercanos
			'''
	}

	InfectedOcarina: {
		DisplayName: Ocarina Infectada
		Tooltip:
			'''
			Emite un silbido maldito de ruido
