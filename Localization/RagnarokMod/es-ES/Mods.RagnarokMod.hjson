	JellySlicer: {
		DisplayName: Cortadora Gelatinosa
		Tooltip: Dispara un abanico de proyectiles de baba rebotantes al ser blandida
	}

	Splattercannon: {
		DisplayName: Cañón de Salpicaduras
		Tooltip:
			'''
			Presiona <right> para añadir 8 cartuchos a la recámara
			Puede contener un máximo de 64 cartuchos en la recámara
			Presiona <left> para liberar todos los cartuchos de una vez
			Siempre tendrá 8 cartuchos en la recámara
			Expulsa orbes de sangre al golpear enemigos
			Recoger estos orbes de sangre reduce la duración de [rbuff:PotionSickness]
			'¡LA SANGRE ES COMBUSTIBLE!'
			'''
	}

	ProfanedBell: {
		DisplayName: Campana Profanada
		Tooltip:
			'''
			Dispara ráfagas de fuego sagrado
			Los enemigos golpeados son afligidos con [cbuff:CalamityMod/HolyFlames] durante 3 segundos
			'''
	}

	AuricDamru: {
		DisplayName: Damru Áurico
		Tooltip:
			'''
			Toca los bongós, infligiendo daño a todos los enemigos cercanos
			Presiona <right> para disparar una Bengala Explosiva
			Las Bengalas Explosivas afligen a los enemigos con [cbuff:CalamityMod/Dragonfire] durante 3 segundos
			'''
	}

	NewLichRequirement: {
		DisplayName: Nuevo Requisito del Liche
		Tooltip: se supone que no deberías ver esto, ehhh...
	}

	EldritchShellFragment: {
		DisplayName: Fragmento de Caparazón Eldritch
		Tooltip:
			'''
			Consigue una buena fortuna en el mercado
			'Un fragmento encantado de la prisión de un dios antiguo'
			'''
	}

	SigilOfACruelWorld: {
		DisplayName: Sigilo de un Mundo Cruel
		Tooltip:
			'''
			Aumenta el daño sinfónico en 15%
			Aumenta la velocidad de ejecución sinfónica en 8%
			Aumenta la tasa de regeneración de inspiración en 8%
			Aumenta la inspiración máxima en 3
			'''
	}

	UniversalHeadset: {
		DisplayName: Auriculares Universales
		Tooltip:
			'''
			Aumenta el daño sinfónico en 20%
			Aumenta la probabilidad de golpe crítico sinfónico en 7%
			Aumenta la velocidad de ejecución sinfónica en 10%
			Aumenta la tasa de regeneración de inspiración en 10%
			Aumenta la inspiración máxima en 5
			Cada potenciación única que tengas aumenta la velocidad de movimiento en 2% y la velocidad de ejecución en 1%
			'''
	}

	GoldenBatDroppings: {
		DisplayName: Excremento de Murciélago Dorado
		Tooltip:
			'''
			+25% de monedas de los enemigos (50% en modo furia)
			Aumenta el daño según las monedas que llevas (solo ranuras de monedas)
			Este bono aumenta un 50% adicional en modo adrenalina
			Perderás 25% de tus monedas de forma permanente al morir (50% al morir en modo maestro)
			"¡No eres codicioso, solo estás loco por el dinero!"
			'''
	}

	VerdurantBloom: {
		DisplayName: Florecimiento Verdeante
		Tooltip: Dispara una ráfaga de varios pétalos de flores
	}

	CosmicInjector: {
		DisplayName: Inyector Cósmico
		Tooltip:
			'''
			Dispara rápidamente agujas curativas y dañinas
			Inflige [cbuff:CalamityMod/GodSlayerInferno] al golpear
			Usa Jeringas como munición
			'''
	}

	Korobeiniki: {
		DisplayName: Korobeiniki
		Tooltip:
			'''
			Hace que caigan Tetriminós desde el cielo
			'Una consola de videojuegos sin ningún distintivo'
			'''
	}

	GraspofVoid: {
		DisplayName: Garra del Vacío
		Tooltip: Dispara un fragmento de esencia del vacío, infligiendo [rbuff:ShadowFlame] al golpear
	}

	PhantasmalEdge: {
		DisplayName: Filo Fantasmal
		Tooltip:
			'''
			Girar esta guadaña crea muchas bolas de fuego en miniatura que te siguen mientras continúas girando la guadaña
			Al dejar de girar la guadaña, las bolas de fuego buscan de inmediato el objetivo más cercano y explotan

			Presiona <right> para lanzar la guadaña como un gancho, atrayendo a los enemigos hacia ti
			¡Sin embargo, los enemigos más fuertes te atraerán a ti en su lugar!
			'''
	}

	GodSlayersReap: {
		DisplayName: Cosecha del Matadioses
		Tooltip:
			'''
			Crea un pequeño holograma que se asemeja al Devorador de Dioses en el borde del giro de tu guadaña
			Este holograma aumentará su daño con el tiempo hasta un límite e infligirá [cbuff:CalamityMod/GodSlayerInferno] al golpear
			Dejar de usar la guadaña mientras un holograma está activo lo liberará para atacar al enemigo más cercano
			El holograma liberado infligirá más daño e inflingirá [cbuff:CalamityMod/WhisperingDeath]
			'''
	}

	LucentGemini: {
		DisplayName: Géminis Luciente
		Tooltip:
			'''
			Girar esta guadaña te rodea de un pulso etéreo de luz de luna
			Los golpes generan [c/78C8FF:Esencia de Alma] y tienen probabilidad de generar [c/78C8FF:Estallido Estelar]
			Presiona <right> con 5 o más Estallidos para invocar la constelación de [c/A0DCFF:Géminis]
			Cada estrella dispara rayos perforantes de luz de luna que infligen [cbuff:CalamityMod/Voidfrost]
			Presiona <right> de nuevo para descartar la constelación
			'''
	}

	Arpeggiator: {
		DisplayName: Arpegiador
		Tooltip: Dispara proyectiles rápidamente en un patrón de arpegio
	}

	ElementalReaper: {
		DisplayName: Guadaña Elemental
		Tooltip:
			'''
			Girar esta guadaña crea proyectiles teledirigidos que infligen [rbuff:CalamityMod/ElementalMix]
			Presiona <right> para otorgarte a ti y a todos tus aliados una de las siguientes Bendiciones Elementales durante 10 segundos:
			[rbuff:RagnarokMod/ScytheAirBuff]
			[rbuff:RagnarokMod/ScytheBrimstoneBuff]
			[rbuff:RagnarokMod/ScytheEarthBuff]
			[rbuff:RagnarokMod/ScytheOasisBuff]
			[rbuff:RagnarokMod/ScytheSandBuff]
			[rbuff:RagnarokMod/ScytheWaterBuff]
			'''
	}

	BrimScythe: {
		DisplayName: Guadaña de Azufre
		Tooltip:
			'''
			Mientras giras, te rodea un círculo de Llamas de Azufre que inflige daño constante
			Los enemigos golpeados por el círculo también son afligidos por [cbuff:CalamityMod/BrimstoneFlames] durante 5 segundos
			Con menos del 25% de vida, matar a un enemigo con el círculo de fuego te curará por 3 + 5% de la vida máxima del enemigo
			'''
	}

	MaxEmpowermentTester: {
		DisplayName: Probador de Potenciación Máxima
		Tooltip: Otorga todas las potenciaciones en un nivel especificado en el código del ítem :P
	}

	UnbreakableCombatUkulele: {
		DisplayName: Ukelele de Combate Irrompible
