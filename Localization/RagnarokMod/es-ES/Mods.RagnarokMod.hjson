	}

	AntarcticReinforcementBuff: {
		DisplayName: Refuerzo Antártico
		Description: El frío te protege
		ItemTooltip: +8 de defensa y +2 de curación adicional
	}

	AntarcticExhaustionDebuff: {
		DisplayName: Agotamiento Antártico
		Description: El frío se instala en tus huesos
	}

	GuardianHealerBeamBuff: {
		DisplayName: Bendición del Guardián Sanador
		Description: Estás bajo una bendición profana
		ItemTooltip: +10% de reducción de daño y +5 PV/s de regeneración de vida
	}

