Buffs: {
	AssassinPotionBuff: {
		DisplayName: Asesino
		Description: Los ataques de pícaro fuera de combate causan un golpe crítico con x4 de daño
	}

	DeepFreezeCoatingBuff: {
		DisplayName: Imbuición de Arma de Pícaro: Congelación Profunda
		Description: El daño de pícaro tiene una probabilidad de entorpecer gravemente el movimiento del enemigo alcanzado
	}

	ExplosiveCoatingBuff: {
		DisplayName: Imbuición de Arma de Pícaro: Explosiva
		Description: El daño de pícaro tiene una probabilidad de estallar, incendiando a los enemigos cercanos
	}

	GorgonCoatingBuff: {
		DisplayName: Imbuición de Arma de Pícaro: Jugo de Gorgona
		Description: El daño de pícaro tiene una probabilidad de petrificar a los enemigos alcanzados
	}

	LichSetBuff: {
		DisplayName: Cosecha de Almas
		Description: Tu velocidad de movimiento y de ataque de pícaro se incrementan considerablemente
	}

	MyceliumVeins: {
		DisplayName: Venas de Micelio
		Description: La velocidad de ataque de pícaro ha aumentado un 10%
	}

	NinjaBuff: {
		DisplayName: Juego de Manos
		Description: Aumenta la velocidad del arma de pícaro, su cadencia y la probabilidad de golpe crítico
	}

	SporeCoatingBuff: {
		DisplayName: Imbuición de Arma de Pícaro: Esporas
		Description: El daño de pícaro tiene una probabilidad de infectar a los enemigos con micelio
	}

	LastStandBuff: {
		DisplayName: Última Resistencia
		Description: Velocidad y daño de arma de pícaro aumentados en 30%, pero a un precio...
	}

	ThrowingSpeed: {
		DisplayName: Velocidad del Pícaro
		Description: Tu velocidad de ataque de pícaro ha aumentado en 15%
	}

	ToxicCoatingBuff: {
		DisplayName: Imbuición de Arma de Pícaro: Tóxico
		Description: El daño de pícaro tiene una probabilidad de envenenar a los enemigos alcanzados
	}

	TrueStrike: {
		DisplayName: Golpes Verdaderos
		Description: Tu daño tiene una probabilidad del 100% de ser golpe crítico
	}

	GoldenScaleBuff: {
		DisplayName: Pez Dorado
		Description: Ahora tienes branquias y un delicioso sabor a galleta salada.\nPor desgracia, a los peces dorados no les gusta el Abismo.
	}
}

