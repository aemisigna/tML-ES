Keybinds.ThrowingTechnique.DisplayName: Técnica de Pícaro

ThrowerTechniques: {
	UseToEnable: Establece tu técnica activa al usar | Inflige daño de pícaro para generar puntos
	UseToDisable: Técnica Activa | Úsala de nuevo para desactivarla | Inflige daño de pícaro para generar puntos

	LastStand: {
		DisplayName: Última Resistencia
		Description:
			'''
			Se activa automáticamente al recibir daño letal, otorgándote 8 segundos de invulnerabilidad
			Mientras eres invulnerable, obtienes {1}% más de velocidad y daño de pícaro, pero mueres al finalizar la duración
			'''
	}
}

