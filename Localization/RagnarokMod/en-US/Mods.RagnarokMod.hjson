	}
}

Tooltips: {
	WhiteDwarfSetBonus:
		'''
		Rogue attacks have a 5% chance unleash an ivory flare from the cosmos for 1.75x damage
		The flare's damage is based on non-crit damage, but itself can crit
		'''

	LeviathanHeart: {
		NormalTooltip:
			'''
			Healing spells heal 25% more hp
			Healing spells apply [rbuff:RagnarokMod/LeviathanHeartBubble] to their target.
			'''
		CorruptTooltip:
			'''
			The Leviathan's Bubble reacts to your dark energy!
			All health costs are reduced by 1
			Spending health grants you [rbuff:RagnarokMod/LeviathanHeartBubbleCorrupted]
			10% increased radiant attack speed
			'''
	}
}

Compat: {
	TechPoints: Increases your maximum technique points by
	Recharge: and recharge by
	BasicDamage: basic damage
	DupeDamage: of your rogue damage is duplicated
	DupeCap: Duplication damage caps at
	NoGuideStack: Effect does not stack with other Guides
	Power: % Power
	Smited: was smited.
	Darkness: fell into darkness.
	TurnedToAmmo: was converted into ammunition.
	Recoil: could not handle the recoil.
}

Items: {
	DrumStick: {
		DisplayName: Drum Stick
		Tooltip: "'Your enemies are your drums!'"
	}

	AerospecBard: {
		DisplayName: Aerospec Shovel Hat
		Tooltip:
			'''
			5% increased playing and inspiration regeneration speed
			+2 seconds to empowerment duration
			'''
