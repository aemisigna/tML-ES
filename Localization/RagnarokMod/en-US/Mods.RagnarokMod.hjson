		DisplayName: Item Balancer Config
		Headers.ItemBalanceChanges: Item Balance Changes Header

		OmegaCore: {
			Label: Omega Core
			Tooltip: Nerfs the movement speed bonus of Omega Core to keep it more balanced for the further progression in the game.
		}

		genericweaponchanges: {
			Label: Generic Weapon Tweaks
			Tooltip: Applies general weapon rebalances.
		}
