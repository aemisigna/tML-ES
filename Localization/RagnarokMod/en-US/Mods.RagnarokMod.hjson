			'''
			Bloodflare, God Slayer, and Rhapsodist armor effects
			Pressing the '{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}' key will trigger both Rhapsodist armor abilities
			'''
		SetBonusHelheim: Tarragon, Bloodflare, and God Slayer armor effects
	}

	AuricTeslaHealerHead: {
		DisplayName: Auric Tesla Irradiant Visage
		DisplayNameEclipse: Primordial Tesla Irradiant Visage
		Tooltip:
			'''
			Corrupts your radiant powers
			100% increased radiant damage but 80% decreased non-radiant damage
			25% increased radiant critical strike chance
			5% increased movement speed
			25% decreased mana usage
			Healing spells heal an additional 10 life
			+100 maximum mana
			'''
		ToggleTooltip: "[c/aaaaaa:Shift-Right Click this item in your inventory to toggle] [c/CC44FF:corrupted radiant powers]"
		SetBonus:
			'''
			Bloodflare, Silva, and Dreamweaver armor effects
			Pressing the '{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}' key will trigger both Dreamweaver armor abilities
			50% increased radiant damage
			'''
		SetBonusHelheim:
			'''
			Tarragon, Bloodflare, and Silva armor effects
			50% increased radiant damage
			'''
	}

	BlazingDrumBeat: {
		DisplayName: Emblazoned Drum Stick
		Tooltip:
			'''
			Successfully timing hits will steadily increase its damage and empowerment level
			Mistiming hits will decrease these bonuses greatly and cost 9 inspiration
			These bonuses will stay between weapon swaps, but gradually fade while not your active weapon
			Chaining two or more successes will let out a large flaming slash
			Flaming slashes inflict all enemies in range with [cbuff:CalamityMod/HolyFlames]
			'''
	}

	BloodflareHeadBard: {
		DisplayName: Bloodflare Spiked Helmet
		Tooltip:
			'''
			20% increased symphonic damage and 12% increased symphonic critical strike chance
			+15% increased inspiration regeneration and +6 maximum inspiration
			+15% chance for inspiration notes to drop from enemies
			'''
		SetBonus:
			'''
			Doing symphonic damage will apply Burning Blood on enemies
			You will build a blood lust, 2 points for every hit enemy (can only occur 3 times a second)
			Upon reaching 100 points: 20% increased symphonic damage and strike chance, 25% increased movement speed
			Empowerments will be prolonged for an additional 3 seconds and 10% faster inspiration regen
			Pressing the 'Armor Ability' key will consume 20 points to replenish 10 inspiration
			You will lose 25 points upon getting hit and rapidly points when not hitting enemies for more than 5 seconds
			Your points are also reset when a boss is spawned
			'''
	}

	BloodflareHeadHealer: {
		DisplayName: Bloodflare Grim Visage
		Tooltip:
			'''
			20% reduced mana usage
			70% decreased non-radiant damage and 50% increased radiant damage
			20% increased radiant critical strike chance
			Healing spells will heal for an additional 7 life
			+60 maximum mana
			'''
		SetBonus:
			'''
			Doing radiant damage will apply Burning Blood on enemies
			You will build a blood lust, 2 points for every hit enemy (can only occur 3 times a second)
			Upon reaching 100 points: 20% increased radiant damage and strike chance, 20% increased movement speed
			and your healing spells will heal for an additional 3 health
			Additionally you get healed for a small fraction of your dealt damage
			Pressing the 'Armor Ability' key will consume 20 points to replenish 25 + bonus heal life 
			You will lose 25 points upon getting hit and rapidly points when not hitting enemies for more than 5 seconds
			Your points are also reset when a boss is spawned
			'''
	}

