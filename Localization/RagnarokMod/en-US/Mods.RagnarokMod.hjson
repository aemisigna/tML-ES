		DisplayName: April Chaos

		Headers: {
			AprilChaos: April Chaos
			RadiantMage: Radiant Mage
			MeleeSummoner: Melee Summoner
			RogueRanger: Rogue Ranger
			ObnoxiousBard: Obnoxious Bard
		}

		MasterToggle: {
			Label: Master Toggle
			Tooltip: Disables/Enables all options below.
		}

		RadMage: {
			Label: Radiant Mage
			Tooltip:
				'''
				Healer just felt like an extension of mage.
				So we fixed that.
				By replacing Mage with Healer.
				All magic is healing if you believe hard enough. 
				Or hit hard enough.
				'''
		}

		MelSum: {
			Label: Melee Summoner
			Tooltip:
				'''
				Summoner had some unfortunate progression gaps.
				So we fixed that.
				By giving all of Melee to Summoner.
				Your minions now respect you. 
				Your sword does not.
				'''
		}

		RogRan: {
			Label: Rogue Ranger
			Tooltip:
				'''
				Rogue is taking back its roots.
				By absorbing Ranger.
				They were always the same person. 
				One just had better shoes.
				'''
		}

		ObBard: {
			Label: Obnoxious Bard
			Tooltip: Makes your riffs... less riffin
		}

