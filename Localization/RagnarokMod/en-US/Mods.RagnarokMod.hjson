			'''
	}

	LeviathanHeartBubble: {
		DisplayName: Leviathan Bubble
		Description: The Leviathan's Bubble grants you +5% damage reduction
		ItemTooltip: +5% damage reduction
	}

	LeviathanHeartBubbleCorrupted: {
		DisplayName: Corrupted Leviathan Bubble
		Description:
			'''
			The Corrupted Leviathan's Bubble grants you +10% damage
