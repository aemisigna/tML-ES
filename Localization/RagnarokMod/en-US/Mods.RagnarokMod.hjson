Configs: {
	BossProgressionConfig: {
		DisplayName: Boss Progression Config
		Headers.BossProgressionChanges: Boss Progression Changes

		GrandFlareGun: {
			Label: Grand Thunder Bird Recipe Change
			Tooltip: Changes Grand Flare Gun and Storm Flare to require Stormlion Mandibles rather than Vulture Feathers. Defaults to True
		}

		DesertMedallion: {
			Label: Desert Scourge Recipe Change
			Tooltip: Changes Desert Medallion to use Sandstone Ingots from the Grand Thunder Bird. Defaults to True
		}

		DecapoditaSprout: {
			Label: Crabulon Recipe Change
			Tooltip: Changes Decapodita Sprout to use Pearl Shards, Storm Feathers, and Queen Jelly. Defaults to True
		}

		MarbleGranite: {
			Label: Granite Energy Storms and Buried Champion Recipe Changes
			Tooltip: Changes Ancient Blade and Unstable Core to require Aerialite Bars. Defaults to True
		}

		OverloadedSludge: {
			Label: Slime God Recipe Change
			Tooltip: Changes Overloaded Sludge to use Enchanted Marble and Empowered Granite. Defaults to True
		}

		StarCaller: {
			Label: Star Scouter Recipe Change
			Tooltip: Changes Star Caller to use Aerialite Bars and the evil boss material. Defaults to True
		}

		CryoKey: {
			Label: Cryogen Recipe Change
			Tooltip: Changes Cryo Key to use Strider Fangs. Defaults to True
		}

		MechBosses: {
			Label: Mech Bosses Recipe Change
			Tooltip: Changes Mechanical Eye, Worm, and Skull to each require a Strange Alien Motherboard. Defaults to True
		}

		Lich: {
			Label: Lich Summon Change
			Tooltip: Changes the Ancient Phylactory to require Essence of Havoc to summon the Lich rather than pumpkins. Defaults to True
		}

		CharredIdol: {
			Label: Brimstone Elemental Recipe Change
			Tooltip: Changes Charred Idol to require a Void Heart. Defaults to True
		}

		Seafood: {
			Label: Aquatic Scourge Recipe Change
			Tooltip: Changes Seafood to require Queen Jelly. Defaults to True
		}

		EyeOfDesolation: {
			Label: Calamitas Clone Recipe Change
			Tooltip: Changes Eye of Desolation to require Voidseer's Pearl. Defaults to True
		}

		DeathWhistle: {
			Label: Ravager Recipe Change
			Tooltip: Changes Death Whistle to require Cursed Cloth. Defaults to True
		}

		DoomSayerCoin: {
			Label: Primordials Recipe Change
			Tooltip: Changes Doom Sayer's Coin to require Ashes of Calamity. Defaults to True
		}

		RuneOfKos: {
			Label: Providence Spawning Changes
			Tooltip: Changes Mark of Providence recipe to require Divine Geodes and Primordials Essences, and makes it no longer drop from Providence. Defaults to True
		}
	}

	ClassBalancerConfig: {
		DisplayName: Class Balancer Config

		Headers: {
			ClassBalanceChanges: Class Balance Changes
			ClassMechanicChanges: Class Mechanic Changes
		}

		HealerDamageModifier: {
			Label: Healer Damage Modifier
			Tooltip: Multiplier for Healer damage. Multiplier applies after all other changes have been applied.
		}

		BardDamageModifier: {
			Label: Bard Damage Modifier
			Tooltip: Multiplier for Bard damage. Multiplier applies after all other changes have been applied.
		}

		RogueDamageModifier: {
			Label: Rogue Damage Modifier
			Tooltip: Multiplier for Rogue/Throwing damage. Multiplier applies after all other changes have been applied.
		}

		RangedDamageModifier: {
			Label: Ranged Damage Modifier
			Tooltip: Multiplier for Ranged damage. Multiplier applies after all other changes have been applied.
		}

		MagicDamageModifier: {
			Label: Magic Damage Modifier
			Tooltip: Multiplier for Magic damage. Multiplier applies after all other changes have been applied.
		}

		SummonDamageModifier: {
			Label: Summon Damage Modifier
			Tooltip: Multiplier for Summon damage. Multiplier applies after all other changes have been applied.
		}

		MeleeDamageModifier: {
			Label: Melee Damage Modifier
			Tooltip: Multiplier for Melee damage. Multiplier applies after all other changes have been applied.
		}

		HealingBonusModifier: {
			Label: Healing Bonus Modifier
			Tooltip: Multiplier for healing bonuses. Multiplier applies after all other changes have been applied.
		}

		RiffsRequireRiffInstrumentToBeHeld: {
			Label: Riffs Require Riff Instrument To Be Held
			Tooltip: Riffs end automatically when the weapon is no longer held.
		}

		MistimedDamagePen: {
			Label: Mistimed Damage Penanlty
			Tooltip:
				'''
				Thorium's damage penalty for mistimed big instrument attacks.
				Thorium's default is 0.75, meaning mistimed attacks deal 75% less damage.
				Ragnarok's default is 0.6, meaning mistimed attacks deal 60% less damage.
				[c/7C0A02:Some mods may force this value to another value for their own balance, however.]
				'''
		}
	}

