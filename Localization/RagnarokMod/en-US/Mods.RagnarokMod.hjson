	AntarcticExhaustionDebuff: {
		DisplayName: Antarctic Exhaustion
		Description: The cold settles into your bones
	}

	GuardianHealerBeamBuff: {
		DisplayName: Guardian Healer's Blessing
		Description: You are under a profane blessing
		ItemTooltip: +10% damage reduction and +5 hp/s life regen
	}

