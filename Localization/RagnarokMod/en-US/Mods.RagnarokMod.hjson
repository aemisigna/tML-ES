		ItemTooltip: Inflict [cbuff:CalamityMod/BrimstoneFlames] on hit
	}

	ScytheEarthBuff: {
		DisplayName: Blessing of the Earth
		Description: The earth protects you
		ItemTooltip: +10 defense
	}

	ScytheOasisBuff: {
		DisplayName: Blessing of the Oasis
		Description: You feel rejuvenated from the desert oasis
		ItemTooltip: +15 hp/s life regen
	}

	ScytheSandBuff: {
		DisplayName: Blessing of the Sand
		Description: The sands strengthen you
		ItemTooltip: +5% attack damage
	}

	ScytheWaterBuff: {
		DisplayName: Blessing of the Water
		Description: The water guides your hand
		ItemTooltip: +5% all attack speed
	}

	AuricSurge: {
		DisplayName: Auric Surge
		Description: You are being smited from within.
	}

	KellyPetBuff: {
		DisplayName: Kelly!
		Description: Kelly will follow you.
	}

	NightfallenDebuff: {
		DisplayName: Nightfallen
		Description: The darkness consumes.
