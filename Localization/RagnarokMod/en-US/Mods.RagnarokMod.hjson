		DisplayName: Elemental Reaper Cooldown
		Description: Elemental Reaper is on cooldown!
	}

	ScytheAirBuff: {
		DisplayName: Blessing of the Air
		Description: You always have a tailwind
		ItemTooltip: +20% movement speed and wing time
	}

	ScytheBrimstoneBuff: {
		DisplayName: Blessing of the Brimstone
