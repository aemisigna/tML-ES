		Items: {
			ArcaneQuiver: {
				DisplayName: Carcaj Arcano
				Tooltip:
					'''
					El daño de tus flechas se ve afectado por la Enfermedad del Maná
					Te permite consumir maná para encantar flechas, causando daño extra
					El bonus de daño se basa en el maná restante
					Activar la visibilidad reemplazará cualquier flecha por una flecha arcana
					Aumenta enormemente la velocidad de las flechas
					20% de probabilidad de no consumir flechas
					"Los magos conjuraban flechas arcanas para vendérselas a los cazadores, hasta que estos aprendieron la magia suficiente para hacerlo ellos mismos."
					'''
			}

			EvilMushroom: {
				DisplayName: Hongo Maligno
				Tooltip: Tanto tú como los enemigos que golpees reciben Marcado para Morir
			}

			FastHolster: {
				DisplayName: Funda Rápida
				Tooltip:
					'''
					Reduce el tiempo de uso de las armas de fuego en 10%
					Reduce la probabilidad de golpe crítico a distancia en 4%
					"No te preocupes por tu puntería. Dispara lo suficiente y te garantizo que algo va a impactar."
					'''
			}

			GrapeLauncher: {
				DisplayName: Lanzador de Cartuchos Colgantes
				Tooltip: Dispara una serie de balas tras golpear a un enemigo 8 veces seguidas
			}

			InfectedCrabGill: {
				DisplayName: Branquia de Cangrejo Infectada
				Tooltip:
					'''
					Invoca esporas con el tiempo que dañan a los enemigos
					Las armas de fuego tienen probabilidad de disparar una ronda fúngica extra que se divide al morir
					Reduce la regeneración de vida en 1
					'''
			}

			LifeMushroom: {
				DisplayName: Hongo Vivo
				Tooltip: Crecen hongos aleatoriamente a tu alrededor; recógelos para restaurar 15 de vida
			}

			MarvelousMycelium: {
				DisplayName: Micelio Maravilloso
				Tooltip:
					'''
					6% de aumento al daño a distancia y 9% de aumento a la probabilidad de golpe crítico a distancia
					Al recibir daño pierdes estos beneficios por un breve tiempo y obtienes Reblandecido
					"La muerte continúa hacia la vida, y la vida alcanza la muerte pronto"
					'''
			}

			ModifiedCoil: {
				DisplayName: Bobina Modificada
				Tooltip:
					'''
					7% de aumento al daño a distancia
					Aumenta ligeramente la velocidad de los proyectiles a distancia
					"Cables expuestos, manéjalo con cuidado"
					'''
			}

			MushroomUnitedNations: {
				DisplayName: Naciones Unidas del Hongo
				Tooltip:
					'''
					Reduce la defensa en 5 y la regeneración de vida en 2, 15% de aumento al daño a distancia y 5% de aumento a la probabilidad de golpe crítico a distancia
					El efecto anterior se revierte brevemente al recibir daño
					Invoca esporas con el tiempo que dañan a los enemigos
					Las armas de fuego tienen probabilidad de disparar una ronda fúngica extra que se divide al morir
					Al recibir daño pierdes estos beneficios por un breve tiempo y obtienes Reblandecido
					Presiona [KEY] para activar el efecto Alucinado
					Un rifle de francotirador con forma de hongo flota sobre tu cabeza, disparando al enemigo más lejano dentro de rango
					Reduce la probabilidad de que los enemigos te ataquen a ti
					"¿Por qué siento que cada vez somos menos miembros?"
					'''
			}

			OdddMushroom: {
				DisplayName: Hongo Extraño
				Tooltip:
					'''
					Presiona [KEY] para activar el efecto Alucinado
					"No siempre puedes confiar en lo que ves."
					'''
			}

			SuperCoil: {
				DisplayName: Bobina de Adamantita
				Tooltip:
					'''
					Aumenta la probabilidad de golpe crítico a distancia según la velocidad de uso del arma equipada
					Aumenta moderadamente la velocidad de los proyectiles a distancia
					'''
			}

			TitaniumCoil: {
				DisplayName: Bobina de Titanio
				Tooltip:
					'''
					Aumenta el daño a distancia según la velocidad de uso del arma equipada
					Aumenta moderadamente la velocidad de los proyectiles a distancia
					'''
			}

			WulfrumCoil: {
				DisplayName: Bobina de Wulfrum
				Tooltip:
					'''
					7% de aumento al daño a distancia
					Aumenta ligeramente la velocidad de los proyectiles a distancia
					'''
			}

			AstralArrow: {
				DisplayName: Flecha Astral
				Tooltip: Derrota a los terrores entre las estrellas para completar nuestra propia evolución
			}

			AstralBullet: {
				DisplayName: Bala Astral
				Tooltip: Derrota a los terrores entre las estrellas para completar nuestra propia evolución
			}

			DazzlingAstralArrow: {
				DisplayName: Flecha Astral Deslumbrante (Antigua)
				Tooltip: ""
			}

			DazzlingAstralBullet: {
				DisplayName: Bala Astral Deslumbrante
				Tooltip: ¡Planetas y estrellas! ¡Poder para tomar!
			}

			FossilArrow: {
				DisplayName: Flecha Fósil
				Tooltip:
					'''
					El fósil sólido destroza la defensa del enemigo
					El fósil corroído causa envenenamiento sulfúrico
					'''
			}

			FossilBullet: {
				DisplayName: Bala Fósil
				Tooltip:
					'''
					El fósil sólido destroza la defensa del enemigo
					El fósil corroído causa envenenamiento sulfúrico
					'''
			}

			HydrothermicArrow: {
				DisplayName: Flecha Hidrotérmica
				Tooltip:
					'''
					Libera una explosión hidrotérmica
					"¿Te atreves a golpear mi escudo con tu lanza? ¡Eso va a terminar contigo hecho pedazos!"
					'''
			}

			HydrothermicBullet: {
				DisplayName: Bala Hidrotérmica
				Tooltip:
					'''
					Invoca un volcán hidrotérmico bajo el enemigo
					El volcán hidrotérmico emite un pilar de fuego y llamas hidrotérmicas
					"¡Mi cuerpo arde a más de 1.400 grados!"
					'''
			}

			NapalmBullet: {
				DisplayName: Bala de Napalm
				Tooltip:
					'''
					¡Causa Embadurnado y En Llamas!
					"Jajaja, ¡un poco de fuego nunca le hizo daño a nadie!"
					'''
			}

			PerennialSeed: {
				DisplayName: Semilla Perenne
				Tooltip: Prosperidad duradera
			}

			WeakAstralArrow: {
				DisplayName: Flecha Astral Débil
				Tooltip: Derrota a un Mech Behemoth infectado por lo Astral para evolucionar
			}

			WeakAstralBullet: {
				DisplayName: Bala Astral Débil
				Tooltip: Derrota a un Mech Behemoth infectado por lo Astral para evolucionar
			}

			ElementalBullet: {
				DisplayName: Zanahoria Celestial Triturada
				Tooltip:
					'''
					Inflige Mezcla Elemental
					Golpear a un enemigo hace que los siguientes proyectiles del mismo tipo reciban un bonus de daño del 100%, que decae linealmente a 0 en 0.25 segundos
					'''
			}

			GoldenFeatherArrow: {
				DisplayName: Flecha de Pluma Dorada
				Tooltip:
					'''
					Puede atraer algo pequeño
					Invoca un rayo rojo al infligir golpes no críticos
					'''
			}

			MirageArrow: {
				DisplayName: Flecha Espejismo
				Tooltip: Otras dos, otras dos, otras dos, y otras dos más
			}

			SoulBullet: {
				DisplayName: Bala de Alma
				Tooltip:
					'''
					Se dirige hacia el enemigo más cercano, perforando tres veces con daño decreciente en cada golpe
					"Hecha al comprimir almas miserables dentro de casquillos, puede atraer a esas mismas almas lastimeras."
					'''
			}

			BloodBullet: {
				DisplayName: Bala de Sangre
				Tooltip:
					'''
					Inflige Sangre Ardiente
					Absorbe vida de los enemigos, curándote por el 20% del daño infligido
					"¿Pero a qué costo?"
					'''
			}

			DesertFeatherArrow: {
				DisplayName: Flecha de Pluma del Desierto
				Tooltip: "Cuando la pluma todavía estaba en el buitre, no era tan rápida"
			}

			DesertFeather: {
				DisplayName: Pluma del Desierto
				Tooltip: ""
			}

			ElectricArrow: {
				DisplayName: Flecha Eléctrica
				Tooltip: Persiguiendo la tormenta
			}

			PearlArrow: {
				DisplayName: Flecha de Perla
				Tooltip: Invoca un fragmento de perla al impactar
			}

			PearlBullet: {
				DisplayName: Bala de Perla
				Tooltip: Cubre a los enemigos con un brillo nacarado calmante, ralentizando sus movimientos
			}

			RottenBullet: {
				DisplayName: Bala Podrida
				Tooltip:
					'''
					Inflige Podredumbre Cerebral
					Matar a un enemigo hace que explote en cuatro disparos
					'''
			}

			SPBullet: {
				DisplayName: Bala de Prisma Marino
				Tooltip: Crea fragmentos de prisma al impactar
			}

			VictideArrow: {
				DisplayName: Flecha de Victide
				Tooltip:
					'''
					Se mueve más rápido bajo el agua
					Golpear a un enemigo invoca una Marea de la Victoria
					'''
			}

			VictideBullet: {
