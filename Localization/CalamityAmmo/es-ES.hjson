			}

			WulfrumArrow: {
				DisplayName: Flecha de Wulfrum
				Tooltip:
					'''
					"Es demasiado pesado para hacer flechas."
					"¿En serio?"
					'''
			}

			WulfrumBullet: {
				DisplayName: Bala de Chatarra de Wulfrum
				Tooltip:
					'''
					Irradia rayos de energía de Wulfrum con una ligera capacidad de rastreo
					El rayo tiene 10 de penetración de armadura base
