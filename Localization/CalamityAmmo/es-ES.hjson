					'''
					Los disparos reducen la protección del enemigo
					"¿Te apetece bailar con la muerte?"
					'''
			}

			FrigidCoil: {
				DisplayName: Bobina Gélida
				Tooltip:
					'''
					Reduce la velocidad a distancia en 10%
					Aumenta moderadamente la velocidad de los proyectiles a distancia
					Los proyectiles a distancia causarán Quemadura de Hielo
					Coloca bombas de hielo alrededor del enemigo que golpees
					Este efecto tiene un tiempo de reutilización de 5 segundos
					'''
			}

			ScorchingCoil: {
				DisplayName: Bobina Abrasadora
				Tooltip:
					'''
					Aumenta la probabilidad de golpe crítico a distancia en 7%
					Aumenta moderadamente la velocidad de los proyectiles a distancia
					Los proyectiles a distancia causarán Llamas de Azufre
					Dispara una ráfaga en forma de arco de 6 Explosiones Infernales de Azufre cada 6 golpes
					Los proyectiles que pueden dañar a los enemigos varias veces solo se contarán una vez
					'''
			}

			AutoCalculationCoil: {
				DisplayName: Bobina de Autocálculo de Draedon
				Tooltip:
					'''
					Aumenta moderadamente la velocidad de los proyectiles a distancia
					Los proyectiles a distancia perseguirán automáticamente a los enemigos
					Presiona [KEY] para cambiar entre distintos algoritmos de búsqueda
					'''
			}

			TransformerCoil: {
				DisplayName: Bobina Transformadora
				Tooltip:
					'''
					Aumenta significativamente la velocidad de los proyectiles a distancia
					Los proyectiles a distancia causarán Electrificado, eres inmune a Electrificado
					Una descarga eléctrica destellará en los últimos dos enemigos que golpees
					'''
			}

			AuricBullet: {
				DisplayName: Bala Áurica
				Tooltip: ""
			}
		}

