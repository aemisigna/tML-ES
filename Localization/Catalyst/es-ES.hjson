Mods: {
	CatalystMod: {
		Common: {
			UnboundKey: "[Sin asignar]"
			BoundKey: "{0}"
		}

		Items: {
			Lore: {
				LoreAstrageldon: {
					DisplayName: Astrageldon
					Lore:
						'''
						Semejante existencia desafía toda comprensión. Draedon informó en su momento sobre este poder anómalo durante su estudio de la Infección Astral.
						Pero incluso con toda su brillantez, no logró comprender del todo su peculiar naturaleza astral-gelatinosa.
						Lo que sí descubrió... fue que la entidad había sido contaminada con una cepa más potente de la infección.
						Su densidad era incalculable, superando con creces los límites de la razón. Y aun así, su extraña viscosidad desafiaba cualquier explicación.
						Si en verdad era gelatinosa, entonces su ambición no conocía límites. El huésped ideal para semejante infección.
						Su hambre habría sido insaciable. Incontrolable e indomable. Una perfección del orden natural.
						El codicioso Dios Slime habría enfermado de envidia con solo imaginar semejante potencial.
						Ahora que ha sido erradicado, solo cabe preguntarse qué amenazas mayores acechan más allá.
						'''
					Tooltip: ""
				}
			}

			AstrageldonBag: {
				DisplayName: Vaina del Tesoro ({$Mods.CatalystMod.NPCs.Astrageldon.DisplayName})
				Tooltip: "{$CommonItemTooltip.RightClickToOpen}"
			}

			AstrageldonMask: {
				DisplayName: Máscara de Astrageldon
				Tooltip: ""
			}

			InterstellarCorruptionDye: {
				DisplayName: Tinte de Corrupción Interestelar
				Tooltip: ""
			}

			AstrageldonPhase1MusicBox: {
				DisplayName: Caja de música (Astrageldon - Fase 1)
				Tooltip: Reproduce 'Cosmic Disgust' de DM DOKURO
			}

			AstrageldonPhase2MusicBox: {
				DisplayName: Caja de música (Astrageldon - Fase 2)
				Tooltip: Reproduce 'Galactic Destruction' de Heart Plus Up!
			}

			AstrageldonTitleMusicBox: {
				DisplayName: Caja de música (Título de Astrageldon)
				Tooltip: Reproduce 'Heaven's Hell-Sent Gift' de DM DOKURO
			}

			MetanovaOre: {
				DisplayName: Mena de Metanova
				Tooltip: ""
			}

			MetanovaBar: {
				DisplayName: Barra de Metanova
				Tooltip: Un universo entero comprimido
			}

			LoreAstrageldon: {
				DisplayName: "{$Mods.CatalystMod.NPCs.Astrageldon.DisplayName}"
				Tooltip:
					'''
					[c/E3AF40:Susurros de las alturas danzan en tus oídos...]
					[c/BEBEBE:Mantén presionado Shift para escuchar más de cerca]
					'''
			}

			AstralCommunicator: {
				DisplayName: Comunicador Astral
				Tooltip:
					'''
					Invoca a Astrageldon en la Infección Astral
					[c/870808:A menos que Astrageldon sea derrotado antes, este objeto dejará de funcionar cuando se elimine al Señor de la Luna.]
					{$Mods.CatalystMod.Tooltips.NotConsumable}
					'''
			}

			IntergelacticHeadMelee: {
				DisplayName: Casco Intergeláctico
				Tooltip:
					'''
					22% de daño y probabilidad de ataque crítico aumentados
					10% de velocidad cuerpo a cuerpo y de movimiento aumentadas
					Reduce el daño recibido un 15%
					'''
			}

			IntergelacticHeadRanged: {
				DisplayName: Visor Intergeláctico
				Tooltip:
					'''
					Aumenta el daño a distancia y la probabilidad de ataque crítico en un 14%
					12% de reducción de daño aumentada
					'''
			}

			IntergelacticHeadMagic: {
				DisplayName: Máscara Intergeláctica
				Tooltip:
					'''
					Aumenta el maná máximo en 100
					15% de daño mágico y probabilidad de ataque crítico aumentados
					Reduce el daño recibido un 12%
					'''
			}

			IntergelacticHeadSummon: {
				DisplayName: Casco con Cuernos Intergeláctico
				Tooltip:
					'''
					Aumenta en 1 tu cantidad máxima de súbditos
					Reduce el daño recibido un 12%
					'''
			}

			IntergelacticHeadRogue: {
				DisplayName: Tocado Intergeláctico
				Tooltip:
					'''
					Aumenta el daño y la probabilidad de ataque crítico de pícaro en un 22%
					12% de reducción de daño aumentada
					'''
			}

			IntergelacticBreastplate: {
				DisplayName: Peto Intergeláctico
				Tooltip: Otorga inmunidad a la Infección Astral y a múltiples debilitamientos que reducen la defensa
			}

			IntergelacticGreaves: {
				DisplayName: Grebas Intergelácticas
				Tooltip:
					'''
					20% de velocidad de movimiento aumentada
					Mayor velocidad de salto y resistencia adicional a caídas
					'''
			}

			AstralsEnd: {
				DisplayName: Fin Astral
				Tooltip: Invoca un asteroide interdimensional y sus fragmentos
			}

			Astragelgun: {
				DisplayName: Astragelcañón
				Tooltip:
					'''
					Dispara bombas de supernova que explotan al contacto
					Clic derecho para disparar una bola de plasma con 200% de daño
					{$Mods.CatalystMod.Tooltips.Flamethrower}
					75% de probabilidad de no consumir munición
					'''
			}

			InterstellarVolution: {
				DisplayName: Volución Interestelar
				Tooltip:
					'''
					Explota en slimers nova teledirigidos
					Los golpes furtivos hacen que los slimers disparen láseres
					'''
			}

			ExaltedHorizon: {
				DisplayName: Horizonte Exaltado
				Tooltip:
					'''
					Invoca una lanza teledirigida que acumula corrupción interestelar en los enemigos
					Al acumular 5 niveles, el enemigo explotará violentamente infligiendo daño extremo
					'''
			}

			AstralpodStaff: {
				DisplayName: Bastón de Astralpod
				Tooltip: Invoca a un astralpod que dispara ráfagas de láseres y rayos mortales para protegerte
			}

			ScytheoftheAbandonedGod: {
				DisplayName: Guadaña del Dios Abandonado
				Tooltip:
					'''
					Rota, invocando varias bolas de baba teledirigidas, y desacelera para desatar una tormenta de truenos de otro mundo
					Clic derecho para lanzarla hacia el cursor
					{$Mods.CatalystMod.Tooltips.FlawlessDrop}
					'''
			}

			AstralLash: {
				DisplayName: Látigo Astral
				Tooltip:
					'''
					Alcance: 40 bloques
					Velocidad de lanzamiento: 50
					Velocidad de retracción: 72
					Velocidad de arrastre: 16
					Te teletransporta a la ubicación del gancho
					Cualquier bloque que bloquee el camino entre tú y el gancho será ignorado
					'''
			}

			AstrageldonTrophy: {
				DisplayName: Trofeo de Astrageldon
				Tooltip: ""
			}

			InfluxCluster: {
