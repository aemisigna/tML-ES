			}

			DivineJello: {
				DisplayName: Gelatina Divina
				Tooltip:
					'''
					Invoca a una Deidad Slime
					'¡Un postre digno de un dios!'
					'''
			}

			AstrageldonRelic: {
				DisplayName: Reliquia de Astrageldon
				Tooltip: ""
			}

			BreathofGlacies: {
				DisplayName: Aliento de Glacies
				Tooltip:
					'''
					Lanza un círculo rúnico cada 5º disparo
					El círculo rúnico dispara fragmentos de hielo con 50% de daño
					{$Mods.CatalystMod.Tooltips.Flamethrower}
					50% de probabilidad de no consumir munición
					'''
			}

			DesertScorcher: {
				DisplayName: Abrasador del Desierto
				Tooltip:
					'''
					Dispara un chorro de agua abrasadora
					Ignora 5 puntos de Defensa enemiga
					{$Mods.CatalystMod.Tooltips.Flamethrower}
					40% de probabilidad de no consumir munición
					'''
			}

			Ichorthrower: {
				DisplayName: Lanzaicor
				Tooltip:
					'''
					Enciende el gel convirtiéndolo en un miasma llameante
					Este miasma puede condensarse en orbes de icor
					{$Mods.CatalystMod.Tooltips.Flamethrower}
					40% de probabilidad de no consumir munición
					'''
			}

			Plasmilegion: {
				DisplayName: Plasmilegion
				Tooltip:
					'''
					Ioniza el gel convirtiéndolo en plasma puro
					Clic izquierdo para cargar un poderoso rayo de energía, pero arriesgándote a sobrecalentar
					Clic derecho para disparar bolas de fuego, sin sobrecalentar
					{$Mods.CatalystMod.Tooltips.Flamethrower}
					40% de probabilidad de no consumir munición
					'''
			}

			Repentance: {
				DisplayName: Arrepentimiento
				Tooltip:
					'''
					Invoca llamas del sexto círculo
					{$Mods.CatalystMod.Tooltips.Flamethrower}
					70% de probabilidad de no consumir munición
					'''
			}

			RookOfVengeance: {
				DisplayName: Torre de la Anarquía
				Tooltip:
					'''
					Dispara bolas de fuego que se dividen ortogonalmente al golpear
					{$Mods.CatalystMod.Tooltips.Flamethrower}
					70% de probabilidad de no consumir munición
					'''
			}

			StaticInferno: {
				DisplayName: Tormenta de Fuego Voltaica
				Tooltip:
					'''
					Libera 3 orbes de electricidad que se materializan como plasma
					{$Mods.CatalystMod.Tooltips.Flamethrower}
					50% de probabilidad de no consumir munición
					'''
			}

			AstralNeutron: {
				DisplayName: Neutrón Astral
				Tooltip: "'PokerFace'"
			}

			CongeledDuoWhip: {
				DisplayName: Látigo Doble Coagulado
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.WhipTooltip}
					5% de daño conexión por invocación
					Clic izquierdo para liberar ambos látigos frente a ti
					Clic derecho para liberar un látigo al frente, el otro detrás
					'''
			}

			PrismBreak: {
				DisplayName: Ruptura de Prisma
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.WhipTooltip}
					Tus súbditos liberarán cristales de agua teledirigidos al golpear
					'''
			}

			ResonantStriker: {
				DisplayName: Golpeador Resonante
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.WhipTooltip}
					Libera orbes de electricidad teledirigidos al golpear
					Tus súbditos aturden a los enemigos que no sean jefes al golpear
					'''
			}

			UnderBite: {
				DisplayName: Mordida Inferior
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.WhipTooltip}
					Lanza un cráneo cáustico que inflige Veneno Ácido y 6% de daño de conexión por invocación
					'''
			}

			UnrelentingTorment: {
				DisplayName: Tormento Implacable
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.WhipTooltip}
					Libera una cascada de garras de otro mundo para desgarrar a los enemigos
					'''
			}

			BlossomsBlessing: {
				DisplayName: Bendición de la Flor
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.WhipTooltip}
					Es arrastrada por el viento cargando flores
					Toca el pétalo más grande para recibir una bendición de regeneración, daño y espinas
					'Florece, florece, se marchita y se dobla.'
					'''
			}

			Catharsis: {
				DisplayName: Catarsis
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.WhipTooltip}
					Atacar con el látigo cuesta salud
					Golpear enemigos almacena una carga de sangre. Se pueden almacenar hasta 20 cargas
					Clic derecho activa las cargas, potenciando temporalmente a Catarsis y restaurando la salud perdida
					[c/c61b40:La luz purificadora, abandonada y consumida por el dolor,]
					[c/c61b40:regresó a este reino como sombra aniquiladora.]
					'''
			}

			SandstoneReigns: {
				DisplayName: Riendas de Arenisca
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.WhipTooltip}
					Invoca a un pequeño Tiburón de Arenisca para morder a tus enemigos
					'¡Ökenhaj!'
					'''
			}

			CoralCrusher: {
				DisplayName: Triturador de Coral
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.WhipTooltip}
					Golpear a un enemigo con la punta incrusta un fragmento de coral
					Los ataques de los súbditos pueden romper el fragmento de coral, deteniendo su movimiento y provocando 6% de daño de conexión por invocación
					'''
			}

			WulfrumSatchelCharge: {
				DisplayName: Carga Explosiva de Wulfrum
				Tooltip:
					'''
					Provoca una explosión masiva que destruye bloques al realizar un golpe furtivo
					'No te acerques demasiado'
					'''
			}

			WulfrumFlashlight: {
				DisplayName: Linterna de Wulfrum
				Tooltip:
					'''
					'Iluminando el camino hacia una nueva actualización'
					Clic izquierdo para encender la linterna, doble clic para alternar entre las diferentes lentes en tu inventario
					'''
			}

			AmethystFlashlightLens: {
				DisplayName: Lente de Linterna de Amatista
				Tooltip: "{$Mods.CatalystMod.Tooltips.LensTooltip}"
			}

			TopazFlashlightLens: {
				DisplayName: Lente de Linterna de Topacio
				Tooltip: "{$Mods.CatalystMod.Tooltips.LensTooltip}"
			}

			SapphireFlashlightLens: {
				DisplayName: Lente de Linterna de Zafiro
				Tooltip: "{$Mods.CatalystMod.Tooltips.LensTooltip}"
			}

			EmeraldFlashlightLens: {
				DisplayName: Lente de Linterna de Esmeralda
				Tooltip: "{$Mods.CatalystMod.Tooltips.LensTooltip}"
			}

			RubyFlashlightLens: {
				DisplayName: Lente de Linterna de Rubí
				Tooltip: "{$Mods.CatalystMod.Tooltips.LensTooltip}"
			}

			DiamondFlashlightLens: {
				DisplayName: Lente de Linterna de Diamante
				Tooltip: "{$Mods.CatalystMod.Tooltips.LensTooltip}"
			}

			AmberFlashlightLens: {
				DisplayName: Lente de Linterna de Ámbar
				Tooltip: "{$Mods.CatalystMod.Tooltips.LensTooltip}"
			}

			TeamFlashlightLens: {
				DisplayName: Lente de Linterna de Equipo
				Tooltip:
					'''
					{$Mods.CatalystMod.Tooltips.LensTooltip}
					El color depende de tu equipo seleccionado
					'''
			}

			WulfrumMineBanner: {
				DisplayName: Estandarte de {$Mods.CatalystMod.NPCs.WulfrumMine.DisplayName}
				Tooltip: "{$CommonItemTooltip.BannerBonus}{$Mods.CatalystMod.NPCs.WulfrumMine.DisplayName}"
			}

			WulfrumSlimeBanner: {
				DisplayName: Estandarte de {$Mods.CatalystMod.NPCs.WulfrumSlime.DisplayName}
				Tooltip: "{$CommonItemTooltip.BannerBonus}{$Mods.CatalystMod.NPCs.WulfrumSlime.DisplayName}"
			}
		}

		ItemTooltip.Extra.HideofAstrumDeus: 50% de resistencia al debilitamiento Marchitez Astral
		ItemTooltipExtra0.AstralCommunicator: Clic derecho para invocar a Astrageldon en su primera fase
		ItemTooltipExtra1.AstralCommunicator: El núcleo ha sido destruido por la energía liberada tras la muerte de una deidad lunar...

		ArmorSetBonus: {
			IntergelacticAll:
				'''
				Te rodea con dos anillos de asteroides cuyo daño escala con tus estadísticas
				Presiona {0} para hacer los asteroides más transparentes
				'''
			IntergelacticMelee:
				'''
				Te rodea con cuatro anillos de asteroides cuyo daño escala con tus estadísticas
				Otorga inmunidad al retroceso y a múltiples debilitamientos de movimiento
				Eres inmune a la Marchitez Astral y tus ataques la infligen
				'''
			IntergelacticRanged:
				'''
				Las armas a distancia invocan estrellas con 30% de daño
				Eres inmune a la Marchitez Astral y tus ataques la infligen
				'''
			IntergelacticMagic:
				'''
				Los golpes críticos mágicos hacen que estallen estrellas de los enemigos golpeados
				20% de uso de maná reducido
				Aumenta en 100 el maná recibido de las pociones
				Eres inmune a la Marchitez Astral y tus ataques la infligen
				'''
			IntergelacticSummon:
				'''
				Aumenta en 3 tu número máximo de súbditos
				Los súbditos tienen 6% de probabilidad de golpe crítico
				Los súbditos lanzan asteroides recolectados a los enemigos
				Eres inmune a la Marchitez Astral y tus ataques la infligen
				'''
			IntergelacticRogue:
				'''
				+120 de sigilo máximo
				Los golpes furtivos liberarán el cinturón de asteroides hacia los enemigos objetivo
				Eres inmune a la Marchitez Astral y tus ataques la infligen
				'''
		}

