		AuricTeslaPlusSet: {
			Melee:
				'''
				Efectos de armadura Intergeláctica, Llamasangre y Asesino de Dioses cuerpo a cuerpo
				Presiona {0} para hacer los asteroides más transparentes
				Los enemigos son más propensos a atacarte
				Todos los proyectiles generan orbes áuricos curativos al golpear enemigos
				'''
			Ranged:
				'''
				Efectos de armadura Intergeláctica, Llamasangre y Asesino de Dioses a distancia
				Presiona {0} para hacer los asteroides más transparentes
				Todos los proyectiles generan orbes áuricos curativos al golpear enemigos
				'''
			Magic:
				'''
				Efectos de armadura Intergeláctica, Llamasangre y Silva mágicos
				Presiona {0} para hacer los asteroides más transparentes
				Todos los proyectiles generan orbes áuricos curativos al golpear enemigos
				Velocidad y aceleración máximas de carrera aumentadas un 5%
				'''
			Summoner:
				'''
				Efectos de armadura Intergeláctica, Llamasangre y Silva de invocación
				Presiona {0} para hacer los asteroides más transparentes
				Todos los proyectiles generan orbes áuricos curativos al golpear
				Velocidad y aceleración máximas de carrera aumentadas un 5%
				+6 súbditos máximos y 75% de daño de súbditos aumentado
				'''
			Rogue:
				'''
				Efectos de armadura Intergeláctica, Llamasangre y Asesino de Dioses de pícaro
				Presiona {0} para hacer los asteroides más transparentes
				Todos los proyectiles generan orbes áuricos curativos al golpear enemigos
				El sigilo de pícaro se acumula mientras no atacas y más lento mientras te mueves, hasta un máximo de 130
				Una vez que hayas acumulado el sigilo máximo, podrás realizar un Golpe Furtivo
				El sigilo de pícaro solo se reduce cuando atacas, no se reduce mientras te mueves
				Cuanto mayor sea tu sigilo de pícaro, mayor será tu daño, crítico y velocidad de pícaro
				'''
		}

