			}

			AstraJelly: {
				DisplayName: Gelatina Astral
				Tooltip: Otorga aumento de maná máximo y regeneración de maná
			}

			Lean: {
				DisplayName: Astracola
				Tooltip:
					'''
					Otorga aumento de maná máximo y de poder
					Gran aumento de la regeneración de maná
					'¡Siente la carbonatación cósmica!'
