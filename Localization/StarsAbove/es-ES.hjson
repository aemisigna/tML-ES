			StellarNova: {
				AfterNovaDialogue: {
					Asphodene: {
						1: ¿Qué sigue en la lista?
						2: Se actualizó la Nova Estelar. ¿Qué sigue?
						3: Los cambios a la Nova Estelar quedaron confirmados. Genial. ¿Necesitas algo más?
					}

					Eridani: {
						1: Bien, los cambios a la Nova Estelar se aplicaron. ¿Qué harás ahora?
						2: ¿Terminaste de modificar la Nova Estelar? Genial.
						3: Bien, cambiamos la Nova Estelar. ¿Tienes algo más en mente?
					}
				}

				AfterArrayDialogue: {
					Asphodene: {
						1: Bien, ya nos encargamos de la Matriz Estelar. ¿Necesitas algo más?
						2: Veo que terminaste tus cambios en la Matriz Estelar. Perfecto.
						3: La Matriz Estelar terminó de actualizarse. Eso es todo por ahora, a menos que tengas algo más en mente.
					}

					Eridani: {
						1: Bien, la Matriz Estelar quedó modificada. Lo siguiente en la lista es...
						2: ¿Terminaste con la Matriz Estelar? Genial. ¿Algo más?
						3: Bien, la Matriz Estelar quedó modificada. ¿Ya lograste lo que buscabas?
					}
				}

				AfterCartographyDialogue: {
					Asphodene: ¿Cambiaste de opinión?
					Eridani: ¿Tienes otros planes?
				}
			}

			StarfarerMenuButtons: {
				Archive: {
					Asphodene: Bien... ¿Sobre qué quieres leer? Los diálogos están agrupados en 4 categorías: ocio, jefes, armas y de largo formato. Recórrelas y elige la que quieras.
					Eridani: Bien, ¿sobre qué quieres leer? Los diálogos están agrupados en 4 categorías: ocio, jefes, armas y de largo formato. Elige libremente la que quieras ver.
				}

				ExitArchive: {
					Asphodene: ¿Cambiaste de opinión?
					Eridani: ¿Tenías otros planes?
				}

				ArchiveHover: {
					Asphodene: Este es el Archivo. Por si no captaste todo lo que dije, puedes leerlo aquí. Lo sé, no te cansas de mis análisis, ¿verdad? También puedes recuperar objetos que hayas perdido, como Esencias.
					Eridani: Este es el Archivo. Si alguna vez necesitas que repita algo que dije, está aquí. Además, si perdiste algo como una Esencia, puedes recuperarla.
				}

				Confirm: {
					Asphodene: {
						1: ¿Eso es todo?
						2: Bien, ¿terminaste?
						3: ¿Ya acabaste?
					}

					Eridani: {
						1: ¿Ya hiciste lo que necesitabas?
						2: ¿Terminaste?
						3: ¿Eso fue todo?
					}
				}

				HairstyleHover: {
					Asphodene: ¿Cambiando mi peinado, eh?
					Eridani: ¿Un peinado nuevo? No me molesta.
				}

				VoyageHover: {
					Asphodene: Aquí accedemos a la Cartografía Celestial: un mapa mágico de la galaxia cercana con la ayuda del Astrolabio. Recuerda que igual necesitarás el Vitroglifo Estelar cerca para ir a cualquier lugar que no sea el Observatorio.
					Eridani: Aquí es donde el Astrolabio resulta útil: con su poder, puedes acceder a la Cartografía Celestial, un mapa de la galaxia. Aun así, necesitarás el Vitroglifo Estelar cerca si quieres ir más allá del Observatorio.
				}

				Locked: {
					Asphodene: Aún no podemos usar esto.
					Eridani: Todavía no desbloqueamos esto.
				}

				NovaHover: {
					Asphodene: Este es el Menú de Nova Estelar. Puedes revisar las estadísticas de la Nova Estelar, cambiarla por otra o equipar Prismas Estelares para cambiar lo que pueden hacer.
					Eridani: Este es el Menú de Nova Estelar. Puedes explorar las Novas Estelares, alternar entre ellas o equipar Prismas Estelares para cambiar los efectos que tienen las Novas Estelares.
				}

				ArrayBoss: {
					Asphodene: Me encantaría dejarte modificar la Matriz Estelar, pero primero deberíamos encargarnos de ESO. ¡Vamos, ya sabes a qué me refiero!
					Eridani: Sé que te gustaría modificar la Matriz Estelar, pero hay un asunto mucho más urgente entre manos... ¿Eres consciente de eso, verdad?
				}

				ArrayHover: {
					Asphodene: Desde aquí puedes acceder a la Matriz Estelar. Podemos equipar habilidades pasivas aquí, sin superar el costo máximo, además de cambiar el tipo de daño de las Armas Aspecto.
					Eridani: Esta es la Matriz Estelar. Puedes equipar habilidades pasivas aquí, siempre que el costo total no supere el máximo. También aquí configuras el tipo de daño de las Armas Aspecto.
				}

				StarfarerAttire: {
					Asphodene: Si tienes algún Atuendo de Viajera Espacial para mí, este es el lugar para dejarlo. Me será bastante útil, ¡y a ti por asociación! Y oye, ¡el estilo es igual a habilidad!
					Eridani: Puedes colocar aquí el Atuendo de Viajera Espacial. Me dará algunos beneficios útiles para ayudarte mejor. Sé que tu sentido de la moda es... particular, así que al menos intenta tenerme piedad.
				}

				StarfarerVanity: {
					Asphodene: Usaré el Atuendo de Viajera Espacial aquí, sobre el Espacio de Armadura. Le dicen espacio de vanidad, o eso me contaron.
					Eridani: Este es el espacio de vanidad para el Atuendo de Viajera Espacial. Lo que se coloque aquí se usará sobre el set de armadura.
				}

				StarfarerOutfitChanged: {
					Asphodene: {
						1: Vaya. ¿Sabes qué? ¡Me gusta!
						2: Esto me queda bien, ¿no crees?
						3: ¡Podría acostumbrarme a esto!
					}

					Eridani: {
						1: Mmm. ¡Sí me sienta bien!
						2: ¡Es bastante cómodo! Sin quejas.
						3: ¡Vaya, sí me queda bastante bien! Al menos, eso creo.
					}
				}
			}
		}

		StellarNova: {
			StellarNovaDialogue: {
				StellarNovaQuotes: {
					1: {
						Special1: ¡Jamás voy a retroceder!
						Special2: Ni se te ocurra huir.
						Special3: ¡Con un solo golpe!
						Special4: Tu deseo es mi orden.
						Special5: ¡Ríndete! A estas alturas, ni yo puedo detenerme.
						Special6: No tengo arrepentimientos; este es el único camino.
						1: ¡Se acabaron los juegos!
						2: ¡Hora de contraatacar!
						3: ¡No podemos detenernos ahora!
						4: (Ríe), ¡muy bien!
						5: ¡Jamás voy a retroceder!
						6: ¡Hora de cambiar el rumbo de la batalla!
						7: ¡Te mostraré de lo que soy REALMENTE capaz!
						8: Tu destino quedó sellado cuando te alzaste contra nosotras.
						9: Acepta tu destino.
						10: ¿Para qué contenerse si puedo resolver el problema ahora mismo?
						11: ¡Subestímame si quieres!
						12: Terminemos con esto.
						13: ¡Ni se te ocurra huir!
						14: Tu deseo es mi orden.
						15: ¡Te reduciré a polvo estelar!
						16: ¡He estado esperando este momento exacto!
						17: No pienso detenerme aquí.
						18: Ahora o nunca.
						Joke: Espera, ¿cuál era la que estábamos usando?
					}

					2: {
						Special1: Hora de demostrar mi valía.
						Special2: Ni se te ocurra huir.
						Special3: No la viste venir, ¿verdad?
						Special4: Te mostraré el dominio del alma.
						Special5: Debes saber que estás muy por debajo de mí.
						Special6: Soy el hueso de mi espada...
						1: Objetivo fijado.
						2: Te mostraré de lo que soy realmente capaz.
						3: Tu destino quedó sellado cuando te alzaste contra nosotras.
						4: Acepta tu destino.
						5: Vaya. ¿Eso es todo lo que tienes?
						6: Acepta tu destino. No hay nada más que puedas hacer.
						7: Perder nunca fue una opción.
						8: No pienso detenerme aquí.
						9: ¡Sométete a la entropía!
						10: Hora de terminar con esto.
						11: No la viste venir, ¿verdad?
						12: ¡Ni se te ocurra huir!
						13: Hora de demostrar mi valía.
						14: (Ríe)
						15: ¡No podemos detenernos ahora!
						16: Hora de contraatacar.
						17: ¡Se acabaron los juegos!
						18: Solo tenemos una oportunidad; que valga la pena.
						Joke: Eh, ¿cómo era? Algo así...
					}
				}

				MiscInfo: {
