		Items: {
			AlienCoral: {
				Tooltip:
					'''
					[c/2DD2FE:Reliquia del Observador Estelar]
					Por cada punto de Energía de la Matriz Estelar sin usar, obtén 8% de daño incrementado
					En su lugar, obtén 8 de defensa con la Matriz Estelar completa
					[c/ADEEFF:Solo se puede equipar una Reliquia del Observador Estelar a la vez]
					'De un mundo alienígena más allá de toda creencia'
					'''
				DisplayName: Coral Alienígena
			}

			CrystallizedAbsence: {
				Tooltip:
					'''
					[c/2DD2FE:Reliquia del Observador Estelar]
					La Vida máxima se reduce en 300 y la defensa en 20, pero el daño aumenta en 50%
					Solo está activo cuando la Vida máxima sin modificar es 400 o más
					[c/ADEEFF:Solo se puede equipar una Reliquia del Observador Estelar a la vez]
					'De un mundo condenado a desvanecerse'
					'''
				DisplayName: Ausencia Cristalizada
			}

			Crystallize: {
				DisplayName: Cristalizar
				Tooltip: ""
			}

			DragonwardTalisman: {
				Tooltip:
					'''
					Otorga inmunidad a Silenciado, Confundido, Sangrado e Icor
					Obtén 20 de Defensa por encima de 500 de Vida
					'Previene la corrupción etérea... ¡solo no la rayes!'
					'''
				DisplayName: Talismán Guardadragón
			}

			GaleflameFeather: {
				Tooltip:
					'''

					Obtén 5% de daño incrementado en el aire
					Los fotogramas de inmunidad en el aire otorgan un 18% adicional de daño incrementado y Celeridad
					'Algunos dirán que está sobreutilizado'
					'''
				DisplayName: Pluma Ígneogalerna
			}

			Glitterglue: {
				Tooltip:
					'''
					Golpear enemigos tiene 5% de probabilidad de infligir Pegamento Brillante durante 4 segundos
					Los ataques contra enemigos con Pegamento Brillante tienen 30% de probabilidad de convertir golpes no críticos en críticos
					No aplica al daño de invocación
					'No se recomienda olerlo'
					'''
				DisplayName: Taza de Pegamento Brillante
			}

			Luciferium: {
				Tooltip:
					'''
					La defensa se reduce en 30
					Al matar a un enemigo, obtén el buff 'Angustia Saciada' durante 15 segundos
					Durante este tiempo, obtén 20% de daño incrementado, poderosa regeneración de vida y se restaura la defensa
					'''
				DisplayName: El Pacto de Lucifer
			}

			PerfectlyGenericAccessory: {
				Tooltip:
					'''
					Aumenta el daño de las Armas Aspecto en 8%
					'Un poco demasiado perfecto'
					'''
				DisplayName: Accesorio Perfectamente Genérico
			}

			ToMurder: {
				Tooltip:
					'''
					Los enemigos tienen una probabilidad drásticamente mayor de atacarte a ti
					Cuando la Defensa es menor a 40, obtén 5% de daño, aumentado a 15% por debajo de 10 de Defensa
					'¿Podrás salirte con la tuya?'
					'''
				DisplayName: "'Para Asesinar'"
			}

			AegisDriver: {
				Tooltip:
					'''
					Con 40 de maná disponible, esta arma se lanzará con efectos especiales, consumiendo 40 de maná en el proceso
					La hoja se encenderá, causando daño incrementado y quemará a los enemigos
					Los enemigos en llamas recibirán daño adicional al volver a encenderse
					Si no hay maná disponible, el arma quedará sin potencia y hará la mitad de daño
					Atacar con la versión potenciada de esta arma carga el [c/FF5858:Medidor de la Égida]
					Una vez lleno el [c/FF5858:Medidor de la Égida], el siguiente ataque hará explotar al enemigo, causando un enorme daño crítico mientras consume el [c/FF5858:Medidor de la Égida]
					El [c/FF5858:Medidor de la Égida] también se carga lentamente con el tiempo mientras se sostiene esta arma
					'¡Este es el poder de la Égida!'
					'''
				DisplayName: Portadora de la Égida
			}

			AncientBook: {
				Tooltip:
					'''
					Invoca [c/B875F0:Pulpos del Vacío] para atacar enemigos con láseres teledirigidos
					Cada [c/B875F0:Pulpo del Vacío] invocado aumenta el daño de todos los súbditos y armas de invocación en 1%
					Clic derecho para disparar un [c/E752B3:Estallido Arcano] hacia tu cursor durante 3 segundos, derritiendo enemigos en línea recta frente a ti (1 minuto de reutilización)
					Con al menos un [c/B875F0:Pulpo del Vacío] invocado, aparecerá el [c/5652E7:Medidor Abisal]
					Cuando los [c/B875F0:Pulpos del Vacío] o el [c/E752B3:Estallido Arcano] hagan daño, el [c/5652E7:Medidor Abisal] aumentará, incluso sin sostener esta arma
					Cuando el [c/5652E7:Medidor Abisal] esté lleno, la [c/AC49F5:Invocación del Antiguo] se activará mientras se sostenga esta arma
					La [c/AC49F5:Invocación del Antiguo] hará que portales mágicos rodeen al enemigo más cercano
					Tras una breve demora, se invocarán tentáculos para atacar, infligiendo Llamasombra durante 7 segundos
					Por cada pulpo del vacío invocado, la cantidad de portales de la [c/AC49F5:Invocación del Antiguo] aumentará y el [c/E752B3:Estallido Arcano] hará más daño
					El daño escala con el progreso del mundo
					'Estamos felices. Estamos aquí. Estamos emocionados. Somos...'
					'''
				DisplayName: Takonomicón
			}

			Apalistik: {
				Tooltip:
					'''
					5 de daño de conexión por invocación
					Golpear enemigos con el arma inflige [c/4A91FF:Resaca] durante 4 segundos
					Cuando un súbdito golpea a un enemigo con [c/4A91FF:Resaca], recibe 30% de daño adicional, eliminando [c/4A91FF:Resaca]
					Además, mientras se sostenga esta arma, los súbditos tienen 10% de probabilidad de aplicar [c/4776A7:Purga del Océano] durante 5 segundos al golpear enemigos
					Cuando golpeas a un enemigo con [c/4776A7:Purga del Océano] usando esta arma, el enemigo detonará, recibiendo daño y esparciendo burbujas dañinas en el área
					Las burbujas cuentan como daño de invocación y tienen 30% de probabilidad de crítico
					Si las burbujas golpean a un enemigo con [c/4A91FF:Resaca], esta probabilidad aumenta a 100%
					El daño escala con el progreso del mundo
					'''
				DisplayName: Apalistik
			}

			ApalistikUpgraded: {
				Tooltip:
					'''
					18 de daño de conexión por invocación
					Golpear enemigos con el arma inflige [c/4A91FF:Resaca] durante 4 segundos
					Cuando un súbdito golpea a un enemigo con [c/4A91FF:Resaca], recibe 30% de daño adicional, eliminando [c/4A91FF:Resaca]
					Además, mientras se sostenga esta arma, los súbditos tienen 10% de probabilidad de aplicar [c/4776A7:Purga del Océano] durante 5 segundos al golpear enemigos
					Cuando golpeas a un enemigo con [c/4776A7:Purga del Océano] usando esta arma, el enemigo detonará, recibiendo daño y esparciendo burbujas dañinas en el área
					Las burbujas cuentan como daño de invocación y tienen 30% de probabilidad de crítico
					Si las burbujas golpean a un enemigo con [c/4A91FF:Resaca], esta probabilidad aumenta a 100%
					Clic derecho para imbuirte con [c/00FFC1:Ira Nacida del Mar] durante 8 segundos
					Bajo los efectos de [c/00FFC1:Ira Nacida del Mar], los ataques con esta arma dispararán burbujas en patrón disperso
					Además, los súbditos harán el doble de daño
					Tras usarla, [c/00FFC1:Ira Nacida del Mar] tiene 30 segundos de reutilización
					El daño escala enormemente con el progreso del mundo
					'''
				DisplayName: Apalistik Nacido del Mar
			}

			ArachnidNeedlepoint: {
				Tooltip:
					'''
					3 de daño de conexión por invocación
					Ataca con este látigo en un amplio arco ignorando el terreno, apuntando a los enemigos golpeados
					Clic derecho para desplegar un [c/83CAEB:Aracnoide Mecánico], que flotará y se aferrará a los objetivos
					Solo un [c/83CAEB:Aracnoide Mecánico] puede aferrarse a un objetivo a la vez
					Los [c/83CAEB:Aracnoides Mecánicos] se atarán entre sí al aferrarse, infligiendo daño rápidamente a los enemigos entre ellos
					Doble toque hacia ABAJO para desplegar un [c/83CAEB:Aracnoide Mecánico] estacionario después de que al menos uno no estacionario haya sido invocado
					Los [c/83CAEB:Aracnoides Mecánicos] estacionarios no infligen daño, pero los no estacionarios pueden atarse a ellos para infligir daño
					Golpear a un enemigo al que un [c/83CAEB:Aracnoide Mecánico] esté aferrado con el látigo causa daño crítico y otorga [c/3A8BF3:Telaraña de Agujas] durante 4 segundos
					[c/3A8BF3:Telaraña de Agujas] aumenta todo el daño de súbdito en 30%
					'''
				DisplayName: Aguja de Aracnoide
			}

			ArchitectLuminance: {
				Tooltip:
					'''
					[c/F592BF:Esta arma no se ve afectada por la penalización de Tipo de Daño del Aspecto]
					Sostener esta arma te equipa con el [c/6EF367:Armamento Luminario], aumentando la defensa en 30
					Clic derecho para invocar a la [c/70D38B:Sirena de Artificio] durante 15 segundos en tu cursor (1 minuto de reutilización)
					La [c/70D38B:Sirena de Artificio] aniquilará a los enemigos cercanos con rayos de luz hiperpotenciados, incluso sin sostener esta arma
					El [c/F592BF:Tipo de Daño del Aspecto] actual influye en los ataques del arma
					[c/FFAB4D:Cuerpo a cuerpo]: El arma se blande mucho más rápido y la defensa se suma al daño crítico
					[c/EF4DFF:Magia]: En lugar de blandirse, el arma conjurará 6 estallidos explosivos en abanico, causando 1/3 del daño base
					[c/4DFF5B:A distancia]: En lugar de blandirse, el arma disparará rápidamente proyectiles perforantes sin consumir munición, causando 1/2 del daño base
					[c/00CDFF:Invocación]: El [c/6EF367:Armamento Luminario] ataca periódicamente a los enemigos cercanos y puede causar golpes críticos
					'¡Por el futuro!'
					'''
				DisplayName: Luminiscencia del Arquitecto
			}

