				[c/DADADA:Código Abierto: ScalarVector, tomat, jopojelly, John Snail, Kazzymodus, Mirsario, Lion8cake, Rhoenicx]



				'''
			NeopursuantSetBonusFullMetalArcanist: "[c/F19559:Arcanista de Acero Completo]: Restaura toda tu Maná y limpia la Enfermedad de Maná al activar la Nova Estelar"
			NeopursuantSetBonusBackupBattery: "[c/F19559:Batería de Respaldo]: Cuando el Maná se agota, restaura todo el maná pero quédate congelado por 2 segundos"
			NeopursuantSetBonusCataphractArms: "[c/F19559:Brazos Catafracta]: Gana defensa adicional basada en el 0.5% del Costo de Energía de Nova Estelar"
			NeopursuantSetBonusInfiltrator: "[c/F19559:Infiltrador]: Gana 12% de daño adicional durante marcos de inmunidad"
			NeopursuantSetBonusViralUpload: "[c/F19559:Carga Viral]: Activar la Nova Estelar inflige daño a todos los enemigos cercanos basado en tu defensa"
			NeopursuantSetBonusEnviroSavant: "[c/F19559:Sabio Ambiental]: Gana mejoras permanentes de Cazador y Sentido del Peligro y cura 2 PV al derrotar enemigos"
			HardlightMonitor: "[c/F19559:Luz Sólida Actual:] [c/DAEFDA:{0}/25000] [c/F19559:- 100 necesarios por intercambio]"
			HardlightAcquired: +{0} Luz Sólida
			HardlightNotEnough: El confluxo no responde; necesitas {0} más de Luz Sólida para intercambiar
			HardlightNotEnoughGarridine: No tienes suficiente Luz Sólida para el artilugio de Garridina, así que no lo mencionó...
		}

		DamageClass.CelestialDamageClass: daño celestial

		NPCs: {
			Astrologian: {
				DisplayName: Astróloga

				# This is what displays during all of an NPC's happiness levels.
				TownNPCMood: {
					Content: No tengo quejas.
					NoHome: El hecho de que disfrute mirando las estrellas no significa que quiera estar sin techo.
					FarFromHome: Me duele preguntar, pero ¿dónde estoy?
					LoveSpace: El espacio extra para tomar medidas siempre es bienvenido.
					DislikeCrowded: Disfruto de la atmósfera animada, pero todo tiene un límite; he encontrado el mío.
					HateCrowded: No me digas. No puedo ni armar mi telescopio sin que se caiga, por no hablar de la contaminación lumínica.
					LoveBiome: ¿No es obvio? El mejor lugar para ver las estrellas es el Espacio.
					LikeBiome: No tengo quejas sobre {BiomeName}. El horizonte es una vista conmovedora, después de todo.
					DislikeBiome: Como un hada, pensarías que preferiría {BiomeName}. Déjame ser claro: no lo hago. Intenta mirar por un telescopio mientras te pisotea un unicornio.
					HateBiome: ¿En serio? ¿{BiomeName}? Debes tener algunos rencores contra mí... Siéntete libre de compartirlos.
					LoveNPC: No hay vuelta que darle: {NPCName} es mucho mejor en artes mágicas que yo. Me encantaría aprender bajo su tutoría.
					LikeNPC: Un colega científico en {NPCName} proporciona un discurso valioso.
					DislikeNPC: No es que odie a {NPCName}... sin embargo, no podríamos ser más diferentes en nuestros gustos.
					HateNPC: Brusco, ignorante e inculto. {NPCName} es la esencia destilada del individuo que nunca quiero volver a ver.
					LikeNPC_Princess: ¿{NPCName} es una princesa? Podría ser pertinente construir una buena relación; sus arcas podrían permitirse instrumentos más fuertes.
					Princess_LovesNPC: ¡{NPCName} es tan exótico! ¿No es algo de admirar?
				}

				# This key is generated and used when the "Census" mod is enabled: It allows the user to see the spawn condition of this town NPC in the Housing UI
				Census.SpawnCondition: Ten una Memoria de Arma en tu inventario
			}

