			VagrantBoss: {
				DisplayName: El Errante del Espacio-Tiempo

				BossChecklistIntegration: {
					EntryName: El Errante del Espacio-Tiempo
					SpawnInfo: Derrota a este extraño enemigo usando el Disco Fracturado, obtenido de tu Astróloga después de derrotar al Ojo de Cthulhu. ¡Este combate será crítico para la progresión posterior!
					DespawnMessage: ""
				}
			}

			ThespianBoss: {
				DisplayName: Thespian, el Acto de la Alquimia

				BossChecklistIntegration: {
					EntryName: Thespian, el Acto de la Alquimia
					SpawnInfo: Desafía a este extraño enemigo preguntando sobre la Poción Extraña con la Astróloga. Se muda al pueblo después de que obtengas una Memoria de Arma o derrotes al Errante del Espacio-Tiempo.
					DespawnMessage: ""
				}
			}

			PolluxBoss: {
				DisplayName: Pollux, Fuerza Maldita

				BossChecklistIntegration: {
					EntryName: Dioskouroi, las Fuerzas Gemelas
					SpawnInfo: Derrota a estos demonios gemelos usando el Colgante Twincrux, otorgado después de derrotar a Esqueletrón. (El Errante del Espacio-Tiempo debe haber sido derrotado.)
					DespawnMessage: ""
				}
			}

			PenthesileaBoss: {
				DisplayName: Pentesilea, la Bruja de Tinta

				BossChecklistIntegration: {
					EntryName: Pentesilea, la Bruja de Tinta
					SpawnInfo: Enfrenta a este terrible enemigo con el Lienzo Inmaculado, dado por tu Astróloga después de derrotar a los ojos mecánicos gemelos. (El Errante del Espacio-Tiempo debe haber sido derrotado.)
					DespawnMessage: ""
				}
			}

			NalhaunBossPhase2: {
				DisplayName: Nalhaun, Rey del Mundo Hueco

				BossChecklistIntegration: {
					EntryName: Nalhaun, el Rey Bruñido
					SpawnInfo: Enfrenta a este monarca anciano con la Corona Antigua, dada por tu Astróloga después de derrotar al Gólem. (El Errante del Espacio-Tiempo debe haber sido derrotado.)
					DespawnMessage: ""
				}
			}

			ArbitrationBoss: {
				DisplayName: Arbitrio

				BossChecklistIntegration: {
					EntryName: Arbitrio
					SpawnInfo: Este misterioso enemigo acecha en submundos anómalos; pasar demasiado tiempo en uno te llevará a Katabasis, donde te espera. Derrotar a este jefe suelta un objeto que te llevará inmediatamente a Katabasis. Con Modo de Compatibilidad Multijugador, puedes obtener este objeto viajando a Lira.
					DespawnMessage: ""
				}
			}

			StarfarerBoss: {
				DisplayName: Asphodene y Eridani

				BossChecklistIntegration: {
					EntryName: Asphodene y Eridani
					SpawnInfo: Enfrenta a tus Viajeras Espaciales en este combate amistoso; desbloqueado después de derrotar a Plantera (¡TODOS los jefes anteriores de The Stars Above deben haber sido derrotados!)
					DespawnMessage: ""
				}
			}

			WarriorOfLightBossFinalPhase: {
				DisplayName: El Guerrero de Luz

				BossChecklistIntegration: {
					EntryName: El Guerrero de Luz
					SpawnInfo: Después de derrotar al Señor de la Luna, pueden ocurrir eventos extraños. Después de 2 días en el juego (esto no puede acelerarse de ninguna manera) puedes obtener un objeto de tu Astróloga para continuar.
					DespawnMessage: ""
				}
			}

			TsukiyomiBoss: {
				DisplayName: Tsukiyomi, la Primera Viajera Espacial

				BossChecklistIntegration: {
					EntryName: Tsukiyomi, la Primera Viajera Espacial
					SpawnInfo: Finalmente ha llegado el momento. Elabora todos los Rastros Mnémónicos juntos con la Raíz de Triada Celestial para crear el Sello Mnémónico, y úsalo para ser llevado a la arena de jefe de Tsukiyomi.
					DespawnMessage: ""
				}
			}

