			DraggedBelowGloves: {
				DisplayName: Guantes de Arrastrado al Fondo
				Tooltip: ""
			}

			DraggedBelow: {
				DisplayName: Arrastrado al Fondo
				Tooltip:
					'''
					Los ataques con esta arma desatan [c/7444FF:Ahogo], disparando un dardo perforante débil que golpea 2 veces, causando 15% de daño adicional a enemigos con Llamasombra
					Clic derecho para desatar [c/9036F5:Inundación], disparando un dardo de energía del vacío que explota al impactar, causando 400% de daño mientras inflige Llamasombra durante 5 segundos (8 segundos de reutilización)
					Recibir daño o usar [c/7444FF:Ahogo] aumenta la [c/7A1AE7:Corrupción del Vacío] (la [c/7A1AE7:Corrupción del Vacío] aumenta pasivamente con el tiempo)
					Presionar la Tecla de Acción del Arma consumirá 25% de [c/7A1AE7:Corrupción del Vacío] para activar [c/73C84E:Suprimir], curando 25 de Vida y 25% del Maná máximo (2 segundos de reutilización)
					Las activaciones consecutivas de [c/73C84E:Suprimir] curan 5 de Vida en su lugar
					Cuando la [c/7A1AE7:Corrupción del Vacío] alcanza el máximo, recibes [c/E71A1A:Corrupción Diabólica]
					Bajo los efectos de [c/E71A1A:Corrupción Diabólica], obtén 12 de defensa, la [c/7A1AE7:Corrupción del Vacío] se drena con el tiempo, y las habilidades del arma se transforman
					[c/7444FF:Ahogo] se convierte en [c/CD1717:Ahogo Corrupto], transformándose en un rayo canalizado que causa poderoso daño, pero ya no carga [c/7A1AE7:Corrupción del Vacío] e inflige Lentitud a ti mismo mientras está activo
					[c/9036F5:Inundación] se convierte en [c/B1296D:Inundación Corrupta], causando 1000% de daño y su reutilización se reduce a 4 segundos, pero no inflige Llamasombra
					[c/73C84E:Suprimir] se convierte en [c/C84EB6:Supresión Corrupta], consumiendo 50 de Vida para restaurar 50% del Maná máximo y aumentar la [c/7A1AE7:Corrupción del Vacío] en 25%
					'...y así llega... para todos nosotros.'
					'''
			}

			Poltergrasp5000: {
				Tooltip:
					'''
					Mientras se sostiene, aspira instantáneamente todos los objetos cercanos hacia tu posición
					Usa el objeto para atraer objetos más lejanos
					'''
				DisplayName: Poltergrasp 5000
			}

			GundbitStaves: {
				DisplayName: Asedio Gund-bit
				Tooltip:
					'''
					Sostener esta arma invoca [c/B6E3F5:Báculos Bit] y otorga [c/3899E1:Matriz Defensiva Aérea], otorgando defensa adicional según el Maná actual (hasta 10)
					Los ataques con esta arma disparan láseres perforantes y marcan objetivos, haciendo que los [c/B6E3F5:Báculos Bit] orbiten y ataquen
					Presiona la Tecla de Acción del Arma para retirar todos los [c/B6E3F5:Báculos Bit] y formar un escudo defensivo durante 3 segundos (20 segundos de reutilización)
					Durante este tiempo, el escudo seguirá tu cursor y destruirá todos los proyectiles hostiles en contacto
					Además, mientras el escudo está activo, el efecto de [c/3899E1:Matriz Defensiva Aérea] se amplifica en 50%
					Clic derecho para retirar todos los [c/B6E3F5:Báculos Bit], transformando el arma tras una breve demora (30 segundos de reutilización)
					Tras la transformación, desata un rayo extremadamente poderoso que ignora colisiones y golpea varias veces
					Solo un efecto que use los [c/B6E3F5:Báculos Bit] puede estar activo a la vez
					'''
			}

			DragaliaFound: {
				DisplayName: Dragalia Encontrada
				Tooltip:
					'''
					Sostener esta arma otorga [c/CAFF93:Luz de Dragón de la Tormenta], otorgando 2 de defensa por cada espacio de invocación
					Los ataques con esta arma ejecutan un combo de corto alcance, otorgando Invencibilidad por un breve tiempo antes de terminar el combo
					Al completar un combo, obtén [c/FFF593:Hoja Forjada por el Vínculo] durante 3 segundos, cargando [c/78F178:Energía de Transformación Dracónica] mientras está activo
					Una vez que la [c/78F178:Energía de Transformación Dracónica] alcanza 50% o más, presiona la Tecla de Acción del Arma para activar el [c/9AFE35:Estado de Wyrm del Viento]
					El [c/9AFE35:Estado de Wyrm del Viento] te transforma en un poderoso dragón, curando 100 de Vida al instante mientras drena constantemente la [c/78F178:Energía de Transformación Dracónica]
					Además, recibir daño resta [c/78F178:Energía de Transformación Dracónica] en su lugar
					Dentro del [c/9AFE35:Estado de Wyrm del Viento], los ataques se convierten en poderosos zarpazos que causan 200% de daño en un área amplia e infligen [c/CCEDAA:Azote de Tormenta] durante 3 segundos
					[c/CCEDAA:Azote de Tormenta] se consume cuando los súbditos causan daño y aumenta el daño causado en 1% por cada espacio de invocación
					Clic derecho para invocar poderosos tornados sobre todos los enemigos cercanos mientras infliges [c/CCEDAA:Azote de Tormenta] durante 1 segundo por golpe (6 segundos de reutilización)
					El [c/9AFE35:Estado de Wyrm del Viento] termina cuando se agota toda la [c/78F178:Energía de Transformación Dracónica]
					Cambiar de esta arma terminará inmediatamente el [c/9AFE35:Estado de Wyrm del Viento] y reiniciará la [c/78F178:Energía de Transformación Dracónica]
					El daño escala con el progreso del mundo
					'''
			}

			Wavedancer: {
				DisplayName: Danzante de Olas
				Tooltip:
					'''
					Invoca una hoja bendecida por el océano para asaltar enemigos
					El arma requiere 3 espacios de súbdito disponibles para invocarse, pero no los consume
					Mientras se sostiene esta arma, mantener presionado clic izquierdo mientras el arma está invocada permite control manual del arma con tu cursor
					Además, el daño se reduce o multiplica hasta 1.500% según la velocidad, y esta arma obtiene 2% de probabilidad crítica por cada espacio de invocación, solo para ella
					Los golpes críticos con esta arma infligen [c/4A91FF:Resaca] durante 2 segundos y otorgan Celeridad durante 4 segundos
					[c/4A91FF:Resaca] aumenta el daño del siguiente ataque de súbdito en 30% (esta arma puede detonar este efecto)
					Presiona la Tecla de Acción del Arma mientras la controlas manualmente para cortar en un área alrededor del arma, infligiendo [c/4A91FF:Resaca] durante 2 segundos (4 segundos de reutilización)
					'Doblega la rapidez y el poder de una tormenta oceánica para la protección de su dueño'
					'''
			}

