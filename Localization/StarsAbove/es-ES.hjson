			TarotCard: {
				DisplayName: Carta del Tarot
				Tooltip:
					'''
					[c/D294FF:Memoria de Arma]
					Al Grabarse en un arma, obtén los siguientes efectos:
					Obtén 8% de daño incrementado al cumplir una condición específica (la condición se asigna aleatoriamente por arma)
					Este bono se duplica a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado]
					'''

				TooltipAttached: {
					Fool: El Loco: obtén 8% de daño incrementado (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Magician: El Mago: obtén 8% de daño incrementado con el Maná al máximo (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Priestess: La Sacerdotisa: obtén 8% de daño incrementado en un Pueblo (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Empress: La Emperatriz: obtén 8% de daño incrementado mientras seas femenino (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Emperor: El Emperador: obtén 8% de daño incrementado mientras seas masculino (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Heirophant: El Hierofante: obtén 8% de daño incrementado con la Vida al máximo (aumentado a 16% bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Lovers: Los Enamorados: obtén 8% de daño incrementado en multijugador (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Chariot: El Carro: obtén 8% de daño incrementado al moverte rápido horizontalmente (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Justice: La Justicia: obtén 8% de daño incrementado durante una invasión (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Hermit: El Ermitaño: obtén 8% de daño incrementado en un jugador (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Fortune: La Rueda de la Fortuna: obtén 8% de daño incrementado aleatoriamente (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Strength: La Fuerza: obtén 8% de daño incrementado si esta arma tiene retroceso fuerte o mayor (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					HangedMan: El Colgado: obtén 8% de daño incrementado por debajo de 75% de Vida (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Death: La Muerte: obtén 16% de daño incrementado (reducido a 8% por debajo de la mitad de la vida)
					Temperance: La Templanza: obtén 8% de daño incrementado mientras estés Bien Alimentado (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Devil: El Diablo: obtén 8% de daño incrementado en el Inframundo (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Tower: La Torre: obtén 8% de daño incrementado en la Mazmorra (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Star: La Estrella: obtén 8% de daño incrementado en el espacio (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Moon: La Luna: obtén 8% de daño incrementado durante la noche (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
					Sun: El Sol: obtén 8% de daño incrementado durante el día (aumentado a 16% por debajo de la mitad de la vida o bajo el efecto de [c/FF7DEF:Destino Adivinado])
				}
			}

