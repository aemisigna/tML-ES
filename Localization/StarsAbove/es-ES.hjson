			AegisOfHopesLegacy: {
				Tooltip:
					'''
					Una de las vestimentas legendarias de leyendas pasadas
					Equípala en tu Viajera Espacial para obtener lo siguiente:
					[c/FFCA5A:Viaje Resplandeciente]
					Atacar y recibir daño otorga cargas de [c/FFCA5A:Brillo de la Esperanza] (máximo 100 cargas)
					Cada 10 cargas de [c/FFCA5A:Brillo de la Esperanza] aumentan el daño de la Nova Estelar en 2%
					Golpear a un enemigo con la Nova Estelar consume todas las cargas de [c/FFCA5A:Brillo de la Esperanza]
					[c/87E3DE:Paso de las Armas]
					Los enemigos tienen mayor probabilidad de atacarte a ti
					Recibir daño otorga Piel de Hierro, Regeneración y Resistencia durante 8 segundos
					Además, obtén el buff Aria Naciente durante 3 segundos, aumentando la defensa en 20 y potenciando la regeneración de vida
					[c/F94135:Prueba de un Héroe]
					Los ataques causarán 40% menos daño a enemigos que no te tengan como objetivo
					Además, los ataques causan 70% menos daño durante los fotogramas de inmunidad
					[c/8BB9F8:El Eco de la Esperanza]
					Las Habilidades de Nivel 3 de la Matriz Estelar obtienen efectos adicionales
					Más Allá del Infinito: Todas las armas por debajo del nivel Cian se tratan como si tuvieran una rareza menos al calcular el bono de daño
					Llave de la Cronología: Elimina el Mareo de Poción y obtén Alcance del Corazón durante 30 segundos al activarse
					Entre la Frontera: Obtén 40 de defensa durante el Flujo, y pierde 20 de defensa durante el Reflujo
					Radiancia Desatada: La Energía de Nova Estelar no puede bajar de 10
					'Mantente en pie- amigo mío / Que toda la oscuridad profunda en tu interior / Vuelva a encontrar la Luz'
					'''
				DisplayName: Égida del Legado de la Esperanza
			}

			RenegadeTechnomancerSynthweave: {
				Tooltip: {
					$parentVal: ""
					Asphodene:
						'''
						Una de las vestimentas legendarias de leyendas pasadas
						Equípala en tu Viajera Espacial para obtener lo siguiente:
						[c/FFA700:Alineación de Arquetipo]
						Este atuendo tiene habilidades variables según el Aspecto elegido
						[c/FF3B91:El Camino Rebelde]
						Las Novas Estelares pueden lanzarse con cualquier carga en vez de con el 100%
						Este efecto solo puede activarse una vez antes de que la Nova Estelar deba cargarse de nuevo naturalmente, o tras 8 minutos
						[c/9DFCFF:Totalmente Cromado]
						5% del bono de daño de los Prismas Estelares equipados también se te aplica a ti
						[c/B195AC:Sobrecargado]
						Recibir daño carga la Nova Estelar en 10%, pero también inflige cargas de [c/E57CD3:Sobretensión de Circuito], hasta 4
						Con 4 cargas de [c/E57CD3:Sobretensión de Circuito], el siguiente golpe infligirá [c/AA2192:Ciberpsicosis], reduciendo la defensa en 40%
						Además, la efectividad de las pociones de vida se reduce en 90%
						[c/AA2192:Ciberpsicosis] solo puede eliminarse activando la Nova Estelar
						'Nunca te desvanezcas'
						'''
					Eridani:
						'''
						Una de las vestimentas legendarias de leyendas pasadas
						Equípala en tu Viajera Espacial para obtener lo siguiente:
						[c/FFA700:Alineación de Arquetipo]
						Este atuendo tiene habilidades variables según el Aspecto elegido
						[c/8EEF69:Corredora de Filo]
						Tu Nova Estelar ya no se carga con el tiempo; en su lugar, causar y recibir daño otorga Energía de Nova Estelar (breve reutilización por carga)
						No se puede obtener energía de Nova fuera de combate
						[c/BB83FF:Motor de Hadrones]
						Tras activar la Nova Estelar, obtén [c/F3EF67:Impulso de Quarks] durante 5 segundos
						[c/F3EF67:Impulso de Quarks] anula el costo de munición y el Mareo de Maná mientras esté activo
						La duración de [c/F3EF67:Impulso de Quarks] aumenta según el 5% del Costo de Energía de la Nova Estelar
						[c/83A3DB:Ciclo de Carga]
						La regeneración de vida se desactiva en combate
						[c/F3EF67:Impulso de Quarks] anula este efecto mientras esté activo y otorga regeneración de vida adicional
						'Nunca te desvanezcas'
						'''
				}

				DisplayName: Tejido Sintético de la Tecnomante Renegada
			}

			CelestialPrincessGenesis: {
				Tooltip:
					'''
					Una de las vestimentas legendarias de leyendas pasadas
					Equípala en tu Viajera Espacial para obtener lo siguiente:
					[c/FF30AD:Cosmos del Comienzo]
					La Nova Estelar queda fija en Cuásar Génesis de Edin
					Atacar enemigos durante Impulsor Astarte provoca un ataque de seguimiento, causando 1/3 del daño original de nuevo
					[c/30D6FF:Origen del Espíritu Galáctico]
					Derrotar enemigos renueva la duración de Impulsor Astarte
					Recibir daño carga el Medidor de Nova Estelar en 3
					[c/3068FF:Estrella Luminante]
					El daño recibido se reduce en 10%
					[c/A55396:Blasfemia Primigenia]
					Causa 70% menos daño cuando Impulsor Astarte no está activo
