				TooltipAttached: {
					//0
					Destruction: Te guía el Sendero de la Destrucción: causa 12% más de daño crítico
					//1
					Hunt: Te guía el Sendero de la Cacería: causa 12% más de daño a los jefes
					//2
					Erudition: Te guía el Sendero de la Erudición: causa 12% más de daño a enemigos que no sean jefes
					//3
					Harmony: Te guía el Sendero de la Armonía: causa 0.5% más de daño por cada buff activo
					//4
					Nihility: Te guía el Sendero de la Nihilidad: causa 12% más de daño a enemigos con efectos negativos
					//5
					Preservation: Te guía el Sendero de la Preservación: 1% del daño del arma se suma como defensa (tope de 30 de defensa)
					//6
					Abundance: Te guía el Sendero de la Abundancia: cura 2 de Vida al derrotar enemigos
					//7
					Elation: Te guía el Sendero del Júbilo: causa aleatoriamente hasta 12% de daño adicional
					//8
					Propagation: Te guía el Sendero de la Propagación: causa 2% más de daño por cada súbdito activo
					//9
					Rememberance: Te guía el Sendero del Recuerdo: causa 12% más de daño a enemigos aturdidos
					//10
					Trailblaze: Te guía el Sendero de la Exploración: otros jugadores causan 12% más de daño a los enemigos que atacas
				}
			}

