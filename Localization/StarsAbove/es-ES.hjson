			StarsAboveConfigClient: {
				DisplayName: Config. de Stars Above (lado del cliente)

				DisableStellarNovaCutIns: {
					Label: Desactivar irrupciones de Nova Estelar
					Tooltip: Desactiva el retrato de tu Viajera Espacial al activar tu Nova Estelar.
				}

				DisableStarfarerVoices: {
					Label: Desactivar voces de la Viajera Espacial
					Tooltip: Desactiva las líneas de voz de la Viajera Espacial. (AV: Kiera Rhodes)
				}

				DisableStellarNovaDialogue: {
					Label: Desactivar cuadro de diálogo de Nova Estelar
					Tooltip: Desactiva el cuadro de diálogo durante la irrupción de la Nova Estelar.
				}

				DisableStarfarerCommentary: {
					Label: Desactivar comentarios de la Viajera Espacial
					Tooltip: Desactiva por completo las intervenciones de la Viajera Espacial.
				}

				DisableStarfarerCommentaryBuffs: {
					Label: Desactivar comentarios de la Viajera Espacial sobre mejoras/efectos negativos
					Tooltip: Ya no recibirás intervenciones de la Viajera Espacial al recibir mejoras o efectos negativos.
				}

				DisableStarfarerCommentaryCombat: {
					Label: Desactivar comentarios de la Viajera Espacial en eventos de combate
					Tooltip: Ya no recibirás intervenciones de la Viajera Espacial por derrotar enemigos, etc.
				}

				StarfarerPromptCooldown: {
					Label: Tiempo de reutilización de intervenciones de la Viajera Espacial
					Tooltip: El tiempo entre intervenciones de la Viajera Espacial, en minutos. Si el disparador de una intervención ocurre durante este tiempo, se ignora. No aplica a intervenciones únicas (jefes, etc.)
				}

				CommentaryTimer: {
					Label: Duración de intervenciones de la Viajera Espacial
					Tooltip: Cambia cuánto tiempo permanecen en pantalla las intervenciones de la Viajera Espacial.
				}

				DialogueScrollValue: {
					Label: Velocidad de texto de la Viajera Espacial
					Tooltip: El tiempo, en fotogramas, para que aparezca cada letra del diálogo. Por debajo de 2, se recomienda desactivar los efectos de sonido del diálogo.
				}

				DialogueAudio: {
					Label: Efecto de sonido de texto de la Viajera Espacial
					Tooltip: El efecto de sonido que suena cuando aparecen letras durante el diálogo de la Viajera Espacial. La opción 5 desactiva el efecto de sonido.
				}

				InstantText: {
					Label: Texto instantáneo
					Tooltip: Ignora la opción de Velocidad de texto de la Viajera Espacial; todo el texto aparecerá al instante.
				}

				EnableMusicOverride: {
					Label: La música de las armas anula el resto de la música
					Tooltip: Cuando está activado, las armas que cambian la música del juego tendrán prioridad sobre casi todo lo demás.
				}

				DisableWeaponCutIns: {
					Label: Desactivar efecto de irrupción de armas
					Tooltip: Desactiva las animaciones a pantalla completa que se reproducen al usar ciertas armas.
				}

				PromptLoc: {
					Label: Posición de las intervenciones de la Viajera Espacial
					Tooltip: ""
				}

				NovaGaugeLoc: {
					Label: Posición del medidor de Nova
					Tooltip: ""
				}

				MovingDialogueAmount: {
					Label: Movimiento del menú de Viajera Espacial
					Tooltip: Ajusta cuánto se mueven los menús de la Viajera Espacial mientras te mueves.
				}

				DisableBlur: {
					Label: Desactivar desenfoque
					Tooltip: Desactiva el efecto de desenfoque de menús/cinemáticas.
				}

				DisableScreenShake: {
					Label: Desactivar vibración de pantalla
					Tooltip: Desactiva los efectos de vibración de pantalla de todas las fuentes.
				}

				StarfarerVoiceCooldown: {
					Label: Tiempo de reutilización de voz de la Viajera Espacial
					Tooltip: El retraso en segundos entre diálogos con voz. Ten en cuenta que valores bajos pueden causar que los diálogos se superpongan, y el diálogo con voz solo tiene una probabilidad de reproducirse.
				}

				StarfarerDialogueVoiceVolume: {
					Label: Volumen de voz de diálogo de la Viajera Espacial
					Tooltip: ""
				}

				DisableShockwaveEffect: {
					Label: Desactivar efecto de onda expansiva
					Tooltip: ""
				}

				ForceNeonVeilShader: {
					Label: Forzar shader del Velo de Neón
					Tooltip: ""
				}

				StellarNovaCutsceneOption: {
					Label: Cinemáticas de Nova Estelar
					Tooltip: Determina con qué frecuencia se muestran las cinemáticas de las Novas Estelares.
				}

				bossVoiceVolume: {
					Label: Volumen de voz de jefes
					Tooltip: ""
				}

				DisableBossVoiceLines: {
					Label: Desactivar líneas de voz de jefes
					Tooltip: Desactiva las líneas de voz heredadas de los jefes.
				}
			}

			StarsAboveServersideConfig: {
				DisplayName: Config de Stars Above (lado del servidor)

				DisableTypePenalty: {
					Label: Desactivar penalización de daño por modificar el Daño Aspecto
					Tooltip: Elimina la penalización de daño del 10% cuando la modificación de Daño Aspecto está activada. Ten en cuenta que algunos efectos que también eliminan esta penalización quedarán sobrecargados como resultado.
				}

				DisableBossAggro: {
					Label: Desactivar marcador de aggro de jefes
					Tooltip: Desactiva el marcador que aparece sobre la cabeza de un jugador cuando un jefe lo tiene como objetivo. Esta es una función en desarrollo.
				}

				DisableCalamityWeaponBuffs: {
					Label: Desactivar modificadores de daño global para compatibilidad con mods
					Tooltip: Desactiva el aumento de daño de las Armas Aspecto cuando Calamity Mod está activado.
				}

				DisableWeaponRestrictions: {
					Label: Desactivar restricciones de Armas Aspecto
					Tooltip: Desactiva la restricción que impide usar armas Astrales y Umbrales con el Aspecto opuesto.
				}

				DisableBossEnemySpawnMod: {
					Label: Desactivar modificador de aparición de enemigos en jefes
					Tooltip: Desactiva el buff otorgado a todos los jugadores que evita la aparición de enemigos durante los jefes. Otros mods a veces incluyen versiones duplicadas de esta función.
				}

				DisableManaSicknessChange: {
					Label: Desactivar cambio del Mareo de Maná
					Tooltip: Desactiva el cambio del Mareo de Maná que aplica la reducción de daño a todo el daño y no solo al Mágico. Ten en cuenta que esto hará que las armas no mágicas que consumen Maná queden sobrecargadas.
				}

				ColorblindBoss: {
					Label: Activar pelea de Pentesilea apta para daltónicos
					Tooltip: Reemplaza ciertas mecánicas basadas en color en la pelea contra Pentesilea.
				}

				DisableCompatibilityMode: {
					Label: Viajes Cósmicos alternativos para multijugador
					Tooltip: Cuando está activado, intentar un Viaje Cósmico generará objetos de botín con un temporizador. Cuando está desactivado, permite que los jugadores en multijugador realicen Viajes Cósmicos. Se sabe que esto causa problemas; úsalo bajo tu propio riesgo o junto con el parche no oficial.
				}

				CombatTimer: {
					Label: Temporizador de combate
					Tooltip: Al golpear a un enemigo o ser golpeado, este es el tiempo en segundos que permaneces "en combate".
				}

				MultiplayerFallbackSubworlds: {
					Label: Viajes Cósmicos alternativos para multijugador
					Tooltip: Cuando está activado, intentar un Viaje Cósmico generará objetos de botín con un temporizador. Cuando está desactivado, permite que los jugadores en multijugador realicen Viajes Cósmicos. Úsalo bajo tu propio riesgo y/o junto con el parche no oficial.
				}
			}

