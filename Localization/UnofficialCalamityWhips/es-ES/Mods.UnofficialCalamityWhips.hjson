Configs: {
	UnofficialCalamityWhipsConfig: {
		DisplayName: Configuración de Unofficial Calamity Whips
		Headers.Config: Encabezado de Configuración

		WhipDamageModifier: {
			Label: Modificador de Daño de Látigo
			Tooltip: Modifica el daño de todos los látigos de este mod según el número elegido. Usa esto para reforzar o debilitar el mod como prefieras
		}

		AddArmorStats: {
			Label: Añadir Estadísticas de Látigo a las Armaduras de Calamity
			Tooltip: Añade estadísticas adicionales de látigo a algunas armaduras de Calamity mientras está activado, para hacer los látigos más viables
		}

		AllowTagStacking: {
			Label: Habilitar Acumulación de Efectos Negativos de Marca
			Tooltip: Permite que los látigos de este mod acumulen sus efectos de marca. Si se desactiva, todos los efectos de marca previos se eliminarán al aplicar uno nuevo
		}

		CatalystDisclaimer: {
			Label: Aviso de Catalyst
			Tooltip: Desactiva esto para eliminar el aviso que promociona el mod Catalyst
		}
	}
}

