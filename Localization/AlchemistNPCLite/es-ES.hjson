					Tooltip: El precio predeterminado es de 10 por 1000 monedas de plata
					Label: Precio de la poción de recuperación
				}

				StarPrice: {
					Tooltip: El precio predeterminado es de 10 por 1000 monedas de plata
					Label: Precio de la Estrella caída
				}

				PotsPriceMulti: {
					Tooltip: Multiplica el precio de las pociones por X. El valor predeterminado es 1.
					Label: Multiplicador del precio de las pociones
				}

				CatchNPC: {
					Tooltip: Si se activa esta opción, los PNJ de la ciudad del mod se pueden atrapar. El valor predeterminado es Verdadero.
					Label: Opción para activar o desactivar los PNJ del mod «Atrapable»
				}

				ModItems: {
					Tooltip: Si se activa, permite que existan los objetos y pociones personalizados de los mods (poción de desenfoque, World Warper, etc.). El valor predeterminado es Verdadero. Requiere que los mods se actualicen para que la información se refleje.
					Label: Botón para activar o desactivar los elementos personalizados del mod
				}

				OperatorCustomItems: {
					Tooltip:
						'''
						Añade cualquier objeto vanilla o modificado (materiales, bolsas de jefes, etc.) a la pestaña "Objetos personalizados" de la tienda de la Operadora.
						Define el objeto, el precio (en cobre) y cuándo se desbloquea.
						Los objetos de mods que no estén cargados se ignoran. Requiere recargar los mods.
						'''
					Label: Objetos personalizados de la tienda de la Operadora
				}

				TinkererCustomItems: {
					Tooltip:
						'''
						Añade cualquier objeto vanilla o modificado a la pestaña "Objetos personalizados" de la tienda del Chapucero.
						Define el objeto, el precio (en cobre) y cuándo se desbloquea.
						Los objetos de mods que no estén cargados se ignoran. Requiere recargar los mods.
						'''
					Label: Objetos personalizados de la tienda del Chapucero
				}

				RevPrices: {
					Tooltip: Verdadero para aumentar los precios de las pociones. El valor predeterminado es Verdadero.
					Label: Escalado de precios en el modo Revengeance
				}

				DisabledLocatorNpcs: {
					Tooltip: Las flechas no apuntarán a estos PNJs
					Label: PNJ desactivados para el localizador del analizador de formas de vida
				}

				LocatorRange: {
					Tooltip: Distancia máxima que seguirá el puntero. 4000 por defecto
					Label: Rango de detección del analizador de formas de vida
				}

				LifeformAnalyzer: {
					Tooltip: Activa o desactiva el puntero láser del Analizador de formas de vida (parpadea cada segundo). El valor predeterminado es Verdadero.
					Label: Puntero láser del Analizador de Formas de Vida
				}

				TinkererSpawn: {
