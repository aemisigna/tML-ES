					Teletranspórtate a la playa
					El lado depende de donde se utilice el cursor
					'''
			}

			BewitchingPotion: {
				DisplayName: Poción encantadora
				Tooltip:
					'''
					Otorga el Beneficio embrujado (Incrementa el número de invocaciones máximas)
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			BlurringPotion: {
				DisplayName: Poción de difuminación
				Tooltip:
					'''
					Otorga el Beneficio difuminación (Activa el esquive de las sombras por 10 segundos después 30 segundos de recarga)
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			BuilderCombination: {
				DisplayName: Combinación de Constructor
				Tooltip: Otorga las mejoras, Para la construcción (Calma, Constructor, Minera)
			}

			CalamityCombination: {
				DisplayName: Combinación de Calamity
				Tooltip: Otorga las mejoras de Calamity mod (Fotosíntesis, Purple Haze, Vuelo y Rebote)
			}

			DiscordPotion: {
				DisplayName: Poción de la Discordia
				Tooltip:
					'''
					Te puedes teletransportar a la posición del cursor usando hotkey 1
					Distorsiona al jugador por 1 segundo después del teletransporte
					Inflige mucho daño si tienes el estado del caos
					El tiempo del estado de caos se incrementa a 10 segundos
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			Dopamine: {
				DisplayName: Dopamina
				Tooltip:
					'''
					Te hace feliz
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			DungeonTeleportationPotion: {
				DisplayName: Poción de teletransporte a la mazmorra
				Tooltip: Te teletransporta a la entrada de la mazmorra
			}

			ExcavationPotion: {
				DisplayName: Poción de excavación
				Tooltip:
					'''
					Expande tu área de minería en un solo bloque de 3x3.
					Clic derecho en la mejora para cambiar el área de minado de 1x1 y 3x3.
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			ExplorerCombination: {
				DisplayName: Combinación de Exploración
				Tooltip: Otorga las mejoras necesarias para explorar (Sentido del peligro, Cazador, Espeleólogo, Visión nocturna, Brillo, Minera, Branquias, Aletas, Flotación)
			}

			FishingCombination: {
				DisplayName: Combinación de Pesca
				Tooltip:
					'''
					Otorga la mejora de Caja, Sonar, Pesca, Regeneración, Espinas, Piel de hierro, Calma y Infierno
					Haz clic con el botón derecho para activar o desactivar el efecto relajante.
					'''
			}

			FortitudePotion: {
				DisplayName: Poción de Fortaleza
				Tooltip:
					'''
					Otorga inmunidad al retroceso
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			GreaterDangersensePotion: {
				DisplayName: Poción del sentido del peligro mejorado
				Tooltip:
					'''
					Otorga una mejora del sentido del peligro (Los proyectiles enemigos brillan)
					Algunos proyectiles enemigos pueden volverse invisibles (por ejemplo, los del Señor de la Luna). Úsalo con cuidado
					Este efecto es global para los jugadores
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			InvincibilityPotion: {
				DisplayName: Poción de invencibilidad
				Tooltip:
					'''
					Incrementa la invencibilidad después de recibir daño
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			JungleTeleporterPotion: {
				DisplayName: Poción de teletransporte a la jungla
				Tooltip:
					'''
					Teletranspórtate directamente a la jungla
					Clic izquierdo para teletransportarte a la jungla
					Clic derecho para teletransportarte al árbol de caoba viviente
					'''
			}

			MageCombination: {
				DisplayName: Combinación de Mago
				Tooltip: Mejoras de habilidades, que son necesarias para los magos (Poder mágico, Regeneración de maná, Clarividencia, Ira, Furia)
			}

			AlchemistCharmTier1: {
				DisplayName: Amuleto de Alquimista (Nivel 1)
				Tooltip:
					'''
					Mientras tengas esto en tu inventario, tienes una probabilidad baja de no consumir las pociones
					La Alquimista, el Destilador y el Joven Destilador ofrecen un descuento del 10%
					La duración de los efectos positivos es un 10% mayor
					'''
			}

			AlchemistCharmTier2: {
				DisplayName: Amuleto de Alquimista (Nivel 2)
				Tooltip:
					'''
					Mientras tengas esto en tu inventario, tienes una probabilidad moderada de no consumir las pociones
					Permite usar pociones de la Hucha mediante la tecla de potenciador rápido
					La Alquimista, el Destilador y el Joven Destilador ofrecen un descuento del 25%
					La duración de los beneficios es un 25% mayor
					'''
			}

			AlchemistCharmTier3: {
				DisplayName: Amuleto de Alquimista, (Nivel 3)
				Tooltip:
					'''
					Mientras tengas esto en tu inventario, tienes una probabilidad alta de no consumir las pociones
					Permite usar pociones de la Hucha mediante la tecla de potenciador rápido
					La Alquimista, el Destilador y el Joven Destilador ofrecen un descuento del 35%
					La duración de los beneficios es un 35% mayor
					'''
			}

			AlchemistCharmTier4: {
				DisplayName: Amuleto de Alquimista, (Nivel 4)
				Tooltip:
					'''
					Mientras tengas esto en tu inventario, tienes una probabilidad muy alta de no consumir las pociones
					Permite usar pociones de la Hucha mediante la tecla de potenciador rápido
					La Alquimista, el Destilador y el Joven Destilador ofrecen un descuento del 50%
					Hace que las pociones no sean consumibles si se derrota a Calamitas Supremo
					La duración de los beneficios es un 50% mayor
					'''
			}

			GlobalTeleporter: {
				DisplayName: Deformador de mundos
				Tooltip:
					'''
					Te teletransporta a cualquier punto del mapa 
					Usa clic derecho en el mapa para teletransportarte 
					No funciona si un jefe está vivo 
					Se rompe después de usarlo 
					"O, la justicia azure, el amor carmesí,
					En nombre de aquel destino sepultado,
					Haré un juramento a la luz,
					que les mostraremos a aquellos que
					¡Frente a nosotros - el poder del amor!"
					'''
			}

			GlobalTeleporterUp: {
				DisplayName: Deformador de mundos modificado
				Tooltip:
					'''
					Te teletransporta a cualquier punto del mapa 
					Usa clic derecho en el mapa para teletransportarte 
					No funciona si un jefe está vivo 
					No se rompe después de usarlo 
					"O, la justicia azure, el amor carmesí,
					En nombre de aquel destino sepultado,
					Haré un juramento a la luz,
					que les mostraremos a aquellos que
					¡Frente a nosotros - el poder del amor!"
					'''
			}

			WorldControlUnit: {
				DisplayName: Unidad de control de simulación
				Tooltip:
					'''
					Producto exclusivo, diseñado por Angela
					Clic izquierdo para cambiar entre el día y la noche 
					Clic derecho para activar o desactivar la lluvia (Tormenta de arena en el desierto)
					'''
			}

			LuckCharm: {
				DisplayName: Amuleto de la suerte
				Tooltip:
					'''
					Mientras tengas este amuleto en tu inventario, tienes una mejor probabilidad de tener mejores reforjamientos
					Esto no afecta a los accesorios 
					'''
			}

			LuckCharmT2: {
				DisplayName: Amuleto de la suerte absoluta
				Tooltip:
					'''
					Mientras tengas este amuleto en tu inventario, tienes una mejor probabilidad de tener mejores reforjamientos
					También afecta a los accesorios (Amenazante → Afortunado → Protector)
					'''
			}

			MorePotionsCombination: {
				DisplayName: Más combinaciones de pociones
				Tooltip:
					'''
					Otorga la mayoría de los beneficios de Más pociones *pociones
					Sequías, Regeneración mejorada, Valentía, Vínculo espiritual, Piel de diamante, Crepúsculo, Amanecer, Manos ágiles, Velocidad
					'''
			}

			NatureBlessingPotion: {
				DisplayName: Poción de bendición de la naturaleza
				Tooltip: Otorga la bendición de la dríada
			}

			NinjaPotion: {
				DisplayName: Poción de ninja
				Tooltip:
					'''
					Aumenta un 5% el daño y la probabilidad de ataque crítico
					Tienes una probabilidad de esquivar los ataques y puedes escalar las paredes
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			InformatingNote: {
				DisplayName: Nota informativa
				Tooltip:
					'''
					Aún no hay bolsas de tesoros disponibles.
					Vence a Esqueletrón para desbloquear la primera tanda de bolsas.
					'''
			}

			OceanTeleporterPotion: {
				DisplayName: Poción del teletransportador oceánico
				Tooltip:
					'''
					Te teletransporta al océano (cerca del coral más a la izquierda o más a la derecha)
					El lado depende del botón del mouse que se utilice
					No te teletransportará a ningún lado si no hay corales.
					'''
			}

			PerfectDiscordPotion: {
				DisplayName: Poción de la Discordia Perfecta
				Tooltip:
					'''
					[c/00FF00:Poción única del explorador]
					Permite teletransportarse a la posición del cursor mediante una tecla de acceso rápido
					Se comporta exactamente igual que la Vara de la Discordia
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			HMCraftPound: {
				DisplayName: Excelente libra de artesanía
				Tooltip:
					'''
					Ahora puedes hacer las mejores cosas
					Se puede colocar como una estación de trabajo
					'''
			}

			MateriaTransmutator: {
				DisplayName: Transmutador de materia
				Tooltip:
					'''
					Misma funcionalidad que la mayoría de las estaciones de crafteo en una sola.
					Todas las estaciones de crafteo incluidas :)
					También funciona como fuente de agua, miel y lava.
					'''
			}

			PreHMPenny: {
				DisplayName: Moneda de manualidades sencillas
				Tooltip:
					'''
					Te hace parecer un maestro de la carpintería.
					Se puede colocar como una estación de trabajo
					'''
			}

			SpecCraftPoint: {
				DisplayName: Punto de fabricación especial
				Tooltip:
					'''
					Has demostrado que puedes hacer cualquier cosa con cualquier material.
					Se puede colocar como una estación de trabajo
					'''
			}

			RangerCombination: {
				DisplayName: Combinación de Rango
				Tooltip: Mejoras de habilidades, que son necesarias para la clase de Rango (Tiro con arco, Reserva de munición, Ira, Furia)
			}

			SpiritCombination: {
				DisplayName: Combinación de Espíritus
				Tooltip: Otorga la mayoría de los beneficios de las pociones de modificación de espíritu (Runescribe, Soulguard, Spirit, Starburn, Steadfast y Toxin)
			}

			SummonerCombination: {
				DisplayName: Combinación de Invocador
				Tooltip: Otorga mejoras, que son necesarias para los Invocadores (Invocación, Embrujado, Ira)
			}

			AlchemistHorcrux: {
				DisplayName: Horrocrux de la Alquimista
				Tooltip: En su interior se encuentra un fragmento del alma de la Alquimista.
			}

			APMC: {
				DisplayName: IA y Chip de Memoria
				Tooltip: Es la copia de seguridad de Ángela.
			}

			ArchitectHorcrux: {
				DisplayName: Horrocrux del Arquitecto
				Tooltip: En su interior se encuentra un fragmento del alma del arquitecto.
			}

			BrewerHorcrux: {
				DisplayName: Horrocrux del Destilador
				Tooltip: En su interior se encuentra un fragmento del alma de El Destilador.
			}

			HorrifyingSkull: {
				DisplayName: Cráneo espeluznante
				Tooltip:
					'''
					Convoca al enemigo más poderoso
					Usar con extremo cuidado 
					'''
			}

			JewelerHorcrux: {
				DisplayName: Horrocrux del Joyero
				Tooltip: En su interior se encuentra un fragmento del alma del joyero.
			}

			MusicianHorcrux: {
				DisplayName: Horrocrux del Músico
				Tooltip: En su interior se encuentra un fragmento del alma del músico.
			}

			TinkererHorcrux: {
				DisplayName: Horrocrux del Chapucero
				Tooltip: En su interior se encuentra un fragmento del alma del chapucero.
			}

			SunshinePotion: {
				DisplayName: Poción de brillo solar
				Tooltip:
					'''
					Incrementa el radio de luz generado 
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			TankCombination: {
				DisplayName: Combinación de Tanque (con Mods)
				Tooltip: Mejoras de habilidades, que son necesarias para los tanques (Rapidez, Resistencia, Fuerza vital, Piel de hierro, Piel de obsidiana, Espinas, Regeneración, Piel de titán, Invencibilidad)
			}

			TempleTeleportationPotion: {
				DisplayName: Poción de teletransporte al templo
				Tooltip: Teletranspórtate al templo de la jungla
			}

			ThoriumCombination: {
				DisplayName: Combinación de Thorium
				Tooltip:
					'''
					Otorga la mayoría de los beneficios de las pociones del mod Thorium
					Asesino, Sangre, Frenesí, Creatividad, Melodía pegajosa, Alcance inspirador, Resplandeciente, Bendito, Hidratación
					'''
			}

			TitanSkinPotion: {
				DisplayName: Poción de Piel de Titán
				Tooltip:
					'''
					Otorga inmunidad a algunos efectos negativos (¡En llamas!, Quemadura por hielo, Llama maldita, Congelado, Helado, Ícor)
					La inmunidad a Llama maldita e Ícor solo funcionaría después de derrotar a los Gemelos
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			TrapsPotion: {
				DisplayName: Poción del cazador
				Tooltip:
					'''
					Activa todas las trampas
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			UltimaCake: {
				DisplayName: UltraPastel
				Tooltip:
					'''
					Permite aplicar efectos especiales en casi todas las estaciones al mismo tiempo
					Esto incluye fogatas, lámparas, la estatua de Bast, la estación de afilado, la caja de municiones, la bola de cristal, una rebanada de pastel y la mesa encantada.
					Por alguna magia inimaginable, nunca se consumirá
					POCIÓN NO OFICIAL DE CALAMITY
					'''
			}

			UnderworldTeleportationPotion: {
				DisplayName: Poción de teletransporte al inframundo
				Tooltip:
					'''
					Te teletransporta al Inframundo, a la Torre de Obsidiana más a la izquierda o más a la derecha
					El lado depende del botón del mouse que se utilice
					Sería útil tomar la poción de «Piel de Obsidiana» antes de beber eso
					'''
			}

			UniversalCombination: {
				DisplayName: Combinación Universal
				Tooltip: Ofrece los efectos combinados de las combinaciones de Tanque, Rango, Mago e Invocador en una sola mejora.
			}

			VanTankCombination: {
				DisplayName: Combinación de Tanque (Vanilla)
				Tooltip: Mejoras de habilidades, que son necesarias para los tanques (Rapidez, Resistencia, Fuerza vital, Piel de hierro, Piel de obsidiana, Espinas, Regeneración)
			}

			MateriaTransmutatorMK2: {
				DisplayName: Transmutador de Materia MK 2
				Tooltip: Transmutador de Materia MK 2
			}

			SingleUseCellphone: {
				Tooltip: Se busca comerciante ambulante. Solo se puede utilizar durante el día.
				DisplayName: Celular de un solo uso
			}
		}

