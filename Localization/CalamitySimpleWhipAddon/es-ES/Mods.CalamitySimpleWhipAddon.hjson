	MandibleLash: {
		DisplayName: Latigazo de Mandíbula
		Tooltip:
			'''
			1 de daño de conexión por invocación
			Todos los enemigos golpeados por este látigo
			hacen que el siguiente ataque de un súbdito lance una bola de arena
			que cae por gravedad e inflige 40% de daño.
			Explota al impactar con un bloque, dañando a los enemigos cercanos.
			'''
	}

	DarkMandibleLash: {
		DisplayName: Latigazo de Mandíbula Oscura
		Tooltip:
			'''
			2 de daño de conexión por invocación
			Todos los enemigos golpeados por este látigo
			hacen que el siguiente ataque de un súbdito lance una bola de arena
