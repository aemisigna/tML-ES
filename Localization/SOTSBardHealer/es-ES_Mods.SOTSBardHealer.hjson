	Precarious.DisplayName: "{$Mods.SOTS.Prefixes.Precarious.DisplayName}"
}

DamageClasses: {
	VoidRadiant.DisplayName: vacío + {$Mods.ThoriumMod.DamageClasses.HealerDamage.DisplayName}
	VoidSymphonic.DisplayName: vacío + {$Mods.ThoriumMod.DamageClasses.BardDamage.DisplayName}
	VoidThrowing.DisplayName: vacío + daño de lanzamiento
}

Configs: {
	BalanceConfig: {
		DisplayName: Ajustes de Balance

		thrower: {
			Label: Multiplicador de daño de armas arrojadizas
			Tooltip:
				'''
				Multiplicador de daño para armas arrojadizas
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}

		bard: {
			Label: Multiplicador de daño de armas de bardo
			Tooltip:
				'''
				Multiplicador de daño para armas de bardo
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}

		radiant: {
			Label: Multiplicador de daño de armas radiantes
			Tooltip:
				'''
				Multiplicador de daño para armas ofensivas de sanador
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}

		soulEssence: {
			Label: Multiplicador de esencia del alma
			Tooltip:
				'''
				Multiplicador de esencia del alma otorgada para armas ofensivas de sanador
				Limitado a 5
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}

		healing: {
			Label: Multiplicador de curación
			Tooltip:
				'''
				Multiplicador de curación para hechizos curativos
				Un valor de 0 significa que solo curará 1 de vida
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}

		voidCost: {
			Label: Costo de vacío
			Tooltip:
				'''
				Multiplicador de costo de vacío para las armas de vacío de este mod
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}
	}
}
