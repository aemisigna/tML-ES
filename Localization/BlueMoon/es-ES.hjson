			}
		}

		Buffs: {
			BountifulHarvestBuff: {
				DisplayName: Cosecha Abundante
				Description: La bendición de la Luna de la Cosecha llena tus bolsillos de riquezas. Los enemigos sueltan más monedas para ti.
			}

			FloralBlessingBuff: {
				DisplayName: Bendición Floral
				Description: Abraza la aura curativa de la Luna de Cereza. Tus heridas sanan rápidamente.
			}

			LunarEmpowermentBuff: {
				DisplayName: Empoderamiento Lunar
				Description: La luna otorga parte de su suerte a ti.
			}

			MintyFreshnessBuff: {
				DisplayName: Frescura Mentolada
				Description: La luz brillante de la Luna de Menta mejora tus habilidades mágicas. Infliges más daño y tienes menores tiempos de reutilización.
			}

			MoonsRingBuff: {
				DisplayName: Armonía Lunar
				Description: Estás bendecido por el poder de las cuatro lunas celestiales.
			}
		}

		Tiles: {
			HarvestMoonMusicBoxTile.MapEntry: Caja de Música de la Luna de la Cosecha
