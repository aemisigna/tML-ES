			}

			TopazRing: {
				DisplayName: Anillo de Topacio
				Tooltip: Otorga la Mejora Cosecha Abundante
			}

			AmethystRing: {
				DisplayName: Anillo de Amatista
				Tooltip: Otorga la Mejora Bendición Floral
			}

			EmeraldRing: {
				DisplayName: Anillo de Esmeralda
				Tooltip: Otorga la Mejora Frescura Mentolada
			}

			MoonsRing: {
				DisplayName: Anillo de las Lunas
