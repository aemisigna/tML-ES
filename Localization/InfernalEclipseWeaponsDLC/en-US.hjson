			PocketConcert: {
				DisplayName: I-PMA Mechamatone
				Tooltip:
					'''
					Releases music notes of varying colors
					Music notes will inflict a variety of debuffs based on the notes color
					Releases an additional music note to a cap of 5 for each unique empowerment you have at level 2 or higher
					[c/1FFBFF:'Once I was dispatched to find that 'order of warriors' that call themselves trackers. When I did,]
					[c/1FFBFF:one of the things they showed me an unique instrument shaped like a music note, but with a mouth.]
					[c/1FFBFF:While odd, I was able to turn it into a weapon that is stronger based on number of the users]
					[c/1FFBFF:other enhancements, however, it required me to make it much bigger than the original instrument.']
					'''
			}

			GammaKnife: {
				DisplayName: C-GSS Gamma Knife
				Tooltip:
					'''
					Ignores 15 points of defence
					<left> to swing the knife directionally, firing a high intensity slash of gamma radiation
