					'''
			}

			GrandAmplifier: {
				DisplayName: Grand Amplifier
				Tooltip:
					'''
					<left> to fire a small thunderbolt that inflicts [rbuff:Electrified]
					<right> to summon lightning above all nearby enemies with the [rbuff:Electrified] debuff
					This lightning will remove the [rbuff:Electrified] debuff but deal a burst of high damage
					'''
