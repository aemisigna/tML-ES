					'''
			}

			BrimstoneHarp: {
				DisplayName: Brimstone Harp
				Tooltip:
					'''
					Fires a fan of 3 piercing brimstone skulls
					Skulls on bounce split into 3 brimstone petals that fire at the closest enemy
					'''
			}

			NecroticChorus: {
				DisplayName: Necrotic Chorus
				Tooltip:
					'''
					Summons up to 10 wisps that home onto foes
					<right> for an alternate blood spit attack
					Blood spit inflicts [cbuff:CalamityMod/ArmorCrunch] and [cbuff:CalamityMod/BurningBlood]
					'''
			}

			DeusFlute: {
				DisplayName: Starwind Flute
				Tooltip: ""
			}

			CorrodedCane: {
				DisplayName: Corroded Cane
				Tooltip: ""
			}

			Weapons: {
				Rogue: {
					OcramKnife: {
						Tooltip: Stealth strikes summon extra demon scythes that home on foes as they speed up
