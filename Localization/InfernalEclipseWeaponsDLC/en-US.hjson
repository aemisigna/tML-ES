					'''
			}

			DeepSeaDrawlShard2: {
				DisplayName: Bell Shard
				Tooltip:
					'''
					'The bell of the Restored Deep Sea Drawl'
					[c/010057:In an attempt to keep others from this power, the mouthpiece was sealed in the dungeon]
					[c/010057:It is heard that the key was tossed to the blue depths below]
