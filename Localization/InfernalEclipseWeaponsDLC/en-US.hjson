					Pressing the '{$Keybinds.AccessoryAbility.DisplayName}' key will freeze the camera in place
					'I see a unbreakable fortress in your future'
					'''
			}

			SwordofaThousandTruths: {
				DisplayName: Sword of a Thousand Truths
				Tooltip:
					'''
					<left> to swing the sword, restoring 7 life on hit
					Hold <right> to charge and throw the sword, embedding itself into the hit enemy
					When the sword is embedded it will release light and dark energy
					Light energy will home onto nearby allies and heal life equal to bonus healing
					Dark energy will home onto nearby enemies, dealing damage
