Items: {
	BandofCratons: {
		DisplayName: "{$Mods.ThoriumRework.Items.BandofCratonsCosmetic.DisplayName}"
		Tooltip:
			'''
			Grants immunity to Overflowed and makes your attacks inflict it
			Grants a passive 40 shield
			Restores player resources based on the amount of shield lost
			Losing more than 20 shield creates an electric shock that destroys 3 nearby projectiles
			{$Mods.ThoriumRework.Items.BandofCratonsCosmetic.Tooltip}
			'''
	}

	BandofCratonsCosmetic: {
		DisplayName: Band of Cratons
		Tooltip: '''"Durable enough to withstand continental drift"'''
	}

	BannerofWar: {
		DisplayName: "{$Mods.ThoriumRework.Items.BannerofWarCosmetic.DisplayName}"
		Tooltip:
			'''
			Damage and bonus healing slowly increases over time while in combat
			These bonuses gradually fade when out of combat
			While in combat, periodically emit a healing pulse that heals allies equal to bonus healing
			The frequency of the pulses increases the longer you are in combat
			Bard empowerment range affects the range of the healing pulse
			'''
	}

	BannerofWarCosmetic: {
		DisplayName: Banner of War
		Tooltip: ""
	}

	BeholderBlade: {
		DisplayName: Will of Coznix
		Tooltip:
			'''
			The third and fourth attacks shoots out an eradicating void beam
			Critical strikes create a void bubble on hit target's location
			The void bubble summons eyes to attack enemies for 50% damage
			Only one void bubble can be active at a time
			'''
	}

	BeholderHeart: {
		DisplayName: Heart of the Beholder
		Tooltip:
			'''
			Increases maximum life by 10 and bonus healing by 1
			Every 30 ally life healed releases a bolt of damaging radiant energy
			Additionally, you recover life equal to bonus healing
			'''
	}

	BeholderTentacles: {
		DisplayName: "{$Mods.ThoriumRework.Items.BeholderTentaclesCosmetic.DisplayName}"
		Tooltip:
			'''
			Attacks inflict Singed, damage against Singed targets are increased by 20%
