		champ: {
			Label: "[i:ThoriumMod/BuriedChampionMask]Buried Champion"
			Tooltip: Buried Champion rework
		}

		ges: {
			Label: "[i:ThoriumMod/GraniteEnergyStormMask]Granite Energy Storm"
			Tooltip: Granite Energy Storm rework
		}

		scout: {
			Label: "[i:ThoriumMod/StarScouterMask]Star Scouter"
			Tooltip: Star Scouter rework
		}

		coznix: {
			Label: "[i:ThoriumMod/FallenBeholderMask]Coznix"
			Tooltip: Fallen Beholder rework
		}

		strider: {
			Label: "[i:ThoriumMod/BoreanStriderMask]Borean Strider"
			Tooltip: Borean Strider rework
		}

		lich: {
			Label: "[i:ThoriumMod/LichMask]Lich"
			Tooltip: Lich rework
		}

		abyssion: {
			Label: "[i:ThoriumMod/ForgottenOneMask]Abyssion"
			Tooltip: Forgotten One rework
		}

		requireAbyssion: {
			Label: "[i:ThoriumMod/ForgottenOneMask]Require Abyssion in Progression"
			Tooltip:
				'''
				The Forgotten One now needs to be killed alongside Golem to allow the cultists to spawn
				Automatically disabled in worlds where the Aquatic Depths didn't generate
				'''
		}

		rag: {
			Label: "[i:ThoriumMod/TheOmegaCore]Ragnarök"
			Tooltip: Primordials and Dream Eater rework
		}

		terminalLucidity: {
			Label: "[i:ThoriumMod/TheOmegaCore]Terminal Lucidity Minimum Difficulty"
			Tooltip:
				'''
				The lowest difficulty Terminal Lucidity can appear in
				0 - Boss rush only
				1 - Enabled for all
				2 - Master or Revengeance
				3 - Legendary, Death or Eternity
				4 - GFB, Infernum, Masochist or Eternity-Death
				'''
		}
	}

