Configs: {
	ReworkConfig: {
		DisplayName: Visual Settings

		flash: {
			Label: Flashing lights intensity
			Tooltip: How bright or how dim flashes are
		}

		overlay: {
			Label: Overlay intensity
			Tooltip: How transparent screen overlays are
		}

		seizures: {
			Label: Photosensitivity warning
			Tooltip: Prompts a photosensitivity warning when joining a world
		}

		bossRenames: {
			Label: Boss renames
			Tooltip: Enables boss renames added by this mod
		}

		starScouterEnrageText: {
			Label: "[i:ThoriumMod/StarScouterMask]Star Scouter Enrage Text"
			Tooltip:
				'''
				Whether or not Star Scouter shows a text pop-up indicating enrage
				Only works on reworked Star Scouter, the unreworked version is unaffected by this setting as it cannot enrage
				'''
		}

		starScouterEnrageVisuals: {
			Label: "[i:ThoriumMod/StarScouterMask]Star Scouter Enrage Visuals"
			Tooltip:
				'''
				Whether or not Star Scouter turns red when enraged
				Only works on reworked Star Scouter, the unreworked version is unaffected by this setting as it cannot enrage
				'''
		}

		lichOutline: {
			Label: "[i:ThoriumMod/LichMask]Lich Aura Intensity"
			Tooltip:
				'''
				Controls the intensity of the faint red glow around the Lich
				Only works on reworked Lich, the unreworked version is unaffected by this setting
				Use this if you want visual parity with the original design or if you're having troubles seeing him
				'''
		}
	}

	CompatConfig: {
		DisplayName: Cross Mod Compatibility Settings

		healthScale: {
			Label: Health multiplier
			Tooltip: Multiplies the health of Thorium's bosses by this amount
		}

		damageScale: {
			Label: Damage multiplier
			Tooltip: Multiplies the attack damage of Thorium's bosses by this amount
		}

		speedScale: {
			Label: Speed multiplier
			Tooltip:
				'''
				Multiplies the movement speed of Thorium's bosses by this amount
				Limited to 2x speed as any higher breaks bosses
				1.35x is recommended for Infernum
				'''
		}

		terraItemsFix: {
			Label: Thorium Terra Item Recipes Parity
			Tooltip:
				'''
				(Recommended!)
				Changes all of the Terra weapons from Thorium to use similar recipes to the vanilla Terra Blade
				Automatically disabled if Unofficial Calamity Bard & Healer is installed as that mod already does this
				'''
		}

		extraItems: {
			Label: Extra Item Contents
			Tooltip:
				'''
				(Optional)
				Adds some unrelated items that are from this mod
				'''
		}

		extraPotions: {
			Label: Extra Potion Contents
			Tooltip:
				'''
				(Optional)
				Adds some buff potions relating to Thorium's class that are from this mod
				'''
		}

		extraPrefixes: {
			Label: Extra Prefix Contents
			Tooltip:
				'''
				(Optional)
				Adds some prefixes relating to Thorium's class items that are from this mod
				'''
		}

		masterDrops: {
			Label: Master Mode Drops
			Tooltip:
				'''
				(Recommended!)
				Thorium's bosses will have exclusive weapons dropped in master, revengeance or eternity mode
				'''
		}

		masterDropsAreNonExclusive: {
			Label: Master weapon drops are expert drops
			Tooltip:
				'''
				Master mode exclusive weapons drop in expert mode
				Recommended if you don't like playing on master or other mods break master drops
				(e.g. eternity mode becoming masochist mode or infernum not being usable in master mode)
				'''
		}

		itemReworks: {
			Label: Rework Some of Thorium's Items
			Tooltip:
				'''
				(Recommended!)
				Reworks some items from Thorium mod to be a lot better
				'''
		}

		postDoGRag: {
			Label: Re-tier Primordials in Calamity or Fargo's Souls
			Tooltip:
				'''
				(Recommended!)
				Makes the Primordials post-Devourer in progression
				Pre-Eridanus in Fargo's Souls
				In between if both of those mods are enabled
				'''
		}

		vanillaBard: {
			Label: Stellar Tune and Magical Harp are bard
			Tooltip: Stellar Tune and Magical Harp are now string instruments and grant empowerments
		}

		DoD: {
			Label: Devourer of Dreams (Joke setting)
			Tooltip:
				'''
				This setting is entirely a joke, it gives Devourer of Gods Dream Eater's original attacks
				May or may not be fair and balanced
				'''
		}

		thorlamityBR: {
			Label: Thorium Bosses in Calamity Boss Rush
			Tooltip: Thorium Bosses spawn in Calamity Boss Rush, ordered according to appropriate tier of progression
		}

		defenseDamage: {
			Label: Defense Damage Support
			Tooltip: Allows some of Thorium's boss attacks to inflict defense damage if Calamity mod is enabled
		}

		eternityModeOnly: {
			Label: Eternity mode only
			Tooltip:
				'''
				The boss reworks from this mod only applies when eternity mode is active
				Also changes master weapon drops (if enabled) into eternity weapon drops
				Additionally, Thorium bosses can now drop eternity mode accessories
				This setting does nothing if Fargo's Souls is not installed
				'''
		}

		infernumModeOnly: {
			Label: Infernum mode only
			Tooltip:
				'''
				The boss reworks from this mod only applies when infernum mode is active
				This setting does nothing if Infernum is not installed
				'''
		}
	}

	ReworkTogglesConfig: {
		DisplayName: Boss Rework Toggles

		bird: {
