Configs: {
	ReworkConfig: {
		DisplayName: Configuración Visual

		flash: {
			Label: Intensidad de luces parpadeantes
			Tooltip: Qué tan brillantes o tenues son los destellos
		}

		overlay: {
			Label: Intensidad de superposición
			Tooltip: Qué tan transparentes son las superposiciones de pantalla
		}

		seizures: {
			Label: Advertencia de fotosensibilidad
			Tooltip: Muestra una advertencia de fotosensibilidad al entrar a un mundo
		}

		bossRenames: {
			Label: Renombrado de jefes
			Tooltip: Activa los renombrados de jefes añadidos por este mod
		}

		starScouterEnrageText: {
			Label: "[i:ThoriumMod/StarScouterMask]Texto de Furia del Explorador Estelar"
			Tooltip:
				'''
				Si el Explorador Estelar muestra o no un texto emergente indicando furia
				Solo funciona en el Explorador Estelar reworkeado, la versión sin reworkear no se ve afectada por esta configuración ya que no puede enfurecerse
				'''
		}

		starScouterEnrageVisuals: {
			Label: "[i:ThoriumMod/StarScouterMask]Visuales de Furia del Explorador Estelar"
			Tooltip:
				'''
				Si el Explorador Estelar se pone rojo o no al enfurecerse
				Solo funciona en el Explorador Estelar reworkeado, la versión sin reworkear no se ve afectada por esta configuración ya que no puede enfurecerse
				'''
		}

		lichOutline: {
			Label: "[i:ThoriumMod/LichMask]Intensidad del Aura del Liche"
			Tooltip:
				'''
				Controla la intensidad del tenue resplandor rojo alrededor del Liche
				Solo funciona en el Liche reworkeado, la versión sin reworkear no se ve afectada por esta configuración
				Usa esto si quieres paridad visual con el diseño original o si tienes problemas para verlo
				'''
		}
	}

	CompatConfig: {
		DisplayName: Configuración de Compatibilidad entre Mods

		healthScale: {
			Label: Multiplicador de vida
			Tooltip: Multiplica la vida de los jefes de Thorium por esta cantidad
		}

		damageScale: {
			Label: Multiplicador de daño
			Tooltip: Multiplica el daño de ataque de los jefes de Thorium por esta cantidad
		}

		speedScale: {
			Label: Multiplicador de velocidad
			Tooltip:
				'''
				Multiplica la velocidad de movimiento de los jefes de Thorium por esta cantidad
				Limitado a 2x de velocidad, ya que más alto rompe a los jefes
				1.35x es lo recomendado para Infernum
				'''
		}

		terraItemsFix: {
			Label: Paridad de Recetas de Objetos Terra de Thorium
			Tooltip:
				'''
				(¡Recomendado!)
				Cambia todas las armas Terra de Thorium para usar recetas similares a la Espada Terra vanilla
				Se desactiva automáticamente si Unofficial Calamity Bard & Healer está instalado, ya que ese mod ya hace esto
				'''
		}

		extraItems: {
			Label: Contenido de Objetos Extra
			Tooltip:
				'''
				(Opcional)
				Añade algunos objetos no relacionados que provienen de este mod
				'''
		}

		extraPotions: {
			Label: Contenido de Pociones Extra
			Tooltip:
				'''
				(Opcional)
				Añade algunas pociones de mejora relacionadas con las clases de Thorium que provienen de este mod
				'''
		}

		extraPrefixes: {
			Label: Contenido de Prefijos Extra
			Tooltip:
				'''
				(Opcional)
				Añade algunos prefijos relacionados con los objetos de clase de Thorium que provienen de este mod
				'''
		}

		masterDrops: {
			Label: Objetos de Modo Maestro
			Tooltip:
				'''
				(¡Recomendado!)
				Los jefes de Thorium tendrán armas exclusivas que caen en modo maestro, revancha o eternidad
				'''
		}

		masterDropsAreNonExclusive: {
			Label: Los objetos de maestro caen como objetos de experto
			Tooltip:
				'''
				Las armas exclusivas de modo maestro caen en modo experto
				Recomendado si no te gusta jugar en maestro u otros mods rompen los objetos de maestro
				(ej: el modo eternidad se convierte en modo masoquista o infernum no es usable en modo maestro)
				'''
		}

		itemReworks: {
			Label: Reworkear Algunos Objetos de Thorium
			Tooltip:
				'''
				(¡Recomendado!)
				Reworkea algunos objetos del mod Thorium para que sean mucho mejores
				'''
		}

		postDoGRag: {
			Label: Reajustar Tier de los Primordiales en Calamity o Fargo's Souls
			Tooltip:
				'''
				(¡Recomendado!)
				Hace que los Primordiales se ubiquen en progresión después del Devorador
				Antes de Eridanus en Fargo's Souls
				Entre ambos si los dos mods están activados
				'''
		}

		vanillaBard: {
			Label: Stellar Tune y Magical Harp son de Bardo
			Tooltip: Stellar Tune y Magical Harp ahora son instrumentos de cuerda y otorgan potenciaciones
		}

		DoD: {
			Label: Devorador de Sueños (Configuración de broma)
			Tooltip:
				'''
				Esta configuración es completamente una broma, le da al Devorador de Dioses los ataques originales del Devorador de Sueños
				Puede que sea justa y equilibrada, o puede que no
				'''
		}

		thorlamityBR: {
			Label: Jefes de Thorium en el Boss Rush de Calamity
			Tooltip: Los Jefes de Thorium aparecen en el Boss Rush de Calamity, ordenados según el tier apropiado de progresión
		}

		defenseDamage: {
			Label: Soporte de Daño a la Defensa
			Tooltip: Permite que algunos ataques de jefes de Thorium inflijan daño a la defensa si el mod Calamity está activado
		}

		eternityModeOnly: {
			Label: Solo modo eternidad
			Tooltip:
				'''
				Los reworks de jefes de este mod solo se aplican cuando el modo eternidad está activo
				También cambia los objetos de maestro (si están activados) por objetos de eternidad
				Además, los jefes de Thorium ahora pueden dejar caer accesorios de modo eternidad
				Esta configuración no hace nada si Fargo's Souls no está instalado
				'''
		}

		infernumModeOnly: {
			Label: Solo modo infernum
			Tooltip:
				'''
				Los reworks de jefes de este mod solo se aplican cuando el modo infernum está activo
				Esta configuración no hace nada si Infernum no está instalado
				'''
		}
	}

