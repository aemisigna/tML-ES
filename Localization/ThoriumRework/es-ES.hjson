Items: {
	BandofCratons: {
		DisplayName: "{$Mods.ThoriumRework.Items.BandofCratonsCosmetic.DisplayName}"
		Tooltip:
			'''
			Otorga inmunidad a Desbordado y hace que tus ataques lo inflijan
			Otorga un escudo pasivo de 40
			Restaura los recursos del jugador según la cantidad de escudo perdido
			Perder más de 20 de escudo crea una descarga eléctrica que destruye 3 proyectiles cercanos
			{$Mods.ThoriumRework.Items.BandofCratonsCosmetic.Tooltip}
			'''
	}

	BandofCratonsCosmetic: {
		DisplayName: Banda de Cratones
		Tooltip: '''"Suficientemente resistente para soportar la deriva continental"'''
	}

	BannerofWar: {
		DisplayName: "{$Mods.ThoriumRework.Items.BannerofWarCosmetic.DisplayName}"
		Tooltip:
			'''
			El daño y la curación adicional aumentan lentamente con el tiempo mientras estás en combate
			Estos bonos se desvanecen gradualmente al salir del combate
			Mientras estás en combate, emites periódicamente un pulso curativo que sana a los aliados por una cantidad igual a la curación adicional
			La frecuencia de los pulsos aumenta cuanto más tiempo llevas en combate
			El alcance de potenciación de Bardo afecta el alcance del pulso curativo
			'''
	}

	BannerofWarCosmetic: {
		DisplayName: Estandarte de Guerra
		Tooltip: ""
	}

	BeholderBlade: {
		DisplayName: Voluntad de Coznix
		Tooltip:
			'''
			El tercer y cuarto ataque disparan un rayo vacío erradicador
			Los golpes críticos crean una burbuja vacía en la ubicación del objetivo golpeado
			La burbuja vacía invoca ojos para atacar a los enemigos causando 50% de daño
			Solo puede haber una burbuja vacía activa a la vez
			'''
	}

	BeholderHeart: {
		DisplayName: Corazón del Observador
		Tooltip:
			'''
			Aumenta la vida máxima en 10 y la curación adicional en 1
			Cada 30 de vida aliada curada libera un rayo de energía radiante dañina
			Además, recuperas vida igual a la curación adicional
			'''
	}

	BeholderTentacles: {
		DisplayName: "{$Mods.ThoriumRework.Items.BeholderTentaclesCosmetic.DisplayName}"
		Tooltip:
			'''
			Los ataques infligen Chamuscado, el daño contra objetivos Chamuscados aumenta en un 20%
			{$Mods.ThoriumRework.Items.BeholderTentaclesCosmetic.Tooltip}
			'''
	}

	BeholderTentaclesCosmetic: {
		DisplayName: Tentáculos del Observador
		Tooltip:
			'''
			Efectos de {$ItemName.FrogLeg} y {$ItemName.LavaWaders} pero sin la inmunidad a la lava
			"Deben ser de Will"
			'''
	}

	BiterofSouls: {
		DisplayName: Mordedor de Almas
		Tooltip:
			'''
			Lanza pequeños devoradores de almas que enfurecen tras cierta distancia
			Mientras están enfurecidos, atraviesan indefinidamente y pueden golpear al mismo objetivo varias veces
			'''
	}

	ChampionWarHorn: {
		DisplayName: Cuerno de Guerra del Campeón
		Tooltip:
			'''
			Dispara un eco de guerra teledirigido
			"¡A LA CARGA!"
			'''
	}

	ChironsCure: {
		DisplayName: Cura de Chirón
		Tooltip: Intercambia vida por un rayo sanador de vida que cura algunos efectos negativos básicos
	}

	ConcussiveInstrument: {
		DisplayName: Instrumento Contundente
		Tooltip:
			'''
			Los ataques de instrumentos de percusión lanzan martillos hacia arriba que eventualmente caen
			"¿Es... solo un martillo?"
			'''
	}

	CrystallizedFinality: {
		DisplayName: Finalidad Cristalizada
		Tooltip:
			'''
			Efectos de [i:ThoriumRework/BeholderTentacles]{$ItemName.FrogLeg}, [i:ThoriumRework/BeholderTentacles]{$ItemName.LavaWaders} pero sin la inmunidad a la lava, y [i:ThoriumRework/StriderMouthguard]{$ItemName.HandWarmer}
			[i:ThoriumRework/BeholderTentacles][i:ThoriumRework/StriderMouthguard] Los ataques infligen Congelación por Escarcha y Fuego Infernal, causan más daño y otorgan escudo contra objetivos afectados por cualquiera de esos efectos negativos
			[i:ThoriumRework/StriderMouthguard][i:ThoriumRework/UndyingGaze] Mantén el ataque para generar hasta tres Ácaros de Escarcha, deja de atacar para liberarlos, otorgando Esencia del Alma al golpear
			[i:ThoriumRework/UndyingGaze] Los golpes críticos otorgan Esencia del Alma, los ataques que usan vida o que ya otorgan Esencia del Alma dan más
			[i:ThoriumRework/DeepDarkShellShield] Otorga un escudo pasivo de 20, inmunidad al retroceso y duplica el aumento de vida por escudo, además de incrementar tus estadísticas defensivas
			"UN. ÚLTIMO. ACTO. DE ENTROPÍA."
			'''
	}

	DeathsingerPotion: {
		DisplayName: Poción del Cantor de la Muerte
		Tooltip: 7% más de daño y velocidad de interpretación sinfónica
	}

	DeepDarkShellShield: {
		DisplayName: "{$Mods.ThoriumRework.Items.DeepDarkShellShieldCosmetic.DisplayName}"
		Tooltip:
			'''
			{$Mods.ThoriumRework.Items.DeepDarkShellShieldCosmetic.Tooltip}
			Duplica el aumento de vida por escudo
			Además, el escudo aumenta la defensa y la reducción de daño
			'''
	}

	DeepDarkShellShieldCosmetic: {
		DisplayName: Escudo de Concha de las Profundidades Oscuras
		Tooltip:
			'''
			Otorga un escudo pasivo de 20
			Otorga inmunidad al retroceso
			'''
	}

	DukeFish: {
		DisplayName: Pez Duque
		Tooltip:
			'''
			Mantén <left> para inflar una burbuja creciente y suéltala para dispararla
			La burbuja curará a los aliados y los encerrará en un escudo protector
			"Se llama Ron, por cierto"
			'''
	}

	EaterPiper: {
		DisplayName: Flautista Devorador
		Tooltip:
			'''
			Invoca gusanos retorcidos que muerden a los enemigos
			Ignora 15 puntos de Defensa enemiga
			"Dale un frasco de pimientos encurtidos"
			'''
	}

	ExecutionersContract: {
		DisplayName: Contrato del Verdugo
		Tooltip:
			'''
			Ganar esencia de alma con guadañas radiantes otorga una carga agregada acumulable
			El daño radiante de proyectiles de guadaña o armas que no son guadañas consume la carga agregada para otorgar esencia de alma
			"Tráeme sus almas..."
			'''
	}

	FanDonations: {
		DisplayName: Donaciones de Fans
		Tooltip:
			'''
			Todos los ataques de instrumentos explotan al golpear, el tamaño de la explosión varía y causa 50% menos de daño crítico
			Los ataques de instrumentos de cuerda que atraviesan aumentan de velocidad con cada golpe y ya no pierden daño
			Ciertos ataques de instrumentos de cuerda que activan efectos al colisionar con bloques también se activan al golpear
			Los ataques de instrumentos de percusión lanzan martillos hacia arriba que eventualmente caen
			Los proyectiles de instrumentos electrónicos son considerablemente más rápidos
			Aumenta la inspiración máxima en 5
			"No vende mucho, lamentablemente. Al menos alguien es lo bastante amable para aportar..."
			'''
	}

	FlyingFlute: {
		DisplayName: Flauta Voladora
		Tooltip:
			'''
			Invoca una flauta alada que disparará a los enemigos
			Otorga Tiempo de Vuelo II y Regeneración de Recursos I cada vez que ataca
			"¿Acaso te parece que le importa un pito?"
			'''
	}

	GildedFlyingFlute: {
		DisplayName: Flauta Voladora Dorada
		Tooltip:
			'''
			{0}% más de daño sinfónico
			{1}% más de velocidad de interpretación sinfónica
			Aumenta la velocidad de persecución de los instrumentos de viento en {2}%
			Tus ataques de instrumentos de viento ahora intentan perseguir rápidamente a los enemigos
			Si el ataque ya persigue a los enemigos, lo hace mucho más rápido
			Invoca una flauta alada que disparará a los enemigos
			Otorga Tiempo de Vuelo II y Regeneración de Recursos I cada vez que ataca
			'''
	}

	HandheldRocket: {
		DisplayName: Cohete de Mano
		Tooltip:
			'''
			Lanza un cohete de mano que explotará cuatro veces a una distancia determinada
			"¡Cohete de Bolsillo!"
			'''
	}

	HeadHunter: {
		DisplayName: Cazacabezas
		Tooltip:
			'''
			Esta guadaña se blande direccionalmente y gira dos veces cada 2 golpes
			Ganar esencia de alma, dar golpes críticos o estar en combate crea fragmentos de hielo que te siguen
			Los fragmentos de hielo otorgan +10 de defensa cada uno, pero solo puede haber 4 a la vez
			<right> o cambia de arma para disparar todos los fragmentos de hielo al enemigo más cercano a tu cursor
			"Pertenece a cierto demonio que supuestamente regenta una cafetería..."
			'''
	}

	HelheimSoul: {
		DisplayName: Alma de Helheim
		Tooltip:
			'''
			Otorga inmunidad a [i:ThoriumRework/QueenJellyPin]En Burbuja, [i:ThoriumRework/VampireCape]Sangrado, [i:ThoriumRework/VampireCape]Maldición del Vampiro y [i:ThoriumRework/DeepDarkShellShield]retroceso
			Efectos de [i:ThoriumRework/BeholderTentacles]{$ItemName.FrogLeg}, [i:ThoriumRework/BeholderTentacles]{$ItemName.LavaWaders}, y [i:ThoriumRework/StriderMouthguard]{$ItemName.HandWarmer}
			[i:ThoriumRework/BeholderTentacles][i:ThoriumRework/StriderMouthguard] Los ataques infligen Congelación por Escarcha y Fuego Infernal, causan más daño y otorgan escudo contra objetivos afectados por cualquiera de esos efectos negativos
			[i:ThoriumRework/StriderMouthguard][i:ThoriumRework/UndyingGaze] Mantén el ataque para generar hasta tres Ácaros de Escarcha, deja de atacar para liberarlos, otorgando Esencia del Alma al golpear
			[i:ThoriumRework/DeepDarkShellShield][i:ThoriumRework/BandofCratons] Otorga un escudo pasivo de 40, inmunidad a Desbordado y hace que tus ataques lo inflijan, y duplica el aumento de vida por escudo además de incrementar tus estadísticas defensivas
			[i:ThoriumRework/BandofCratons] Restaura los recursos del jugador según la cantidad de escudo perdido, perder más de 20 de escudo crea una descarga eléctrica que destruye 3 proyectiles
			[i:ThoriumRework/UndyingGaze] Los golpes críticos otorgan Esencia del Alma, los ataques que usan vida o que ya otorgan Esencia del Alma dan más
			[i:ThoriumRework/QueenJellyPin] Invoca tentáculos a tu alrededor que se aferran a los enemigos, aumentando la regeneración de vida y recursos al golpear, el daño de los tentáculos aumenta según la defensa
			[i:ThoriumRework/VampireCape] Recibes considerablemente menos daño y tienes muchas menos probabilidades de ser el objetivo de los enemigos mientras el Enjambre de Murciélagos está activo
			[i:ThoriumRework/ZephyrWings] Engancharse en el aire con la cría del Agarre de Céfiro extiende el tiempo de vuelo
			[i:ThoriumRework/ZephyrWings] La cría del Agarre de Céfiro puede volver a invocarse tras planear un rato, causar daño la restaura más rápido
			[i:ThoriumRework/StarScoutReticle] Permite respirar en el espacio y otorga visión nocturna
			[i:ThoriumRework/StarScoutReticle] El impulso te teletransporta unos bloques hacia adelante y te da un impulso si aún no tienes uno
			[i:ThoriumRework/BannerofWar] El daño y la curación adicional aumentan con el tiempo mientras estás en combate, pero se desvanecen gradualmente al salir de él
			[i:ThoriumRework/BannerofWar] Mientras estás en combate, emites periódicamente un pulso que cura a los aliados por una cantidad igual a la curación adicional, el alcance de potenciación de Bardo afecta el alcance, y la frecuencia aumenta con el tiempo
			'''
	}

	ImpulseAmplifier: {
		DisplayName: Amplificador de Impulso
		Tooltip: Los proyectiles de instrumentos electrónicos son considerablemente más rápidos
	}

	InspirationRegenerationPotion: {
		DisplayName: Poción de Regeneración de Inspiración
		Tooltip: Mayor regeneración de inspiración
	}

	FluteofCurses: {
		DisplayName: Flauta de Maldiciones
		Tooltip: Dispara calaveras malditas que se aferran a los enemigos, causando daño continuo
	}

	JellyfishJam: {
		DisplayName: Medusa Interferente
		Tooltip: Dispara medusas danzantes que atraviesan
	}

	KingTrumpet: {
		DisplayName: Trompeta Real
		Tooltip:
			'''
			Rocía una ráfaga de esporas que infectan a los objetivos golpeados
			Ignora 10 puntos de Defensa enemiga
			'''
	}

	Kusarigama: {
		DisplayName: Kusarigama
		Tooltip:
			'''
			Esta maza cuenta como guadaña
			Golpear enemigos con la cuchilla genera esencia de alma
			Golpear enemigos con el mango genera energía curativa persistente
			Puede haber hasta 2 energías curativas a la vez
			'''
	}

	LichWhip: {
		DisplayName: Instrumento de Tormento
		Tooltip:
			'''
			Lanza un triple latigazo potenciado por fuego de alma
			Los enemigos golpeados sangrarán sus almas y curarán a sus objetivos
			"Una herramienta usada para atormentar almas en el más allá"
			'''
	}

	LodeStoneMagnetMace: {
		DisplayName: Maza Magnética de Piedra Imán
		Tooltip:
			'''
			Blande una maza magnética que libera energía curativa persistente en su primer golpe
			Puede haber hasta 4 energías curativas a la vez
			El daño quiebra a los enemigos, aumentando el daño que reciben en un 10% y atrayendo la maza hacia ellos
			'''
	}

	Loudener: {
		DisplayName: Amplificador
		Tooltip:
			'''
			Los ataques de instrumentos de viento y metal explotan al golpear
			El tamaño de la explosión varía según el instrumento tocado
			Las explosiones causan 50% menos de daño crítico
			"¡Tú tienes un silenciador, yo tengo un amplificador!"
			'''
	}

	LunateCharm: {
		DisplayName: Amuleto Lunar
		Tooltip: Ganar esencia de alma otorga escudo cuando la vida está al máximo
	}

	RedCresent: {
		DisplayName: Media Luna Roja
		Tooltip:
			'''
			Dispara murciélagos que regresan al golpear, otorgando sangre
			<right> para consumir sangre y liberar murciélagos que curan a los aliados por <healAmount> de vida
			<legendaryModeOnly>Cuesta vida usarlo en el modo Legendario
			Sifón de Sangre: <bloodSiphon>
			"Una maravillosa balada de los murciélagos"
			'''
	}

	MagicalHarp: {
		DisplayName: "{$ItemName.MagicalHarp}"
		Tooltip: ""
	}

	Oneirophobia: {
		DisplayName: Oneirofobia
		Tooltip:
			'''
			Crea una aparición lúcida que funciona como armas aleatorias
			En los dos primeros ataques, el arma se transforma en espada
			El primer golpe crea una feroz onda de choque, el segundo crea tres
			En el tercer ataque, la cuchilla del arma se desprende y es lanzada hacia adelante
			El arma entonces se transforma en guadaña
			En el cuarto ataque, el arma gira y libera rayos teledirigidos
			En el quinto ataque, el arma se transforma en un bastón mágico
			Luego dispara una bola de energía volátil que explota tras un tiempo
			En el sexto ataque, el arma se transforma en un arma láser con puntería automática
			Se convierte en un sintetizador invocación consciente cuando se guarda, atacando enemigos
			"La manifestación del miedo irracional a los sueños y pesadillas"
			'''
	}

	QueenJellyPin: {
		DisplayName: "{$Mods.ThoriumRework.Items.QueenJellyPinCosmetic.DisplayName}"
		Tooltip:
			'''
			Otorga inmunidad a En Burbuja
			Invoca tentáculos a tu alrededor que se aferran a los enemigos
			El daño de los tentáculos aumenta según la defensa
			Los tentáculos aumentan la regeneración de vida y recursos al golpear
			{$Mods.ThoriumRework.Items.QueenJellyPinCosmetic.Tooltip}
			'''
	}

	QueenJellyPinCosmetic: {
		DisplayName: Alfiler de Medusa Reina
		Tooltip: '''"¡Arriba y junto a tu cabeza!"'''
	}

	PickShapedPebble: {
		DisplayName: Guijarro con Forma de Pico
		Tooltip:
			'''
			Ciertos ataques de instrumentos de cuerda que activan efectos al colisionar con bloques también se activan al golpear
			"¡Es para música rock!"
			'''
	}

	PocketEnergyStorm: {
		DisplayName: Tormenta de Energía de Bolsillo
		Tooltip:
			'''
			Lanza hasta 20 bolas de energía inestable que desbordan a los objetivos
			Los enemigos desbordados reciben 5% más de daño
			Suelta <left> para liberar todas esas bolas a la vez
			No te agota
			"Un nuevo significado para quedarse con las bolas"
			'''
	}

	RepurposedStarCaller: {
		DisplayName: Llamador Estelar Reutilizado
		Tooltip:
			'''
			Invoca los núcleos elementales del Explorador Estelar para luchar por ti
			Los núcleos Piro queman a los objetivos, los núcleos Bio envenenan, y los núcleos Crio infligen quemadura por frío
			"Hemos recibido tu llamado, ¿ahora qué?"
			'''
	}

	SealedContract: {
		DisplayName: Contrato Sellado
		Tooltip:
			'''
			Aumenta la vida máxima en 60
			Los hechizos curativos otorgan 5 de vida adicional
			Ganar esencia de alma con guadañas radiantes otorga una carga agregada acumulable y escudo cuando la vida está al máximo
			El daño radiante de proyectiles de guadaña o armas que no son guadañas consume la carga agregada para otorgar esencia de alma
			"¡Sella el trato!"
			'''
	}

	Shellxophone: {
		DisplayName: Odisea del Mar Profundo
		Tooltip:
			'''
			Dispara ondas rebotantes acompañadas de golpes abisales teledirigidos
			<right> para disparar gotas teledirigidas que curan a los aliados a costa de 10 de inspiración
			La curación aumenta por cada potenciación única que tengan los aliados según su nivel
			"Llamando a los acechantes de las profundidades acuáticas a tocar la más fina sinfonía"
			'''
	}

	ShoulderBlade: {
		DisplayName: Cuchilla del Hombro
		Tooltip:
			'''
			Lanza un hacha de carne que se detiene a cierta distancia
			Mientras está estacionaria, el arma tiene un breve punto óptimo donde invoca rayos de sanguijuela teledirigidos al golpear
			'''
	}

	SierraChimera: {
		DisplayName: Sierra Chimera
		Tooltip:
			'''
			Otorga inmunidad a [i:ThoriumRework/QueenJellyPin]En Burbuja, [i:ThoriumRework/VampireCape]Sangrado y [i:ThoriumRework/VampireCape]Maldición del Vampiro
			[i:ThoriumRework/QueenJellyPin] Invoca tentáculos a tu alrededor que se aferran a los enemigos y aumentan la regeneración de vida y recursos al golpear
			[i:ThoriumRework/QueenJellyPin] El daño de los tentáculos aumenta según la defensa
			[i:ThoriumRework/VampireCape] Recibes considerablemente menos daño y tienes muchas menos probabilidades de ser el objetivo de los enemigos mientras el Enjambre de Murciélagos está activo
			[i:ThoriumRework/ZephyrWings] Engancharse en el aire con la cría del Agarre de Céfiro extiende el tiempo de vuelo
			[i:ThoriumRework/ZephyrWings] La cría del Agarre de Céfiro puede volver a invocarse tras planear un rato, causar daño la restaura más rápido
			'''
	}

	SoulSnatcher: {
		DisplayName: Arrebatador de Almas
		Tooltip:
			'''
			Esta maza cuenta como guadaña
			Golpear enemigos con la cuchilla genera esencia de alma
			Golpear enemigos con el mango genera energía curativa persistente
			Puede haber hasta 5 energías curativas a la vez
			"¡Tu alma pertenece al arrebatador!"
			'''
	}

	SpittingShroomStaff: {
		DisplayName: Bastón del Hongo Escupidor
		Tooltip:
			'''
			Invoca un hongo escupidor de esporas que ataca a los enemigos
			Se esconde cuando los enemigos se acercan, causando una explosión letal
			'''
	}

	StarScoutReticle: {
		DisplayName: "{$Mods.ThoriumRework.Items.StarScoutReticleCosmetic.DisplayName}"
		Tooltip:
			'''
			Permite respirar en el espacio y otorga visión nocturna
			El impulso te teletransporta unos bloques hacia adelante
			No funciona con impulsos especiales
			Te da un impulso si aún no tienes uno
			{$Mods.ThoriumRework.Items.StarScoutReticleCosmetic.Tooltip}
			'''
	}

	StarScoutReticleCosmetic: {
		DisplayName: Retícula del Explorador Estelar
		Tooltip: '''"¿Miedo a la oscuridad? No te preocupes, ¡me tienes a mí!"'''
	}

	StellarTune: {
		DisplayName: "{$ItemName.SparkleGuitar}"
		Tooltip: "{$ItemTooltip.SparkleGuitar}"
	}

	StriderMouthguard: {
		DisplayName: "{$Mods.ThoriumRework.Items.StriderMouthguardCosmetic.DisplayName}"
		Tooltip:
			'''
			Los ataques infligen Quemadura por Frío, otorgan escudo al dañar objetivos afectados por Quemadura por Frío
			Mantén el ataque para generar hasta tres Ácaros de Escarcha, deja de atacar para liberarlos
			{$Mods.ThoriumRework.Items.StriderMouthguardCosmetic.Tooltip}
			'''
	}

	StriderMouthguardCosmetic: {
		DisplayName: Protector Bucal del Estríder
		Tooltip: Efectos de {$ItemName.HandWarmer}
	}

	TerrariumSoulScourge: {
		DisplayName: Azote de Almas de Terrarium
		Tooltip:
			'''
			Blande una maza prismática que libera energía curativa persistente en su primer golpe
			Puede haber hasta 10 energías curativas a la vez
			Invoca copias arcoíris de sí misma al generar orbes curativos
			'''
	}

	TitanHat: {
		DisplayName: Sombrero Titánico
		Tooltip:
			'''
			'Imbuido de energía primordial'
			Aumenta la velocidad de interpretación sinfónica y la tasa de regeneración de inspiración en 15%
			Aumenta la duración de potenciación en 3 segundos
			Aumenta enormemente el alcance de potenciación
			'''
	}

	TitanHood: {
		DisplayName: Capucha Titánica
		Tooltip:
			'''
			'Imbuido de energía primordial'
			Aumenta la velocidad de lanzamiento en 15%
			Aumenta los puntos de técnica máximos en 3
			Las armas de lanzamiento no consumibles tardan 40% más en agotarte
			'''
	}

	TitanVisage: {
		DisplayName: Semblante Titánico
		Tooltip:
			'''
			'Imbuido de energía primordial'
			Aumenta el daño radiante y la velocidad de lanzamiento en 15%
			Los hechizos curativos curarán 6 de vida adicional
			Tus hechizos curativos pueden dar golpe crítico, duplicando su curación
			'''
	}

	TitanVisor: {
		DisplayName: Visor Titánico
		Tooltip:
			'''
			'Imbuido de energía primordial'
			Aumenta el máximo de invocaciones en 3 y de centinelas en 1
			Aumenta el alcance del látigo en 15%
			Aumenta la probabilidad de golpe crítico de invocación en 6%
			Las invocaciones y centinelas pueden dar golpe crítico
			'''
	}

	ThoriumBludgeon: {
		DisplayName: Maza de Torio
		Tooltip:
			'''
			Blande una maza radiactiva que libera energía curativa persistente en su primer golpe
			Puede haber hasta 2 energías curativas a la vez
			'''
	}

	ThoriumHeavyScythe: {
		DisplayName: Guadaña Pesada de Torio
		Tooltip: Esta guadaña se blande direccionalmente en lugar de girar
	}

	ThoriumWhistle: {
		DisplayName: Silbato de Torio
		Tooltip: Dispara una descarga de rayos de corto alcance
	}

	UndyingGaze: {
		DisplayName: "{$Mods.ThoriumRework.Items.UndyingGazeCosmetic.DisplayName}"
		Tooltip:
			'''
			Cualquier golpe crítico ahora otorga Esencia del Alma
			Los ataques que usan vida otorgarán Esencia del Alma con cualquier golpe
			Los ataques que ya otorgan Esencia del Alma otorgarán una carga extra
			'''
	}

	UndyingGazeCosmetic: {
		DisplayName: Mirada Inmortal
		Tooltip: Tus ojos emiten un tenue resplandor
	}

	ValadiumHeavyScythe: {
		DisplayName: Guadaña Pesada de Valadium
		Tooltip:
			'''
			Esta guadaña se blande direccionalmente en lugar de girar
			Libera una onda de energía oscura de corto alcance que atraviesa
			El daño golpea a los enemigos con energía interdimensional
			'''
	}

	ValkyrienSkyStone: {
		DisplayName: Piedra Celeste Valkyrien
		Tooltip:
			'''
			[i:ThoriumRework/StarScoutReticle] Permite respirar en el espacio y otorga visión nocturna
			[i:ThoriumRework/StarScoutReticle] El impulso te teletransporta unos bloques hacia adelante y te da un impulso si aún no tienes uno
			[i:ThoriumRework/BannerofWar] El daño y la curación adicional aumentan con el tiempo mientras estás en combate, pero se desvanecen gradualmente al salir de él
			[i:ThoriumRework/BannerofWar] Mientras estás en combate, emites periódicamente un pulso curativo que sana a los aliados por una cantidad igual a la curación adicional, el alcance de potenciación de Bardo afecta el alcance del pulso
			[i:ThoriumRework/BannerofWar] La frecuencia de los pulsos aumenta cuanto más tiempo llevas en combate
			[i:ThoriumRework/BandofCratons] Otorga un escudo pasivo de 40, inmunidad a Desbordado y hace que tus ataques lo inflijan
			[i:ThoriumRework/BandofCratons] Restaura los recursos del jugador según la cantidad de escudo perdido, perder más de 20 de escudo crea una descarga eléctrica que destruye 3 proyectiles
			'''
	}

	VampireCape: {
		DisplayName: "{$Mods.ThoriumRework.Items.VampireCapeCosmetic.DisplayName}"
		Tooltip: Otorga inmunidad al sangrado y a la Maldición del Vampiro
	}

	VampireCapeCosmetic: {
		DisplayName: Capa de Murciélago Vampiro
		Tooltip: ""
	}

	ZephyrsRuin: {
		DisplayName: Ruina de Céfiro
		Tooltip:
			'''
			Se clava en los enemigos golpeados, o en el suelo si falla
			Invoca un rayo que castiga a los enemigos golpeados tras un tiempo
			Los golpes críticos castigan a los enemigos al impacto inicial
			No te agota
			"Dicen que un rayo nunca cae dos veces en el mismo lugar"
			'''
	}

	ZephyrWings: {
		DisplayName: "{$Mods.ThoriumRework.Items.ZephyrWingsCosmetic.DisplayName}"
		Tooltip:
			'''
			{$Mods.ThoriumRework.Items.ZephyrWingsCosmetic.Tooltip}
			Engancharse en el aire con la cría del Agarre de Céfiro extiende la duración de vuelo
			La cría del Agarre de Céfiro puede volver a invocarse tras planear un rato
			Causar daño hace que la cría pueda volver a invocarse mucho antes
			'''
	}

	ZephyrWingsCosmetic: {
		DisplayName: Alas de Céfiro
		Tooltip:
			'''
			Permite volar y caer lentamente
			Las mismas estadísticas que {$ItemName.CreativeWings}
			'''
	}
}

Buffs: {
	BubblyShield: {
		DisplayName: Escudo Burbujeante
		Description: +10 de defensa, sobreescudo y reducción de daño especial
	}

	Deathsinger: {
		DisplayName: Cantor de la Muerte
		Description: 7% más de daño y velocidad de interpretación sinfónica
	}

	Inspired: {
		DisplayName: Inspirado
		Description: Mayor regeneración de inspiración
	}

	SoulBleed: {
		DisplayName: Sangrado de Alma
		Description: Tu alma se está disipando...
	}

	StarCalled: {
		DisplayName: Llamado Estelar
		Description: Ellos recibieron tu señal
	}

	TerminalLucidity: {
		DisplayName: Lucidez Terminal
		Description:
			'''
			-Mecánica de Jefe-
			El Devorador de Sueños no puede recibir daño mientras este efecto negativo esté activo
			Te mata cuando el temporizador se agota
			Toca una grieta de realidad estable para iniciar la fase de DPS y reiniciar el temporizador
			Las grietas de realidad estables son los portales morados brillantes
			"El destino aguarda..."
			'''
	}

	LucidRetaliation: {
		DisplayName: Represalia Lúcida
		Description:
			'''
			-Mecánica de Jefe-
			El Devorador de Sueños puede recibir daño mientras esta mejora esté activa
			Recibir un golpe de grietas de realidad inestables elimina esta mejora antes de tiempo
			Las grietas de realidad inestables son los ataques de grietas negras
			Otorga vuelo infinito
			"El destino llega..."
			'''
	}

	VampireCape: {
		DisplayName: Enjambre de Murciélagos Vampiro
		Description: Eres un enjambre de murciélagos vampíricos
	}
}

