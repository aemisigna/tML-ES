	EbonianMask: {
		DisplayName: Máscara Eboniana
		Tooltip: ""
	}

	StellarMask: {
		DisplayName: Máscara Estelar
		Tooltip: ""
	}

	Goozmaga: {
		DisplayName: Goozmaga
		Tooltip:
			'''
			Lanza planetas que orbitan a los enemigos golpeados
			Golpear a un enemigo que tiene un planeta orbitándolo aumentará la velocidad del planeta
			Esto se acumula hasta 8 veces
			Los golpes furtivos hacen que dos planetoides más pequeños orbiten adicionalmente al objetivo golpeado
			<right> para destruir todos los planetas y planetoides existentes
			'''
	}

	ShogunChestplate: {
		DisplayName: Pechera del Shogún Resbaladizo
		Tooltip:
			'''
			20% más de daño
			Reduce el daño recibido un 9% y aumenta enormemente la regeneración de vida
			Aumenta la vida y el maná máximos en 150
			'''
	}

	ShogunHelm: {
		DisplayName: Yelmo del Shogún Resbaladizo
		Tooltip:
			'''
			20% más de daño
			15% más de probabilidad de ataque crítico
			15% más de velocidad cuerpo a cuerpo
			'''
		SetBonus:
			'''
			+5 súbditos máximos
			+100 de sigilo máximo mientras sostengas un arma de Pícaro
			{$CommonItemTooltip.FlightAndSlowfall}
			Llevar puestas alas anula este vuelo
			{$CommonItemTooltip.PressDownToHover}
			Permite la habilidad de impulsarte y potencia otros impulsos
			Mantén ABAJO para caer rápidamente
			Aumenta la velocidad de salto
			Otorga inmunidad al retroceso y a muchos efectos negativos de fin de juego
			'''
	}

	ShogunPants: {
		DisplayName: Pantalones del Shogún Resbaladizo
		Tooltip:
			'''
			20% más de daño
			50% más de velocidad de movimiento
			Mejora enormemente la aceleración y la maniobrabilidad
			'''
	}

	AuricSole: {
		DisplayName: Suela Áurica
		Tooltip:
			'''
			<right> para desactivar
			Te permite deslizarte sobre cualquier superficie
			Advertencia: Puede resultar en velocidades extraordinariamente altas
			'Yharim te odiaría por esto'
			'''
	}

	DischargedAuricSole: {
		DisplayName: Suela Áurica Descargada
		Tooltip:
			'''
			<right> para activar
			Te permite deslizarte sobre cualquier superficie
			Advertencia: Puede resultar en velocidades extraordinariamente altas
			'Yharim te odiaría por esto'
			'''
	}

