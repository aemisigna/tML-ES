	StellarGeliathTrophy: {
		DisplayName: Trofeo del Geliat Estelar
		Tooltip: ""
	}

	PumpActionSwampgun: {
		DisplayName: Escopeta de Bombeo del Pantano
		Tooltip: Dispara una ráfaga generalmente inofensiva de slime
	}

	Parasanguine: {
		DisplayName: Parasanguine
		Tooltip:
			'''
			Mantener <left> o golpear enemigos acumula sangre excedente
			<right> cuando tu medidor de sangre esté alto para expulsar tu excedente
			<left> después de hacer clic derecho para realizar un giro devastador
			'¿Qué obtienes al alimentar a un slime? Un slime más grande.'
			'''
	}

	Gobflogger: {
		DisplayName: Gobflogger
		Tooltip:
			'''
			{$CommonItemTooltip.SummonTagDamage}
			{$CommonItemTooltip.Whips}
			Golpear enemigos otorga un pequeño impulso a la velocidad de ataque del látigo
			'Despacio y con paso firme se gana la carrera'
			'''
	}

	CrystalGauntlets: {
		DisplayName: Guanteletes de Cristal
		Tooltip:
			'''
			Mantén <left> para cargar una poderosa ráfaga de rayo esférico
			Cuando la carga esté completa, suelta <left> para desatar el rayo esférico sobre tus enemigos
			<right> para aplaudir, detonando todo el rayo esférico desatado
			'¡Poder ilimitado!'
			'''
	}

	SplendorJam: {
		DisplayName: Mermelada del Esplendor
		Tooltip:
			'''
			Activa la Barra de Estrés
			El estrés se acumula pasivamente, aunque estar cerca de enemigos acelera la velocidad a la que aumenta
			Emites luz que se ajusta según tu nivel de Estrés
			Otorga un Espectáculo al 0%, 25%, 50%, 75% y 100% de Estrés
			Al 25% de Estrés tus armas producirán explosiones
			Al 75% de Estrés tus explosiones se volverán más grandes e infligirán más daño
			Pulsa dos veces ABAJO mientras el Estrés esté por encima del 25% para entrar en Modo Malicia
			El Modo Malicia aumenta significativamente tu daño, además de otorgar daño plano, penetración de armadura y probabilidad de ataque crítico
			Estos beneficios y su duración se ajustan según la cantidad de estrés que tengas
			'Algo horrible se aproxima...'
			'''
		StressBar: Estrés: {0}
	}

	SludgeShaker: {
		DisplayName: Agitador de Lodo
		Tooltip:
			'''
			Rocía una considerable mezcla de slime pegajoso
			El slime se adhiere a estructuras y a otro slime mientras es expulsado
			'Agitado, no revuelto'
			'''
	}

	SupremeRestorationPotion: {
		DisplayName: Poción de Restauración Omega
		Tooltip: "{$ItemTooltip.RestorationPotion}"
	}

	ChromaticTorch: {
		DisplayName: Antorcha Cromática
		Tooltip: ""
	}

	StickyHand: {
		DisplayName: Mano Asquerosa
		Tooltip:
			'''
			Se desengancha automáticamente cuando estás cerca del gancho
			Mantén pulsado el botón del gancho para mantenerlo pegado a los bloques
			'No se romperá, lo prometo'
			{$}
			'''
		Stats:
			'''
			Alcance: 56
			Velocidad de Lanzamiento: 25
			Velocidad de Retorno: 10
			Velocidad de Tracción: 17
			'''
	}

	Trailblazer: {
		DisplayName: Abrecaminos
		Tooltip:
			'''
			Usa gel como munición
			Ignora 30 puntos de la Defensa enemiga
			80% de probabilidad de no consumir munición
			'''
	}

	SlimeCane: {
		DisplayName: Bastón de Slime
		Tooltip:
			'''
			Invoca a un grupo de 4 escuderos de slime para protegerte
			Usar el arma de nuevo consumirá un espacio de súbdito para mejorar los slimes
			Los slimes pueden mejorarse un máximo de 4 veces
			Una vez que los slimes hayan sido mejorados por completo, aparecerá un Goozmoem que dispara rayos de fusión a los enemigos
			'Si tan solo pudiera borrar las impurezas y hacerlo tan hermoso como yo'
			'''
	}

	FissionFlyer: {
		DisplayName: Volador de Fisión
		Tooltip:
			'''
			Arroja un chakram que se divide en una andanada de 3 Anillos de Filo
			Los golpes furtivos dejan atrás una hoja colosal
			'''
	}

	ScytheOfTheOldGod: {
		DisplayName: Guadaña del Dios Antiguo
		Tooltip:
			'''
			Blande una guadaña colosal en un combo de tres tajos
			'No confundir con la Guadaña del Viejo Duque...
			...Y nada más.'
			'''
	}

	Goomoire: {
		DisplayName: Goomoire
		Tooltip:
			'''
			Lanza un hechizo de sellado que succiona a los enemigos
			'¡Al pozo no! ¡Quema!'
			'''
	}

	SlimeNinjaStatue: {
		DisplayName: Estatua del Ninja Slime
		Tooltip:
			'''
			Rodéala con 4 Estatuas de Slime para empoderarla
			Puede realizar varios rituales cuando está empoderada
			'¿Quién es este tipo, de todos modos?'
			'''
	}

	GelatinousCatalyst: {
		DisplayName: Catalizador Gelatinoso
		Tooltip: Úsalo en una Estatua del Ninja Slime empoderada para iniciar una Lluvia de Slime
	}

	PluripotentSpawnEgg: {
		DisplayName: Huevo de Cría Pluripotente
		Tooltip:
			'''
			Úsalo en una Estatua del Ninja Slime empoderada para invocar algo siniestro
			No se consume
			'''
	}

	PaladinPalanquin: {
		DisplayName: Palanquín del Paladín
		Tooltip:
			'''
			Invoca una montura de Burbuja Aceitosa que se puede cabalgar
			'¡Se siente como ser de la realeza!'
			'''
	}

	ChromaticGooztick: {
		DisplayName: Gooztick Cromático
		Tooltip: Ignora la gravedad y rebota en los bloques
	}

	BadApple: {
		DisplayName: Manzana Podrida
		Tooltip:
			'''
			'Una manzana de un árbol arrasado durante uno de los arrebatos de Goozma.
			Parece haberse transformado en algo prácticamente nuevo, y como resultado probablemente sepa terrible.
			Si el sabor no es extraño, el olor ciertamente lo es.'
			'''
	}

	CometKunai: {
		DisplayName: Kunai Cometa
		Tooltip:
			'''
			Libera una ráfaga de kunais y estrellas que se duplican con cada golpe exitoso
			Los golpes furtivos invocan una lluvia de estrellas donde caigan
			'El poder de las estrellas, en la palma de mi mano...'
			'''
	}

