	}

	SlimeMonsoonMonolith: {
		DisplayName: Monolito del Monzón de Slime
		Tooltip: "'Invoca una cantidad bastante considerable de slime'"
	}

	CrimulanMask: {
		DisplayName: Máscara Crimulana
		Tooltip: ""
	}

	DivineMask: {
		DisplayName: Máscara Divina
		Tooltip: ""
