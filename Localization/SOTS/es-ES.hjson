		Configs: {
			SOTSConfig: {
				DisplayName: Configuración

				Headers: {
					UI: Interfaz
					GS: Ajustes Gráficos
					TPS: Ajustes del Paquete de Texturas
					GPS: Ajustes de Jugabilidad
					MS: Ajustes de Música
				}

				StarterHouseType: {
					Label: Tipo de Casa Inicial (Al Generar el Mundo)
					Tooltip:
						'''
						-2 = Sin casa inicial (estás loco)
						-1 = Casa inicial aleatoria
						0 = Legacy House
						1 = Legacy Angel
						2 = Legacy Barrel
						3 = Legacy BIG Hotel
						4 = Legacy Origin
						5 = Legacy Tower
						6 = Legacy Sword
						7 = Legacy Tree
						8 = Legacy Library
						9 = Legacy Crate
						10 = Mushnib's
						11 = Astrobit's
						12 = Bloodmoon
						13 = Bandit
						14 = Boulder
						15 = Mine
						16 = Tavern
						17 = Chaos
						18 = Drowned
						19 = Comfy
						20 = Nature
						'''
				}

				voidBarPointX: {
					Label: Barra del Vacío X
					Tooltip:
						'''
						Posición horizontal de la Barra del Vacío en la pantalla
						Medida en píxeles desde la izquierda
						'''
				}

				voidBarPointY: {
					Label: Barra del Vacío Y
					Tooltip:
						'''
						Posición vertical de la Barra del Vacío en la pantalla
						Medida en píxeles desde arriba
						'''
				}

				lockVoidBar: {
					Label: Bloquear Barra del Vacío
					Tooltip:
						'''
						Evita que la Barra del Vacío sea movida por tu cursor
						También evita que la Barra del Vacío cambie de posición automáticamente al usar el ajuste de interfaz de Estilo de Vida y Maná 'Barras'
						'''
				}

				alternateVoidBarDirection: {
					Label: Dirección Alternativa de la Barra del Vacío
					Tooltip: Cambia la dirección de desplazamiento de la Barra del Vacío
				}

				alternateVoidBarStyle: {
					Label: Estilo Alternativo de la Barra del Vacío
					Tooltip: Modifica ligeramente los efectos visuales de la Barra del Vacío
				}

				voidBarTextOn: {
					Label: Texto Superior de la Barra del Vacío
					Tooltip: Activa/desactiva el texto sobre la Barra del Vacío
				}

				voidBarHoverTextOn: {
					Label: Texto al Pasar el Cursor sobre la Barra del Vacío
					Tooltip: Activa/desactiva el texto que aparece al pasar el cursor sobre la Barra del Vacío
				}

				simpleVoidText: {
					Label: Texto Simple de la Barra del Vacío
					Tooltip: Elimina los indicadores de cantidad de Súbditos del Vacío del texto de la Barra del Vacío
				}

				simpleVoidFill: {
					Label: Relleno Simple de la Barra del Vacío
					Tooltip: Elimina las líneas divisorias entre los elementos internos de relleno de la Barra del Vacío
				}

				lowFidelityMode: {
					Label: Modo de Rendimiento
					Tooltip:
						'''
						Reduce varios efectos visuales para aumentar los cuadros por segundo
						Afecta principalmente a los visuales relacionados con jefes y las estelas de proyectiles
						'''
				}

				coloredTimeFreeze: {
					Label: Congelamiento de Tiempo con Color
					Tooltip: Determina si el color de la pantalla durante el congelamiento de tiempo tiene tinte o es en blanco y negro
				}

				screenShake: {
					Label: Vibración de Pantalla
					Tooltip: Solo afecta la vibración de pantalla originada por SOTS
				}

				additionalTexturePackVisuals: {
					Label: Efectos Visuales Adicionales
					Tooltip:
						'''
						Agrega visuales adicionales, como partículas de polvo, a algunos bloques
						Solo funciona con el Paquete de Texturas de SOTS activado
						'''
				}

				alternativeMusic: {
					Label: Música Alternativa de SOTS
					Tooltip:
						'''
						Si está activado, SOTS reproducirá la banda sonora hecha por Banana Lizard donde corresponda
						Si está desactivado, SOTS reproducirá la banda sonora hecha por Heart Plus Up donde corresponda
						'''
				}

				SanctuaryLagReduction: {
					Label: Reducción de Lag en el Santuario
					Tooltip: Si está activado, reduce la cantidad de resplandores difuminados usados en el Santuario, mejorando el rendimiento
				}
			}

			SOTSServerConfig: {
				DisplayName: Configuración del Servidor

				Headers: {
					GPS: Ajustes de Jugabilidad
					BAL: Cambios de Balance
				}

				NerfInsignia: {
					Label: Debilitar la Insignia Voladora Antes de Lux
					Tooltip:
						'''
						Debilita la Insignia Voladora, haciendo que solo otorgue vuelo infinito después de derrotar a Lux.
						Antes de derrotar a Lux, solo duplicará tu tiempo de vuelo.
						Si no estás de acuerdo con este cambio, puedes desactivarlo aquí.
						'''
				}

				AddPlightToVanillaRecipes: {
					Label: Añadir Aflicción a Recetas Vanilla
					Tooltip: Desactiva y recarga para quitar el Alma de la Aflicción de las recetas que normalmente no la requieren
				}

				GeneratePhaseOreAfterDefeatingLux: {
					Label: Generar Mineral de Fase Tras Derrotar a Lux
					Tooltip: Desactiva para evitar que el Mineral de Fase se genere después de la primera derrota de Lux
				}

				NaturallySpawningPeanutBushes: {
					Label: Arbustos de Maní con Generación Natural
					Tooltip: Desactiva para evitar que los Arbustos de Maní crezcan naturalmente sobre el césped
				}
			}
		}

