		Items: {
			AncientSteelBar: {
				# Abandoned Village
				DisplayName: Barra de Acero Antiguo
				Tooltip: "'Un proto-acero antiguo usado por varias civilizaciones... y goblins'"
			}

			AncientSteelHalberd: {
				DisplayName: Alabarda de Acero Antiguo
				Tooltip:
					'''
					Hace añicos a los enemigos, haciendo que el siguiente ataque cuerpo a cuerpo sea un golpe crítico garantizado que ignora la defensa
					La alabarda no puede aprovechar el efecto de hacer añicos
					'''
			}

			AncientSteelLongbow: {
				DisplayName: Arco Largo de Acero Antiguo
				Tooltip:
					'''
					Debe cargarse antes de disparar
					Las flechas viajan rápido y explotan en metralla perforante que causa 100% de daño al golpear enemigos
					'''
			}

			AncientSteelSword: {
				DisplayName: Espada de Acero Antiguo
				Tooltip:
					'''
					Hace daño en área al golpear, equivalente al 80% del daño
					Los golpes críticos causan 50% más de daño y también pueden aplicar un sangrado permanente acumulable que causa 5 de daño por segundo
					'''
			}

