					Libera más ondas con poca vida
					Las ondas ignoran hasta 16 de defensa en total
					Las ondas se desactivan mientras está oculto
					'''
			}

			PurpleJellyfishStaff: {
				DisplayName: Bastón de Medusa Morada
				Tooltip:
					'''
					Dispara 2 orbes morados que, al detonar, liberan trueno morado hacia tu cursor
					El trueno morado se encadena entre enemigos por 70% de daño
					Proporciona una fuente de luz mientras está marcado como favorito en el inventario
					'''
			}

			Riptide: {
				DisplayName: Resaca
