					Libera ondas de daño periódicamente
					Libera más ondas con poca vida
					Las ondas ignoran hasta 8 de defensa
					Aumenta la vida máxima en 20
					Las ondas se desactivan mientras está oculto
					'Muerte por latido'
					'''
			}

			PinkJellyfishStaff: {
				DisplayName: Bastón de Medusa Rosa
				Tooltip: Dispara un rayo rosa que se encadena entre enemigos por 60% de daño
			}

			PiscesPuncher: {
				DisplayName: Puño de Piscis
				Tooltip:
					'''
					'pez'
					'sustantivo'
					'un animal vertebrado de sangre fría, sin extremidades, con branquias y aletas, que vive enteramente en el agua'
					'''
			}

			PistolShrimp: {
				DisplayName: Camarón Pistola
				Tooltip:
					'''
					Dispara plasma caliente de camarón que persigue a los enemigos cercanos
					'El trabajo en equipo hace que el sueño funcione'
					'''
			}

			PlasmaShrimp: {
				DisplayName: Camarón de Plasma
				Tooltip:
					'''
					Por encima del 40% de maná, las armas mágicas disparan plasma caliente de camarón adicional por 50% de daño
					Reduce el costo de maná en 5%
					'Ya no tan camarón'
					'''
			}

			PrismarineNecklace: {
				DisplayName: Collar de Prismarina
