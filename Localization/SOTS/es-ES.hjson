			Apocalypse: {
				# Celestial
				DisplayName: Apocalipsis
				Tooltip:
					'''
					Libera un trueno verde hacia tu cursor
					El trueno verde rebota entre enemigos causando 90% de daño
					Proporciona una fuente de luz mientras esté marcado como favorito en el inventario
					'Poder directo del inframundo'
					'''
			}

			CataclysmSpheres: {
				DisplayName: Esferas del Cataclismo
				Tooltip: Lanza un racimo de bombas cargadas que explotan en rayos del cataclismo autodirigidos que causan 100% de daño
			}

			CatalystBomb: {
				DisplayName: Bomba Catalizadora
				Tooltip: "'Es casi lo bastante fuerte como para abrir un agujero entre dimensiones, si tan solo se usara en el lugar correcto'"
			}

			ContinuumCollapse: {
				DisplayName: Colapso del Continuo
				Tooltip:
					'''
					'Devora todo lo que es infinito, incluida la memoria de tu sistema'
					Puede golpear hasta 15 enemigos a la vez
					No dañará a los jugadores
					'''
			}

			DanceOfDeath: {
				DisplayName: Danza de la Muerte
				Tooltip: Invoca muchas guadañas demoníacas a tu alrededor
			}

			DimensionShredder: {
				DisplayName: Desgarrador de Dimensiones
				Tooltip:
					'''
					Invoca wisps dimensionales a tu alrededor que disparan hacia tu cursor
					Haz clic derecho para invocar un racimo de wisps dimensionales
					Las balas atraviesan bloques y liberan rayos que causan 50% de daño
					66% de probabilidad de no consumir munición
					'Abre una grieta a través de tus enemigos'
					'''
			}

			FoggyClairvoyance: {
				DisplayName: Clarividencia Nebulosa
				Tooltip:
					'''
					Aumenta el daño en 15% y otorga inmunidad a la mayoría de los efectos negativos
					'Maldito'
					'''
			}

			Lemegeton: {
				DisplayName: Lemegeton
				Tooltip:
					'''
					Invoca una horda de wisps para defenderte de los enemigos cercanos
					Los wisps rojos atacarán a los enemigos más cercanos y robarán vida causando 100% de daño
					Los wisps verdes dispararán ráfagas de corto alcance que causan 200% de daño
					Los wisps morados lanzan un racimo de proyectiles autodirigidos que causan 75% de daño cada uno
					'''
			}

			PlasmaCutterButOnAChain: {
				DisplayName: Cortador de Plasma con Cadena
				Tooltip: "'Esta es una idea sumamente maravillosa'"
			}

			SanguiteBar: {
				DisplayName: Escamas de Sanguita
				Tooltip: "'Huele a azufre y sangre'"
			}

			SerpentSpine: {
				DisplayName: Espina de Serpiente
				Tooltip:
					'''
					Aumenta el tamaño de las armas cuerpo a cuerpo en 40% y la longitud de los látigos en 40%
					Aumenta la velocidad cuerpo a cuerpo en 10%
					Los ataques cuerpo a cuerpo y de látigo pueden chamuscar a los enemigos, aumentando permanentemente el daño causado en 3%
					'''
			}

			SubspaceBag: {
				DisplayName: Bolsa del Tesoro (Serpiente del Subespacio)
				Tooltip: "{$CommonItemTooltip.RightClickToOpen}"
			}

			SubspaceLocket: {
				DisplayName: Medallón del Subespacio
				Tooltip:
					'''
					Invoca a un Sirviente del Subespacio para que te asista en combate
					Usa por ti el objeto en tu último espacio de inventario
					Reduce el daño en 25% de forma multiplicativa
					Aumenta el vacío máximo en 50, pero reduce la curación recibida de las pociones en 40
					'''
			}

			SubspaceScissors: {
				DisplayName: Tijeras Espirituales
				Tooltip: "'Asistencia desde el purgatorio'"
			}

			VoidspaceAuraStaff: {
				DisplayName: Báculo de Aura del Espacio Vacío
				Tooltip:
					'''
					Invoca una Célula del Espacio Vacío en tu cursor que libera llamas hacia todos los enemigos cercanos
					Otorga mejoras de estadísticas mientras estés dentro del radio de la célula
					La velocidad de regeneración de vacío aumenta en 4%, la regeneración de vida en 4, la defensa en 4, y reduce el daño recibido en 4%
					El alcance escala con el daño de invocación
					'''
			}

			VoidspaceEmblem: {
				DisplayName: Emblema del Espacio Vacío
				Tooltip:
					'''
					Aumenta el daño de vacío y el daño mágico en 10%
					Aumenta la probabilidad de golpe crítico de vacío en 10%
					Los golpes críticos restauran pequeñas cantidades de vacío
					Reduce el costo de vacío en 8%
					Aumenta la ganancia de vacío en 4 y el vacío máximo en 50
					Regenera vacío al ser golpeado
					Inmunidad a Armadura Rota e Ícor
					'''
			}

			Armaggedon: {
				# Chaos
				DisplayName: Armagedón
				Tooltip:
					'''
					Desata una ráfaga de golpes
					Proporciona una fuente de luz mientras esté marcado como favorito en el inventario
					'Poder proveniente de los cielos'
					'''
			}

			ChaosChamber: {
				DisplayName: Cámara del Caos
				Tooltip:
					'''
					Descarga casi tan rápido como se aprieta el gatillo
					Las balas obtienen capacidad autodirigida
					Transforma las balas en esferas láser cada 6º disparo
					'''
			}

			EtherealScepter: {
				DisplayName: Cetro Etéreo
				Tooltip:
					'''
					Invoca una Llama Etérea que lucha por ti
					Las Llamas Etéreas atacan a los enemigos embistiéndolos rápidamente
					'''
			}

			Hyperdrive: {
				DisplayName: Hipermotor
				Tooltip:
					'''
					La segunda carga de un Crusher tiene 33% de probabilidad de no consumir vacío
					La cuarta carga de los Crushers ya no consume vacío
					Extiende el alcance de los Crushers en 1
					Aumenta la velocidad de ataque en 25% y el daño cuerpo a cuerpo en 5%
					Reduce el costo de vacío en 10%
					'''
			}

			HyperlightGeyser: {
				DisplayName: Géiser de Hiperluz
				Tooltip: Lanza 4 rayos de luz que se dirigen cada uno hacia hasta 10 enemigos
			}

			LuxBag: {
				DisplayName: Bolsa del Tesoro (Lux)
				Tooltip: "{$CommonItemTooltip.RightClickToOpen}"
			}

			ParticleRelocator: {
				DisplayName: Reubicador de Partículas
				Tooltip:
					'''
					Cuando un enemigo te golpea, serás teletransportado detrás de él, evitando el daño y congelándolo en el tiempo temporalmente
					Tiene un tiempo de reutilización de 16 segundos, pero aumenta el daño cuerpo a cuerpo en 50% durante 7 segundos después de teletransportarte
					Causa daño igual a tu defensa
					'''
			}

			PhaseBar: {
				DisplayName: Barra de Fase
				Tooltip: "'Está al borde de la realidad'"
			}

			PhaseOre: {
				DisplayName: Mena de Fase
				Tooltip: ""
			}

			RealityShatter: {
				DisplayName: Fractura de la Realidad
				Tooltip: Los enemigos reciben una ráfaga adicional de cortes que causan 4x50% de daño
			}

			RoseBow: {
				DisplayName: Arco de Rosa
				Tooltip:
					'''
					Transforma las flechas en lanzas de luz que pueden atravesar paredes
					Cuando se cargan brevemente, las flechas explotan causando 600% de daño
					Cuando se cargan completamente, las flechas florecen causando 1500% de daño
					Cargar también conjura espinas, que son lanzadas causando 2x100% de daño cada una
					Solo consume vacío al cargarse
					'''
			}

			StellarSerpentLauncher: {
				DisplayName: Lanzador de Serpiente Estelar
				Tooltip: Lanza una Serpiente de Luz Estelar que se dirige hacia los enemigos y los ataca repetidamente
			}

			StellarShot: {
				DisplayName: Disparo Estelar
				Tooltip: Dispara rápidamente láseres perforantes
			}

			SupernovaStorm: {
				DisplayName: Tormenta de Supernova
				Tooltip:
					'''
					Invoca un Rayo de Supernova desde el cielo
					Hace que los enemigos se rompan en proyectiles autodirigidos que causan 3x140% de daño
					'''
			}

			VoidmageIncubator: {
				DisplayName: Incubadora del Mago del Vacío
				Tooltip:
					'''
					Gamer Épico
					Aumenta la ganancia de vacío en 2
					Ser golpeado congelará el tiempo, convirtiendo vacío en vida durante la duración
					Aumenta la potencia de Choque de Vacío y Recuperación de Vacío
					Permite acceso a recetas de fabricación de agujeros de gusano
					'''
			}

			SpiritSymphony: {
				DisplayName: Sinfonía Espiritual
				Tooltip:
					'''
					Aumenta la ganancia de vacío en 1 y la velocidad de regeneración de vacío en 25%
					Duplica el daño causado a los enemigos espirituales que no sean Lux
					'''
			}

			SpiritInsignia: {
				DisplayName: Insignia Espiritual
				Tooltip:
					'''
					Otorga vuelo infinito con alas y botas cohete
					Aumenta la movilidad de vuelo y salto
					Aumenta la ganancia de vacío en 1 y la velocidad de regeneración de vacío en 25%
					Duplica el daño causado a los enemigos espirituales que no sean Lux
					'''
			}

			BagOfAmmoGathering: {
				# ChestItems
				DisplayName: Bolsa de Recolección de Munición
				Tooltip:
					'''
					20% de probabilidad de no consumir munición
					Golpear enemigos tiene probabilidad de reembolsar munición
					Asestar el golpe de gracia a los enemigos también puede reembolsar munición
					'''
			}

			BetrayersKnife: {
				DisplayName: Cuchillo del Traidor
				Tooltip:
					'''
					Ataca con 2 cortes, que siempre hacen sangrar a los enemigos en el primer golpe
					El segundo corte causa 150% de daño
					'''
			}

			CoconutGun: {
				DisplayName: Pistola de Coco
				Tooltip:
					'''
					Lanza bombas racimo de coco con metralla autodirigida de leche de coco
					'Dispara a chorros'
					'''
			}

			GlazeBow: {
				DisplayName: Arco Glaseado
				Tooltip:
					'''
					Concentra niebla helada para potenciar tus flechas
