				SetBonus:
					'''
					Los enemigos golpeados por el teletransporte quedarán temporalmente congelados en el tiempo
					Reduce el tiempo de reutilización del teletransporte a 6 segundos y aumenta en un 50% el rango en el que los enemigos reciben daño del teletransporte
					Aumenta el daño del teletransporte según los modificadores de daño de vacío
					'''
			}

			ElementalLeggings: {
				DisplayName: Pantalones Elementales
				Tooltip:
					'''
					Aumenta el daño de invocación, el alcance de látigo y la velocidad de movimiento en un 15%
					Aumenta la probabilidad de golpe crítico cuerpo a cuerpo en un 15%
					Aumenta la ganancia de vacío en 2 y el vacío máximo en 100
