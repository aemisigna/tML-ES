			ElementalBreastplate: {
				DisplayName: Peto Elemental
				Tooltip:
					'''
					Aumenta el daño cuerpo a cuerpo y de invocación en un 30%
					Aumenta la regeneración de vida en 4
					Presiona '{0}' para teletransportarte a tu cursor, causando 200% de tu defensa como daño a todos los enemigos en tu camino
					Tiene un tiempo de reutilización de 15 segundos, pero aumenta la velocidad cuerpo a cuerpo en un 40% durante el tiempo de reutilización
					'''
			}

			ElementalHelmet: {
				DisplayName: Casco Elemental
				Tooltip:
					'''
					Aumenta el daño cuerpo a cuerpo, de invocación y de vacío en un 15%
					Aumenta la ganancia de vacío en 3 y el vacío máximo en 100
					Aumenta el máximo de esbirros en 2
