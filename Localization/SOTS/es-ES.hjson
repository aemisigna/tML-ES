			Atlantis: {
				DisplayName: Atlantis
				Tooltip:
					'''
					Lanza un tridente leal que regresa poco después
					Clic derecho para lanzar un Tiburón de Agua teledirigido
					Si el tridente golpea a un enemigo en su regreso, robará vida y otorgará una mejora al atraparlo
					La mejora aumenta el daño mágico y cuerpo a cuerpo según los aumentos de estadísticas del otro, aumenta la velocidad de movimiento en un 20% y reduce el daño recibido en un 10%
					Mientras está mejorado, esta arma tampoco consume vacío
					Los enemigos golpeados por el Tiburón de Agua o el tridente al regresar serán rodeados de agua, cortados varias veces por un 20% de daño, y ralentizados
					'''
			}

			LockingMechanism: {
