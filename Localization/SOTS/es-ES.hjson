			VoidspaceMask: {
				DisplayName: Máscara del Guardabosques del Vacío
				Tooltip:
					'''
					Aumenta la probabilidad de golpe crítico mágico y a distancia en un 25%
					Aumenta la probabilidad de golpe crítico de vacío en un 15% y la mana máxima en 100
					Aumenta la ganancia de vacío en 4 y el vacío máximo en 50
					'''
				SetBonus:
					'''
					Los ataques infligen permanentemente el efecto negativo Llamas del Subespacio, que causa 10 de daño por segundo
					Cuando un enemigo con Llamas del Subespacio muere, inflige a todos los demás enemigos un daño igual al daño acumulado que recibió por Llamas del Subespacio
					Los enemigos que reciban daño de esta forma también serán afligidos con Llamas del Subespacio
					'''
			}

			VoidspaceBreastplate: {
				DisplayName: Peto del Guardabosques del Vacío
				Tooltip:
					'''
					Al recibir daño, el 15% del daño recibido se convierte en vacío
					Al usar vacío, el 15% del vacío usado se convierte en vida
					Reduce el costo de mana en un 15%
					Aumenta la ganancia de vacío en 3 y el vacío máximo en 100
					'''
			}

			VoidspaceLeggings: {
				DisplayName: Pantalones del Guardabosques del Vacío
				Tooltip:
					'''
					Aumenta el daño mágico y a distancia en un 25%
					Aumenta el daño de vacío en un 15% y la velocidad de movimiento en un 20%
					Aumenta la ganancia de vacío en 3 y el vacío máximo en 50
					'''
			}

			HandCannon: {
				DisplayName: Cañón de Mano
				Tooltip:
					'''
					Dispara tres balas: la bala central causa 100% de daño y las balas laterales causan 75% de daño
					Convierte balas de mosquete en balas explosivas
					'''
			}

			MineralSpewer: {
				DisplayName: Escupidor de Hollín
				Tooltip:
					'''
					Cubre a los enemigos con polvo combustible
					Los enemigos cubiertos de polvo combustionan al ser incendiados, recibiendo instantáneamente todo el daño que habría causado el efecto negativo de fuego
					'''
			}

			AutoClicker: {
				DisplayName: Clicker Automático
				Tooltip: Aumenta la velocidad de ataque en un 10% y hace que todos los objetos se usen automáticamente de forma repetida
			}

			SupernovaEmblem: {
				DisplayName: Emblema de la Supernova
				Tooltip:
					'''
					Matar enemigos libera un buscador que causa 150% de daño
					Los enemigos muertos por buscadores liberan 2 buscadores adicionales, cada uno causando 75% de daño
					Aumenta el daño cuerpo a cuerpo en un 15%
					Aumenta la ganancia de vacío en 2 y el vacío máximo en 50
					Al recibir daño, el 12% del daño recibido se convierte en vacío
					Inmunidad a Armadura Rota e Icor
					'''
			}

			InfinityPouch: {
				DisplayName: Bolsa del Infinito
				Tooltip: Consume vacío en lugar de munición
			}

			ChallengerRing: {
				DisplayName: Anillo del Retador
				Tooltip:
					'''
					Clic derecho mientras está marcado como favorito para invertir la gema actualmente seleccionada, desactivando el efecto de la gema y activando el efecto invertido
					0
					1
					2
					3
					4
					5
					6
					'''
				G0: Encadena bloques al minar, rompiendo hasta 50 bloques a la vez
				G1: Matar enemigos otorga una mejora aleatoria durante 30 segundos
				G2: Genera monedas al ganar vacío
				G3: Los enemigos tienen 14.3% de probabilidad de soltar el doble de botín
				G4:
					'''
					Los enemigos muertos tienen 50% de probabilidad de soltar corazones adicionales
					Esta probabilidad aumenta al 100% con golpes críticos
					Recolectar corazones extiende la duración de las mejoras activas, hasta el doble de la duración original
					'''
				G5:
					'''
					Aumenta el daño según la defensa, luego reduce la defensa en un tercio del aumento de daño
					Aumenta el daño en {0}%
					Reduce la defensa en {1}
					'''
				G6: Recibir daño otorga una mejora aleatoria durante 30 segundos
				# Opposite of Sloth, Diligence
				I0:
					'''
					Aumenta la velocidad de colocación de bloques y paredes en un 20% y el rango de colocación en 3
					Aumenta la velocidad de movimiento en un 20%
					'''
				# Opposite of Wrath, Patience
				I1: Recibe una mejora aleatoria durante 30 segundos cada 20 segundos
				# Opposite of Greed, Charity
				I2:
					'''
					Al recibir daño, el 10% del daño recibido se convierte en vacío
					Al usar vacío, el 10% del vacío usado se convierte en vida
					'''
				# Opposite of Envy, Kindness
				I3:
					'''
					Reduce el daño recibido en un 15%
					Reduce el daño causado en un 15%
					'''
				# Opposite of Gluttony, Temperance
				I4:
					'''
					Otorga Bien Alimentado permanente
					Los consumibles de vacío recuperan 75% menos vacío
					'''
				# Opposite of Pride, Humility
				I5:
					'''
					Ya no puedes causar golpes críticos
					Los aumentos recibidos a la probabilidad de golpe crítico se convierten en aumentos multiplicativos al daño
					'''
				# Opposite of Lust, Chastity
				I6:
					'''
					Las mejoras no decaen mientras estés por encima del 90% de vida
					Recibir daño estando por debajo del 90% de vida hace que la duración de todas las mejoras se reduzca a la mitad
					'''
			}

			EarthGrinder: {
				DisplayName: Trituradora de Tierra
				Tooltip:
					'''
					Clic derecho para golpear con 2 tajos
					El primer tajo siempre será crítico
					El segundo tajo golpeará a los enemigos repetidamente
					'''
			}

			Tesseract: {
				DisplayName: Teseracto
				Tooltip:
					'''
					Invoca un Clon del Vacío que usa objetos para atacar enemigos
					Comenzando con el objeto en la ranura inferior izquierda del inventario y terminando con la ranura inferior derecha, cada Clon usa un objeto diferente
					Al ser invocado por primera vez, el Clon esperará una orden sobre cómo debe usar el objeto (clic izquierdo o derecho) y por cuánto tiempo (para objetos con carga)
					Después del primer uso del objeto, el Clon lo usará automáticamente según lo especificado
					Los objetos usados por los Clones se ven afectados por los bonos de daño de Vacío e Invocación, pero tienen el daño reducido en un 30% de forma multiplicativa
					'''
			}

			InfiniteVoid: {
				DisplayName: Vacío Infinito
				Tooltip: Aumenta el vacío máximo en 10000
			}

			TinyPlanetoid: {
