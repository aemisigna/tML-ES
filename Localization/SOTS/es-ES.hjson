		EggDescription: {
			0: "'Esto podría venderse a buen precio'"
			1: "'Esto pertenece a una colección'"
			2: "'Una recompensa por aventurarse'"
			3: "'Refleja la luz de manera hermosa'"
			4: "'Calienta tu espíritu'"
			5: "'El mundo es tuyo'"
			6: "'Puede que haya algo que aprender de este huevo'"
			7: "'Quizás pueda cambiar tu destino'"
			x0: "'No parece muy valioso'"
			x1: "'No pertenece a tu colección'"
			x2: "'No valió la pena la aventura'"
			x3: "'Se ve apagado'"
			x4: "'Se siente terriblemente frío'"
			x5: "'No pertenece a tu actuación'"
			x6: "'No puede enseñarte nada'"
			x7: "'No puedes escapar de tu destino'"
