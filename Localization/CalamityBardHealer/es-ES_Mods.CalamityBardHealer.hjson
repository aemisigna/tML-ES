			'''
	}

	TimesOldRoman: {
		DisplayName: Times Old Roman
		Tooltip:
			'''
			Blande una pluma cómicamente grande que deja un rastro de tinta dañino
			El rastro de tinta puede otorgarle esencia del alma al usuario
