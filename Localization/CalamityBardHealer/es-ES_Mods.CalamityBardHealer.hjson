	BelchingSaxophone: {
		DisplayName: "{$Mods.CalamityMod.Items.Weapons.Magic.BelchingSaxophone.DisplayName}"
		Tooltip:
			'''
			Dispara una variedad de lengüetas, burbujas y notas
			Las lengüetas y burbujas infligen irradiación
			Las notas infligen [cbuff:CalamityMod/SulphuricPoisoning] y [cbuff:70]
			'''
