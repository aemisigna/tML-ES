	PurgatoriumPandemonium: {
		DisplayName: Pandemonio Purgatorio
		Tooltip:
			'''
			Ignora 150 puntos de defensa
			Dispara una descarga de almas buenas y malas que ondulan mientras viajan
			Las almas buenas persiguen a los jugadores y los curan, o curan al usuario si golpean enemigos
			Las almas malas persiguen a los enemigos e infligen muerte susurrante al golpearlos
			"¡La primera alma en salvar a un jugador moribundo gana un boleto solo de ida al Cielo!"
			'''
	}

	ReturntoSludge: {
		DisplayName: Vuelta al Lodo
		Tooltip:
			'''
			Mantén <left> para acumular una bomba de lodo y suelta para dispararla
			La bomba de lodo inflige más daño cuanto más tiempo se cargue
			La bomba de lodo puede infligir hasta 10 veces más daño como máximo
			'''
	}

	SARS: {
		DisplayName: S.A.R.S.
		Tooltip:
			'''
			Ignora 10 puntos de defensa
			Libera rastros de plaga mientras gira
