	}

	StarCluster: {
		DisplayName: Cúmulo de Estrellas
		Tooltip:
			'''
			Mantén <left> para acumular lentamente un cúmulo de estrellas
			Suelta <left> para liberarlas todas de golpe en una ráfaga
			Las estrellas perforan infinitamente, pero solo pueden golpear al mismo enemigo una vez
			La cantidad máxima de estrellas que se pueden acumular es igual a la inspiración máxima
			'''
	}

	StatigelEarrings: {
		DisplayName: Aretes de Estatigel
		Tooltip:
			'''
			10% más de daño y velocidad de ejecución sinfónica
			7% más de probabilidad de golpe crítico sinfónico
			Los instrumentos de cuerda rebotan una vez adicional
			'''
	}

	StatigelFoxMask: {
		DisplayName: Máscara de Zorro de Estatigel
		Tooltip:
			'''
			9% más de daño y velocidad de lanzamiento radiante
			27% menos de daño no radiante
			Los hechizos de curación curan 4 de vida adicional
			'''
		SetBonus:
			'''
			9% más de velocidad de curación
			14% más de daño radiante
			'''
	}

	Supercluster: {
		DisplayName: Supercúmulo
		Tooltip:
			'''
			Dispara un cúmulo en miniatura de estrellas que caen hacia arriba
