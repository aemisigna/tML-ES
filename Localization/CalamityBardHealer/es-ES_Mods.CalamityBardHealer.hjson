			'''
	}

	TreeWhispererAmulet: {
		DisplayName: Amuleto del Susurrador de Árboles
		Tooltip:
			'''
			12% más de daño, velocidad de ejecución y probabilidad de golpe crítico sinfónico
			Los instrumentos de cuerda rebotan dos veces adicionales
			Tus ataques con instrumentos de viento ahora intentan autoguiarse rápidamente hacia enemigos
			Si el ataque ya se autoguía hacia enemigos, lo hace con mayor rapidez
			Los golpes críticos causados por ataques de instrumentos de metal liberan una dispersión de energía perforante
			Los golpes críticos de percusión infligen 10% más de daño y aturden brevemente a los enemigos
			"¡Habla por los árboles, escúchalos, usa sus ideas para componer algunos ritmos!"
			'''
	}

	TreeWhisperersHarp: {
		DisplayName: Arpa del Susurrador de Árboles
		Tooltip:
			'''
			Dispara un tronco de árbol que se ramifica y crece hojas
			Las hojas eventualmente caen y se autoguían hacia los enemigos
			"Todos necesitan un amigo, ¡incluso un pequeño árbol feliz!"
			'''
	}

	Trinity: {
		DisplayName: Trinidad
		Tooltip:
			'''
			Gira una guadaña triple muy veloz que golpea objetivos con mayor frecuencia
			Los golpes con esta arma ocasionalmente generan tres rayos curvos de fuego astral
			<right> para arrojar la guadaña, que se curvará en su camino de regreso
			La guadaña inflige 30% más de daño al ser arrojada
			'''
	}

	VictideAmmoniteHat: {
		DisplayName: Sombrero de Amonita Victide
		Tooltip: 5% más de daño sinfónico y velocidad de regeneración de inspiración
		SetBonus: +1.5 de regeneración de vida por segundo y 10% más de velocidad de regeneración de inspiración mientras estás sumergido en líquido
	}

	Violince: {
		DisplayName: Violince
		Tooltip:
			'''
			Dispara una dispersión de icor rebotante
			Acertar el ritmo correctamente aumenta constantemente su nivel de empoderamiento y velocidad
			Cada 3 aciertos de ritmo consecutivos, la cantidad de proyectiles disparados aumenta hasta un máximo de 6
			{$Mods.ThoriumMod.Common.Tooltips.BigInstrument}
			"Clasificada +18 por saxo y violince"
			Basada en el violín de "Blood Coagulant" por DM Dokuro feat. SixteenInMono
			'''
	}

	Vivapollum: {
		DisplayName: Vivapollum
		Tooltip:
			'''
			Dispara una ráfaga de burbujas abisales que explotan al golpear infligiendo opresión vital
			Quedarte sin inspiración provoca un torrente ascendente de burbujas abisales de corta duración
			Una vez activado, no puede volver a ocurrir hasta que el usuario recupere toda su inspiración
			'''
	}

	VoidFaquirBiretta: {
		DisplayName: Birreta de Sacerdote de Guerra Faquir del Vacío
		Tooltip:
			'''
			+30% de Daño Radiante
			-35% de Daño No Radiante
			+15% de Velocidad de Curación
			+8 de Curación Adicional
			<armorBonus>
			'''
		SetBonus:
			'''
			Aumenta la energía del vacío generada poco después de curar a un aliado u obtener esencia del alma
			La energía del vacío obtenida al curar aliados disminuye lentamente cuanto más tiempo los cures
			'''
	}

	VoidFaquirChapeau: {
		DisplayName: Sombrero de Cantante de la Muerte Faquir del Vacío
		Tooltip:
			'''
			+25% de Daño Sinfónico
			+15% de Velocidad de Ejecución Sinfónica
			+15% de Velocidad de Regeneración de Inspiración
			<armorBonus>
			'''
		SetBonus:
			'''
			Aumenta la energía del vacío generada por cada empoderamiento activo
			Aumenta aún más cuanto mayor sea el nivel de cada empoderamiento
			'''
	}

	WilloftheRagnarok: {
		DisplayName: Voluntad del Ragnarök
		Tooltip:
			'''
			Efectos combinados de todas las degradaciones
			"Borra a quienes perturben el equilibrio del universo"
			'''
	}

	Windward: {
		DisplayName: A Favor del Viento
		Tooltip: Dispara dos plumas ligeramente autoguiadas
	}

	WulfrumMegaphone: {
		DisplayName: Megáfono Wulfrum
		Tooltip:
			'''
			Dispara una onda sonora que crece y acelera
			Atraviesa objetivos, pero el daño se reduce en una cantidad fija
			Afina a los objetivos al golpear, aumentando el daño que reciben en un 5%
			"¡He aquí! ¡El Insultador-Barato-Inator!"
			'''
	}

	WulfrumWeedWacker: {
		DisplayName: Desmalezadora Wulfrum
		Tooltip:
			'''
			Esta guadaña se blande direccionalmente en vez de girar
			Dispara una onda de corto alcance en cada golpe
			"La desmalezadora wulfrum desmaleza maleza con wulfrum"
			'''
	}

	YharimsJam: {
		DisplayName: Jam de Yharim
		Tooltip:
			'''
			930 de daño sinfónico
			Invoca tres parlantes supersónicos que flotan a tu lado y debajo de ti
			Los parlantes dispararán ritmos ardientes que rastrean al enemigo más cercano
			Inflige [cbuff:CalamityMod/Dragonfire] y afinación a los enemigos golpeados
			"Estamos superando la barrera del sonido con este [i/s1:2701][i/s1:2701][i/s1:2701]"
			'''
	}
}

