			'''
	}

	IntergelacticProtectorHelm: {
		DisplayName: Casco Protector Intergaláctico
		Tooltip:
			'''
			11% más de daño, probabilidad de golpe crítico y velocidad de lanzamiento radiante
			33% menos de daño no radiante
			Los hechizos de curación curan 4 de vida adicional
			'''
		SetBonus:
			'''
			22% más de daño radiante
			Los hechizos de curación curan 6 de vida adicional
			Los asteroides tienen 20% de probabilidad de curar {0} de vida al golpear enemigos
			'''
	}

	InterstellarShredder: {
		DisplayName: Trituradora Interestelar
		Tooltip:
			'''
			Dispara un cristal de llama astral rebotante, no perforante y autoguiado
			El cristal está acompañado de dos láseres astrales que rebotan dos veces
			<right> para invocar 6 cristales de llama astral a costa de más inspiración
			Inflige infección astral al golpear
			"¡Riffs increíbles que viajan por todo el universo!"
			Basado en el solo de guitarra de "Interstellar Stomper" por DM Dokuro
			'''
