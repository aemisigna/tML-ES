ItemDescriptions: {
	AstralBreastplate: +6 de inspiración máxima y +4 de curación adicional
	AstralHelm: 12% más de velocidad de regeneración de inspiración
	CelestialCarrier: Los hechizos de curación curan 4 de vida adicional mientras uses la Armadura Celestial
	ChampionWing: 10% más de daño
	DemonshadeGreaves:
		'''
		Aumenta tus puntos de técnica máximos en 2, tu inspiración máxima en 15 y tu curación adicional en 25 de vida
		Aumenta la velocidad de persecución y el alcance de los instrumentos de viento en un 60%, y los instrumentos de cuerda rebotan seis veces adicionales
		Duplica el radio de efecto de tus empoderamientos y extiende su duración en 6 segundos
		'''
	DemonshadeHelm:
		'''
		30% más de daño radiante y sinfónico
		35% más de velocidad de curación, lanzamiento radiante y ejecución sinfónica
		55% más de velocidad de regeneración de inspiración y probabilidad de caída de notas
		'''
	DemonBloodWings: Regeneración de vida rápida durante el modo Furia mientras uses la Armadura de Sangre Demoníaca
	DragonWings: Los ataques infligen infierno maldito mientras uses la Armadura de Dragón
	DreadWings: Multiplicador de daño del modo Furia aumentado mientras uses la Armadura del Pavor
	DridersGrace: Aumenta el número máximo de esbirros en 1 al usar la Armadura de Araña
	FleshWings: Los ataques tienen probabilidad de robar vida mientras uses la Armadura de Carne
	OmegaBlueSet:
		'''
		Aumenta los puntos de técnica máximos en 2 y la inspiración en 12
		Los hechizos de curación curan 7 de vida adicional
		'''
	OmegaBlueSetNoThrower: Aumenta la inspiración máxima en 12 y la curación adicional en 7 de vida
	RelicOfConvergence: No activa efectos al curar
	ShootingStarTurboTuba: 15% más de velocidad de regeneración de inspiración mientras uses la Armadura de Estrella Fugaz
	TerrariumWings: El tiempo de vuelo se duplica al usar la Armadura de Terrarium
	TitanWings: 15% más de daño y reducción de daño especial mientras uses la Armadura Titánica
	WhiteDwarfThrusters: Las armas arrojadizas tardan un 50% más en agotarte mientras uses la Armadura de Enano Blanco
	WulfrumJacket: 25% más de alcance de empoderamiento
}

WhisperingHood: {
	DesertScourge: Odio la arena, es áspera, es rasposa, se mete en todos lados...
	Crabulon: Todo vuelve a ser cangrejo, tal como vuelve a la tierra...
	HiveMind: Y aun así no pudieron ponerse de acuerdo en cómo derrotarnos...
	PerforatorHive: No creí que fuera posible que un tumor creciera tanto...
	SlimeGod: Con "otro día" te refieres a "nunca"...
	AquaticScourge: ¿Alguna vez te preguntaste cómo se siente nadar en ácido estomacal?
	Leviathan: Ahí va el grandote... ¿Me pregunto quién lo habrá invitado?
	Anahita: Toda esa presentación solo para caer con más fuerza...
	CalamitasClone: Fraude.
	PlaguebringerGoliath: El olor, persiste...
	AstrumAureus: Como con cualquier araña, quémala hasta las cenizas...
	AstrumDeus: Para ser un "Dios", lo único que pudo mostrar fue el motivo de su propia derrota...
	Ravager: La verdad es que es igual a su predecesor...
	Providence: Sorprendente seguir pudiendo ver después de todo eso...
	Polterghast: Tal vez todas esas almas debieron haberse unido en una forma más ideal...
	OldDuke: Ok, boomer.
	DevourerofGods: Palabras valientes de alguien que está al alcance de estas manos...
	Yharon: Ok, ¿pero y si esta es una pelea que sí puedo ganar?
}

Items: {
	AerospecBiretta: {
		DisplayName: Birreta Aerospec
		Tooltip:
			'''
			7% más de daño radiante y velocidad de lanzamiento
			15% menos de daño no radiante
			Los hechizos de curación curan 2 de vida adicional
			'''
		SetBonus:
			'''
			5% más de velocidad de movimiento
			13% más de daño radiante
			Los hechizos de curación curan 3 de vida adicional mientras estás en el aire
			'''
	}

	AerospecHeadphones: {
		DisplayName: Auriculares Aerospec
		Tooltip: 8% más de daño sinfónico y velocidad de ejecución
		SetBonus:
			'''
			5% más de velocidad de movimiento y velocidad de regeneración de inspiración
			10% más de velocidad de persecución de instrumentos de viento
			'''
	}

	AnahitasArpeggio: {
		DisplayName: "{$Mods.CalamityMod.Items.Weapons.Magic.AnahitasArpeggio.DisplayName}"
		Tooltip:
			'''
			Dispara claves de sol rebotantes
			Las claves de sol vuelven a orbitar el cursor pasado un tiempo
			Mientras orbitan, el daño infligido aumenta según cuántas veces rebotaron antes
			Basada en el arpa de "Forbidden Lullaby" por DM Dokuro
			'''
	}

	AquaiusAdvice: {
		DisplayName: Consejo de Aquaius
		Tooltip:
			'''
			Dispara rápidamente tentáculos abisales que se curvan en direcciones aleatorias
			Eventualmente se asientan y forman corrientes de agua dañinas
			Inflige [cbuff:CalamityMod/CrushDepth] al golpear
			"Ahógate en las profundidades, o resurge de ellas... como aconsejó Aquaius, la Marea Sin Fin"
			'''
	}

	ArcticReinforcement: {
		DisplayName: Refuerzo Ártico
		Tooltip:
			'''
			Dispara una mini tormenta de nieve de carámbanos
			"La contraparte polar norteña"
			Basada en el xilófono de "Antarctic Reinforcement" por DM Dokuro
			'''
	}

	AugmentedAuricTeslaFeatheredHeadwear: {
		DisplayName: Tocado Emplumado Áurico Tesla[c/70f4f4:+]
		Tooltip:
			'''
			25% más de daño sinfónico
			20% más de probabilidad de golpe crítico sinfónico
