			'''
			Efectos de las armaduras Bardo Intergeláctica, Bloodflare y del Verdugo de Dioses
			Presiona {0} para hacer los asteroides más transparentes
			El dash del Verdugo de Dioses usa la tecla de habilidad de armadura de Calamity
			Canción Seductora usa la tecla de habilidad de armadura de Thorium
			Aumenta la duración del empoderamiento en 5 segundos
			Aumenta la velocidad de regeneración de inspiración en 20%
			Aumenta la probabilidad de caída de notas de inspiración en 45%
			'''
	}

	AugmentedAuricTeslaValkyrieVisage: {
		DisplayName: Semblante de Valquiria Áurico Tesla[c/70f4f4:+]
