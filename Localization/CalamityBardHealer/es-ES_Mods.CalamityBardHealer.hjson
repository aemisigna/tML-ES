		DisplayName: Canción del Cosmos
		Tooltip:
			'''
			Ignora 75 puntos de defensa
			Dispara cinco rayos cósmicos que se mueven en patrón de hélice
			Puede golpear al mismo objetivo varias veces
			Infligir suficiente daño permite usar <right> con esta arma para invocar un pequeño estallido
			Los pequeños estallidos producen estrellas más débiles que se autoguían hacia el enemigo más cercano e infligen el doble de daño
			Mientras cualquier pequeño estallido esté activo, el costo de inspiración se reduce a la mitad
			"La misma canción que armoniza el universo"
			'''
	}

	SongoftheElements: {
		DisplayName: Canción de los Elementos
		Tooltip:
			'''
			Ignora 25 puntos de defensa
			Dispara tres rayos elementales que se mueven en patrón de hélice
			Puede golpear al mismo objetivo varias veces
			"La misma canción que trae equilibrio a muchos mundos"
			'''
	}

