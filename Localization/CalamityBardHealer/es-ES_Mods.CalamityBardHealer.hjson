	IrradiatedKusarigama: {
		DisplayName: Kusarigama Irradiada
		Tooltip:
			'''
			Esta maza cuenta como una guadaña
			Realiza un combo doble arrojando primero un núcleo de maza y luego una pequeña guadaña
			Los golpes con la bola generan niebla curativa, con solo 3 permitidas a la vez
			Los golpes con la guadaña, o cuando regresa al usuario, crean burbujas autoguiadas
			Inflige [cbuff:70] y [cbuff:CalamityMod/SulphuricPoisoning] al golpear
			'''
	}

	LostOasis: {
		DisplayName: Oasis Perdido
		Tooltip:
			'''
			Invoca un oasis en expansión
			Cura cada medio segundo
			"Da igual chicos, ya lo encontré"
			'''
	}

	MilkyWay: {
		DisplayName: Vía Láctea
		Tooltip:
			'''
			Ignora 35 puntos de defensa
			<right> para arrojar la guadaña, que se curvará en su camino de regreso
			Emite estrellas desde la distancia que giran en espiral hacia adentro
			"Los astros se han alineado"
			'''
	}

	NoisebringerGoliath: {
		DisplayName: Goliat Portador de Ruido
		Tooltip:
			'''
