Buffs: {
	AlluringSong: {
		DisplayName: Canción Seductora
		Description:
			'''
			50% más de velocidad de regeneración de inspiración y alcance de empoderamiento
			La duración del empoderamiento se extiende 5 segundos más
			Recibir daño te cura 250 de vida fija, pero elimina Canción Seductora
			"Para conquistar a algunas elementales"
			'''
	}

	AlluringSongCD: {
		DisplayName: Tiempo de Reutilización de Canción Seductora
		Description:
			'''
			No puedes usar Canción Seductora por un tiempo
			"Nunca vuelvas a cocinar"
			'''
	}

	CalamityBell: {
		DisplayName: Campana de Calamity
		Description: Solo está ahí, esperando, amenazante...
	}
}

FargoEnchantments: {
	AtaxiaEnchant:
		'''
		Recibir más de 75 de daño genera un oasis que dura 3 segundos
		El oasis cura vida equivalente a tu curación adicional cada 1/3 de segundo
		Los golpes críticos sinfónicos hacen que los objetivos estallen en llamas de sulfuro
		Solo puede ocurrir una erupción y tiene un tiempo de reutilización de 3 segundos por activación
		'''
	BloodflareEnchant:
		'''
		Presiona la tecla de 'Habilidad de Armadura' para usar la mitad de tu vida e invocar un ritual de curación que curará a los aliados una cantidad equivalente a tu curación adicional
		Solo puede haber un ritual activo a la vez y esta habilidad no tiene tiempo de reutilización, pero abusar de ella te matará
		Al hacer esto también obtienes la mejora Canción Seductora por 5 segundos
		Canción Seductora aumenta la velocidad de regeneración de inspiración y el alcance de empoderamiento en 50%, y la duración del empoderamiento en 5 segundos
		Recibir daño mientras Canción Seductora está activa te cura 200 de vida fija, pero elimina Canción Seductora
		'''
	GodSlayerEnchant:
		'''
		Una campana de Calamity flota sobre tu cabeza y suena ocasionalmente mientras atacas
		Cuando la campana suena, los enemigos a tu alrededor reciben 15000 de daño verdadero y los proyectiles enemigos cercanos son destruidos
		'''
	SilvaEnchant: Recibir daño intenso de un solo golpe le otorga a los jugadores con menos vida la mejora Ángel Guardián por 30 segundos
	TarragonEnchant:
		'''
		Generas dos silencios de negra a tu alrededor que curan inspiración al golpear enemigos
		Ocasionalmente emites un pulso curativo que cura y protege a los aliados una cantidad equivalente a tu curación adicional
		'''
}

Configs: {
	BalanceConfig: {
		DisplayName: Configuración de Equilibrio

		expensiveDraedonsForge: {
			Label: Forja de Draedon Costosa
			Tooltip: La Forja de Draedon requiere materiales raros de Thorium para ser fabricada
		}

		rogueThrowerMerge: {
			Label: Fusionar las clases Pícaro y Lanzador
			Tooltip: Se desactiva automáticamente cuando el mod Ragnarok está instalado
		}

		generalItemBalanceChanges: {
			Label: Cambios Generales de Equilibrio de Ítems
			Tooltip: Habilita cambios de equilibrio variados en los ítems de Thorium
		}

		showItemChanges: {
			Label: Mostrar Cambios de Ítems
			Tooltip: Define si se muestra o no el tooltip "Modificado por" en los ítems cambiados por este mod
		}

		defenseDamage: {
			Label: Daño por Defensa en enemigos de Thorium
			Tooltip: Habilita el daño por defensa para los enemigos de Thorium
		}

		convertItems: {
			Label: Convertir ítems de Calamity a sus respectivas clases de Thorium
			Tooltip:
				'''
				Convierte ciertos ítems de Calamity en un ítem de bardo o sanador
				Podría rediseñar los ítems respectivos para que funcionen mejor con este cambio
				Ítems modificados:
				-Arpegio de Anahita -> Instrumento de cuerda, su comportamiento también fue rediseñado
				-Saxofón Eructante -> Instrumento de metal
				-Derretidor de Rostros -> Híbrido de instrumento eléctrico-de cuerda, su comportamiento también fue rediseñado
				-Reliquia de Convergencia -> Hechizo de curación, curación base aumentada para mantenerse a la par de otros hechizos de curación
				'''
		}

		bard: {
			Label: Multiplicador de daño de armas de bardo
			Tooltip:
				'''
				Multiplicador de daño para armas de bardo
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}

		radiant: {
			Label: Multiplicador de daño de armas radiantes
			Tooltip:
				'''
				Multiplicador de daño para armas de sanador ofensivo
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}

		soulEssence: {
			Label: Multiplicador de esencia del alma
			Tooltip:
				'''
				Multiplicador de esencia del alma otorgada para armas de sanador ofensivo
				Limitado a 5
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}

		healing: {
			Label: Multiplicador de curación
			Tooltip:
				'''
				Multiplicador de curación para hechizos de curación
				Un valor de 0 significa que solo curará 1 de vida
				(¡Se requiere reiniciar el mundo para que esto tenga efecto!)
				'''
		}
	}
}
