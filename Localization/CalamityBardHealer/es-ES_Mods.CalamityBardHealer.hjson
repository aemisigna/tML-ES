			El oasis cura {0} de vida cada 1/3 de segundo
			Solo puede haber un oasis activo a la vez
			'''
	}

	HydrothermicHat: {
		DisplayName: Sombrero Hidrotérmico
		Tooltip:
			'''
			12% más de daño sinfónico
			5% más de velocidad de ejecución sinfónica
			10% más de probabilidad de golpe crítico sinfónico
			'''
		SetBonus:
			'''
			15% más de daño crítico de percusión
			Aumenta la velocidad de regeneración de inspiración en 12%
			Los golpes críticos sinfónicos hacen que los objetivos estallen en llamas de sulfuro
