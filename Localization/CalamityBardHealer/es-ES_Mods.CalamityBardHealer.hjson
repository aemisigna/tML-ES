	Procioplexon: {
		DisplayName: Procioplexón
		Tooltip:
			'''
			100 de Penetración de Armadura
			Esta guadaña se blande direccionalmente en vez de girar
			Envía mareas abisales en cada golpe junto con tajos abisales
			Cada tercer golpe, la guadaña gira sobre sí misma
			Mientras gira, esta arma libera múltiples tormentas implacables
			'''
