	BigBangCymbals: {
		DisplayName: Platillos del Big Bang
		Tooltip:
			'''
			Mantén <left> y suelta para cargar un gran estruendo
			Libera una imprecisa ráfaga de estrellas que se expanden hacia afuera
			'''
	}

	BloodflareRitualistMask: {
		DisplayName: Máscara de Ritualista Bloodflare
		Tooltip:
			'''
			15% más de daño y probabilidad de golpe crítico radiante
			25% menos de daño no radiante
			+80 de vida máxima
			Regeneración de vida moderadamente aumentada
			Los hechizos de curación curan 12 de vida adicional
			'''
		SetBonus:
			'''
			27% más de daño radiante
			11% más de velocidad de lanzamiento radiante
			Presiona '{0}' para usar la mitad de tu vida e invocar un ritual de curación
			El ritual curará a los aliados por {1} de vida rápidamente
			Solo puede haber un ritual activo a la vez
			Esta habilidad no tiene tiempo de reutilización, pero abusar de ella te matará
			'''
	}

	BloodflareSirenSkull: {
		DisplayName: Cráneo de Sirena Bloodflare
		Tooltip:
			'''
			10% más de daño y probabilidad de golpe crítico sinfónico
			12% más de velocidad de ejecución sinfónica
			'''
		SetBonus:
			'''
			+4 de inspiración máxima
			8% más de daño sinfónico
			5% más de probabilidad de golpe crítico y velocidad de ejecución sinfónica
			Aumenta la duración del empoderamiento en 4 segundos
			Presiona '{0}' para obtener la mejora Canción Seductora por 5 segundos
			Canción Seductora aumenta la velocidad de regeneración de inspiración y el alcance de empoderamiento en 50%, y la duración del empoderamiento en 5 segundos
			Recibir daño mientras Canción Seductora está activa te cura 200 de vida fija, pero elimina Canción Seductora
			Canción Seductora tiene un tiempo de reutilización de 45 segundos
			'''
	}

	BloomingSaintessDevotion: {
		DisplayName: Devoción de la Santa Floreciente
		Tooltip:
			'''
			Dispara un tallo expansivo que florece en flores explosivas
			"La devoción inspira valentía, la valentía inspira sacrificio"
			'''
	}

	BloomingSaintessStatue: {
		DisplayName: Estatua de la Santa Floreciente
		Tooltip:
			'''
			Vida máxima aumentada en 20
			Maná máximo aumentado en 20
			12% más de velocidad de curación
			14% más de daño radiante
			6% más de velocidad de lanzamiento radiante
			8% más de probabilidad de golpe crítico radiante
			Los hechizos de curación curan 2 de vida adicional
			Empodera los ataques radiantes con amanecer roto
			"Por suerte, es demasiado grande para caber en un frasco"
			'''
	}

	CherubimOmega: {
		DisplayName: Cherubim Omega
		Tooltip:
			'''
			Ignora 75 puntos de defensa
			Esta guadaña se blande direccionalmente en vez de girar
			Envía tajos de siega divina hacia el cursor en cada golpe
			Los tajos abren una gran grieta en el tejido de la realidad
			La grieta libera hasta cinco energías celestiales autoguiadas
			Cada tercer golpe, la guadaña gira sobre sí misma
			Mientras gira, la cantidad de tajos generados se duplica
			"Un momento, ¡esto no es Celestus!"
			'''
	}

	ChristmasCarol: {
		DisplayName: Villancico Navideño
		Tooltip:
			'''
			Arroja una pandereta grande y muy decorada que vuelve a ti
			Al golpear, la pandereta rebota hacia atrás y luego se congela en el aire para bombardear al último objetivo golpeado con adornos
			Acertar el ritmo correctamente aumenta constantemente su nivel de empoderamiento y daño
			Acertar el ritmo correctamente también hace que la pandereta embista a los enemigos
			{$Mods.ThoriumMod.Common.Tooltips.BigInstrument}
			'''
	}

	ColdShoulder: {
		DisplayName: Frialdad
		Tooltip:
			'''
			Ignora 10 puntos de defensa
			Gira una guadaña criónica que inflige [cbuff:324] al golpear
			Escupe constantemente carámbanos que infligen 50% de daño
			<right> para arrojar la guadaña, que se curvará en su camino de regreso
			La guadaña inflige 30% más de daño al ser arrojada
			"¡Toma tu dosis de frialdad!"
			'''
	}

	CottonMouth: {
		DisplayName: Boca Seca
		Tooltip:
			'''
			Ignora 20 puntos de defensa
			Esta guadaña se blande direccionalmente en vez de girar
			Dispara una ráfaga de nubes de gas ácido por cada golpe
			Inflige [cbuff:70] y [cbuff:CalamityMod/SulphuricPoisoning] al golpear
			'''
	}

	CrystalHydraulophone: {
		DisplayName: Hidrauliófono de Cristal
		Tooltip:
			'''
			Dispara dos cristales de agua curvos que se hacen añicos al golpear
			"Lo mejor del hombre es como el agua, el agua beneficia a todas las cosas"
			Basado en el sonido similar al piano de "Sanctuary" por DM Dokuro
			'''
	}

	DaedalusCowl: {
		DisplayName: Capucha de Dédalo
		Tooltip:
			'''
			10% más de daño radiante
			25% menos de daño no radiante
			5% más de velocidad de curación
			Los hechizos de curación curan 3 de vida adicional
			'''
		SetBonus:
			'''
			25% más de daño radiante
			Los hechizos de curación curan 1 de vida adicional
			Presiona '{0}' para invocar una máquina de helados en tu ubicación, presiona '{0}' de nuevo para desinvocarla
			Los jugadores pueden hacer clic derecho en la máquina de helados para recibir la mejora Subidón de Azúcar por 1 minuto
			Los jugadores también se curan {1}0 de vida al hacerlo, pero tiene un tiempo de reutilización de 3 minutos
			'''
	}

	DaedalusHat: {
		DisplayName: Sombrero de Dédalo
		Tooltip:
			'''
			13% más de daño sinfónico
			7% más de probabilidad de golpe crítico sinfónico
			'''
		SetBonus:
			'''
			5% más de velocidad de ejecución sinfónica
			Aumenta la velocidad de regeneración de inspiración en 10%
			Aumenta la duración del empoderamiento en 3 segundos
			El daño sinfónico inflige [cbuff:44] y [cbuff:324] al golpear
			Los aliados cercanos tienen probabilidad de infligir [cbuff:44] al golpear
			'''
	}

	DeathAdder: {
		DisplayName: Víbora de la Muerte
		Tooltip:
			'''
			Ignora 35 puntos de defensa
			Esta guadaña se blande direccionalmente en vez de girar
			Dispara una ráfaga de espíritus fantasma en cada golpe
			Los espíritus fantasma persiguen a los objetivos
			"Omnicidio estaría orgulloso... y enfadado"
			'''
	}

	DesertedDrugDeal: {
		DisplayName: Sangre de Grandes Tiburones de Arena
		Tooltip:
			'''
			Ignora 30 puntos de defensa
			Dispara jeringas llenas de sangre de Gran Tiburón de Arena
			Las jeringas se aferran a enemigos o jugadores golpeados y los inyectan
			Al hacerlo, los daña continuamente o cura si es un jugador
			Inflige [cbuff:CalamityMod/CrushDepth] y [cbuff:CalamityMod/ArmorCrunch] a los enemigos golpeados
			Inflige [cbuff:ThoriumMod/LifeRecovery] de larga duración a los aliados curados
			Puede usarse para curarte a ti mismo
			"Contiene una pequeña cantidad de Herobrine"
			'''
	}

	Disaster: {
		DisplayName: Desastre
		Tooltip:
			'''
			Ignora 70 puntos de defensa
			Crea tres látigos ardientes que dejan un rastro de tajos
			Cada tercer golpe, la guadaña gira sobre sí misma
			Al girar, deja atrás un torbellino abrasador en su lugar
			El torbellino abrasador daña tanto a jugadores como a enemigos
			Inflige [cbuff:CalamityMod/VulnerabilityHex] al golpear
			Esta guadaña se blande direccionalmente en vez de girar
			[c/C61B40:'¿Estás seguro de querer perder la vida?]
			[c/C61B40:¿A manos de una bruja que solo te ha traído conflicto?']
			'''
	}

	DoomsdayCatharsis: {
		DisplayName: Catarsis del Juicio Final
		Tooltip:
			'''
			Dispara rápidamente un bocinazo ardiente que se autoguía hacia los objetivos
			Ignora 35 puntos de defensa
			Inflige [cbuff:CalamityMod/Dragonfire] al golpear
			Cada 25.° ataque, dos versiones más grandes del arma aparecen a los costados de la pantalla para atacar en una dirección fija
			Acertar el ritmo correctamente aumenta constantemente su nivel de empoderamiento, daño, alcance de persecución y cantidad de trompetas
			{$Mods.ThoriumMod.Common.Tooltips.BigInstrument}
			"¡Necesita al menos tres pulmones para tocarse! Es decir, de a pares"
			'''
	}

	DryMouth: {
		DisplayName: Sequedad Bucal
		Tooltip:
			'''
			Ignora 5 puntos de defensa
			Esta guadaña se blande direccionalmente en vez de girar
			Dispara una tormenta de polvo en miniatura en cada golpe
			"¡Arena de bolsillo!"
			'''
	}

	Duality: {
		DisplayName: Dualidad
		Tooltip:
			'''
			Gira una guadaña de estatigel que emite energía roja y morada en cada filo
			Golpear enemigos con la energía morada les inflige [cbuff:153]
			Golpear enemigos con la energía roja aumenta enormemente la regeneración de vida
			<right> para arrojar la guadaña, que se curvará en su camino de regreso
			La guadaña inflige 20% más de daño al ser arrojada
			"Tengo dos lados: el que olfida y el que se acurerda"
			'''
	}

	DustDevilDrums: {
		DisplayName: Tambores de Torbellino de Polvo
		Tooltip:
			'''
			Libera unos cuantos torbellinos de polvo alrededor del usuario que atraviesan enemigos y bloques
			Tiene 25% de probabilidad de invocar un torbellino de polvo turquesa que persigue a los enemigos
			"¿Qué travesuras hay que hacer para necesitar un sistema de refrigeración para esto?"
			'''
	}

	ElectricQuarterstaff: {
		DisplayName: S-TSL: Bastón Eléctrico
		Tooltip:
			'''
			Gira un bastón eléctrico aturdidor
			Emite un relámpago encadenado al primer golpe de cada giro
			El relámpago encadenado puede rebotar de nuevo en los mismos enemigos
			"Un bastón retráctil con un táser incorporado"
			'''
	}

	ElementalBloom: {
		DisplayName: Florecimiento Elemental
		Tooltip:
			'''
			Vida máxima aumentada en 40
			Maná máximo aumentado en 20
			15% más de velocidad de curación
			20% más de daño radiante
			10% más de velocidad de lanzamiento radiante
			12% más de probabilidad de golpe crítico radiante
			Los hechizos de curación curan 2 de vida adicional
			Empodera los ataques radiantes con [cbuff:CalamityMod/ElementalMix]
			Aumenta la fuerza de los efectos de daño continuo en 66%
			"Cuando la luz y la oscuridad chocan, armonizan en una forma final"
			'''
	}

	Exorectionist: {
		DisplayName: Exorectionista
		Tooltip:
			'''
			Dispara una larga línea de carga eléctrica que cura rápidamente a los jugadores
			"El intento de Draedon de innovar la tecnología de desfibrilación"
			'''
	}

	FaceMelter: {
		DisplayName: "{$Mods.CalamityMod.Items.Weapons.Magic.FaceMelter.DisplayName}"
		Tooltip:
			'''
			Dispara un chorro de notas al rojo vivo
			Las notas pueden infligir afinación o [cbuff:CalamityMod/Dragonfire], o devolver inspiración
			Las notas infligen más daño contra objetivos que sufren efectos de daño continuo
			<right> para invocar un amplificador que dispara notas hacia tu cursor
			"¡WOOO!! ¡MUNDOOO FAAAAANTÁSTICOOO!"
			'''
	}

	FeralKeytar: {
		DisplayName: Keytar Feral
		Tooltip:
			'''
			Ignora 30 puntos de defensa
			Dispara un pentagrama musical que atraviesa indefinidamente
			"Una amalgama muy feral de notas y almas"
			'''
	}

	FilthyFlute: {
		DisplayName: Flauta Inmunda
		Tooltip:
			'''
			Dispara una bola veloz de infierno maldito
			Acertar el ritmo correctamente aumenta constantemente su nivel de empoderamiento y velocidad
			Al quinto acierto de ritmo consecutivo, atraes a un raro espécimen de arrastrado inmundo que pelea por ti
			{$Mods.ThoriumMod.Common.Tooltips.BigInstrument}
			"La canción de la consciencia colectiva de la corrupción"
			Basada en la flauta de "Filthy Mind" por DM Dokuro feat. SixteenInMono
			'''
	}

	FireHazard: {
		DisplayName: Riesgo de Incendio
		Tooltip:
			'''
			Ignora 15 puntos de defensa
			Libera una ráfaga ardiente de llamas
			Inflige [cbuff:CalamityMod/BrimstoneFlames] al golpear
			"Llamar a esto un riesgo de incendio sería quedarse corto"
			'''
	}

	FlightoftheGoliath: {
		DisplayName: Vuelo del Goliat
		Tooltip:
			'''
			Ignora 20 puntos de defensa
			Dispara misiles enjambradores de plaga que atacan continuamente a su objetivo
			"¡HAGAN RUIDOOOOO!"
			Basado en el sonido chiptune de "Fly of Beelzebub" por DM Dokuro
			'''
	}

	Gashadokuro: {
		DisplayName: Gashadokuro
		Tooltip:
			'''
			Toca la icónica campana que todos conocen y aman
			Inflige [cbuff:CalamityMod/VulnerabilityHex] al golpear y causa que rayos de piedra sulfúrea castiguen a los enemigos
			[c/C61B40:'Una campana perteneciente a un músico legendario, si tan solo aún estuviera con nosotros...']
			'''
	}

	GelatinTherapy: {
