				}
			}

			Ninja.DisplayName: Ninja
			BuilderDroneBig.DisplayName: Dron Constructor Grande
			BuilderDroneSmall.DisplayName: Dron Constructor Pequeño
			ExplosivePlagueCharger.DisplayName: Cargador Explosivo de la Plaga
			PlagueNuke.DisplayName: Explosión de la Plaga
