		DifficultyUI: {
			Name: Infernum
			ShortDescription:
				'''
				[c/B32E81:Un reto distinto para aquellos que buscan algo muy diferente pero también más exigente que el Modo Muerte.]
				[c/B32E81:Este modo no funciona con el modo Maestro o la semilla «For the Worthy».]
				'''
			ExpandedDescription:
				'''
				[c/B32E81:Varios enemigos principales serán diferentes, teniendo una IA más desafiante.]
				[c/B32E81:La Adrenalina tarda considerablemente más en cargarse.]
				[c/B32E81:La adaptabilidad es imperativa.]
				'''
			InfernumText: Buena suerte.
			InfernumText2: Está bien, supongo.
		}

		ExoMechsFight: {
			PickTwoText: Elige dos. El primer exomecánico se enfrentará solo. Una vez que esté lo suficientemente dañado, se invocará al segundo y los dos lucharán juntos
			ThanatosDesc: Thanatos, un terror serpentino con armadura impermeable e innumerables torretas láser
			AresDesc: Ares, una monstruosidad diabólica y de peso pesado con seis Exo-superarmas
			ArtemisApolloDesc: Artemis y Apollo, un par de destructores extremadamente ágiles con reservas de energía inestables
		}

