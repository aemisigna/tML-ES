		Configs: {
			InfernumConfig: {
				DisplayName: Configuración

				BossIntroductionAnimationsAreAllowed: {
					Label: Introducciones de Jefes
					Tooltip: Habilita animaciones de presentación de jefes. Solo se activan cuando el modo Infernum está activo.
				}

				DisplayTipsInChat: {
					Label: Consejos de la chica del sombrero
					Tooltip: Determina si la mascota del Sombrero de copa maldito debe mostrar sus consejos en el chat o no
				}

				ReducedGraphicsConfig: {
					Label: Configuración gráfica reducida
					Tooltip: Habilita el modo de gráficos reducidos. Use esto si el retraso es un problema.
				}

				FlashbangOverlays: {
					Label: Superposiciones de pantalla
					Tooltip: Habilita los efectos 'flashbang' de superposición de pantalla. Esto no afectará directamente la mecánica del juego.
				}

				CreditsRecordings: {
					Label: Grabación de créditos
					Tooltip: Habilita las grabaciones de material de archivo principal para la reproducción durante los créditos.
				}

				CameraAnimations: {
					Label: Cámara del Vacío Incesante
					Tooltip: Determina si el Vacío Incesante cambia el comportamiento de la cámara durante la pelea.
				}

				CustomAbyssGeneration: {
					Label: Generación personalizada del Abismo
					Tooltip: Solo efectivo durante la generación del mundo, habilita la generación reestructurada del Abismo de Infernum.
				}
			}
		}

