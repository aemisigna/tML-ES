Mods: {
	InfernumMode: {
		Achievements: {
			BabysFirstAchievement: {
				DisplayName: Primera de muchas
				Description:
					'''
					Mientras mas alto el conteo, mas has aprendido
					[c/777777:Muere ante un jefe del modo Infernum]
					'''
			}

			BereftVassalAchievement: {
				DisplayName: Arenas olvidadas
				Description:
					'''
					Supera al Vasallo Despojado en combate, en las lejanas arenas del desierto
					[c/777777:Derrota al Vasallo Despojado]
					'''
			}

			ExoPathAchievement: {
				DisplayName: Rata de laboratorio
				Description:
					'''
					Conviértete en el sujeto de prueba favorito de Draedon
					[c/777777:Supera todas las combinaciones de los Exo Mecánicos en modo Infernum]
					'''
			}

			InfernalChaliceAchievement: {
				DisplayName: Bautizado por el fuego infernal
				Description:
					'''
					Completa el desafío final y gana tu recompensa
					[c/777777:Obtén el Cáliz Infernum]
					'''
			}

			KillAllBossesAchievement: {
				DisplayName: ¡Infer-i-todo!
				Description:
					'''
					Rasgar y rasgar, hasta que esté listo
					[c/777777:Vence a todos los jefes en el modo Infernum]
					'''
			}

			KillAllMinibossesAchievement: {
				DisplayName: ¡Mini-malvado!
				Description:
					'''
					¡Derrota las diversas amenazas menores en todo el mundo!
					[c/777777:Vence a todos los minijefes en el modo Infernum]
					'''
			}

			MechaMayhemAchievement: {
				DisplayName: Maquinaria maliciosa
				Description:
					'''
					¡Desmantela el trío mecánico de una sola vez!
					[c/777777:Derrota a Mechdusa en el modo Infernum]
					'''
			}

			NightProviAchievement: {
				DisplayName: Night Knight
				Description:
					'''
					Desafía a la Diosa Profana bajo la mirada de las estrellas
					[c/777777:Derrota a Providencia durante la noche en el modo Infernum]
					'''
			}

			RamlessDoGAchievement: {
				DisplayName: Rampaje
				Description:
					'''
					Derrota al Devorador en su propio juego: ¡sin un embestida de carnero!
					[c/777777:Derrota al Devorador de Dioses en el modo Infernum sin usar una embestida]
					'''
			}

			Wishes: {
				BlahajWish: {
					DisplayName: Fuerza benevolente
					Description:
						'''
						Abrazos cálidos
						[c/777777:Derrota al Duque Fishron en el modo Infernum en menos de 1 minuto]
						'''
				}

				CrescentWish: {
					DisplayName: Post-apocalíptico
					Description:
						'''
						Los pecados de la bruja nunca podrían ser completamente expiados
						[c/777777:Derrota la Sombra de Calamitas en el inframundo]
						'''
				}

				EggWish: {
					DisplayName: El Elegido
					Description:
						'''
						Las leyendas cuentan de un poderoso guerrero que se aventurará en el mundo y encontrará la legendaria espada escondida dentro
						[c/777777:Encuentra un santuario de huevo después de derrotar al Gólem]
						'''
				}

				MatrixWish: {
					DisplayName: El Método Científico
					Description:
						'''
						Experimentar es fallar. Fallar es aprender. Aprender es avanzar
						Derrota a cada Exo Mecánico y sus combinaciones
						'''
				}

				NightmareWish: {
					DisplayName: El Despertar
					Description:
						'''
						Demanda un sacrificio, y pareces una buena elección
						[c/777777:Duerme en las Grietas de Azufre durante {0} segundos]
						'''
				}

				PurityWish: {
					DisplayName: La Semilla Estelar Bronceadora
					Description:
						'''
						Se siente como vientos solares, y campanas solares
						[c/777777:Derrota a la Providencia Nocturna en el modo Infernum en menos de 3.5 minutos]
						'''
				}

				SakuraWish: {
					DisplayName: Brisa inocente
					Description:
						'''
						Cien espíritus caprichosos, bailando juguetonamente
						[c/777777:Encuentra un capullo de Sakura]
						'''
				}

				StormMaidenWish: {
					DisplayName: Lamento
					Description:
						'''
						Sus lágrimas se mezclan con las gotas de lluvia, lamentándose por todo lo que no pudo ser
						Derrota a los Exo Mecánicos, a Calamitas y encuentra la lanza cerca de tu punto de aparición durante la lluvia
						'''
				}

				TabletWish: {
					DisplayName: Inmaculado
					Description:
						'''
						No todas las bestias son monstruos
						[c/777777:Derrota al Azote Acuático sin dejar que el medidor de ácido exceda el 50% durante la batalla]
						'''
				}

				TophatWish: {
					DisplayName: Asistente increíblemente asinino
					Description:
						'''
						¡Estás mejorando con cada fracaso! ¡Sigue así!
						[c/777777:Ten 3 muertes seguidas contra un jefe]
						'''
				}
			}
		}

		Bestiary: {
			BereftVassal: Un guardián vigilante, una vez vagando sin propósito. Al haber aprendido que su rey aún vive, parece que ha comenzado a recuperar su voluntad de vivir. Espera con ansias luchar contigo nuevamente.
			DepthFeeder: Incluso en el entorno abrumadoramente hostil de la Zona Abisal, los ecosistemas pueden florecer.
			Herring: Inusualmente resistentes, estas criaturas de alguna manera florecen en las cavernas abisales superiores tóxicas. Sin embargo, están en la parte inferior de la cadena alimenticia.
			Lionfish: Estos peces resistentes rara vez son cazados en sus hábitats naturales, confiando en gran medida en sus espinas venenosas tanto para la ofensiva como para la defensa.
		}

