		Items: {
			// Beware translators, this line must match the "enrage" word in the tooltip of your language
			EnrageTooltip: enfurecerá
			DeveloperItem: "[c/{0}:~ Ítem de Desarrollador ~]"
			InfernumOnly: "[c/{0}:Infernum]"
			InfernalRelicText: Imbuido de las llamas infernales de un enemigo derrotado

			Lore: {
				KnowledgeBereftVassal: {
					Lore:
						'''
						Un par inusual de camaradería solitaria.
						Alguna vez un guerrero de renombre noble, parecería que Argus fue uno de los pocos sobrevivientes que emergieron de las ruinas de Ilmeris.
						Sin propósito, buscó refugio en estas enigmáticas ruinas, presenciando en silencio el paso del tiempo hasta tu llegada.
						Destinos como el suyo son la consecuencia de la autocomplacencia equivocada. No causes dolor sin sentido en la búsqueda de causas mayores.
						'''
					DisplayName: El Vasallo Despojado
					Tooltip: ""
				}
			}

			CelestialSigil.SummoningText:
				'''
				Invoca inmediatamente al Señor de la Luna
				Crea una arena en la posición del jugador
				No consumible
				'''

			ProfanedCore: {
				SummoningText: Invoca a Providencia al usarlo en el altar del Templo Profanado en el extremo derecho del Inframundo
				EnrageText: Se enfurece cuando se invoca durante la noche
			}

			ProfanedShard: {
				SummoningText: Invoca a los Guardianes Profanados al usarlo en el acantilado de la izquierda en el Jardín Profanado en el extremo derecho del Inframundo
				GardenWarning:
					'''
					Tu mundo actualmente no tiene un Jardín Profanado. Mata al Señor de la Luna nuevamente para generarlo
					Asegúrate de obtener primero la esquemática del Infierno si haces esto, ya que el jardín podría destruir el laboratorio
					'''
			}

			EyeofDesolation.SummoningText: Invoca a {0} cuando se usa durante la noche
			RuneofKos.DeveloperText: El Vacío Incesante solo puede ser combatido en la librería de la mazmorra

			SandstormsCore: {
				PortalDetail:
					'''
					Abre un portal hacia el Coliseo Perdido
					Debe usarse en el altar en el desierto subterráneo 
					'''
				GatewayWarning: Tu mundo actualmente no tiene un Portal Perdido. Mata al cultista lunático nuevamente para generarlo.
			}

			LihzahrdPowerCell.SummoningText:
				'''
				Invoca a Gólem al usarlo en el Altar de Lihzhard
				El Gólem invocará una arena rectangular alrededor del altar
				Si el altar está dentro del templo, los bloques sólidos dentro de la arena se rompen
				'''

			CherishedSealocket: {
				DisplayName: Amuleto de la querida
				Tooltip:
					'''
					Otorga un campo de fuerza de agua que se disipa después de 2 golpes
					Cuando el campo de fuerza está activo, los golpes fuertes hacen un 60% menos de daño en general, y recibes un aumento de daño del 12%
					El campo de fuerza reaparece después de 90 segundos
					'''
			}

			FlowerOfTheOcean: {
				DisplayName: Flor del océano
				Tooltip:
					'''
					La vocación del arquitecto oceánico calma los cielos nocturnos, bendiciéndolos con la gracia de los mares
					Protege contra eventos nocturnos peligrosos incluso cuando se usa en las ranuras del tocador y otorga una visibilidad mucho mayor mientras está bajo el agua
					'''
			}

			Purity: {
				DisplayName: Pureza
				Tooltip:
					'''
					Multiplica el daño por 1,4x y aumenta un 40% la velocidad de ataque
					Las invocaciones no pueden beneficiarse de esta bonificación de daño
					[c/ff5d5d:No puedes hacer golpes críticos]
					[c/59aae7:Suena como dos hermanos persiguiendo ranas de cristal bajo el sol]
					'''
			}

			// Important: Don't translate this tooltip, currently is being used for the tooltip effect
			SakuraBloom: {
				DisplayName: Flor de Cerezo
				Tooltip:
					'''
					A symbol of how beautiful love is when in bloom, and how easily it can wither away whyyyy
					Temporary
					'''

				TooltipEffect: {
					FirstText: "Un símbolo de lo hermoso que es el "
					SecondText: amor
