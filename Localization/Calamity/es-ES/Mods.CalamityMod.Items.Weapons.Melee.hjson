AbsoluteZero: {
	DisplayName: Cero Absoluto
	Tooltip:
		'''
		Dispara cristales de hielo oscuro
		La hoja crea explosiones de escarcha en golpes directos
		Hoja ancestral imbuida con la magia del Archimago del Hielo
		'''
}

AbyssBlade: {
	DisplayName: Espada del Abismo
	Tooltip:
		'''
		Lanza una espada abisal giratoria que atraviesa enemigos y libera energía acuática al golpear un bloque
		La espada se lanzará hacia los enemigos tras un rebote, infligiendo 2x de daño
		'''
}

AcidwoodSword: {
	DisplayName: Espada de Madera Ácida
	Tooltip: ""
}

AegisBlade: {
	DisplayName: Hoja Égida
	Tooltip:
		'''
		Golpear a un enemigo con la hoja provoca una erupción terrenal
		Pulsa <right> para disparar un rayo égida
		'''
}

AirSpinner: {
	DisplayName: Volteador de Aire
	Tooltip:
		'''
		{$Common.YoyoStats}
		Dispara plumas cuando hay enemigos cerca
		'''
}

AmidiasTrident: {
	DisplayName: Tridente de Amidias
	Tooltip: Dispara remolinos teledirigidos
}

AnarchyBlade: {
	DisplayName: Hoja de la Anarquía
	Tooltip:
		'''
		Cuanta menos vida tengas, más daño inflige esta hoja
		Tus golpes generarán una gran explosión
		Con menos del 50% de vida, tus golpes tienen probabilidad de matar instantáneamente a enemigos normales
		'''
}

Aorta: {
	DisplayName: Aorta
	Tooltip:
		'''
		{$Common.YoyoStats}
		Dispara sangre teledirigida cuando hay enemigos cerca
		'''
}

ArkoftheCosmos: {
	DisplayName: Arca del Cosmos
	Tooltip:
		'''
		[COMBO]
		[PARRY]
		[BLAST]
		La culminación física de tu viaje, capaz de desgarrar a los dioses
		'''
	ComboInfo:
		'''
		<left> para realizar un combo de 5 golpes que termina lanzando la hoja
		La hoja lanzada seguirá tu cursor
		Soltarla mientras la hoja está fuera causará un chasquido explosivo
		'''
	ParryInfo:
		'''
		<right> para desplegar las hojas de tijera frente a ti
		Golpear a un enemigo con ellas realizará un parry, otorgándote invulnerabilidad breve
		También puedes hacer parry a proyectiles para que inflijan 120 menos de daño durante un breve período
		El parry potenciará los próximos 16 golpes de la espada
		'''
	BlastInfo: Pulsa <right> dos veces con cargas disponibles para provocar una Gran Ruptura en el espacio-tiempo y consumir todas las cargas
}

ArkoftheElements: {
	DisplayName: Arca de los Elementos
	Tooltip:
		'''
		[COMBO]
		[PARRY]
		Un par celestial de hojas imbuidas con la esencia de Terraria, suficientemente poderosas para cortar el tejido de la realidad
		'''
	ComboInfo:
		'''
		<left> para realizar un combo de 5 golpes que termina lanzando la hoja
		Soltarla mientras la hoja está fuera infligirá daño adicional
		'''
	ParryInfo:
		'''
		<right> para desplegar las hojas de tijera frente a ti
		Golpear a un enemigo con ellas realizará un parry, otorgándote invulnerabilidad breve
		Puedes hacer parry a proyectiles para que inflijan 60 menos de daño durante un breve período
		El parry potenciará los próximos 10 golpes de la espada, permitiéndote usar ambas hojas a la vez
		'''
}

AstralPike: {
	DisplayName: Lanza Astral
	Tooltip: Invoca enjambres de estrellas astrales al golpear que extienden la [cbuff:CalamityMod/AstralInfectionDebuff]
}

AstralScythe: {
	DisplayName: Guadaña Astral
	Tooltip: Dispara un anillo de guadañas que se acelera con el tiempo y extiende la [cbuff:CalamityMod/AstralInfectionDebuff]
}

Ataraxia: {
	DisplayName: Ataraxia
	Tooltip: Ecuanimidad
}

Avalanche: {
	DisplayName: Avalancha
	Tooltip:
		'''
		Golpear enemigos genera bombas de hielo en órbita
		Tras 2 segundos, las bombas de hielo explotan en fragmentos de hielo afectados por la gravedad
		'''
}

BalefulHarvester: {
	DisplayName: Segadora Funesta
	Tooltip:
		'''
		Una guadaña en llamas que se balancea rápidamente tres veces seguidas
		Los golpes a enemigos invocan calaveras en llamas que se dividen en orbes de fuego teledirigidos
		'''
}

BallOFugu: {
	DisplayName: Bola de Fugu
	Tooltip:
		'''
		Lanza un pez globo abisal agitándose
		Acumula púas venenosas mientras gira
		Las púas salen despedidas del pez al retraerse
		'''
}

BansheeHook: {
	DisplayName: Garfio de Banshee
	Tooltip: Balancea un garfio de banshee que dispara hojas y explota al golpear
}

Basher: {
	DisplayName: Aporreador
	Tooltip: Balancea un garrote podrido mientras te empuja hacia atrás en el proceso
}

BladecrestOathsword: {
	DisplayName: Espada Jurada de la Cresta Filosa
	Tooltip:
		'''
		Lanza una hoja afilada que empalma y ralentiza a los enemigos
		Hasta tres hojas pueden empalmar a un enemigo a la vez
		Los golpes consecutivos más allá de los primeros tres lanzarán las hojas previamente empaladas
		'''
	HoldShiftTooltip:
		'''
		[c/df0049:Una hoja ritual usada por Demonios para sacrificios.]
		[c/df0049:Cuanta más sangre mancha el filo, más afilado se vuelve.]
		'''
}

BlightedCleaver: {
	DisplayName: Cuchilla Marchita
	Tooltip: Dispara hojas ardientes teledirigidas
}

Bonebreaker: {
	DisplayName: Rompehuesos
	Tooltip:
		'''
		Dispara jabalinas que se clavan en los enemigos antes de estallar en metralla
		Las jabalinas clavadas infligen varios efectos negativos
		'''
}

BotanicPiercer: {
	DisplayName: Perforadora Botánica
	Tooltip: Dispara un rayo de energía botánica
}

Brimlance: {
	DisplayName: Lanzazufre
	Tooltip: Crea una explosión de [cbuff:CalamityMod/BrimstoneFlames] al golpear enemigos
}

Brimlash: {
	DisplayName: Latigazo de Azufre
	Tooltip: Dispara un rayo de azufre que explota en más rayos al golpear
}

BrimstoneSword: {
	DisplayName: Espada de Azufre
	Tooltip:
		'''
		Invoca géiseres de [cbuff:CalamityMod/BrimstoneFlames] al golpear
		Pulsa <right> para lanzar la espada como una jabalina que explota al golpear
		'''
}

BrinyBaron: {
	DisplayName: Barón Salino
	Tooltip:
		'''
		Golpear a un enemigo con la hoja provoca la aparición de un tifón salino
		Pulsa <right> para disparar una hoja acuática de viento cortante
		'''
}

BrokenBiomeBlade: {
	DisplayName: Espada de los Biomas Rota
	// See the attunement file for each attunement
	Tooltip:
		'''
		[FUNC]
		Mantén <right> mientras estás inmóvil sobre terreno plano para sintonizar el arma con los poderes del bioma circundante
		Pulsar <right> en cualquier otro momento alterna entre la sintonía actual y una sintonía almacenada adicional
		Sintonía Principal : [ATT1]
		Sintonía Secundaria : [ATT2]
		'''
	DefaultFunction: No hace nada... todavía
}

BurningRevelation: {
	DisplayName: Revelación Ardiente
	Tooltip:
		'''
		{$Common.YoyoStatsInfinite}
		Un yoyó siempre en llamas que acumula poder constantemente
		Los golpes directos aumentan enormemente la carga y liberan energía profanada que escala con el nivel de carga
		Con la carga máxima, el yoyó desata una ráfaga de estrellas teledirigidas que ganan daño cuanto más viajan
		Las estrellas con daño máximo liberan una explosión adicional al golpear
		'Quema, pero lo acercas a tu corazón. Claridad y propósito llenan tu alma'
		'''
}

BurntSienna: {
	DisplayName: Siena Quemado
	Tooltip: Hace que los enemigos exploten en proyectiles curativos al morir
}

Carnage: {
	DisplayName: Carnicería
	Tooltip: Los enemigos explotan en sangre teledirigida al morir
}

CelestialClaymore: {
	DisplayName: Mandoble Celestial
	Tooltip: Genera estrellas de energía cósmica cerca del cursor
}

ClamCrusher: {
	DisplayName: Trituradora de Almejas
	Tooltip:
		'''
		Lanza una almeja enorme que inflige [cbuff:CalamityMod/Eutrophication], aturdiendo a los enemigos durante un breve período
		Comienza a verse afectada por la gravedad y causa mucho más daño después de estar en el aire un momento
		'''
}

CometQuasher: {
	DisplayName: Destructor de Cometas
	Tooltip: Invoca un enjambre de meteoros desde el cielo al golpear enemigos
}

CosmicDischarge: {
	DisplayName: Descarga Cósmica
	Tooltip:
		'''
		Golpear a un enemigo con el látigo provoca explosiones glaciales que otorgan al jugador la mejora [cbuffplr:CalamityMod/CosmicFreeze]
		[cbuffplr:CalamityMod/CosmicFreeze] otorga al jugador +2 PV/s de regeneración de vida al estar quieto y congela a los enemigos cercanos
		'''
}

CosmicShiv: {
	DisplayName: Chuzón Cósmico
	Tooltip:
		'''
		Dispara una estrella cósmica que se dirige hacia los enemigos
		Al golpear a un enemigo, una ráfaga de hojas atacará persistentemente
		Impactar con más estrellas hace que ataquen más hojas
		'''
}

CrescentMoon: {
	DisplayName: Luna Creciente
	Tooltip:
		'''
		Lanza un mayal lunar que libera lunas teledirigidas en el punto más alto de su trayectoria
		Mantener <left> hace girar el mayal a tu alrededor, generando Destellos Estelares
		Con 20 Destellos Estelares, mantén <left> de nuevo tras lanzar el mayal para hacerlo explotar
		En lugar de liberar lunas, esta explosión invoca a Escorpius para infligir un daño inmenso y aplicar [cbuff:CalamityMod/Voidfrost]
		'Locura nacida del genio'
		'''
}

DarklightGreatsword: {
	DisplayName: Mandoble de Luz Oscura
	Tooltip: Dispara hojas de luz oscura que atraviesan enemigos, creando tajos adicionales
}

DeathsAscension: {
	DisplayName: Ascensión de la Muerte
	Tooltip:
		'''
		Realiza poderosos balanceos imbuidos de almas que crean una grieta orbitada por guadañas al golpear enemigos
		Pulsa <right> para lanzar una ráfaga de guadañas teledirigidas
		La grieta también disparará guadañas
		'Se siente perfecta en tu mano...
		[c/660066:Pero las manos que la empuñan no son las tuyas']
		'''
}

DefiledGreatsword: {
	DisplayName: Mandoble Corrupto
	Tooltip: Dispara hojas ardientes, hiper y de luz solar
}

DepthCrusher: {
	DisplayName: Aplastador de las Profundidades
	Tooltip:
		'''
		Lanza un pesado aplastador abisal que libera energía acuática al golpear un bloque
		El aplastador rebotará en bloques y enemigos
		'''
}

DevilsDevastation: {
	DisplayName: Devastación del Diablo
	Tooltip:
		'''
		Lanza una hoja demoníaca que empalma, incinera y ralentiza a los enemigos
		Hasta cinco hojas pueden empalmar a un enemigo a la vez; los golpes adicionales lanzan las hojas previamente empaladas
		Pulsa <right> para adoptar una postura desde la que puedes usar <left> para realizar un tajo colosal y devastador
		En esa postura, recuperas vida y tiempo de vuelo, y tus impulsos tienen menor tiempo de recarga
		El tajo devastador debe recargarse tras su uso
		Golpear a un enemigo empalado con el tajo devastador lanza todas las hojas y prepara otro tajo
		Al último enemigo golpeado con un tajo devastador se le aplica una marca de muerte
		Al salir de la postura, la marca de muerte explota causando un daño masivo
		'''
	HoldShiftTooltip:
		'''
		[c/d13ca2:La hoja perfecta del Inframundo, que ejerce directamente el poder del Azufre.]
		[c/d13ca2:Los humanos comprenden esta fuerza como Estragos, la inevitable destrucción de todo orden en el fuego.]
		[c/d13ca2:Quizás por eso el Elemental de Azufre tenía una fuerza sin igual entre sus hermanas.]
		'''
}

DevilsSunrise: {
	DisplayName: Amanecer del Diablo
	Tooltip:
		'''
		Desata una tanda de cortes diabólicos
		La energía infernal se carga en las hojas con el tiempo, proceso que se acelera golpeando enemigos
		Pulsa <right> mientras balanceas las hojas con energía completa para lanzar las hojas giratorias hacia tu cursor
		Las hojas giratorias se clavan en el primer enemigo que encuentran y lo cortan repetidamente, robándole la vida
		'¿Pelotas? Bolitas.'
		'''
}

DraconicDestruction: {
	DisplayName: Destrucción Dracónica
	Tooltip:
		'''
		Dispara un destello de espada dracónico que explota en rayos adicionales
		Los rayos adicionales vuelan arriba y abajo para destrozar enemigos
		'''
}

DragonPow: {
	DisplayName: Golpe del Dragón
	Tooltip:
		'''
		Dispara una cabeza de dragón que libera chispas de [cbuff:CalamityMod/Dragonfire]
		Invoca una ráfaga de pétalos y cascadas al golpear enemigos
		'''
}

DragonRage: {
	DisplayName: Rabia del Dragón
	Tooltip:
		'''
		Gira un bastón que provoca explosiones de [cbuff:CalamityMod/Dragonfire] al golpear enemigos
		Una vez cada dos segundos, los golpes invocan un anillo de bolas de fuego que apuntan al enemigo con más vida
		'''
}

DriftwoodSword: {
	DisplayName: Espada de Madera a la Deriva
	Tooltip: Esta espada es más poderosa cuando estás mojado
}

Earth: {
	DisplayName: Tierra
	Tooltip:
		'''
		Una hermosa hoja prismática de incomparable habilidad en combate cercano
		Te cura enormemente al golpear
		Cada dos balanceos invoca tres meteoros Gaia para aniquilar a los enemigos cercanos
		'Toda su descendencia conocerá la belleza y la ira de su creador'
		'''
}

EarthenPike: {
	DisplayName: Lanza Terrenal
	Tooltip: Expulsa fragmentos fósiles al balancearse
}

EmpyreanKnives: {
	DisplayName: Cuchillos Empíreos
	Tooltip: Lanza una ráfaga de cuchillos teledirigidos que rebotan en los bloques y curan al usuario
}

EntropicClaymore: {
	DisplayName: Mandoble Entrópico
	Tooltip:
		'''
		Dispara una ráfaga de plasma vivo que nada por el aire
		El plasma seguirá tu cursor o los enemigos cercanos, priorizando el más cercano
		El plasma atraviesa, pero dejará de rastrear tras golpear al primer enemigo
		'''
}

EssenceFlayer: {
	DisplayName: Desuelladora de Esencias
	Tooltip: Dispara una guadaña de esencia que genera espíritus curativos al matar enemigos
}

EvilSmasher: {
	DisplayName: Aplastamalvados
	Tooltip:
		'''
		Canaliza un poderoso golpe de martillo capaz de aplastar todo el mal
		Golpear un bloque con el martillo provocará una explosión y te empujará hacia atrás
		Golpear enemigos inflige [cbuff:CalamityMod/SmashedEvil] tanto al usuario como al objetivo
		Cargar los golpes aumenta el daño, el radio de explosión y la duración de [cbuffplr:CalamityMod/SmashedEvil]
		'¡MaL! ¡ApLaStaR MaL! ¡ApLaStA... DoR!'
		'''
	//All damage and kill dialogue has the capitalization randomized when said
	DamageDialogue0: ¡aplastar!
	DamageDialogue1: ¡malo!
	DamageDialogue2: ¡machacar!
	DamageDialogue3: ¡des.. truir!
	KillDialogue0: ¡aplastar malo!
	KillDialogue1: ¡aplasta.. dor!
}

ExaltedOathblade: {
	DisplayName: Espada Jurada Exaltada
	Tooltip:
		'''
		Lanza una hoja retorcida que empalma, incinera y ralentiza a los enemigos
		Hasta cuatro hojas pueden empalmar a un enemigo a la vez; los golpes adicionales lanzan las hojas previamente empaladas
		Pulsa <right> para adoptar una postura desde la que puedes usar <left> para realizar un tajo devastador
		En esa postura, recuperas vida y tiempo de vuelo, y tus impulsos tienen menor tiempo de recarga
		El tajo devastador debe recargarse tras su uso
		Golpear a un enemigo empalado con el tajo devastador lanza todas las hojas y prepara otro tajo
		'''
	HoldShiftTooltip:
		'''
		[c/b63cd1:Una espada forjada con la leyenda del Último Señor Demonio.]
		[c/b63cd1:Coronado por su poder abrumador, su espada se bañó en la sangre de los Demonios y en los fuegos del infierno.]
		[c/b63cd1:Incluso mucho después de su muerte, nadie se ha atrevido a tomar el trono.]
		[c/b63cd1:Desde entonces, los Demonios no han conocido la unidad.]
		'''
}

Exoblade: {
	DisplayName: Exoespada
	Tooltip:
		'''
		Pulsa <left> para liberar múltiples rayos de energía que se dirigen hacia los enemigos y los cortan al golpear
		Pulsa <right> para realizar un impulso en la dirección del cursor con la hoja
		Los golpes a enemigos con la hoja durante el impulso causan un daño masivo y un rebote
		Pulsa <left> inmediatamente después de un rebote para realizar un tajo poderoso
		Los tajos poderosos son más grandes, te curan y crean una gran explosión
		Los enemigos golpeados son destrozados por [cbuff:CalamityMod/MiracleBlight]
		'''
}

FallenPaladinsHammer: {
	DisplayName: Martillo del Paladín Caído
	Tooltip:
		'''
		Lanza un pesado martillo afectado por la gravedad que explota y vuelve a ti tras golpear a un enemigo
		Tras volver tres veces, se invoca un martillo espectral teledirigido con un impacto devastador
		'''
}

FaultLine: {
	DisplayName: Línea de Falla
	Tooltip:
		'''
		{$Common.YoyoStatsInfinite}
		Explota al golpear enemigos
		'''
}

FeralthornClaymore: {
	DisplayName: Mandoble de Zarza Salvaje
	Tooltip: Hace brotar espinas de los enemigos al golpear
}

FlarefrostBlade: {
	DisplayName: Hoja de Llamahielo
	Tooltip: Dispara un orbe de llamahielo teledirigido
}

Floodtide: {
	DisplayName: Marejada
	Tooltip: ¡Lanza tiburones, porque los tiburones son increíbles!
}

ForbiddenOathblade: {
	DisplayName: Espada Jurada Prohibida
	Tooltip:
		'''
		Lanza una hoja afilada que empalma, quema y ralentiza a los enemigos
		Hasta tres hojas pueden empalmar a un enemigo a la vez; los golpes adicionales lanzan las hojas previamente empaladas
		Pulsa <right> para adoptar una postura desde la que puedes usar <left> para realizar un tajo poderoso
		El tajo poderoso debe recargarse tras su uso
		Golpear a un enemigo empalado con el tajo poderoso lanza todas las hojas y prepara otro tajo
		'''
	HoldShiftTooltip:
		'''
		[c/b63cd1:Una hoja forjada a semejanza de la otorgada al Señor Demonio.]
		[c/b63cd1:El título era codiciado por todos los Demonios. Solo puede existir uno a la vez.]
		[c/b63cd1:Todo aspirante que busca el trono tiene un objetivo simple: la cabeza del antiguo Señor.]
		'''
}

ForsakenSaber: {
	DisplayName: Sable Abandonado
	Tooltip: Dispara dos hojas de arena que modifican su velocidad al viajar
}

FourSeasonsGalaxia: {
	DisplayName: Galaxia
	// See the attunement file for each attunement
	Tooltip:
		'''
		[FUNC]
		Liberada de las ataduras terrenales y repleta de poder cósmico
		Tiene acceso a todas las sintonías en todo momento
		Pulsa <right> para cambiar la sintonía de la espada según la posición del cursor
		Sintonía Activa : [ATT]
		'''
}

FracturedArk: {
	DisplayName: Arca Fracturada
	Tooltip:
		'''
		[PARRY]
		Una hoja desgastada y oxidada que una vez se empuñó contra el mal de este mundo, lista para ser útil una vez más
		'''
	ParryInfo:
		'''
		<right> para extender el Arca frente a ti
		Golpear a un enemigo con ella realizará un parry, otorgándote una breve ventana de invulnerabilidad
		El parry potencia los próximos 10 golpes de la espada, aumentando el daño y permitiéndoles lanzar proyectiles
		'''
}

GaelsGreatsword: {
	DisplayName: Mandoble de Gael
	Tooltip:
		'''
		El primer balanceo dispara calaveras teledirigidas
		El segundo balanceo dispara una calavera gigante y poderosa
		El tercer balanceo no tiene proyectiles
		Genera rabia constantemente mientras se usa
		Los balanceos dejan rastros de sangre explosivos con menos del 50% de vida
		Ocasionalmente invoca una ráfaga de rayos con menos del 50% de vida
		Sustituye el Modo Rabia por una enorme ráfaga de calaveras
		Este ataque tiene un tiempo de recarga de 30 segundos
		'Entrégalo. Esa cosa. Tu alma oscura'
		'''
}

GalactusBlade: {
	DisplayName: Hoja de Galactus
	Tooltip:
		'''
		Lanza una ráfaga de cometas desde el cielo
		Forjada con la furia del caos nuclear
		'''
}

GalaxySmasher: {
	DisplayName: Aplastador de Galaxias
	Tooltip:
		'''
		Lanza un pesado martillo afectado por la gravedad que vuelve a ti tras golpear a un enemigo
		Los golpes consecutivos invocan cada vez más fragmentos cósmicos
		Tras golpear ocho veces, el martillo se supercarga con energías galácticas,
		asestando un golpe apocalíptico que reverbera a través del espacio y el tiempo
		'''
}

GalileoGladius: {
	DisplayName: Gladio de Galileo
	Tooltip:
		'''
		Apuñala rápidamente frente al jugador, generando Destellos Estelares al golpear
		<right> para lanzar el gladio en una cadena de constelación, empalando a los enemigos e infligiendo [cbuff:CalamityMod/Voidfrost]
		Cuando la hoja esté empalada, usa <left> o <right> para liberarla
		<left> la libera y causa un gran daño, consumiendo 10 Destellos Estelares
		<right> te acerca hacia la hoja, permitiéndote saltar desde el enemigo
		Saltar desde un enemigo consume 20 Destellos Estelares y otorga invencibilidad
		'Fígaro, magnífico'
		'''
}

GeliticBlade: {
	DisplayName: Hoja Gelítica
	Tooltip: Dispara una onda de gel rápida que se acelera al golpear enemigos y los cubre con [cbuff:Slimed]
}

GildedProboscis: {
	DisplayName: Probóscide Dorada
	Tooltip:
		'''
		Roba vida proporcional al daño infligido a los enemigos
		<left> para cargar un empuje preciso
		El empuje comienza débil, pero se vuelve más poderoso cuanto más tiempo se mantiene
		<right> para realizar un impulso hacia adelante con un poderoso golpe ascendente
		La distancia del impulso depende de si te estás moviendo a favor o en contra del impulso
