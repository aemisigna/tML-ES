}

Lacerator: {
	DisplayName: Laceradora
	Tooltip:
		'''
		{$Common.YoyoStatsInfinite}
		Golpear enemigos invoca una sierra sangrienta para destrozarlos
		La sierra causa más daño cuanto más frecuentemente golpea el yoyó, y desaparece cuando no golpea enemigos
		Los enemigos que tocan el filo de la sierra tienen orbes de sangre arrancados de ellos
		Recoger estos orbes de sangre reduce la duración de [cbuffplr:PotionSickness]
		La dirección del giro de la sierra depende de la dirección en que lanzaste originalmente el yoyó[GFB]
		'''
	GFBFlavor: "[c/ff0a0a:Puede ser un arma viable contra el DoG...]"
}

LifehuntScythe: {
