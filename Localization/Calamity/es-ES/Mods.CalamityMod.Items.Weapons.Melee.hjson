	TooltipGFB:
		'''
		Una hoja ancestral creada durante la Era Dracónica por el mejor maestro herrero de Azafure
		Balancea una hoja lenta y pesada con un poderoso retroceso
		Mantener <right> comenzará a cargar un balanceo reforzado
		Soltar <right> con la carga completa desatará un tajo devastador que siempre golpea de forma crítica
		[c/0C507F:'Mi amada <3' -Xyk]
		'''
}

HolyCollider: {
