		El tercer golpe desata [ceffect/dog:Devorador de Divinidad] en tu cursor, explotando para causar un daño masivo
		'''
}

MirrorBlade: {
	DisplayName: Hoja Espejo
	Tooltip:
		'''
		Golpear a un enemigo o un proyectil enemigo invoca hasta 10 fragmentos de espejo en órbita
		Los fragmentos que superen los 10 rastrearán enemigos en su lugar
		Mantener <right> fusiona los fragmentos de espejo en órbita en un escudo
		'''
	HoldShiftTooltip:
		'''
		[c/aab7f1:Cada fragmento reduce un 10% el daño de un proyectil que golpee el escudo]
		[c/aab7f1:El escudo se rompe tras un proyectil, lanzando los fragmentos a los enemigos con daño aumentado]
		[c/aab7f1:Con los 10 fragmentos, obtienes un breve período de invulnerabilidad al romper el escudo]
		'''
	FlavorTooltip: "[c/7b6d8d:'Una hoja tomada de tu propio reflejo dentro del Vacío Incesante']"
}

MonolithSword: {
