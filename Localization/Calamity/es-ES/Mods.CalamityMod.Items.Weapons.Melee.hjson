}

TheOracle: {
	DisplayName: El Oráculo
	Tooltip:
		'''
		{$Common.YoyoStatsInfinite}
		Emite un aura de rayos áuricos que se carga al golpear enemigos
		Dispara orbes áuricos al estar supercargado
		'Contempla el pasado, el presente, el futuro... y las circunstancias de tu inevitable fin'
		'''
}

TitanArm: {
	DisplayName: Brazo del Titán
	Tooltip:
		'''
		Envía a los enemigos directamente a las estrellas a la velocidad de la luz
		La Mano que Da Bofetadas pero mejor
		'''
}

TriactisTruePaladinianMageHammerofMight: {
	DisplayName: Martillo Mago Paladino Verdadero de Triactis
	Tooltip:
		'''
		Lanza un pesado martillo afectado por la gravedad que vuelve a ti tras golpear a un enemigo
		Los golpes a enemigos liberan bengalas de luz prismática que orbitan alrededor del enemigo golpeado
		En lugar de volver, el cuarto golpe transforma las bengalas en martillos de luz sólida
		Estos martillos convergen y forman una explosión que colapsa el universo y siempre golpea de forma crítica
		'''
}

TrueArkoftheAncients: {
	DisplayName: Arca de los Antiguos
	Tooltip:
		'''
		[PARRY]
		Una hoja celestial forjada para vencer todo el mal
		'''
	ParryInfo:
		'''
		<right> para extender el Arca frente a ti
		Golpear a un enemigo con ella realizará un parry, otorgándote invulnerabilidad breve
		También puedes hacer parry a proyectiles para que inflijan 30 menos de daño durante un breve período
		El parry potenciará los próximos 10 golpes de la espada, permitiéndole lanzar proyectiles más poderosos
		'''
}

TrueBiomeBlade: {
	DisplayName: Espada de los Biomas
	// See the attunement file for each attunement
	Tooltip:
		'''
		[FUNC]
		Mantén <right> mientras estás inmóvil sobre terreno plano para sintonizar el arma con los poderes del bioma circundante
		Pulsar <right> en cualquier otro momento alterna entre la sintonía actual y una sintonía almacenada adicional
		Sintonía Principal : [ATT1]
		Sintonía Secundaria : [ATT2]
		'''
	DefaultFunction:
		'''
		No hace nada... todavía
		Reparar la hoja parece haber mejorado sus capacidades de sintonía
		'''
}

