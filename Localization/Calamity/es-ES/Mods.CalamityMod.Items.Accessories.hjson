}

DeepDiver: {
	DisplayName: Buceador Profundo
	Tooltip:
		'''
		Permite dar un impulso con menor recarga
		Este impulso puede atravesar enemigos sin recibir daño
		Proporciona una movilidad acuática considerablemente mejorada
		'''
}

DeificAmulet: {
	DisplayName: Amuleto Deífico
	Tooltip:
		'''
		Libera una ráfaga de abejas estelares teledirigidas[TOGGLE] y te baña en [cbuffplr:Honey] al recibir daño
		Aumenta la duración de la invulnerabilidad, aumentando aún más cuando tienes poca vida
		[c/aaaaaa:Shift-<right> este objeto en tu inventario para activar/desactivar] [i:PanicNecklace] [c/aaaaaa:el efecto del Collar de Pánico]
		'''
	ToggleEffect: ", aumenta la velocidad de movimiento,"
}

DepthCharm: {
	DisplayName: Amuleto de las Profundidades
	Tooltip:
		'''
		Reduce el daño causado por ahogarse en el abismo
		Elimina el aumento de pérdida de oxígeno de [cbuffplr:CalamityMod/CrushDepth]
		'''
}

DiamondOfTheDeep: {
	DisplayName: Diamante de las Profundidades
	Tooltip:
		'''
		60% de daño del efecto negativo de Agua aumentado
		Acumulas lentamente hasta tres espíritus abisales diferentes
		Da un impulso para dispersar los espíritus y hacer que ataquen enemigos
		Cuando se dispersan [c/CB7AD7:por debajo del 50% de vida], los espíritus te apoyan en su lugar
		Los espíritus aparecen en orden y tienen efectos diferentes según su color:
		[c/3CB371: Explota al impactar e inflige] [cbuff:CalamityMod/CrushDepth] / [c/CB7AD7:Cura 8 PV]
		[c/FF4500: Atraviesa enemigos e inflige] [cbuff:OnFire3] / [c/CB7AD7:Aumenta la defensa en 10 temporalmente]
		[c/1E90FF: Golpea varias veces e inflige] [cbuff:CalamityMod/HadopelagicPressure] / [c/CB7AD7:Cura el 5% del máximo de PV]
		Los espíritus son transparentes y silenciosos cuando la visibilidad está desactivada
		'''
}

CrushingEgo: {
