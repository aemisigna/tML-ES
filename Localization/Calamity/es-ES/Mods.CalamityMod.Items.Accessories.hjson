}

MoonstoneCrown: {
	DisplayName: Corona de Piedra Lunar
	Tooltip:
		'''
		Aumenta el maná máximo en 40
		Invoca un [c/27F5E0:Sigilo Lunar] cada 2 segundos, hasta un máximo de 10
		Cada [c/27F5E0:Sigilo Lunar] aumenta el daño mágico un 2% y reduce el coste de maná un 1%
		Con 5 sigilos, aumenta la regeneración de maná en +5 PM/s
		Con 10 sigilos, aumenta la probabilidad de ataque crítico mágico un 10% y todos los ataques mágicos infligen [cbuff:CalamityMod/Nightwither]
		Quedarse sin maná o usar una poción de maná rompe todos los sigilos
		Tras romper un sigilo, no pueden aparecer sigilos nuevos durante 5 segundos
		Los sigilos son transparentes y silenciosos si la visibilidad está desactivada
		'''
	HoldShiftTooltip:
