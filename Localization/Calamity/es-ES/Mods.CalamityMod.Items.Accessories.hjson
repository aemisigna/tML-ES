		'''
}

WarbanneroftheRighteous: {
	DisplayName: Estandarte de Guerra de los Justos
	Tooltip:
		'''
		Multiplica todo el daño según la cercanía a los enemigos
		El impulso máximo de daño es el 15% y el mínimo es el -15%
		Emite un aura ardiente que quema y repele a los enemigos cercanos con [cbuff:CalamityMod/HolyFlames]
		Los enemigos reciben daño creciente cuanto más cerca estén de ti y más tiempo permanezcan cerca
		Los efectos son transparentes y silenciosos si la visibilidad está desactivada
		'''
}

WulfrumAcrobaticsPack: {
	DisplayName: Mochila Acrobática de Wulfrum
	Tooltip:
		'''
		Proporciona un gancho de agarre tipo honda de wulfrum
		Las estadísticas de la honda escalan con tu gancho equipado
		Si el gancho tiene efectos especiales, la honda también se beneficia de ellos
		La honda permite física avanzada de balanceo en cuerdas
		Mantén {$Key.UP} o {$Key.DOWN} para retraer o extender la cuerda de la honda
		Se agarra automáticamente a los muros cercanos si se detecta una caída letal
		Esta función de seguridad no se activará si se mantiene {$Key.DOWN}
		8% de velocidad de movimiento aumentada
		'''
}

WulfrumBattery: {
	DisplayName: Batería de Wulfrum
	Tooltip:
		'''
		Tus invocaciones emiten luz si la visibilidad está activada
		7% de daño de invocación aumentado
		Los enemigos de Wulfrum sueltan chatarra adicional
		También puede desmantelarse en un extractinador
		'''
}

YharimsGift: {
	DisplayName: Regalo de Yharim
	Tooltip:
		'''
		{$Common.KnockbackImmunity}
		Aumenta el daño un 10% y la velocidad de movimiento un 20%
		Todos los ataques infligen [cbuff:CalamityMod/AuricRebuke]
		Meteoros en llamas caen mientras eres invulnerable
		[c/FCA92B:'El poder de matar a un dios pulsa dentro de este artefacto']
		'''
}

