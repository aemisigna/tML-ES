// Be warned translators, this thing fucking sucks
StatMeter: {
	DisplayName: Medidor de Estadísticas
	FoolsName: Colador de Pasta
	Tooltip:
		'''
		Muestra casi todas las estadísticas del jugador
		Las estadísticas ofensivas/utilitarias mostradas varían según el objeto sostenido
		[REV]
		[ITEMS]
		[GENERIC]
		[ABYSS]
		'''
	RevStats:
		'''
		Impulso de Daño por Rabia: {0}% | Duración del Modo Rabia: {1} segundos
		Impulso de Daño por Adrenalina: {2}% | Impulso de RD por Adrenalina: {3}%
		'''

	ClassNameOverride: {
		Default: daño verdadero
		Generic: daño sin clase
		NoSpeed: " (sin velocidad)"
		SummonMeleeSpeed: " (látigo)"
	}

	DamageStats:
		'''
		Clase: {0}
		Daño: {1}
		Penetración de Armadura: {2}
		'''
	DamageBase: "[{0} base] +"
	DamageNormal: "{0}%"
	DamageMult: " x{0}"
	DamageFlat: " {0} plano"
	Crit: " | Prob. de Crítico: {0}%"
	AttackSpeed: Velocidad de Ataque: {0}%
	WhipMeleeInheritance: " [{0}% de cuerpo a cuerpo]"
	// Class stats
	AmmoStats: Prob. de Consumo de Munición: {0}%
	ManaStats: Uso de Maná: {0}% | Regen. de Maná: {1}
	SummonStats: Espacios de Súbdito: {0} | Espacios de Centinela: {1}
	WhipStats: Alcance del Látigo: {0}%
	RogueStats:
		'''
		Sigilo Máx.: {0} | Regen. Quieto: {1} / seg | Regen. en Movimiento: {2} / seg
		Impulso de Velocidad de Pícaro: {3}%
		'''
	// Utility stats
	ToolRange: Bonus de Alcance de Herramienta: ({0}, {1})
	MiningSpeed: " | Velocidad de Minería: {0}%"
	PlacementRange: Bonus de Alcance de Colocación: ({0}, {1})
	TileSpeed: " | Vel. de Colocación de Bloques: {0}%"
	WallSpeed: " | Vel. de Colocación de Muros: {0}%"
	// Other stats
	GenericStats:
		'''
		Defensa: {0} | RD: {1}% | Regen. de Vida: {2} PV/s
		Vel. de Movimiento: {3}% | Impulso de Salto: {4}%
		'''
	FlightTime: " | Tiempo de Vuelo de Alas: {0} segundos"
	MiscStats: Agresión: {0} | Suerte: {1}%
	AbyssStats:
		'''
		Oscuridad del Abismo: {0} | Brillo del Jugador: {1}x | Ancho del Foco: {2}x
		Tasa de Pérdida de Oxígeno: {3}
		Vida Perdida por Tik sin Oxígeno: {4}
		Defensa Perdida por Presión: {5}
		'''
	AbyssStatsHidden: Las estadísticas del Abismo solo se muestran mientras estás en el Abismo
}

StressPills: {
	DisplayName: Pastillas de Estrés
	Tooltip:
		'''
		La Adrenalina se carga un 20% más rápido
		Aumenta la velocidad máxima de movimiento y la aceleración un 5%
		'''
	SalesPitch:
		'''
		'Hay gente que disfruta de verdades simples en la vida: el bien y el mal, la salud y la enfermedad.'
		'No sé si son muy sanos, ¡pero estos artilugios oscuros harán que tu sangre hierva! ¡Ayúdame a ponerles etiquetas simples y te daré un descuento de infarto!'
		'''
}

SupremeBaitTackleBoxFishingStation: {
	DisplayName: Estación de Pesca Suprema con Cebo y Aparejos
	Tooltip:
		'''
		Aumenta el poder de pesca en 50
		El sedal nunca se romperá y reduce la probabilidad de consumir cebo
		Permite pescar en lava
		'''
}

TeslasAmulet: {
	DisplayName: Amuleto de Tesla
	Tooltip:
		'''
		Genera un campo electrizante a tu alrededor
		El campo inflige [cbuff:CalamityMod/StaticDischarge] y [cbuff:CalamityMod/GalvanicCorrosion]
		El campo tiene opacidad reducida si la visibilidad está desactivada
		Reduce la duración de [cbuffplr:CalamityMod/StaticDischarge]
		'''
}

TheAbsorber: {
	DisplayName: El Absorbedor
	Tooltip:
		'''
		{$Common.KnockbackImmunity}
		{0}% de velocidad de movimiento y de salto aumentadas
		Los atacantes reciben daño inmenso y son afectados con [cbuff:CalamityMod/AbsorberAffliction]
		Usar una poción de curación generará un aura verde que dura {1} segundos
		Entrar en el aura elimina todos los efectos negativos una vez y otorga {2} PV/s de regeneración, {3}% de daño y {4}% de reducción de daño
		El {5}% del daño de los ataques enemigos se convierte en curación
		'''
}

TheAmalgam: {
	DisplayName: El Amalgama
	Tooltip:
		'''
		Todos los ataques infligen una variedad de efectos negativos, 200% de daño elemental aumentado
		La mayoría de las mejoras duran el doble y persisten al morir
		Recibir daño confunde a los enemigos cercanos e invoca un merodeador tenebroso
		El merodeador tenebroso vuela sobre ti y explota en varias nubes de lluvia sombría
		{$Common.DodgeProvided}
		Tras esquivar, el daño de invocación y la probabilidad de ataque crítico aumentan un 10%
		'No tienes ni idea de cómo sigue unido'
		'''
	HoldShiftTooltip: "{$Common.DodgeInformation}"
}

TheBee: {
	DisplayName: La Abeja
	Tooltip:
		'''
		Cuando tienes la vida al máximo, tu daño aumenta según tu reducción de daño
		El daño recibido con la vida al máximo se reduce a la mitad
		Cualquier escudo de energía debe estar completamente cargado para que este efecto se aplique
		Tiene una recarga de 6 segundos
		'''
}

TheCamper: {
	DisplayName: El Campador
	Tooltip:
		'''
		Infliges un 50% menos de daño a menos que estés quieto
		Quedarte quieto otorga mejoras según el objeto sostenido y crea un aura dañina a tu alrededor
		Al moverte, regeneras vida como si estuvieras quieto
		{$Common.AbyssGlow} cuando estás quieto
		'En el descanso encontremos la victoria'
		'''
}

TheCommunity: {
	DisplayName: La Comunidad
	Tooltip:
		'''
		[STATS]
		'El corazón de (casi toda) la comunidad de Terraria'
		¡Gracias a todos nuestros seguidores que hicieron posible este mod!
		'''
	StatsList:
		'''
		Aumenta el daño un {0}% y la probabilidad de ataque crítico un {1}%
		Aumenta la vida máxima un {2}%, la reducción de daño un {3}% y la defensa en {4}
		+{5} PV/s de regeneración de vida mientras sufres efectos negativos de daño a lo largo del tiempo
		Aumenta la velocidad de movimiento un {6}% y el tiempo de vuelo un {7}%
		Aumenta tu poder al derrotar jefes ({8}% de Poder)
		'''
}

TheEvolution: {
	DisplayName: La Evolución
	Tooltip:
		'''
		Permite esquivar proyectiles, reflejando fragmentos de espejo muy dañinos de vuelta a los enemigos
		{$Common.DodgeInformation}
		Recibir el mismo tipo de proyectil enemigo durante la recarga resistirá su daño un 25%
		'''
}

TheFirstShadowflame: {
	DisplayName: La Primera Llama Sombría
	Tooltip:
		'''
		Aumenta el máximo de súbditos en 1
		Los ataques de los súbditos infligen [cbuff:CalamityMod/Shadowflame] y otorga inmunidad a [cbuffplr:CalamityMod/Shadowflame]
		'''
}

ThePointer: {
	DisplayName: El Puntero
	Tooltip:
		'''
		Permite el apuntado automático de enemigos
		Pulsa [KEY] para cambiar entre objetivos cerca de tu cursor
		Tras pasar por todos los enemigos cercanos, la siguiente pulsación lo desactivará
		'¡Genial para los gatos!'
		'''
}

TheSponge: {
	DisplayName: La Esponja
	Tooltip:
		'''
		{$Common.KnockbackImmunity}
		Obtienes una barrera con {0} de salud
		La barrera otorga {1}% de reducción de daño mientras está activa
		[ADREN]
		La barrera se regenerará {2} segundos después de recibir un golpe, tardando {3} segundos en regenerarse completamente
		Recibir un golpe reinicia el temporizador
		'''
	ShieldAdren: Pérdida de Adrenalina reducida a la mitad si todo el daño es absorbido
}

TheTransformer: {
	DisplayName: El Transformador
	Tooltip: "[GFB]"
	TooltipNormal:
		'''
		Genera un aura a tu alrededor que crea glóbulos metamorfos cuando los proyectiles la atraviesan o cuando los enemigos mueren
		Los glóbulos te rodean y causan poco daño y retroceso a los enemigos con los que colisionan
		El círculo puede contener hasta 30 glóbulos a la vez
		Pulsa [KEY] para transformar todos los glóbulos en agujas y lanzarlas hacia tu cursor
		'¿Cómo salió esto de los trastos que juntaste? Suerte que no te transforma a ti'
		'''
	TooltipGFB:
		'''
		Genera un aura a tu alrededor que crea glóbulos metamorfos cuando los proyectiles la atraviesan o cuando los enemigos mueren
		Los glóbulos te rodean y causan poco daño y retroceso a los enemigos con los que colisionan
		El círculo no tiene límite de glóbulos, pero puede que tu PC sí
		Pulsa [KEY] para transformar todos los glóbulos en agujas y lanzarlas hacia tu cursor
		'No es la Doctrina Beeftank, ¡pero se siente revolucionario!'
		'''
}

ToxicHeart: {
	DisplayName: Corazón Tóxico
	Tooltip:
		'''
		Tu corazón late con [cbuff:CalamityMod/Plague], pulsando fuera de tu cuerpo
		La frecuencia de los pulsos escala con la regeneración, y los pulsos que matan enemigos vuelven a pulsar para curarte
		50% de daño del efecto negativo de Enfermedad aumentado
		Los efectos son transparentes y silenciosos si la visibilidad está desactivada
		'''
}

TrinketofChi: {
