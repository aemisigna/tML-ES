VictideBreastplate: {
	DisplayName: Pechera de Victide
	Tooltip:
		'''
		Aumenta un 5% la reducción de daño y la probabilidad de ataque crítico
		+5 de defensa y 10% de reducción de daño aumentada mientras estás sumergido en un líquido
		'''
	CommonSetBonus:
		'''
		Al usar cualquier arma tienes un 10% de posibilidades de lanzar un proyectil de concha que regresa
		Esta concha inflige daño verdadero y no se beneficia de ninguna clase de daño
		Proporciona mayor movilidad bajo el agua y reduce ligeramente la pérdida de oxígeno en el Abismo
		'''
}

