AerospecBreastplate: {
	DisplayName: Pechera Aerospec
	Tooltip: "{$CommonItemTooltip.PercentIncreasedDamageCritChance}"
	CommonSetBonus:
		'''
		Recibir más de {0} de daño en un solo golpe provocará una lluvia de plumas teledirigidas
		Permite caer más rápido y elimina el daño por caída
		'''
}

AerospecHeadMagic: {
	DisplayName: Sombrero Aerospec
	Tooltip:
		'''
		{$CommonItemTooltip.IncreasesMaxManaBy}
		{$CommonItemTooltip.PercentIncreasedMagicDamage@1}
		'''
	SetBonus:
		'''
		{$CommonItemTooltip.PercentReducedManaCost}
		{1}% de velocidad de movimiento y probabilidad de ataque crítico mágico aumentadas
		{$AerospecBreastplate.CommonSetBonus@2}
		'''
}

AerospecHeadRogue: {
	DisplayName: Casco Aerospec
	Tooltip: "{$Common.RogueDamage} y {$CommonItemTooltip.PercentIncreasedMovementSpeed@1}"
	SetBonus:
		'''
		{$Common.RogueStealth}
		{1}% de velocidad de movimiento y probabilidad de ataque crítico de pícaro aumentadas
		{$AerospecBreastplate.CommonSetBonus@2}
		'''
}

AerospecHeadMelee: {
	DisplayName: Yelmo Aerospec
