DesertProwlerHat: {
	DisplayName: Sombrero del Merodeador del Desierto
	Tooltip: "{$Common.RogueCrit}"
	SetBonus:
		'''
		{$Common.RogueStealth}
		[c/{1}:Bomba de Humo de Arena - {2} para cubrirte en una pequeña nube de arena]
		[c/CCB648:Mientras la nube de arena esté activa, ganarás más movilidad pero con la defensa muy reducida]
		[c/CCB648:Usar un arma de pícaro disipa la capa de arena al instante, pero garantiza un supercrítico de {3}% de daño]
		[c/CCB648:El supercrítico solo se aplica mientras el golpe resultante no supere {4} de daño]
		[c/CCB648:Dar el golpe de gracia a un enemigo con este disparo reduce el tiempo de espera de la habilidad a {5} {^5:segundo;segundos}]
		'''
}

