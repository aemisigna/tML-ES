}

LunarianBow: {
	DisplayName: Arco Lunario
	Tooltip:
		'''
		Dispara dos flechas a la vez
		Convierte flechas de madera en pernos de energía deslizantes
		'''
}

M1Garand: {
	DisplayName: M1 Garand
	Tooltip:
		'''
		Convierte balas en proyectiles .30-06 que heredan el daño de la bala convertida
		Dispara 8 balas antes de eyectar el cartucho del rifle
		Las balas que rebotan en monedas también pueden rebotar en cartuchos
		'Cuidado con el pulgar'
		'''
}

MagnaCannon: {
	DisplayName: Cañón Magna
	Tooltip:
		'''
		Carga una ráfaga rápida de pernos de cristal
		Cargar por más tiempo aumenta el número de pernos disparados
		Los disparos con carga completa disparan una ráfaga aún más larga y rápida
