}

OmniGun: {
	DisplayName: La Omniarma
	Tooltip:
		'''
		Un arma multipropósito con varios modos que se usan en secuencia
		El primer disparo es una bala de francotirador que gana daño con el tiempo y siempre golpea críticamente
		El segundo disparo es una ráfaga de 10 balas estándar
		El tercer disparo es una devastadora dispersión a quemarropa
		El cuarto disparo es una granada peligrosa pero poderosa que destruye todo, incluido tú
		'''
	SalesPitch:
		'''
		'¿Por qué cargar cuatro pistolas diferentes cuando puedes cargar solo una? ¡Eso es lo que yo solía preguntarme!'
		'¡Con esta belleza, hasta el más torpe puede volverse invencible, y al precio correcto puede ser tuya!'
		'''
}

OpalStriker: {
