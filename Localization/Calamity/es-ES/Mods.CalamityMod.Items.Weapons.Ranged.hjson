TheJailor: {
	DisplayName: El Carcelero
	Tooltip: Libera minas eléctricas hacia afuera que se conectan entre sí mediante arcos
}

TheMaelstrom: {
	DisplayName: El Maelstrom
	Tooltip: Dispara Tiburones Segadores cargados que causan explosiones de agua
}

ThePack: {
	DisplayName: La Manada
	Tooltip: Dispara grandes cohetes teledirigidos que explotan en más minicohetes teledirigidos al estar cerca de un enemigo
}

ThermoclineBlaster: {
	DisplayName: Exterminador de Termoclina
	Tooltip:
		'''
		Alterna entre disparar balas imbuidas con fuego y hielo
		Cualquier tipo de bala puede imbuirse al dispararse desde esta pistola
		'''
}

TheSevensStriker: {
	DisplayName: El Golpeador de los Sietes
	Tooltip:
		'''
		Presiona <left> para consumir 1 moneda y jugar a la máquina tragamonedas
		La calidad del resultado depende de la moneda utilizada
		'Un arma dada a un gran pistolero
		Forjada por los brazos de un hombre sin nombre'
		'''
	HoldShiftTooltip: "[c/ADD8E6:'¡A APOSTAR!']"
}

TheStorm: {
	DisplayName: La Tormenta
	Tooltip:
		'''
		Dispara una dispersión de rayos y flechas teledirigidas desde el cielo
		Convierte flechas de madera en poderosos rayos
		'''
}

ThreadOfEradication: {
	DisplayName: Hilo de la Erradicación
	Tooltip:
		'''
		Carga [ceffect/dog:Rayo de Condena del Asesino de Dioses]
		Canalizar el arma hace que cargue [ceffect/dog:Falla de Hipermuerte] en su lugar
		Mientras carga [ceffect/dog:Falla de Hipermuerte], la velocidad de giro del arco se reduce
		Siempre golpea críticamente, y la probabilidad de golpe crítico aumenta el daño crítico
		'''
}

TitaniumRailgun: {
	DisplayName: Pistola de Rieles de Titanio
	Tooltip:
		'''
		Mantén pulsado para cargar una ráfaga de titanio devastadora
		Mayor tiempo de carga aumenta el poder, lo que lleva a más daño, tamaño y retroceso
		El poder tiene límite cuando las miras del cañón convergen completamente
		'''
}

Toxibow: {
	DisplayName: Arco Tóxico
	Tooltip: Convierte flechas de madera en flechas lentas que infligen [cbuff:CalamityMod/Irradiated]
}

TyrannysEnd: {
	DisplayName: Fin de la Tiranía
	Tooltip:
		'''
		Convierte balas de mosquete en proyectiles de francotirador calibre .70 que causan daño devastador
		Hace que los enemigos queden con [cbuff:CalamityMod/MarkedforDeath] y atraviesa la defensa
		Los golpes críticos invocan un enjambre de 6 balas adicionales
		'Perfora el corazón incluso del enemigo más blindado'
		'''
}

Ultima: {
	DisplayName: Ultima
	Tooltip:
		'''
		Lanza un flujo continuo de pernos de plasma
		Con el tiempo, los pernos se potencian en rayos sólidos mientras continúas disparando
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

UniversalGenesis: {
	DisplayName: Génesis Universal
	Tooltip:
		'''
		Dispara una dispersión de balas desde la pistola y una lluvia de estrellas sobre el cursor
		Convierte balas de mosquete en disparos de convocador de estrellas que invocan estrellas adicionales al golpear enemigos
		'Que el cielo estrellado caiga sobre tus enemigos'
		'''
}

VernalBolter: {
	DisplayName: Disparador Primaveral
	Tooltip:
		'''
		Dispara una columna compacta de tres flechas
		Convierte flechas de madera en pernos de energía deslizantes
		'''
}

Voidragon: {
	DisplayName: Dragón del Vacío
	Tooltip:
		'''
		Carga un cargador de 50 rondas de balas y explosiones de vacío concentradas alternadas
		Cuando se disparan todas las balas, la pistola libera un enorme chorro de fuego abisal
		El poder del fuego abisal escala según la cantidad de disparos que impactaron
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		[c/620BB0:'Fundido a negro']
		'''
}

Vortexpopper: {
	DisplayName: Reventavórtex
	Tooltip: Dispara burbujas por doquier que estallan en balas
}

WildfireBloom: {
	DisplayName: Floración de Fuego Salvaje
	Tooltip:
		'''
		Se carga para emitir un flujo de llamas energizadas y pares de bengalas de fuego salvaje teledirigidas
		Usa gel como munición
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

WulfrumBlunderbuss: {
	DisplayName: Trabuco de Wulfrum
	Tooltip:
		'''
		Consume chatarra de Wulfrum o monedas de plata para disparar
		La dispersión del disparo puede reducirse apuntando más lejos, a costa de menos daño
		{$Common.ArmorPenetration}
		[c/83B87E:'Lo bueno del Wulfrum es que aunque se rompe rápido, puede reutilizarse aún más rápido.]
		[c/83B87E:De hecho, es bastante común que un robot se convierta en munición justo después de dejar de funcionar.']
		'''
}
