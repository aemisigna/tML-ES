AcesHigh: {
	DisplayName: El As al Máximo
	Tooltip:
		'''
		Dispara una cadena de cartas con efectos variados según el tipo
		Los Corazones otorgan robo de vida
		Las Picas perforan enemigos
		Los Diamantes explotan violentamente
		Los Tréboles se dividen en tres
		'''
}

AcidwoodBow: {
	DisplayName: Arco de Madera Ácida
	Tooltip: ""
}

AdamantiteParticleAccelerator: {
	DisplayName: Acelerador de Partículas de Adamantita
	Tooltip: Carga y dispara 2 rayos de polaridades opuestas. Golpear con la polaridad opuesta aumenta el daño
}

Alluvion: {
	DisplayName: Aluvión
	Tooltip:
		'''
		Lanza una ráfaga de seis flechas a la vez
		Convierte flechas de madera en una combinación de flechas de tiburón, torrencial y tifón
		'''
}

AngelicShotgun: {
	DisplayName: Escopeta Angelical
	Tooltip:
		'''
		Cada disparo lanza un rayo radiante de [cbuff:CalamityMod/HolyFlames] desde el cielo
		Las balas de mosquete se convierten en balas de punta sagrada que también potencian el rayo
		'Combatiendo hasta ganar la guerra'
		'''
}

Animosity: {
	DisplayName: Animosidad
	GFBName: Escopeta Llena de Odio
	Tooltip: "[GFB]"
	TooltipNormal:
		'''
		Dispara una ráfaga de escopeta concentrada imbuida con [cbuff:CalamityMod/BrimstoneFlames]
		Presiona <right> para disparar una poderosa bala de azufre que hace que los enemigos queden con [cbuff:CalamityMod/MarkedforDeath]
		'''
	TooltipGFB:
		'''
		[c/9c0b0b:Dispara una ráfaga de escopeta llena de odio... entre otras cosas]
		[c/ac14ba:Presiona <right> para usar una bala de rifle maldita en su lugar]
		[c/454545:Por el Ojo de Cthulhu, el diente de Yharon...]
		'''
}

AntiMaterielRifle: {
	DisplayName: Rifle Anti-Material
	Tooltip:
		'''
		Convierte balas de mosquete en balas de francotirador calibre .50 que destrozan la defensa enemiga y hacen que los enemigos queden con [cbuff:CalamityMod/MarkedforDeath]
		Libera un segundo enjambre de balas al impactar, con balas adicionales en golpes críticos
		'''
}

Arbalest: {
	DisplayName: Arbalesta
	Tooltip:
		'''
		Dispara una andanada de 6 flechas de alta velocidad
		Las flechas comienzan pequeñas y crecen con el disparo continuo
		El daño, dispersión y retroceso de las flechas escalan con su tamaño
		'''
}

AquashardShotgun: {
	DisplayName: Escopeta de Fragmentos Aqua
	Tooltip: Convierte balas de mosquete en fragmentos aqua que se dividen al impactar a un enemigo
}

Archerfish: {
	DisplayName: Pez Arquero
	Tooltip:
		'''
		Convierte balas de mosquete en chorros de agua
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

ArcNovaDiffuser: {
	DisplayName: Difusor Nova de Arco
	Tooltip:
		'''
		Carga y dispara una ráfaga rápida de pernos nova
		La primera etapa de carga aumenta la cadencia de disparo de la ráfaga
		La segunda etapa reemplaza la ráfaga rápida con una explosión nova devastadora que siempre golpea críticamente
		'''
}

Arietes41: {
	DisplayName: Arietes 41
	Tooltip:
		'''
		Alterna entre disparar balas imbuidas con robo de vida y [cbuff:Electrified]
		Las balas imbuidas eléctricas crean una pequeña explosión de choque al impactar, causando daño adicional al enemigo
		'''
}

ArterialAssault: {
	DisplayName: Asalto Arterial
	Tooltip:
		'''
		Dispara un grupo de 5 flechas de sangre teledirigidas
		Estas flechas de sangre estallan en orbes de sangre al golpear a un enemigo
		Recoger estos orbes de sangre reduce la duración de [cbuffplr:PotionSickness]
		'''
}

AstralBlaster: {
	DisplayName: Exterminador Astral
	Tooltip: Convierte balas de mosquete en balas astrales teledirigidas que esparcen [cbuff:CalamityMod/AstralInfectionDebuff]
}

AstrealDefeat: {
	DisplayName: Derrota Astreal
	Tooltip: Todas las flechas se convierten en Flechas Astrales que emiten llamas al viajar
}

Auralis: {
	DisplayName: Auralis
	Tooltip:
		'''
		Dispara una bala brillante de alta velocidad que hace que los enemigos queden con [cbuff:CalamityMod/MarkedforDeath]
		Presiona <right> para alejarte
		Permanecer quieto otorga bonificaciones de daño crecientes de hasta 25%
		Permanecer quieto 5 o más segundos usando la mira invocará una aurora
		La aurora reduce el daño del próximo proyectil que te golpee en 100
		Este efecto dura hasta 20 segundos y tiene un tiempo de recarga de 30 segundos
		'''
}

AuroraBlazer: {
	DisplayName: Abrasador Aurora
	Tooltip:
		'''
		Escupe un flujo de nebulosa que forma un patrón de estrella y esparce [cbuff:CalamityMod/AstralInfectionDebuff]
		Usa gel como munición
		'''
}

Barinade: {
	DisplayName: Barinade
	Tooltip: Dispara dos flechas de aleta convergentes de alta velocidad que surcan el aire fácilmente
}

Barinautical: {
	DisplayName: Barinautical
	Tooltip: Convierte flechas de madera en cadenas de 3 flechas de rayo eléctrico que explotan
}

BarracudaGun: {
	DisplayName: Pistola Barracuda
	Tooltip: Dispara cuatro barracudas que se adhieren a los enemigos y los destrozan
}

BladedgeRailbow: {
	DisplayName: Arcocarril de Filo Cortante
	Tooltip: "[GFB]"
	TooltipNormal: Dispara una dispersión de 4 flechas y 2 hojas a la vez
	TooltipGFB: Dispara una dispersión de 4 flechas... junto con otras cosas varias
}

BlightSpewer: {
	DisplayName: Escupidor de Plaga
	Tooltip:
		'''
		Dispara nubes de nanomáquinas de [cbuff:CalamityMod/Plague] que se adhieren a bloques
		Las nanomáquinas se enfocan agresivamente en los enemigos cercanos
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

BlissfulBombardier: {
	DisplayName: Bombardero Dichoso
	Tooltip:
		'''
		Lanza un misil cristalino al cielo, haciendo llover fuego sagrado sobre el cursor
		El misil busca incansablemente un objetivo antes de estallar en una explosión masiva
		'''
}

BloodBoiler: {
	DisplayName: Hervidero de Sangre
	Tooltip:
		'''
		Dispara dos corrientes de sangrefuego que regresan a ti
		El sangrefuego que regresa reduce [cbuffplr:PotionSickness] si golpeó a un enemigo
		Usa tu salud como munición
		20% de probabilidad de ahorrar salud
		'''
}

BlossomFlux: {
	DisplayName: Flujo Floreciente
	Tooltip:
		'''
		Dispara un flujo de hojas
		Presiona <right> para disparar un orbe de esporas que explota en una nube de gas de esporas
		'''
	LegendaryText:
		'''
		'...Ya veo... Mis hijos estaban tan aterrorizados por el Buscador de Dioses que eligieron profanar la muerte por un guardián a mi imagen.
		Lo siento. No pude ver vuestros corazones. La desesperación que os infligí... Debería haber previsto las consecuencias de quitaros a vuestro guardián.
		Pero ya no seréis ignorados.
		Escúchame, bestia floral, por mi autoridad. No arrasarás más este lugar; guarda la morada y los recuerdos de quienes alguna vez vivieron aquí.
		Canaliza todo el poder de este dosel y de los muertos que hay en ti, para que ningún Buscador de Dioses, humilde o poderoso, profane jamás este asentamiento.
		Defiéndelo hasta los últimos rayos del sol, para que mi héroe aún tenga un hogar.'
		'''
}

BrimstoneFury: {
	DisplayName: Furia de Azufre
	Tooltip: Convierte flechas de madera en una dispersión de 3 pernos de azufre
}

BulletFilledShotgun: {
	DisplayName: Escopeta Repleta de Balas
	Tooltip:
		'''
		Dispara una masiva dispersión de balas que rebotan
		Las balas intentan rebotar hacia los enemigos tras rebotar dos veces
		Consume cinco balas por uso
		'¿Apuntar? ¿Eso qué es?'
		'''
}

Buzzkill: {
	DisplayName: Aguafiestas
	Tooltip:
		'''
		Mantén <left> para acelerar una sierra circular que causa daño de corto alcance
		Suéltalo para disparar la sierra, que rebota en bloques y destroza enemigos
		Acelerar la sierra aumenta su daño y permite que perfore más enemigos
		'No confundir con la Escopeta Aserrada'
		'''
}

ChickenCannon: {
	DisplayName: Cañón de Pollos
	Tooltip: Dispara bengalas de pollo que crean enormes explosiones de [cbuff:CalamityMod/Dragonfire]
}

ChromaticEruption: {
	DisplayName: Erupción Cromática
	Tooltip:
		'''
		Se carga para escupir llamas de arcoíris y pares de bengalas cromáticas teledirigidas
		Usa gel como munición
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

ClamorRifle: {
	DisplayName: Rifle del Clamor
	Tooltip:
		'''
		Convierte balas de mosquete en pernos de energía teledirigidos
		Los pernos de energía aturden brevemente a los enemigos
		'''
}

CleansingBlaze: {
	DisplayName: Llamarada Purificadora
	Tooltip:
		'''
		Libera una ráfaga de [cbuff:CalamityMod/GodSlayerInferno] que puede atravesar bloques
		Usa gel como munición
		'''
}

ClockworkBow: {
	DisplayName: Arco de Relojería
	Tooltip:
		'''
		Mantén <left> para cargar hasta seis pernos de precisión
		Cuantos más pernos de precisión se carguen, más fuerte golpean
		'''
}

Condemnation: {
	DisplayName: Condena
	Tooltip:
		'''
		Dispara poderosos pernos escarlatas imbuidos de magia malévola
		Mantén <left> para cargar hasta nueve pernos en una potente ráfaga
		'''
}

ConferenceCall: {
	DisplayName: Llamada en Conferencia
	Tooltip:
		'''
		Dispara una dispersión compacta de balas que invocan más balas desde el cielo
		[c/768EE6:@everyone]
		'''
}

Contagion: {
	DisplayName: Contagio
	Tooltip: Dispara flechas de contagio que dejan orbes explosivos a su paso
}

ContinentalGreatbow: {
	DisplayName: Gran Arco Continental
	Tooltip:
		'''
		Las flechas de madera se encienden con fuego
		Dispara 3 flechas a la vez
		Dispara 2 flechas adicionales de fuego infernal o icor
		'''
}

CorinthPrime: {
	DisplayName: Corinth Prime
	Tooltip:
		'''
		Dispara una ráfaga concentrada de 6 balas de alta velocidad
		Presiona <right> para disparar una granada
		La granada emite una explosión masiva si no toca nada durante 2 segundos
		De lo contrario, la granada emite una explosión extremadamente débil
		Convierte balas de mosquete en balas explosivas de alta velocidad
		'''
}

CorrodedCaustibow: {
	DisplayName: Arco Cáustico Corroído
	Tooltip: Convierte flechas de madera en proyectiles lentos y poderosos que dejan un aura irradiada
}

CrackshotColt: {
	DisplayName: Colt del Tirador Experto
	Tooltip:
		'''
		Presiona <right> para lanzar una Moneda de Cobre al aire
		Golpear una moneda con una bala hace que rebote hacia el enemigo más cercano
		Se pueden lanzar hasta 4 monedas simultáneamente, y los disparos rebotan en múltiples monedas si es posible
		Las monedas garantizan un golpe crítico tras un breve retraso
		'''
}

DaemonsFlame: {
	DisplayName: Llama del Demonio
	Tooltip:
		'''
		Dispara bolas de fuego de llama demoniaca y 4 flechas regulares
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

DarkechoGreatbow: {
	DisplayName: Gran Arco de Eco Oscuro
	Tooltip:
		'''
		Dispara dos flechas a la vez
		Dispara un dardo de cristal adicional
		'''
}

DeadSunsWind: {
	DisplayName: Viento del Sol Muerto
	Tooltip:
		'''
		Dispara una ráfaga concentrada de plasma cósmico sobrecalentado que explota y puede rebotar en bloques
		Los disparos se dirigen agresivamente a los enemigos tras rebotar
		Los golpes consecutivos causan explosiones más grandes
		Usa gel como munición
		'''
}

DeepcoreGK2: {
	DisplayName: Deepcore GK2
	Tooltip:
		'''
		Las balas son el doble de grandes e ignoran 10 puntos de defensa enemiga
		'¡Por la roca y la piedra!'
		'''
}

DragonsBreath: {
	DisplayName: Aliento del Dragón
	Tooltip:
		'''
		Dispara ráfagas intensas de [cbuff:CalamityMod/Dragonfire] a un ritmo acelerado
		Al disparar durante suficiente tiempo, comenzarás a usar un cartucho de energía
		Mientras usas un cartucho, disparas un rayo dracónico de [cbuff:CalamityMod/Dragonfire] puro que no consume munición
		Una vez eyectado el cartucho, volverás a la cadencia original
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

Drataliornus: {
	DisplayName: Drataliornus
	Tooltip:
		'''
		Dispara un flujo escalado de flechas de [cbuff:CalamityMod/Dragonfire]
		Las bolas de fuego llueven meteoros, dejan rastros de polvo de dragón y lanzan pernos adicionales a velocidad máxima
		Recibir daño mientras disparas el flujo lo interrumpirá y reducirá el tiempo de vuelo con alas
		Presiona <right> para disparar dos devastadoras andanadas de cinco bolas de fuego potenciadas
		'Solo evita que te golpeen'
		'''
}

DriftwoodBow: {
	DisplayName: Arco de Madera a la Deriva
	Tooltip: Este arco es más poderoso cuando estás mojado
}

EternalBlizzard: {
	DisplayName: Ventisca Eterna
	Tooltip: Dispara una flecha de carámbano adicional que se congela en un carámbano en caída
}

Eviscerator: {
	DisplayName: Eviscerador
	Tooltip: Convierte balas de mosquete en coágulos de sangre de movimiento rápido
}

FetidEmesis: {
	DisplayName: Émesis Fétida
	Tooltip:
		'''
		Dispara un flujo acelerado de balas hasta que el cañón se sobrecalienta
		Cuando el cañón se sobrecalienta, se vomitan trozos fétidos
		Tras disparar, la pistola debe enfriarse antes de poder usarse de nuevo
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

FirestormCannon: {
	DisplayName: Cañón de Tormenta de Fuego
	Tooltip:
		'''
		Dispara una rápida andanada de bengalas que acumula calor abrasador en el arma
		Disparar durante demasiado tiempo sobrecalienta el arma, dejándola inutilizable por un momento y haciendo que quedes con [cbuffplr:OnFire]
		Presiona <right> para guardar el arma, lo que conserva su calor
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'¿Qué podría salir mal?'
		'''
}

FlakKraken: {
	DisplayName: Kraken de Fragmentación
	Tooltip:
		'''
		Dispara pares de proyectiles antiaéreos abisales que explotan en amplios conos de metralla de tinta
		Los proyectiles abisales estallan al llegar a la posición del cursor
		Los impactos directos con el proyectil reducirán el daño de metralla
		'''
}

FlakToxicannon: {
	DisplayName: Cañón Tóxico de Fragmentación
	Tooltip:
		'''
		Dispara un proyectil tóxico que explota en un cono de lodo radiactivo
		Los proyectiles tóxicos estallan al llegar a la posición del cursor
		Los impactos directos con el proyectil tóxico reducirán el daño del lodo
		Usa cohetes como munición
		'''
}

FlarewingBow: {
	DisplayName: Arco de Ala Ardiente
	Tooltip:
		'''
		Dispara una dispersión de 3 flechas
		Las flechas de madera se convierten en murciélagos de obsidiana que se dirigen al objetivo tras perforar una vez
		'''
}

FlurrystormCannon: {
	DisplayName: Cañón de Tormenta de Vendaval
	Tooltip:
		'''
		Dispara una cadena de bolas de nieve que se aceleran con el tiempo
		Tiene posibilidad de disparar también un trozo de hielo que se astilla en fragmentos
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

FreedomStar: {
	DisplayName: Estrella de la Libertad
	Tooltip:
		'''
		Pulsa <left> para disparar orbes de energía
		Mantén <left> para cargar y disparar un rayo que explota al impactar
		'''
}

FrostbiteBlaster: {
	DisplayName: Exterminador de Mordedura de Hielo
	Tooltip:
		'''
		Dispara una dispersión de 6 balas
		Convierte balas de mosquete en carámbanos
