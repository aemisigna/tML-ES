}

Fungicide: {
	DisplayName: Fungicida
	Tooltip: Convierte balas de mosquete en proyectiles fúngicos que se dividen al impactar
}

Galeforce: {
	DisplayName: Fuerza del Vendaval
	Tooltip: Dispara una dispersión de plumas de bajo daño
}

GoldenEagle: {
	DisplayName: Águila Dorada
	Tooltip: Dispara 5 balas a la vez
}

Goobow: {
	DisplayName: Arco Baboso
	Tooltip: Adicionalmente dispara dos corrientes de limo dañino
}

GunkShot: {
	DisplayName: Disparo Mugriento
	Tooltip: Dispara una dispersión de balas
}

HalibutCannon: {
	DisplayName: Cañón de Halibut
	Tooltip: "[GFB]"
	TooltipNormal: "'Sí, sigue siendo demasiado poderoso'"
	TooltipGFB: "'No, ahora es una porquería'"
}

HalleysInferno: {
	DisplayName: Infierno de Halley
	Tooltip:
		'''
		Dispara una ráfaga de chorros de fuego lunar intensamente concentrados
		<right> para disparar rápidamente Destellos Estelares que infligen [cbuff:CalamityMod/Voidfrost]
		Genera Destellos Estelares al golpear enemigos, según tu precisión
		Usa gel como munición
		'Halley llegó antes de lo esperado'
		'''
}

HandheldTank: {
	DisplayName: Tanque de Mano
	Tooltip: ""
}

HavocsBreath: {
	DisplayName: Aliento del Caos
	Tooltip:
		'''
		Proyecta ráfagas cónicas de [cbuff:CalamityMod/BrimstoneFlames] abrasador
		Usa gel como munición
		'''
}

HeavenlyGale: {
	DisplayName: Vendaval Celestial
	Tooltip:
		'''
		Dispara un rápido flujo de exocristales supercargados
		Mantener el arco y esperar un tiempo antes de disparar hace que los cristales sean más poderosos
		Si los cristales son suficientemente poderosos, invocarán torrentes de exorrelámpago sobre el objetivo que golpeen
		Los enemigos golpeados con exorrelámpago son atomizados por [cbuff:CalamityMod/MiracleBlight]
		'''
}

Hellborn: {
	DisplayName: Engendro del Infierno
	Tooltip:
		'''
		Un arma de fuego ornamentada creada durante la Era Dracónica por el mejor maestro herrero de Azafure
		Mantén <left> para girar la pistola en tu mano, golpeando rápidamente a los enemigos cercanos
		Los golpes con la pistola misma añaden rondas al arma, hasta un máximo de 12
		A costo de una ronda, mantén <right> para disparar una esfera de energía gigante con potente retroceso
		[c/E1B65F:'Conoce la gracia de un arma forjada mediante inspiración sublime']
		'''
}

Helstorm: {
	DisplayName: Helstorm
	Tooltip:
		'''
		Dispara dos balas a la vez
		La pistola también causa daño a los enemigos que la tocan
		'''
}

HoarfrostBow: {
	DisplayName: Arco de Escarcha
	Tooltip:
		'''
		Dispara dos flechas a la vez
		Convierte flechas de madera en flechas de niebla que esparcen niebla helada al colisionar
		'''
}

Hydra: {
	DisplayName: Hidra
	Tooltip:
		'''
		Dispara una dispersión de 3 glóbulos de sangre imbuidos con [cbuff:Venom]
		Crece una cabeza-pistola cada 3 segundos, hasta un máximo de 3 cabezas
		Presiona <left> para ordenar a las cabezas existentes que disparen
		Presiona <right> para lanzar las cabezas causando poderoso daño explosivo
		[c/9D80B0:Fusión de maquinaria pesada y sangre de Lerna]
		'''
}

Infinity: {
	DisplayName: Infinito
	Tooltip:
		'''
		Dispara un doble flujo de pernos de energía que se dividen
		{$Common.ArmorPenetration}
		{$CommonItemTooltip.PercentChanceToSaveAmmo@1}
		'Dicen que el infinito no tiene fin, pero lo sostienes en tus manos'
		'''
}

Karasawa: {
	DisplayName: Karasawa
	Tooltip: ...Esto es pesado... demasiado pesado
}

Kingsbane: {
	DisplayName: Perdición del Rey
	Tooltip:
		'''
		Tras acelerar, dispara balas rápidamente
		Cuando dejas de disparar, liberas una andanada de balas aúricas
		Las balas aúricas se dirigen agresivamente a los enemigos, ignoran 50 puntos de defensa e infligen [cbuff:CalamityMod/AuricRebuke]
