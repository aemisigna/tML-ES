		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

Leviatitan: {
	DisplayName: Leviatitán
	Tooltip:
		'''
		Dispara ráfagas acuáticas de alta velocidad
		Libera aberraciones teledirigidas que destrozan la defensa enemiga cada seis disparos
		<right> para vomitar un meteoro que explota al impactar
		'La L de LMG significa Leviatán'
