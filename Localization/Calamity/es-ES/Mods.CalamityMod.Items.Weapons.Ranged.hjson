}

MagnomalyCannon: {
	DisplayName: Cañón de Anomalía Magna
	Tooltip:
		'''
		Lanza un potente exocohete para aniquilar todo con [cbuff:CalamityMod/MiracleBlight]
		Los cohetes están rodeados de un aura dañina invisible y se dividen en rayos dañinos al impactar
		{$CommonItemTooltip.PercentChanceToSaveAmmo}
		'''
}

Malevolence: {
	DisplayName: Malevolencia
	Tooltip:
		'''
		Dispara dos flechas a la vez
		Convierte flechas de madera en flechas de [cbuff:CalamityMod/Plague] que explotan en abejas
		'''
}

MarksmanBow: {
	DisplayName: Arco del Tirador
	Tooltip:
		'''
