			ArenaBuilder: {
				DisplayName: Constructor de plataformas para arenas
				Tooltip:
					'''
					Construye una plataforma de ~200 bloques de ancho.
					Clic derecho para elegir opciones, material de plataforma y extras
					Usará automáticamente plataformas de asfalto si las tienes en el inventario.
					Elegir la hoguera colocará hogueras.
					También colocará bloques de burbuja para colocar miel.
					Elegir la luz iluminará toda la plataforma de punta a punta.
					No destruye bloques.
					'''
			}

			Arena: {
				DisplayName: Arena
				Tooltip: ""
			}

			FishingBiomeBuilder: {
				DisplayName: Constructor de bioma de pesca
				Tooltip:
					'''
					Construye un bioma para pescar.
					Clic derecho para elegir opciones.
					Selecciona obsidiana para colocar pared de jungla o de champiñón detrás de los bloques.
					Selecciona material de madera/piedra para la barrera exterior.
					Activa la luz para elegir si quieres iluminación o no.
					Piedra perlada/hielo sagrado solo usable en el modo Difícil.
					'''
			}

			FishingBuilder: {
				DisplayName: Constructor de estanques
				Tooltip:
					'''
					Úsalo para construir un estanque de pesca o colocar/quitar líquido.
					Clic derecho para elegir opciones.
					Funciona como el Manipulador de líquidos definitivo cuando el Constructor de estanques de pesca está desactivado.
					Con el Constructor de estanques de pesca activado, al usarlo creará un estanque con el líquido elegido.
					El estanque estará vacío si eliges la esponja (sin plataformas ni bloques exteriores).
					Con obsidiana activada se colocará una pared de fondo (incluida la esponja).
					'''
			}

			GroundFiller: {
				DisplayName: Vara de tierra 2.0
				Tooltip:
					'''
					Clic derecho para cambiar de modo.
					Modo 1: Nivela y rellena el suelo bajo ti, 300 de ancho, 50 de profundidad.
					Modo 2: También limpia 50 bloques hacia arriba.
					Modo 3: También funciona en la Mazmorra, el Templo y el Desierto en el subsuelo, dejando la pared de fondo.
					Los bloques de mods se reemplazarán con bloques vanilla.
					'''
			}

			Hellevator: {
				DisplayName: Hellevator automático
				Tooltip:
					'''
					Construye un hellevator.
					Clic derecho para elegir opciones.
					Estará iluminado de arriba abajo si tienes la luz activada.
					Solo colocará cuerda si tienes uno de los objetos de Cuerda ilimitada en el inventario.
					Haz clic donde quieras la pared superior derecha del hellevator.
					Se detendrá si choca con el Templo.
					'''
			}

			PrisonBuilder: {
				DisplayName: Constructor de prisiones
				Tooltip:
					'''
					Construye una prisión de PNJ.
					Clic derecho para elegir opciones.
					Estará iluminada si la luz está activada (contará como casa de cualquier forma).
					Haz clic donde quieras el bloque inferior derecho.
					'''
			}

			SkyPlatformBuilder: {
				DisplayName: Constructor de puentes celestiales
				Tooltip:
					'''
					Construye una plataforma a lo largo de todo el mapa.
					Clic derecho para elegir opciones.
					Estará iluminada de punta a punta si tienes la luz activada.
					No destruye bloques.
					Usará automáticamente plataformas de asfalto si las tienes en el inventario.
					'''
			}

			SubAndSky: {
				DisplayName: Constructor de vagoneta o plataforma
				Tooltip:
					'''
					Clic derecho para elegir opciones.
					Estará iluminado de punta a punta si tienes la luz activada.
					El material de plataforma puede ser obsidiana (tiene prioridad) o las maderas.
					Si tienes Plataformas de asfalto ilimitadas en el inventario, se colocarán esas en su lugar.
					Elegir obsidiana hará que la vagoneta se coloque sin paredes/suelo.
					Colocar plataformas destruirá bloques.
					Haz clic donde quieras la pista de vagoneta o la plataforma
					Atravesará el templo si el Gólem está muerto.
					'''
			}

			SubwayBuilder: {
				DisplayName: Constructor de metro
				Tooltip:
					'''
					Construye un metro.
					Clic derecho para elegir opciones.
					Estará iluminado de punta a punta si tienes la luz activada.
					Haz clic donde quieras la pista de vagoneta.
					Atravesará el templo si el Gólem está muerto.
					'''
			}

