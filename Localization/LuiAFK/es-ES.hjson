						No activará mejoras si el objeto está en el inventario.
						¡¡¡Actualmente no tiene ningún efecto!!!!
						'''
				}

				certainPotionsEnabled: {
					Label: ciertas pociones activadas
					Tooltip: ""
				}
			}

			LuiAfkConfig: {
				DisplayName: Configuración de Lui AFK

				Headers: {
					Harvester: Encabezado de cosechadoras
