		Configs: {
			LuiAFKConfig: {
				DisplayName: Configuración de servidor de LuiAFK

				Headers: {
					Harvester: Configuración de cosechadoras
					Potions: Configuración de pociones y mejoras
					Accessories: Opciones de accesorios
					NPC: Opciones de PNJs
					Tools: Opciones de herramientas y miscelánea
					Fishing: Flotadores de cañas de pesca
					Ammo: Opciones de munición
				}

				harvesterAvailability: {
					Label: Cosechadoras
					Tooltip:
						'''
						En qué dificultad están disponibles las cosechadoras.
						Opciones: Desactivado, Normal+, Experto+ y Maestro+
						Predeterminado: Experto+
						'''
				}

				potionsEnable: {
					Label: Pociones ilimitadas
					Tooltip:
						'''
						Si las pociones ilimitadas están activadas o no.
						No activará mejoras si el objeto está en el inventario.
						No activará mejoras vanilla si son una pila de 30+.
						Predeterminado: true
						'''
				}

				vanillaPotionsEnable: {
					Label: Autoaplicación de pociones vanilla
					Tooltip:
						'''
						Si las pociones vanilla se autoaplican cuando son una pila de 30+.
						Opciones: Desactivado, Siempre y 1 poción ilimitada presente.
						Predeterminado: 1 poción ilimitada presente
						'''
				}

				PaperAmountForScrollCrafting: {
					Label: Cantidad de papel para crear
					Tooltip:
						'''
						El número de papel requerido para crear pergaminos.
						0 desactiva el papel necesario para crear.
						Predeterminado: 5.
						'''
				}

				ultimateBattlerTimer: {
					Label: Temporizador del combatiente definitivo
					Tooltip:
						'''
						Si el buff de combatiente definitivo tiene un temporizador de 5 segundos antes de activarse, antes de desactivarse o si el temporizador está desactivado.
						Opciones: Desactivado, Antes de activar y Después de activar
						Predeterminado: Antes de activar
						'''
				}

				manaEnable: {
					Label: Maná ilimitado [i:{0}] [i:{1}] [i:{2}] [i:{3}] [i:{4}] [i:{5}]
					Tooltip:
						'''
						Si el maná ilimitado está activado o no.
						No activará mejoras si el objeto está en el inventario.
						Predeterminado: true
						'''
				}

				superTools: {
					Label: Superherramientas [i:{0}] [i:{1}] [i:{2}]
					Tooltip:
						'''
						Si Cava más rápido, Tool Time y Home Improvement están activados o no.
						No activará mejoras si el objeto está en el inventario.
						Predeterminado: true
						'''
				}

				boneEnable: {
					Label: Generar PNJ mercader de huesos
					Tooltip:
						'''
						Si el mercader de huesos puede aparecer o no.
						No eliminará al PNJ mercader de huesos ya generado.
						Predeterminado: true
						'''
				}

				merchantEnable: {
					Label: Generar PNJ mercader ambulante
					Tooltip:
						'''
						Si el PNJ mercader ambulante puede aparecer o no.
						No eliminará al PNJ mercader ambulante ya generado.
						Predeterminado: true
						'''
				}

				builderEnable: {
					Label: Autoconstructores [i:{0}]
					Tooltip:
						'''
						Si cualquier objeto/herramienta de construcción se puede obtener y usar.
						Predeterminado: true
						'''
				}

				worldRemoverEnable: {
					Label: Montura de taladro mejorada [i:{0}]
					Tooltip:
						'''
						Si la montura de taladro mejorada se puede obtener y usar.
						Predeterminado: true
						'''
				}

				moneyEnable: {
					Label: Recolector de dinero [i:{0}]
					Tooltip:
						'''
						Si el recolector de dinero se puede obtener y usar.
						Predeterminado: true
						'''
				}

				killerEnable: {
					Label: Asesino de mercaderes ilimitado [i:{0}]
					Tooltip:
						'''
						Si el asesino de mercaderes ilimitado se puede obtener y usar.
						Predeterminado: true
						'''
				}

				magnetEnable: {
					Label: Imán de botín [i:{0}]
					Tooltip:
						'''
						Si el imán de botín se puede obtener y usar.
						Predeterminado: true
						'''
				}

				neededQuests: {
					Label: Flotadores de pesca extra
					Tooltip:
						'''
						Cuántas misiones del Pescador se necesitan por cada flotador extra.
						0 desactiva esta opción.
						El valor puede ir de 0 a 100.
						Predeterminado: 5 misiones
						'''
				}

				rangerAmmo: {
					Label: Munición ilimitada de armas a distancia
					Tooltip:
						'''
						Cuánta munición a distancia necesitas para no consumir el objeto.
						0 desactiva esta opción.
						Los valores pueden ir de 0 a 10000.
						Predeterminado: 3996
						'''
				}

				thrownAmmo: {
					Label: Munición ilimitada de armas arrojadizas
					Tooltip:
						'''
						Cuánta munición arrojadiza necesitas para no consumir el objeto.
						0 desactiva esta opción.
						Los valores pueden ir de 0 a 10000.
						Predeterminado: 999
						'''
				}
			}

			SettingsConfigClient: {
				DisplayName: Configuración de cliente de LuiAFK
				Headers.Different_Enabling/Disabling_Options: Distintas opciones de activar / desactivar

				certainPotionsEnable: {
					Label: Ciertas pociones ilimitadas
