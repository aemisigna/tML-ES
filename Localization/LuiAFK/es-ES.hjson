				}

				potionsEnabled: {
					Label: pociones activadas
					Tooltip: ""
				}

				vanillaPotionsEnabled: {
					Label: pociones vanilla activadas
					Tooltip: ""
				}

				PaperAmountForScrollCrafting: {
					Label: Cantidad de papel para crear pergaminos
					Tooltip: ""
				}

				ultimateBattlerTimer: {
					Label: temporizador del combatiente definitivo
					Tooltip: ""
				}
			}
		}

