Mods: {
	miningcracks_take_on_luiafk: {
		Conditions: {
			Master: LuiAFK: solo modo Maestro
			Expert: LuiAFK: solo modo Experto(+)
		}

		NPCs: {
			Deeps: {
				DisplayName: Deeps

				TownNPCMood: {
					Content: ...
					NoHome: ...
					FarFromHome: ...
					LoveSpace: ...
					DislikeCrowded: ...
					HateCrowded: ...
					LikeNPC_Princess: ...
					Princess_LovesNPC: ...
				}
			}

			MobileMerchant: {
				DisplayName: Mercader móvil

				TownNPCMood: {
					Content: Hola, qué gusto charlar contigo ^^
					NoHome: No entiendo esta necesidad de tener un hogar, solo soy un mercader estático que flota...
					FarFromHome: ¿Eh? No, no necesito un hogar.
					LoveSpace: Hay tanto espacio para mí y algunos amigos, gracias ^^
					DislikeCrowded: ¿Hay una fiesta por aquí? Hay un poco demasiada gente alrededor.
					HateCrowded: Hay demasiada gente por aquí, por favor haz que se vayan.
					LikeNPC_Princess: Me cae bien {NPCName}.
					Princess_LovesNPC: Me cae bien {NPCName}.
				}

				Chat: Date prisa, no puedo quedarme mucho...
			}

			SkeletonMerchant: {
				DisplayName: Mercader esquelético

				TownNPCMood: {
					Content: Gracias por no matarme todavía, se agradece mucho ^^
					NoHome: A mí también me gustaría tener un hogar, ¿sabes? :(
					LoveSpace: Tanto espacio a mi alrededor es perfecto para practicar con mis yoyós y lanzar huesos... Sin pegarle a alguien en el ojo.
					FarFromHome: ¿Me ayudarías a encontrar el camino de vuelta a casa? Ya sabes, como esqueleto no veo por dónde voy...
					DislikeCrowded: ¿Gran fiesta por aquí? Hay mucha gente...
					HateCrowded: Vaya, hay demasiada gente a mi alrededor... Lo odio
					LikeBiome: Además, me gusta el bosque, es distinto a lo de abajo. ¡Por fin puedo respirar aire fresco!
					LoveBiome: Además, me encantan los subterráneos. ¡Me siento como en casa!
					DislikeBiome: Además, una pregunta: ¿¡POR QUÉ ESTOY AQUÍ?!
					HateBiome: Es un poco difícil hacer mods mientras te atacan monstruos en {BiomeName}.
					LikeNPC: Hablé con {NPCName}, ¡es una persona genial!
					LoveNPC: Hablé con {NPCName}... Le encanta volar cosas, a mí también, ¡estábamos destinados a estar juntos!
					HateNPC: Mmmh, mi compañero aventurero, hay una chica llamada {NPCName} que quiere purificarme... No me gusta, quiere experimentar conmigo... ¡AYUDA!
					LikeNPC_Princess: Me cae bien {NPCName}.
					Princess_LovesNPC: Me cae bien {NPCName}.
				}

				Census.SpawnCondition: Derrota a 50 esqueletos cualquiera
			}

			TravellingMerchant: {
				DisplayName: Mercader ambulante

				TownNPCMood: {
					Content: ¡Ey! ¿Buscas mercancías hoy?
					NoHome: A mí también me gustaría tener un hogar, ¿sabes? :(
					LoveSpace: ¡Aaah, mucho espacio! Ahora puedo pensar en mis negocios.
					FarFromHome: ¡Ayuda! No encuentro el camino de vuelta a casa. Por favor, guíame de regreso.
					DislikeCrowded: Parece que hay un poco demasiados clientes aquí, ¿eh?
					HateCrowded: Bueno, tengo stock limitado... No puedo atenderlos a todos, denme espacio...
					LikeBiome: Sí, el desierto está genial. Me encanta el paisaje y... ¡Oh, un cliente!
					LoveBiome: Aaah, el bosque... Un lugar relajado y pacífico para vivir, ¡y con muchos clientes!
					HateBiome: Además, tengo una pregunta... ¿Qué quieres que haga aquí...? En serio, es demasiado peligroso y nadie comprará mis cosas. Odio este lugar.
					LikeNPC: ¡{NPCName} tiene alma de mercader. ¡Me gusta eso!
					LoveNPC: Oh, ahí está {NPCName}... Oh no, ¿me estoy sonrojando otra vez?
					HateNPC: Por favor, ¿puedo vivir sin tener a {NPCName} cerca? Me está robando mis ahorros de toda la vida...
					LikeNPC_Princess: Me cae bien {NPCName}.
					Princess_LovesNPC: Me cae bien {NPCName}.
				}

				Census.SpawnCondition: Ten 50 monedas de oro contigo
			}

			TargetDummy: {
				DisplayName: Muñeco de pruebas

				TownNPCMood: {
					Content: Estoy contento.
					NoHome: Odio no tener un hogar.
					FarFromHome: Estoy demasiado lejos de casa.
					LoveSpace: Me encanta tener tanto espacio.
					DislikeCrowded: No me gusta lo aglomerado que estoy.
					HateCrowded: Odio lo aglomerado que estoy.
					LikeNPC_Princess: Me cae bien {NPCName}.
					Princess_LovesNPC: Me cae bien {NPCName}.
				}
			}
		}

